    },
    {
      "key": "06f9a2a",
      "nodeTitle": "question_alps",
      "sourceText": "Zu welchem ​​Gebirge gehört der Mont Blanc?",
      "sourceEnText": "What mountain range is Mont Blanc in?",
      "audioFile": "fr_08_06f9a2a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2377,
      "updatedAt": "2026-03-15T12:28:26Z",
      "textHash": "f82aeaa604d25b099e829d4aa597896d7c69d1df57053681c146500b61929891"
    },
    {
      "key": "07102e7",
      "nodeTitle": "item_crampons",
      "sourceText": "Diese helfen Ihnen, sicher auf Eis zu gehen.",
      "sourceEnText": "These help you walk safely on ice.",
      "audioFile": "fr_08_07102e7.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2769,
      "updatedAt": "2026-03-15T12:28:18Z",
      "textHash": "78aa8c4ff53c3e300f777cb36b9e9505961747c44a9edf94730466d5502d2d61"
    },
    {
      "key": "0724de3",
      "nodeTitle": "npc_intro",
      "sourceText": "Hilfe! Ich bin Bergführer. Ein blauer Hund hat unsere Kletterausrüstung gestohlen!",
      "sourceEnText": "Help! I am a mountain guide. A blue dog took our climbing gear!",
      "audioFile": "fr_08_0724de3.mp3",
      "voiceProfile": "alice",
