    {
      "key": "05cabb5",
      "nodeTitle": "npc_intro",
      "sourceText": "Halte danach Ausschau!",
      "sourceEnText": "Look around for it!",
      "audioFile": "fr_08_05cabb5.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1593,
      "updatedAt": "2026-03-15T12:27:22Z",
      "textHash": "6e252b57560f2f9c29cf14b3d0200ec9b6a326b769507cc9cfcaf407b393864b"
    },
    {
      "key": "05e3658",
      "nodeTitle": "snowman",
      "sourceText": "Basislager 2",
      "sourceEnText": "Basecamp 2",
      "audioFile": "fr_08_05e3658.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1228,
      "updatedAt": "2026-03-15T12:28:57Z",
      "textHash": "023d94f3ace3ea36de0b368279a6628a8c488843c40b6fae454a951bd53cba8b"
    },
    {
      "key": "05e80cb",
      "nodeTitle": "item_backpack",
      "sourceText": "Dieser Rucksack bietet Platz für Essen, Wasser und eine Karte.",
      "sourceEnText": "This backpack can carry food, water, and a map.",
      "audioFile": "fr_08_05e80cb.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3918,
      "updatedAt": "2026-03-15T12:27:27Z",
      "textHash": "a16728bdccd4cbd5d3365f6969200fc7801a75bdcbdfd45406abc8fae6f3a00a"
    },
    {
      "key": "0650acc",
      "nodeTitle": "npc_intro",
      "sourceText": "Erkunden Sie Mont Blanc und entdecken Sie unsere Ausrüstung.",
      "sourceEnText": "Please explore Mont Blanc and find our gear.",
      "audioFile": "fr_08_0650acc.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3605,
      "updatedAt": "2026-03-15T12:27:19Z",
      "textHash": "52cfa900ad6448634a7aa8d19b2fe8b1697e27dc628dd6670db3471858b91316"
    },
    {
      "key": "06b15bb",
      "nodeTitle": "npc_base3",
      "sourceText": "Du hast die Eisausrüstung. Nur noch ein letzter Kraftakt bis zum Gipfel!",
      "sourceEnText": "You have the ice gear. One last push to the top!",
      "audioFile": "fr_08_06b15bb.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 5303,
      "updatedAt": "2026-03-15T12:28:04Z",
      "textHash": "8659158f3e420fc88fbdca7507d45b173b74fb3c3d14939291af54a54a79259e"
    },
    {
      "key": "06b3363",
      "nodeTitle": "npc_base2",
      "sourceText": "Du hast die Handschuhe vergessen!",
      "sourceEnText": "You are missing the gloves!",
      "audioFile": "fr_08_06b3363.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2142,
      "updatedAt": "2026-03-15T12:27:48Z",
      "textHash": "ae331d722a4033c4855380728c974e16edd7f370a6e5a105f8cef6639ea998de"
