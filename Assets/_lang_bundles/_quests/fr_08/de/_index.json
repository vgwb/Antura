    {
      "key": "056ec2b",
      "nodeTitle": "chest_base1",
      "sourceText": "Es öffnet sich! Es enthält einige Ausrüstungsgegenstände.",
      "sourceEnText": "It opens! It contains some equipment.",
      "audioFile": "fr_08_056ec2b.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4023,
      "updatedAt": "2026-03-15T12:27:39Z",
      "textHash": "7a8231846fc46e2f11dc9a7c24fb8dbcc803a25ef515b5f4dfcec6608845b438"
    },
    {
      "key": "058bb65",
      "nodeTitle": "snowman",
      "sourceText": "Basislager 3",
      "sourceEnText": "Basecamp 3",
      "audioFile": "fr_08_058bb65.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1411,
      "updatedAt": "2026-03-15T12:28:58Z",
      "textHash": "83dda5f6498cf8ea3df8ece4fc3cb6f323fcc8bc53eb98ec123217eaeef12b30"
    },
    {
      "key": "0590129",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Vergessen Sie nicht, warme Kleidung mitzubringen!",
      "sourceEnText": "Don't forget to bring warm clothes!",
      "audioFile": "fr_08_0590129.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 2717,
      "updatedAt": "2026-03-15T12:29:15Z",
      "textHash": "e8ac17fa3920efe845c9a49eb3184d8e520bb6bc580f27b4a1917d5ccdf4ba84"
    },
    {
      "key": "059d744",
      "nodeTitle": "item_hat",
      "sourceText": "Es hilft auch bei kaltem Wind.",
      "sourceEnText": "It also helps when the wind is cold.",
      "audioFile": "fr_08_059d744.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2011,
      "updatedAt": "2026-03-15T12:27:44Z",
      "textHash": "efd023e825410117e48cb365730945c25476abf2bb1ca51f0a226f9581983f13"
