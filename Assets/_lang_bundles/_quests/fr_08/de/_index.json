    {
      "key": "000fc05",
      "nodeTitle": "item_hat",
      "sourceText": "Eine warme Mütze hält den Kopf warm.",
      "sourceEnText": "A warm hat keeps your head warm.",
      "audioFile": "fr_08_000fc05.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2429,
      "updatedAt": "2026-03-15T12:27:42Z",
      "textHash": "0f8241494840d23764a0da5e2abed77efbf183f3d8604edf3bdaed2b95f83f26"
    },
    {
      "key": "001e940",
      "nodeTitle": "npc_base4",
      "sourceText": "Lasst uns vor dem Flaggenspiel drei Fragen zum Thema Berge beantworten.",
      "sourceEnText": "Let's answer three mountain questions before the flag game.",
      "audioFile": "fr_08_001e940.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4754,
      "updatedAt": "2026-03-15T16:41:02Z",
      "textHash": "881cf3c3fbe1da5d14923d885d446dee92488efc6900485685bb3623e7940ecf"
    },
    {
      "key": "003e87c",
      "nodeTitle": "chest_bonus",
      "sourceText": "Du hast einen warmen Schal gefunden!",
      "sourceEnText": "You found a warm scarf!",
      "audioFile": "fr_08_003e87c.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2299,
      "updatedAt": "2026-03-15T12:29:08Z",
      "textHash": "ea203c0ff19e392532bbf43d2819b91ce0457bf5c454bea612dd74dcaa86a861"
    },
    {
      "key": "003ecb2",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Der Mont Blanc ist der höchste Berg der Alpen!",
      "sourceEnText": "Mont Blanc is the highest mountain in the Alps!",
      "audioFile": "fr_08_003ecb2.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 2900,
      "updatedAt": "2026-03-15T12:29:12Z",
      "textHash": "49367e6e3ad3e354b0fb167c5292186027e14157c8e9e4265d1ddd7cd007d674"
    },
    {
      "key": "00a7e83",
      "nodeTitle": "npc_base3",
      "sourceText": "Richtig! Benutze sie, um das Gleichgewicht zu halten.",
      "sourceEnText": "Correct! Use them to stay steady.",
      "audioFile": "fr_08_00a7e83.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3213,
      "updatedAt": "2026-03-15T12:28:12Z",
      "textHash": "e556d5780e4686c384901a7448ab02f72610a652f0276fd8a59340b3f1dae5ab"
    },
    {
      "key": "011dc7e",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Ich liebe die Berge!",
      "sourceEnText": "I love the mountains!",
      "audioFile": "fr_08_011dc7e.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 1698,
      "updatedAt": "2026-03-15T12:29:11Z",
      "textHash": "c918f2e9ac8c15c6a7cfbabc8422bf35637b041397e32ac36cba9c235df47092"
    },
    {
      "key": "015bf8a",
      "nodeTitle": "npc_base1",
      "sourceText": "Du bist nun bereit zum Klettern!",
      "sourceEnText": "You are now ready to climb!",
      "audioFile": "fr_08_015bf8a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2194,
      "updatedAt": "2026-03-15T12:27:30Z",
      "textHash": "b4e8505c3d1142672d18024e7d392dfc0c43676b3b70be1aa47fc0102040f161"
    },
    {
      "key": "018880a",
      "nodeTitle": "npc_base4",
      "sourceText": "Dieser Gipfel ist 4807 Meter hoch.",
      "sourceEnText": "This summit is 4807 meters high.",
      "audioFile": "fr_08_018880a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3187,
      "updatedAt": "2026-03-15T12:28:23Z",
      "textHash": "22ab2036344b5d9fdf1b1850e5979579f01c78347f73322fe57edb5aee094321"
    },
    {
      "key": "01a4b20",
      "nodeTitle": "npc_base3",
      "sourceText": "Flipper",
      "sourceEnText": "Flippers",
      "audioFile": "fr_08_01a4b20.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 810,
      "updatedAt": "2026-03-15T12:28:14Z",
      "textHash": "2f3861477ef17fc13854e2e5f664e96c4ca172d81a9b64e9c28667e096237c61"
    },
    {
      "key": "01beb5e",
      "nodeTitle": "npc_intro",
      "sourceText": "Wir sahen den Hund den Berg hinauflaufen.",
      "sourceEnText": "We saw the dog run up the mountain.",
      "audioFile": "fr_08_01beb5e.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T12:27:18Z",
      "textHash": "b8957895d99efc90cdbe0d8a0cc710c9c702ae2375fcc6c79b9fd1b3c5c4a45d"
    },
    {
      "key": "01e5f66",
      "nodeTitle": "spawned_hiker",
      "sourceText": "Dieser Gletscher sieht aus wie ein zugefrorener Fluss.",
      "sourceEnText": "That glacier looks like a frozen river.",
      "audioFile": "fr_08_01e5f66.mp3",
      "voiceProfile": "shelley",
      "actorId": "ADULT_M",
      "durationMs": 2795,
      "updatedAt": "2026-03-15T12:29:20Z",
      "textHash": "d91d0c216ff92e68df01f6035f6838b059b336351d6d203644b90636f8971d4f"
    },
    {
      "key": "029a03e",
      "nodeTitle": "npc_base2",
      "sourceText": "Die Sonne scheint sehr hell auf den Schnee. Wir brauchen einen Augenschutz.",
      "sourceEnText": "The sun on the snow is very bright. We need eye protection.",
      "audioFile": "fr_08_029a03e.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4232,
      "updatedAt": "2026-03-15T12:27:50Z",
      "textHash": "4a7293a324d45f3614915b91035136113a645ad748579248b0a5ac44fd4ea49f"
    },
    {
      "key": "029f39c",
      "nodeTitle": "item_backpack",
      "sourceText": "Jetzt können wir das Basislager verlassen und das Abenteuer beginnen!",
      "sourceEnText": "Now we can exit the base camp and start the adventure!",
      "audioFile": "fr_08_029f39c.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4702,
      "updatedAt": "2026-03-15T12:27:29Z",
      "textHash": "14c7aed11ed688ed0184f67f28efa33f518d4cc0853dae26916a9505165c8bb6"
    },
    {
      "key": "02a2ea9",
      "nodeTitle": "item_sunglasses",
      "sourceText": "Schnee und Eis reflektieren helles Sonnenlicht.",
      "sourceEnText": "Snow and ice reflect bright sunlight.",
      "audioFile": "fr_08_02a2ea9.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3082,
      "updatedAt": "2026-03-15T12:28:01Z",
      "textHash": "4822a6cda7f6f4b7b0407620ed48df715c5de78e264e0127797bfeae742bc418"
    },
    {
      "key": "02a3874",
      "nodeTitle": "snowman",
      "sourceText": "Nein, ich bleibe hier.",
      "sourceEnText": "No, I stay here",
      "audioFile": "fr_08_02a3874.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1515,
      "updatedAt": "2026-03-15T12:29:01Z",
      "textHash": "ce71d90516ed8dff6cc91a37e42e684e52b9d8858571111cbe9680cac2632084"
    },
    {
      "key": "02c9805",
      "nodeTitle": "activity_3_done",
      "sourceText": "Öffne die Truhe, um Steigeisen zu erhalten!",
      "sourceEnText": "Open the chest to get crampons!",
      "audioFile": "fr_08_02c9805.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2717,
      "updatedAt": "2026-03-15T12:28:17Z",
      "textHash": "1f03ad35cbf32b73ed50be07c528924bc14ea66fc91a8dd5cf91964fb72c8aa0"
    },
    {
      "key": "030fa1c",
      "nodeTitle": "npc_base4",
      "sourceText": "Du hast es geschafft! Wir sind auf dem Gipfel des Mont Blanc.",
      "sourceEnText": "You made it! We are at the top of Mont Blanc.",
      "audioFile": "fr_08_030fa1c.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3866,
      "updatedAt": "2026-03-15T12:28:21Z",
      "textHash": "b8e7c5786fa6289815203bfe616b36af84c3c8c17747753ca4d3785020035111"
    },
    {
      "key": "035e68a",
      "nodeTitle": "snowman",
      "sourceText": "Basislager 4",
      "sourceEnText": "Basecamp 4",
      "audioFile": "fr_08_035e68a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1097,
      "updatedAt": "2026-03-15T12:29:00Z",
      "textHash": "391e952b7062fc6725dfbacfc6f6fab1d83822102cbe223e3c1762c856c80375"
    },
    {
      "key": "0371d31",
      "nodeTitle": "spawned_alps_climber",
      "sourceText": "Klettern mit einem Bergführer ist sicherer.",
      "sourceEnText": "Climbing with a guide is safer.",
      "audioFile": "fr_08_0371d31.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T12:29:24Z",
      "textHash": "a8a0dfe10dd09991342abbe236242ac14e5e22da308264f349aee8a993287868"
    },
    {
      "key": "038d1bc",
      "nodeTitle": "item_rope",
      "sourceText": "Das Seil hilft Kletterern, auf Eis und Fels sicher zu bleiben.",
      "sourceEnText": "The rope helps climbers stay safe on ice and rock.",
      "audioFile": "fr_08_038d1bc.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4101,
      "updatedAt": "2026-03-15T12:28:20Z",
      "textHash": "73f31451f5c7b21ba875a7abea1b3fa76d41cf1365e9a2ed8054d1c74a993afa"
    },
    {
      "key": "03db010",
      "nodeTitle": "npc_swiss",
      "sourceText": "Die Schweiz liegt nördlich des Mont Blanc.",
      "sourceEnText": "Switzerland is north of Mont Blanc.",
      "audioFile": "fr_08_03db010.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2377,
      "updatedAt": "2026-03-15T16:41:07Z",
      "textHash": "f85747ad79d876c13e454478f53180509b69271f2d9057ead0abecb8c454a9f1"
    },
    {
      "key": "03dd802",
      "nodeTitle": "npc_base1",
      "sourceText": "Dir fehlt der Mantel!",
      "sourceEnText": "You are missing the coat!",
      "audioFile": "fr_08_03dd802.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1646,
      "updatedAt": "2026-03-15T12:27:33Z",
      "textHash": "5b69cab60a42851cbd1d71960c2bd828f6e70990b93e85ddb7e4730b699bc50c"
    },
    {
      "key": "045409f",
      "nodeTitle": "npc_intro",
      "sourceText": "Bevor du losfährst, brauchst du einen Rucksack.",
      "sourceEnText": "Before going, you need a backpack.",
      "audioFile": "fr_08_045409f.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2717,
      "updatedAt": "2026-03-15T12:27:21Z",
      "textHash": "ba65cabe1fcda9bc15c61a0737d2a891a224b6f5a72f4cc1dfee5b6612e39e48"
    },
    {
      "key": "046eb33",
      "nodeTitle": "npc_intro",
      "sourceText": "Komm wieder, wenn du die Aufgabe erledigt hast.",
      "sourceEnText": "Come back when you finish the task.",
      "audioFile": "fr_08_046eb33.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2664,
      "updatedAt": "2026-03-15T12:27:13Z",
      "textHash": "099097da4fd1c44a478cf57ec0d053f2fbb9acfac546e210ffd0bb99032a3920"
    },
    {
      "key": "04bbada",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Ich hoffe, ein Murmeltier zu sehen!",
      "sourceEnText": "I hope to see a marmot!",
      "audioFile": "fr_08_04bbada.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 2534,
      "updatedAt": "2026-03-15T12:29:14Z",
      "textHash": "ebc1517da02669a289653354c3310ba4d435d937cedd8783466c5c8108a13060"
    },
    {
      "key": "04c1c1f",
      "nodeTitle": "npc_intro",
      "sourceText": "Ich sehe, du hast den Rucksack. Jetzt kannst du gehen!",
      "sourceEnText": "I see you have the backpack. Now you can go!",
      "audioFile": "fr_08_04c1c1f.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3448,
      "updatedAt": "2026-03-15T12:27:09Z",
      "textHash": "035522863b6c02fc707b15348f9165ecad1f84e4c51a17587511652d1abca8a1"
    },
    {
      "key": "050fe70",
      "nodeTitle": "npc_italy",
      "sourceText": "Italien liegt östlich des Mont Blanc.",
      "sourceEnText": "Italy is east of Mont Blanc.",
      "audioFile": "fr_08_050fe70.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2560,
      "updatedAt": "2026-03-15T16:41:05Z",
      "textHash": "0eb340008114521b0d2d9dcfd2547bb9be6091235a5c38385c2cd99efa18ed86"
    },
    {
      "key": "0557ef5",
      "nodeTitle": "spawned_hiker",
      "sourceText": "Der Wind kann schnell drehen.",
      "sourceEnText": "The wind can change fast.",
      "audioFile": "fr_08_0557ef5.mp3",
      "voiceProfile": "shelley",
      "actorId": "ADULT_M",
      "durationMs": 1541,
      "updatedAt": "2026-03-15T12:29:19Z",
      "textHash": "f457c22c42276ea6f20e26740d05c6bbe166cb098d10504a166c7f70a538f929"
