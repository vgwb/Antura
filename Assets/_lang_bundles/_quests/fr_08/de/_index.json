      "key": "06d9f34",
      "nodeTitle": "npc_base3",
      "sourceText": "Um auf Gletschereis zu laufen, benötigen wir spezielle Ausrüstung.",
      "sourceEnText": "To walk on glacier ice, we need special gear.",
      "audioFile": "fr_08_06d9f34.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4284,
      "updatedAt": "2026-03-15T12:28:07Z",
