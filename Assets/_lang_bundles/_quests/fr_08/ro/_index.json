    },
    {
      "key": "01beb5e",
      "nodeTitle": "npc_intro",
      "sourceText": "L-am văzut pe câine alergând pe munte.",
      "sourceEnText": "We saw the dog run up the mountain.",
      "audioFile": "fr_08_01beb5e.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 2429,
      "updatedAt": "2026-03-15T12:38:22Z",
      "textHash": "17c3948e3cc5dba96ce741e3c8ea65f77d0aa5266b9a95566cb41566cad38d98"
    },
    {
      "key": "01e5f66",
      "nodeTitle": "spawned_hiker",
      "sourceText": "Ghețarul acela arată ca un râu înghețat.",
      "sourceEnText": "That glacier looks like a frozen river.",
      "audioFile": "fr_08_01e5f66.mp3",
      "voiceProfile": "cristi",
      "actorId": "ADULT_M",
      "durationMs": 2482,
