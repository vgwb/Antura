      "nodeTitle": "npc_base1",
      "sourceText": "Acum ești gata să urci!",
      "sourceEnText": "You are now ready to climb!",
      "audioFile": "fr_08_015bf8a.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
