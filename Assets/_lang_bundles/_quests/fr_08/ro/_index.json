      "key": "05e80cb",
      "nodeTitle": "item_backpack",
      "sourceText": "Acest rucsac poate transporta mâncare, apă și o hartă.",
      "sourceEnText": "This backpack can carry food, water, and a map.",
      "audioFile": "fr_08_05e80cb.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 3448,
