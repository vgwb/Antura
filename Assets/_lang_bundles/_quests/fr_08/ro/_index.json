    },
    {
      "key": "003e87c",
      "nodeTitle": "chest_bonus",
      "sourceText": "Ai găsit o eșarfă călduroasă!",
      "sourceEnText": "You found a warm scarf!",
      "audioFile": "fr_08_003e87c.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 1933,
