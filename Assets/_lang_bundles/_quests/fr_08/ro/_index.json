      "key": "05cabb5",
      "nodeTitle": "npc_intro",
      "sourceText": "Caută-l în jur!",
      "sourceEnText": "Look around for it!",
      "audioFile": "fr_08_05cabb5.mp3",
      "voiceProfile": "cristi",
