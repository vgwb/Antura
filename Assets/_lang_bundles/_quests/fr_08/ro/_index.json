      "textHash": "0f0d052437cc7c9edb138f56a2c79e51b5836686bf198ec979d543ba742c4688"
    },
    {
      "key": "029a03e",
      "nodeTitle": "npc_base2",
      "sourceText": "Soarele pe zăpadă este foarte puternic. Avem nevoie de protecție pentru ochi.",
      "sourceEnText": "The sun on the snow is very bright. We need eye protection.",
      "audioFile": "fr_08_029a03e.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 4441,
      "updatedAt": "2026-03-15T12:38:40Z",
      "textHash": "59bc978dd4651abeb1e0a20329a2fcab0ed7889ec4a95b5b88d1de3ff6756204"
    },
    {
      "key": "029f39c",
      "nodeTitle": "item_backpack",
      "sourceText": "Acum putem ieși din tabăra de bază și începe aventura!",
      "sourceEnText": "Now we can exit the base camp and start the adventure!",
      "audioFile": "fr_08_029f39c.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 3370,
      "updatedAt": "2026-03-15T12:38:28Z",
      "textHash": "dc32252abe5ce52de313cf0e70181338b2df1b7d183933cafce7b32ceec44bd5"
    },
    {
      "key": "02a2ea9",
      "nodeTitle": "item_sunglasses",
      "sourceText": "Zăpada și gheața reflectă lumina puternică a soarelui.",
      "sourceEnText": "Snow and ice reflect bright sunlight.",
      "audioFile": "fr_08_02a2ea9.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 3448,
      "updatedAt": "2026-03-15T12:38:45Z",
      "textHash": "6fc2c0536f01bb0cb5fda0b7c44f0946f21abc0fcc9d366ea67bf0b53701687b"
    },
    {
      "key": "02a3874",
      "nodeTitle": "snowman",
      "sourceText": "Nu, eu rămân aici",
      "sourceEnText": "No, I stay here",
      "audioFile": "fr_08_02a3874.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 1123,
      "updatedAt": "2026-03-15T12:39:16Z",
      "textHash": "d5ba918af1fd692387d8767c2c24fc71f88e5fed91847a6b129a92cfaa7f298b"
    },
    {
      "key": "02c9805",
      "nodeTitle": "activity_3_done",
      "sourceText": "Deschide cufărul ca să iei colțari!",
      "sourceEnText": "Open the chest to get crampons!",
      "audioFile": "fr_08_02c9805.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 2142,
      "updatedAt": "2026-03-15T12:38:53Z",
      "textHash": "7a46cd11b3e599fc64bff7c59e13da2538658e5a076523ef4a76275300f2be9a"
    },
    {
      "key": "030fa1c",
      "nodeTitle": "npc_base4",
      "sourceText": "Ai reușit! Suntem în vârful Mont Blanc.",
      "sourceEnText": "You made it! We are at the top of Mont Blanc.",
