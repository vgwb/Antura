    },
    {
      "key": "003ecb2",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Mont Blanc este cel mai înalt munte din Alpi!",
      "sourceEnText": "Mont Blanc is the highest mountain in the Alps!",
      "audioFile": "fr_08_003ecb2.mp3",
      "voiceProfile": "cristi",
      "actorId": "ADULT_F",
      "durationMs": 2795,
      "updatedAt": "2026-03-15T12:39:22Z",
      "textHash": "855242878880620c40a74836b5a05e151b180d752f1750b8dce7a7a50af02c4c"
    },
    {
      "key": "00a7e83",
      "nodeTitle": "npc_base3",
      "sourceText": "Corect! Folosește-le ca să rămâi stabil.",
      "sourceEnText": "Correct! Use them to stay steady.",
      "audioFile": "fr_08_00a7e83.mp3",
      "voiceProfile": "cristi",
      "actorId": "Default",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T12:38:51Z",
      "textHash": "4f26b0033ed00ead97318d260d849036d73b0ada77f48097ed81a816789e70c5"
    },
    {
      "key": "011dc7e",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Iubesc munții!",
      "sourceEnText": "I love the mountains!",
      "audioFile": "fr_08_011dc7e.mp3",
      "voiceProfile": "cristi",
      "actorId": "ADULT_F",
      "durationMs": 1176,
      "updatedAt": "2026-03-15T12:39:21Z",
