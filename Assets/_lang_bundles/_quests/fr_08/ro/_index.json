      "key": "0650acc",
      "nodeTitle": "npc_intro",
      "sourceText": "Te rugăm să explorezi Mont Blanc și să găsești echipamentul nostru.",
      "sourceEnText": "Please explore Mont Blanc and find our gear.",
      "audioFile": "fr_08_0650acc.mp3",
      "voiceProfile": "cristi",
