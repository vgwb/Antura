  "lines": [
    {
      "key": "000fc05",
      "nodeTitle": "item_hat",
      "sourceText": "Ciepła czapka utrzymuje ciepło głowy.",
      "sourceEnText": "A warm hat keeps your head warm.",
      "audioFile": "fr_08_000fc05.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2664,
      "updatedAt": "2026-03-15T12:36:30Z",
      "textHash": "8d36b12498e1047bf6ddcca231e8d3f5465e4243184be31565a51564a21e9a3c"
    },
    {
      "key": "001e940",
      "nodeTitle": "npc_base4",
      "sourceText": "Przed grą o flagę odpowiedzmy na trzy pytania dotyczące gór.",
      "sourceEnText": "Let's answer three mountain questions before the flag game.",
      "audioFile": "fr_08_001e940.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4049,
      "updatedAt": "2026-03-15T16:42:02Z",
      "textHash": "d92c560cbe877b75109421ffd7c45170bce63147266410a9b11e55146a27ab60"
    },
    {
      "key": "003e87c",
      "nodeTitle": "chest_bonus",
      "sourceText": "Znalazłeś ciepły szalik!",
      "sourceEnText": "You found a warm scarf!",
      "audioFile": "fr_08_003e87c.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1698,
      "updatedAt": "2026-03-15T12:37:55Z",
      "textHash": "368d4275f92c370391f5d076e89d33c79aef8e7d8a203901541820464f2bdf7b"
    },
    {
      "key": "003ecb2",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Mont Blanc jest najwyższą górą w Alpach!",
      "sourceEnText": "Mont Blanc is the highest mountain in the Alps!",
      "audioFile": "fr_08_003ecb2.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 3030,
      "updatedAt": "2026-03-15T12:38:00Z",
      "textHash": "6850e8001fe6ffd1ac5d2160264b71e0a9ce4bc49b0fc94e82e4b7b86152081d"
    },
    {
      "key": "00a7e83",
      "nodeTitle": "npc_base3",
      "sourceText": "Dobrze! Użyj ich, żeby utrzymać równowagę.",
      "sourceEnText": "Correct! Use them to stay steady.",
      "audioFile": "fr_08_00a7e83.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2978,
      "updatedAt": "2026-03-15T12:36:59Z",
      "textHash": "fa6c03f1222c62799fd1b744fd9e43fafca6629596672e0511fa9edbd83246a5"
    },
    {
      "key": "011dc7e",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Uwielbiam góry!",
      "sourceEnText": "I love the mountains!",
      "audioFile": "fr_08_011dc7e.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 1463,
      "updatedAt": "2026-03-15T12:37:58Z",
      "textHash": "6e445da5a652bffdd2f532a7a2b32afc46322322c4afa1a19640f79eba59177e"
    },
    {
      "key": "015bf8a",
      "nodeTitle": "npc_base1",
      "sourceText": "Jesteś teraz gotowy do wspinaczki!",
      "sourceEnText": "You are now ready to climb!",
      "audioFile": "fr_08_015bf8a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T12:36:18Z",
      "textHash": "5695e08e396fc4f704cff5de77ce891809283dba0296a5a9197353b3ee8a7e86"
    },
    {
      "key": "018880a",
      "nodeTitle": "npc_base4",
      "sourceText": "Wysokość tego szczytu wynosi 4807 metrów.",
      "sourceEnText": "This summit is 4807 meters high.",
      "audioFile": "fr_08_018880a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4232,
      "updatedAt": "2026-03-15T12:37:10Z",
      "textHash": "6bcb7d28d38ff0bb13586aa25d330e0f33a80102dd6bb9f9513eb805c55affb9"
    },
    {
      "key": "01a4b20",
      "nodeTitle": "npc_base3",
      "sourceText": "Płetwy",
      "sourceEnText": "Flippers",
      "audioFile": "fr_08_01a4b20.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 888,
      "updatedAt": "2026-03-15T12:37:01Z",
      "textHash": "713dcc07a3b6f26deb0b31df0da072a43fa0a3d6d8600215b80f222e72ff0cad"
    },
    {
      "key": "01beb5e",
      "nodeTitle": "npc_intro",
      "sourceText": "Widzieliśmy psa wbiegającego na górę.",
      "sourceEnText": "We saw the dog run up the mountain.",
      "audioFile": "fr_08_01beb5e.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2429,
      "updatedAt": "2026-03-15T12:36:04Z",
      "textHash": "a0754449f5f429faf2619325bd35e263043de0cc868dc5225645fc40f7f58ec2"
    },
    {
      "key": "01e5f66",
      "nodeTitle": "spawned_hiker",
      "sourceText": "Ten lodowiec wygląda jak zamarznięta rzeka.",
      "sourceEnText": "That glacier looks like a frozen river.",
      "audioFile": "fr_08_01e5f66.mp3",
      "voiceProfile": "shelley",
      "actorId": "ADULT_M",
      "durationMs": 2612,
      "updatedAt": "2026-03-15T12:38:07Z",
      "textHash": "04c1adf2f3ce9beea3cf2e867ce7e83f537a474689d64affddd5c9969bf4f959"
    },
    {
      "key": "029a03e",
      "nodeTitle": "npc_base2",
      "sourceText": "Słońce mocno świeci na śniegu. Potrzebujemy ochrony oczu.",
      "sourceEnText": "The sun on the snow is very bright. We need eye protection.",
      "audioFile": "fr_08_029a03e.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4467,
      "updatedAt": "2026-03-15T12:36:38Z",
      "textHash": "33206590ce363ef68b8412aac513ebcae77179d116f35058f4408fb98a0ca571"
    },
    {
      "key": "029f39c",
      "nodeTitle": "item_backpack",
      "sourceText": "Teraz możemy opuścić obóz bazowy i rozpocząć przygodę!",
      "sourceEnText": "Now we can exit the base camp and start the adventure!",
      "audioFile": "fr_08_029f39c.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3918,
      "updatedAt": "2026-03-15T12:36:15Z",
      "textHash": "21126df21b5931f0ee85159555552f1a5ba524d9ab8c703d4878981b89f6bb71"
    },
    {
      "key": "02a2ea9",
      "nodeTitle": "item_sunglasses",
      "sourceText": "Śnieg i lód odbijają jasne światło słoneczne.",
      "sourceEnText": "Snow and ice reflect bright sunlight.",
      "audioFile": "fr_08_02a2ea9.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3553,
      "updatedAt": "2026-03-15T12:36:49Z",
      "textHash": "02839d0efd1a0b31b8b40d3ef1cdf9ef8e1819fd254aad47f7f4f084ce249db4"
    },
    {
      "key": "02a3874",
      "nodeTitle": "snowman",
      "sourceText": "Nie, zostaję tutaj",
      "sourceEnText": "No, I stay here",
      "audioFile": "fr_08_02a3874.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1411,
      "updatedAt": "2026-03-15T12:37:49Z",
      "textHash": "688a39c170bce4cabade55915c03713e3412b532062acb4eb000ac3be780e1a1"
    },
    {
      "key": "02c9805",
      "nodeTitle": "activity_3_done",
      "sourceText": "Otwórz skrzynię, aby wyjąć raki!",
      "sourceEnText": "Open the chest to get crampons!",
      "audioFile": "fr_08_02c9805.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2377,
      "updatedAt": "2026-03-15T12:37:04Z",
      "textHash": "ffc2c803331744e38005fd9616b771ad2d870219ea97fd7fc3c083dd99ea2d42"
    },
    {
      "key": "030fa1c",
      "nodeTitle": "npc_base4",
      "sourceText": "Udało się! Jesteśmy na szczycie Mont Blanc.",
      "sourceEnText": "You made it! We are at the top of Mont Blanc.",
      "audioFile": "fr_08_030fa1c.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2978,
      "updatedAt": "2026-03-15T12:37:09Z",
      "textHash": "f6ce9f28af4f3b82b97ba9a33089a579fba77a8a35a4bd214d2e1605d3eaa718"
    },
    {
      "key": "035e68a",
      "nodeTitle": "snowman",
      "sourceText": "Baza 4",
      "sourceEnText": "Basecamp 4",
      "audioFile": "fr_08_035e68a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 862,
      "updatedAt": "2026-03-15T12:37:47Z",
      "textHash": "78ba2b5d8745298116c62448356c0be5cea66d549152042d69b2795ac83900f9"
    },
    {
      "key": "0371d31",
      "nodeTitle": "spawned_alps_climber",
      "sourceText": "Wspinaczka z przewodnikiem jest bezpieczniejsza.",
      "sourceEnText": "Climbing with a guide is safer.",
      "audioFile": "fr_08_0371d31.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 3318,
      "updatedAt": "2026-03-15T12:38:12Z",
      "textHash": "2b882db41f2b4b391c20b1eff628e0f56a936a4d4e6429a58f7403625872a720"
    },
    {
      "key": "038d1bc",
      "nodeTitle": "item_rope",
      "sourceText": "Lina pomaga wspinaczom zachować bezpieczeństwo na lodzie i skałach.",
      "sourceEnText": "The rope helps climbers stay safe on ice and rock.",
      "audioFile": "fr_08_038d1bc.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4702,
      "updatedAt": "2026-03-15T12:37:07Z",
      "textHash": "5774c81a1427687b7411c0090d85e286d28befcc347f3bba9afbdf943a8d5b8c"
    },
    {
      "key": "03db010",
      "nodeTitle": "npc_swiss",
      "sourceText": "Szwajcaria leży na północ od Mont Blanc.",
      "sourceEnText": "Switzerland is north of Mont Blanc.",
      "audioFile": "fr_08_03db010.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2769,
      "updatedAt": "2026-03-15T16:42:06Z",
      "textHash": "3d192ef27a2d0396a8ab01c8a91b7b394927a5dab523a546b7fbe3b12fab2bc1"
    },
    {
      "key": "03dd802",
      "nodeTitle": "npc_base1",
      "sourceText": "Brakuje Ci płaszcza!",
      "sourceEnText": "You are missing the coat!",
      "audioFile": "fr_08_03dd802.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1541,
      "updatedAt": "2026-03-15T12:36:21Z",
      "textHash": "6a5d3316eb6f757484b40b6623743643ac28f835944dd8a9cf0892dc14907cdd"
    },
    {
      "key": "045409f",
      "nodeTitle": "npc_intro",
      "sourceText": "Przed wyjazdem będziesz potrzebować plecaka.",
      "sourceEnText": "Before going, you need a backpack.",
      "audioFile": "fr_08_045409f.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2664,
      "updatedAt": "2026-03-15T12:36:07Z",
      "textHash": "ff4477f914f8ecacb4256eb6cdedef4dd6388f917bed1013184b834085801f11"
    },
    {
      "key": "046eb33",
      "nodeTitle": "npc_intro",
      "sourceText": "Wróć, gdy skończysz zadanie.",
      "sourceEnText": "Come back when you finish the task.",
      "audioFile": "fr_08_046eb33.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2011,
      "updatedAt": "2026-03-15T12:36:01Z",
      "textHash": "7cc5d612fd676878e6f4d09de245ccd0a3886fb0ae8dafeadffd11b930b8758f"
    },
    {
      "key": "04bbada",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Mam nadzieję zobaczyć świstaka!",
      "sourceEnText": "I hope to see a marmot!",
      "audioFile": "fr_08_04bbada.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 2142,
      "updatedAt": "2026-03-15T12:38:01Z",
      "textHash": "c373ed65f7499e988f1375618c3f973c243feaeb999baca969e27c8dbf0b0728"
    },
    {
      "key": "04c1c1f",
      "nodeTitle": "npc_intro",
      "sourceText": "Widzę, że masz plecak. Możesz iść!",
      "sourceEnText": "I see you have the backpack. Now you can go!",
      "audioFile": "fr_08_04c1c1f.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2560,
      "updatedAt": "2026-03-15T12:35:56Z",
      "textHash": "3bbbc28458c4c3995078a13871adc4bf030d4b16882051e043ce92bef1bca92a"
    },
    {
      "key": "050fe70",
      "nodeTitle": "npc_italy",
      "sourceText": "Włochy leżą na wschód od Mont Blanc.",
      "sourceEnText": "Italy is east of Mont Blanc.",
      "audioFile": "fr_08_050fe70.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T16:42:05Z",
      "textHash": "18aa2d4ae9ecee1d632ecae35db443fc7915fe7b0da6015c32c492b5f00689a2"
    },
    {
      "key": "0557ef5",
      "nodeTitle": "spawned_hiker",
      "sourceText": "Wiatr może się szybko zmienić.",
      "sourceEnText": "The wind can change fast.",
      "audioFile": "fr_08_0557ef5.mp3",
      "voiceProfile": "shelley",
      "actorId": "ADULT_M",
      "durationMs": 1933,
      "updatedAt": "2026-03-15T12:38:06Z",
      "textHash": "9a07089209cadce90e8b521be1890c68b5b9cd2eb25af132cf016322ce182062"
    },
    {
      "key": "056ec2b",
      "nodeTitle": "chest_base1",
      "sourceText": "Otwiera się! Zawiera trochę sprzętu.",
      "sourceEnText": "It opens! It contains some equipment.",
      "audioFile": "fr_08_056ec2b.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2769,
      "updatedAt": "2026-03-15T12:36:27Z",
      "textHash": "1569ec5982f4fa5b868999735035540c0f0f85c8ae21f7721829152792366543"
    },
    {
      "key": "058bb65",
      "nodeTitle": "snowman",
      "sourceText": "Baza 3",
      "sourceEnText": "Basecamp 3",
      "audioFile": "fr_08_058bb65.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1228,
      "updatedAt": "2026-03-15T12:37:46Z",
      "textHash": "8cc931c474ff02214c9bc9bd3cfc64706a7322e3e9ae6adf490270d4349c559c"
    },
    {
      "key": "0590129",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Nie zapomnij zabrać ciepłych ubrań!",
      "sourceEnText": "Don't forget to bring warm clothes!",
      "audioFile": "fr_08_0590129.mp3",
      "voiceProfile": "alice",
      "actorId": "ADULT_F",
      "durationMs": 2534,
      "updatedAt": "2026-03-15T12:38:03Z",
      "textHash": "8bfa66d35300f23f378c72b3e79980aaead7c1af72fb78833247f2ae92b77f78"
    },
    {
      "key": "059d744",
      "nodeTitle": "item_hat",
      "sourceText": "Pomaga również, gdy wieje zimny wiatr.",
      "sourceEnText": "It also helps when the wind is cold.",
      "audioFile": "fr_08_059d744.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T12:36:32Z",
      "textHash": "463c0623af8195823385ed2e658dab11aafe57614f0cb5bc55b61e63f9d3fd58"
    },
    {
      "key": "05cabb5",
      "nodeTitle": "npc_intro",
      "sourceText": "Rozejrzyj się dookoła!",
      "sourceEnText": "Look around for it!",
      "audioFile": "fr_08_05cabb5.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1646,
      "updatedAt": "2026-03-15T12:36:09Z",
      "textHash": "d901a7254667c99a25b46a234f081198c7c2b560e72b1297a670b6ba55ff25b9"
    },
    {
      "key": "05e3658",
      "nodeTitle": "snowman",
      "sourceText": "Baza 2",
      "sourceEnText": "Basecamp 2",
      "audioFile": "fr_08_05e3658.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1045,
      "updatedAt": "2026-03-15T12:37:45Z",
      "textHash": "01258aff1c14b20bf175038a8c024f560f45b61b7260549116d1095e01b0dd09"
    },
    {
      "key": "05e80cb",
      "nodeTitle": "item_backpack",
      "sourceText": "W tym plecaku można przenosić jedzenie, wodę i mapę.",
      "sourceEnText": "This backpack can carry food, water, and a map.",
      "audioFile": "fr_08_05e80cb.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3814,
      "updatedAt": "2026-03-15T12:36:13Z",
      "textHash": "3503fbab505708511e71c083cf6702a2bf054b78d7dfa00438efea668688b811"
    },
    {
      "key": "0650acc",
      "nodeTitle": "npc_intro",
      "sourceText": "Zapraszamy do eksploracji Mont Blanc i zapoznania się z naszym sprzętem.",
      "sourceEnText": "Please explore Mont Blanc and find our gear.",
      "audioFile": "fr_08_0650acc.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4754,
      "updatedAt": "2026-03-15T12:36:06Z",
      "textHash": "162b1173e091eab3c2fc4353017aaa90c3f357a1b35d4f4b24b599eab97fefc5"
    },
    {
      "key": "06b15bb",
      "nodeTitle": "npc_base3",
      "sourceText": "Masz sprzęt lodowy. Ostatni atak na szczyt!",
      "sourceEnText": "You have the ice gear. One last push to the top!",
      "audioFile": "fr_08_06b15bb.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2900,
      "updatedAt": "2026-03-15T12:36:52Z",
      "textHash": "833acf2950b00eb9f40f986da56c13be88f5da826705512f469f9ce3df8c2b64"
    },
    {
      "key": "06b3363",
      "nodeTitle": "npc_base2",
      "sourceText": "Brakuje Ci rękawiczek!",
      "sourceEnText": "You are missing the gloves!",
      "audioFile": "fr_08_06b3363.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1776,
      "updatedAt": "2026-03-15T12:36:36Z",
      "textHash": "e1d80528b86fbad512e384b7f057515b603f2879e5cd8e6b53fac7e94e354db0"
    },
    {
      "key": "06d9f34",
      "nodeTitle": "npc_base3",
      "sourceText": "Aby chodzić po lodowcu, potrzebujemy specjalnego sprzętu.",
      "sourceEnText": "To walk on glacier ice, we need special gear.",
      "audioFile": "fr_08_06d9f34.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3553,
      "updatedAt": "2026-03-15T12:36:55Z",
      "textHash": "3caca46d8743bfca204f1892ec4d1e43fbe421bd21a444ec1fcfd13eb484476d"
    },
    {
      "key": "06f9a2a",
      "nodeTitle": "question_alps",
      "sourceText": "W jakim paśmie górskim znajduje się Mont Blanc?",
      "sourceEnText": "What mountain range is Mont Blanc in?",
      "audioFile": "fr_08_06f9a2a.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3213,
      "updatedAt": "2026-03-15T12:37:14Z",
      "textHash": "249ede6eef0f73045a4d4fbaeb4f2fd86691f72d92f491927cafc692637dd0f0"
    },
    {
      "key": "07102e7",
      "nodeTitle": "item_crampons",
      "sourceText": "Pomagają bezpiecznie chodzić po lodzie.",
      "sourceEnText": "These help you walk safely on ice.",
      "audioFile": "fr_08_07102e7.mp3",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2534,
      "updatedAt": "2026-03-15T12:37:05Z",
      "textHash": "422bfd56bc57dabab3aaac8da2e48eff4c5bfb2a88b090941e28a513991e359a"
    },
    {
      "key": "0724de3",
      "nodeTitle": "npc_intro",
