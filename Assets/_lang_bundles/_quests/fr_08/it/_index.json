    {
      "key": "0590129",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Non dimenticate di portare abiti caldi!",
      "sourceEnText": "Don't forget to bring warm clothes!",
      "audioFile": "fr_08_0590129.mp3",
      "voiceProfile": "francesco",
      "actorId": "ADULT_F",
      "durationMs": 2142,
      "updatedAt": "2026-03-15T12:35:40Z",
      "textHash": "2ddc59a21fac719aabde76994c19845dfe0422dc63e428cbfc8b3098a94ffa83"
    },
    {
      "key": "059d744",
      "nodeTitle": "item_hat",
      "sourceText": "È utile anche quando il vento è freddo.",
      "sourceEnText": "It also helps when the wind is cold.",
      "audioFile": "fr_08_059d744.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2064,
      "updatedAt": "2026-03-15T12:34:53Z",
      "textHash": "b6dfe5d6cf42a2e32b4b0a9841acc407126dd3811a6baad352d037046784ff07"
    },
    {
      "key": "05cabb5",
      "nodeTitle": "npc_intro",
      "sourceText": "Cercatelo!",
      "sourceEnText": "Look around for it!",
      "audioFile": "fr_08_05cabb5.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 940,
      "updatedAt": "2026-03-15T12:34:41Z",
      "textHash": "046608d51d770690a3f98ee6fdd0cbd325a36135941d000b4bf6f3c550bc2c72"
    },
    {
      "key": "05e3658",
      "nodeTitle": "snowman",
      "sourceText": "Campo base 2",
      "sourceEnText": "Basecamp 2",
      "audioFile": "fr_08_05e3658.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 940,
      "updatedAt": "2026-03-15T12:35:31Z",
      "textHash": "8f70907c734a637969fa1aaa0646ba200b3948c20ee2edfe133ac11a173c98cf"
    },
    {
      "key": "05e80cb",
      "nodeTitle": "item_backpack",
      "sourceText": "Questo zaino può contenere cibo, acqua e una mappa.",
      "sourceEnText": "This backpack can carry food, water, and a map.",
      "audioFile": "fr_08_05e80cb.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3265,
      "updatedAt": "2026-03-15T12:34:44Z",
      "textHash": "7431f2e39c5caec3e96e48c851edb3ce24b446fda51f58f9016802190597f718"
    },
    {
      "key": "0650acc",
      "nodeTitle": "npc_intro",
      "sourceText": "Vi invitiamo a esplorare il Monte Bianco e a trovare la nostra attrezzatura.",
      "sourceEnText": "Please explore Mont Blanc and find our gear.",
      "audioFile": "fr_08_0650acc.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 4519,
      "updatedAt": "2026-03-15T12:34:40Z",
      "textHash": "a2a2bc3812f5a0ae1979ffefbd70f41f5da15f0d93bd150f983362252ba39836"
    },
    {
      "key": "06b15bb",
      "nodeTitle": "npc_base3",
      "sourceText": "Hai l'attrezzatura da ghiaccio. Un ultimo sforzo per raggiungere la cima!",
      "sourceEnText": "You have the ice gear. One last push to the top!",
      "audioFile": "fr_08_06b15bb.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3866,
      "updatedAt": "2026-03-15T12:35:03Z",
      "textHash": "a3cd6c1bef3f72b5171b38ded851eaab4d0c04b77fb1580fdea7f5a79b55f175"
    },
    {
      "key": "06b3363",
      "nodeTitle": "npc_base2",
      "sourceText": "Ti mancano i guanti!",
      "sourceEnText": "You are missing the gloves!",
      "audioFile": "fr_08_06b3363.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3082,
      "updatedAt": "2026-03-15T12:34:55Z",
      "textHash": "52e5444ed9fc88170c5633924534a7f5dc739b3f75892b7d147df8f3709a62bb"
    },
    {
      "key": "06d9f34",
      "nodeTitle": "npc_base3",
      "sourceText": "Per camminare sul ghiaccio di un ghiacciaio, abbiamo bisogno di attrezzature speciali.",
      "sourceEnText": "To walk on glacier ice, we need special gear.",
      "audioFile": "fr_08_06d9f34.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 4101,
      "updatedAt": "2026-03-15T12:35:05Z",
      "textHash": "b1eb7aea1339b79a78e1cb5cde48037d1d962e37a2bc6ee9910a5f28ec962492"
    },
    {
      "key": "06f9a2a",
      "nodeTitle": "question_alps",
      "sourceText": "In quale catena montuosa si trova il Monte Bianco?",
      "sourceEnText": "What mountain range is Mont Blanc in?",
      "audioFile": "fr_08_06f9a2a.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2664,
      "updatedAt": "2026-03-15T12:35:14Z",
      "textHash": "3c7eab75ae86c0dd878b6751f8f9e9f4069b25c897dfa604e5caea73d98faebf"
    },
    {
      "key": "07102e7",
      "nodeTitle": "item_crampons",
      "sourceText": "Questi dispositivi ti aiutano a camminare in sicurezza sul ghiaccio.",
      "sourceEnText": "These help you walk safely on ice.",
      "audioFile": "fr_08_07102e7.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3500,
      "updatedAt": "2026-03-15T12:35:10Z",
      "textHash": "11ab94c7ba6d347a9e839c80eeff971d2a7f40307e632d6d9c9cbe41740415ef"
    },
    {
      "key": "0724de3",
      "nodeTitle": "npc_intro",
      "sourceText": "Aiuto! Sono una guida alpina. Un cane blu ci ha rubato l'attrezzatura da arrampicata!",
      "sourceEnText": "Help! I am a mountain guide. A blue dog took our climbing gear!",
