    {
      "key": "end_1",
      "nodeTitle": "quest_end",
      "sourceText": "Incredibile! Hai raggiunto la cima del Monte Bianco. È alta 4807 metri!",
      "sourceEnText": "Amazing! You reached the top of Mont Blanc. It is 4807 meters high!",
      "audioFile": "fr_08_end_1.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 5042,
      "updatedAt": "2026-03-15T12:34:32Z",
      "textHash": "478ff574b5c521e2944c7397c4f05a66c77c1dbd4d969280a19532c12e7caef9"
    },
    {
      "key": "end_2",
      "nodeTitle": "quest_end",
      "sourceText": "Le Alpi sono ricche di montagne alte e meravigliose.",
      "sourceEnText": "The Alps are full of tall, beautiful mountains.",
      "audioFile": "fr_08_end_2.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2952,
      "updatedAt": "2026-03-15T12:34:33Z",
      "textHash": "3235a3b2d4d8cee8d9d76f088a8620f5795a9f28f55028940228da38ece57dd7"
    },
    {
      "key": "fr08_b2_chest",
      "nodeTitle": "chest_base2",
      "sourceText": "Si apre! Dentro ci sono degli occhiali da sole.",
      "sourceEnText": "It opens! It has sunglasses inside.",
      "audioFile": "fr_08_fr08_b2_chest.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2795,
      "updatedAt": "2026-03-15T12:34:59Z",
      "textHash": "33d35b712afcfe6c845574ed5c66bb6f4c8dfa8c835fd9d8832e2a945e0464da"
    },
    {
      "key": "fr08_b2_help",
      "nodeTitle": "npc_base2",
      "sourceText": "Se rimani bloccato, il pupazzo di neve può aiutarti!",
      "sourceEnText": "If you get stuck, the snowman can help!",
      "audioFile": "fr_08_fr08_b2_help.mp3",
      "voiceProfile": "francesco",
