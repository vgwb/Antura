      "textHash": "26f1100a22bc70a0a299eac3c88c97d0763f9d3666fb8403aeda51756ee1083e"
    },
    {
      "key": "04bbada",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Spero di vedere una marmotta!",
      "sourceEnText": "I hope to see a marmot!",
      "audioFile": "fr_08_04bbada.mp3",
      "voiceProfile": "francesco",
      "actorId": "ADULT_F",
      "durationMs": 1541,
      "updatedAt": "2026-03-15T12:35:39Z",
      "textHash": "dcd705f25d63c1c8065192ccb1451c29d4c43ffb59aa85a7180223cc09a4d75d"
    },
    {
      "key": "04c1c1f",
      "nodeTitle": "npc_intro",
      "sourceText": "Vedo che hai lo zaino. Ora puoi andare!",
      "sourceEnText": "I see you have the backpack. Now you can go!",
      "audioFile": "fr_08_04c1c1f.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2429,
      "updatedAt": "2026-03-15T12:34:35Z",
      "textHash": "dc7b1365020aae0e16f12b90765108d297b617f96a27a9f88e22958b0ce9083a"
    },
    {
      "key": "050fe70",
      "nodeTitle": "npc_italy",
      "sourceText": "L'Italia si trova a est del Monte Bianco.",
      "sourceEnText": "Italy is east of Mont Blanc.",
      "audioFile": "fr_08_050fe70.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2351,
      "updatedAt": "2026-03-15T16:41:52Z",
      "textHash": "88ff873d0593429392a046347bd006897f95b8924f6c0abe6436ecfee1dcaab9"
