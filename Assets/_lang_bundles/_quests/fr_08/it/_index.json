    },
    {
      "key": "fr08_marmot_2",
      "nodeTitle": "marmot",
      "sourceText": "Dormo tutto l'inverno sotto la neve. Questo si chiama ibernazione!",
      "sourceEnText": "I sleep all winter under the snow. This is called hibernation!",
      "audioFile": "fr_08_fr08_marmot_2.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3553,
      "updatedAt": "2026-03-15T12:35:34Z",
      "textHash": "4c7adf117ed146af700565c5efc2709dba367840b300b3053a2f915f02e4fdbb"
    },
    {
      "key": "fr08_marmot_3",
      "nodeTitle": "marmot",
      "sourceText": "Adoro mangiare fiori e erbe alpine. Che bontà!",
      "sourceEnText": "I love eating alpine flowers and grass. Yum!",
      "audioFile": "fr_08_fr08_marmot_3.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2847,
      "updatedAt": "2026-03-15T12:35:35Z",
      "textHash": "5cc89884fb6ca4f5c845af90ad04777f4c1b6c51317b1986265c8253568ef8b0"
    },
    {
      "key": "fr08_marmot_4",
      "nodeTitle": "marmot",
      "sourceText": "Non fate caso a me, sto solo prendendo il sole su questa roccia calda.",
      "sourceEnText": "Don't mind me, I'm just sunbathing on this warm rock.",
      "audioFile": "fr_08_fr08_marmot_4.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3788,
      "updatedAt": "2026-03-15T12:35:35Z",
      "textHash": "5f24b6091e79cc48be811df8e4b68f14759c18a809ba2d092ade5b30507372e7"
    },
    {
      "key": "keep_looking",
      "nodeTitle": "npc_base2",
      "sourceText": "Continuate a cercare. Abbiamo ancora bisogno di tutta l'attrezzatura.",
      "sourceEnText": "Keep looking. We still need all the gear.",
      "audioFile": "fr_08_keep_looking.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3788,
      "updatedAt": "2026-03-15T12:34:57Z",
      "textHash": "4d2a51a0ef06e4ea74693b19263e95ca96eca1d5e26215c7abeb529dd0d2938a"
