    {
      "key": "046eb33",
      "nodeTitle": "npc_intro",
      "sourceText": "Torna quando hai finito il compito.",
      "sourceEnText": "Come back when you finish the task.",
      "audioFile": "fr_08_046eb33.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 1933,
