    },
    {
      "key": "b1_1",
      "nodeTitle": "npc_base1",
      "sourceText": "Il vento comincia a soffiare. Ho bisogno di proteggere le orecchie!",
      "sourceEnText": "The wind is starting to blow. My ears need protection!",
