    {
      "key": "000fc05",
      "nodeTitle": "item_hat",
      "sourceText": "Un cappello caldo mantiene la testa al caldo.",
      "sourceEnText": "A warm hat keeps your head warm.",
      "audioFile": "fr_08_000fc05.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2482,
