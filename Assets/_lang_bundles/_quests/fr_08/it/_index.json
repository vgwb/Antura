    },
    {
      "key": "058bb65",
      "nodeTitle": "snowman",
      "sourceText": "Campo base 3",
      "sourceEnText": "Basecamp 3",
      "audioFile": "fr_08_058bb65.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 993,
      "updatedAt": "2026-03-15T12:35:31Z",
      "textHash": "4d40db4a3b66fc20f53bde8dceac9f4cab83318ae96d107eb16c7d6d1ad7a986"
