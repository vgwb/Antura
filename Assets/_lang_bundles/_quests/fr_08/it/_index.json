    {
      "key": "045409f",
      "nodeTitle": "npc_intro",
      "sourceText": "Prima di partire, ti serve uno zaino.",
      "sourceEnText": "Before going, you need a backpack.",
      "audioFile": "fr_08_045409f.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
