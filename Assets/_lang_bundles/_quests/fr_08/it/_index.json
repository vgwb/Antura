      "key": "056ec2b",
      "nodeTitle": "chest_base1",
      "sourceText": "Si apre! Contiene dell'attrezzatura.",
      "sourceEnText": "It opens! It contains some equipment.",
      "audioFile": "fr_08_056ec2b.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2194,
      "updatedAt": "2026-03-15T12:34:50Z",
