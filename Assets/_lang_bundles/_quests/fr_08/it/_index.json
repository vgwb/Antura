    },
    {
      "key": "001e940",
      "nodeTitle": "npc_base4",
      "sourceText": "Rispondiamo a tre domande sulla montagna prima della partita delle bandiere.",
      "sourceEnText": "Let's answer three mountain questions before the flag game.",
      "audioFile": "fr_08_001e940.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3918,
      "updatedAt": "2026-03-15T16:41:50Z",
      "textHash": "dd8459ffe5d875b12d2fc3383b815cf8975dd0fbeeaf236b211a4ba1ef4c666a"
    },
    {
      "key": "003e87c",
      "nodeTitle": "chest_bonus",
      "sourceText": "Hai trovato una sciarpa calda!",
      "sourceEnText": "You found a warm scarf!",
      "audioFile": "fr_08_003e87c.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 1698,
      "updatedAt": "2026-03-15T12:35:36Z",
      "textHash": "cad496070791b2bcbb8a97b609dd0460e37b6eced0d739a6cb9f7e27b6d05a9b"
    },
    {
      "key": "003ecb2",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Il Monte Bianco è la montagna più alta delle Alpi!",
      "sourceEnText": "Mont Blanc is the highest mountain in the Alps!",
      "audioFile": "fr_08_003ecb2.mp3",
      "voiceProfile": "francesco",
      "actorId": "ADULT_F",
      "durationMs": 2534,
      "updatedAt": "2026-03-15T12:35:38Z",
      "textHash": "5847ca9df6604e9bc85593bacbfb8ff52d8c6f4272f9bc990458c8069b1fbb60"
    },
    {
      "key": "00a7e83",
      "nodeTitle": "npc_base3",
      "sourceText": "Esatto! Usali per rimanere stabile.",
      "sourceEnText": "Correct! Use them to stay steady.",
      "audioFile": "fr_08_00a7e83.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2482,
      "updatedAt": "2026-03-15T12:35:07Z",
      "textHash": "2ea57171a873f16da18f5eb040f37db7369d2a54ad86eaf911d29d0706ca6556"
    },
    {
      "key": "011dc7e",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Adoro la montagna!",
      "sourceEnText": "I love the mountains!",
      "audioFile": "fr_08_011dc7e.mp3",
      "voiceProfile": "francesco",
      "actorId": "ADULT_F",
      "durationMs": 1280,
      "updatedAt": "2026-03-15T12:35:38Z",
      "textHash": "cf5fa987bdb8fd8ac887f2c3584006f275ade37cc3ac5a9b0985c4ca3278e453"
    },
    {
      "key": "015bf8a",
      "nodeTitle": "npc_base1",
      "sourceText": "Ora sei pronto per la scalata!",
      "sourceEnText": "You are now ready to climb!",
      "audioFile": "fr_08_015bf8a.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 1646,
      "updatedAt": "2026-03-15T12:34:45Z",
      "textHash": "243be1a46f4e94972ca8f701571a2e562667211f437a09a83c8abed6ba7cdf8f"
    },
    {
      "key": "018880a",
      "nodeTitle": "npc_base4",
      "sourceText": "Questa vetta è alta 4807 metri.",
      "sourceEnText": "This summit is 4807 meters high.",
      "audioFile": "fr_08_018880a.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2952,
      "updatedAt": "2026-03-15T12:35:13Z",
      "textHash": "d3a85891b7b90f1d7c86ff8c00a1c0f59932cd9251e16985b5f5a9e477ac2beb"
    },
    {
      "key": "01a4b20",
      "nodeTitle": "npc_base3",
      "sourceText": "Pinne",
      "sourceEnText": "Flippers",
      "audioFile": "fr_08_01a4b20.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 679,
      "updatedAt": "2026-03-15T12:35:08Z",
      "textHash": "f7360c1da160c1fbd420581e0a3a4d8e29c8e28719985be5070caef2c8e9a34e"
    },
    {
      "key": "01beb5e",
      "nodeTitle": "npc_intro",
      "sourceText": "Abbiamo visto il cane correre su per la montagna.",
      "sourceEnText": "We saw the dog run up the mountain.",
      "audioFile": "fr_08_01beb5e.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2560,
      "updatedAt": "2026-03-15T12:34:39Z",
      "textHash": "362e1754c25bd1188e217a06720941e88bda764b587b419a18fc1f8006cf6854"
    },
    {
      "key": "01e5f66",
      "nodeTitle": "spawned_hiker",
      "sourceText": "Quel ghiacciaio sembra un fiume ghiacciato.",
      "sourceEnText": "That glacier looks like a frozen river.",
      "audioFile": "fr_08_01e5f66.mp3",
      "voiceProfile": "francesco",
      "actorId": "ADULT_M",
      "durationMs": 2142,
      "updatedAt": "2026-03-15T12:35:44Z",
      "textHash": "385cd764247dd9984d5ade845b9cf8d3aee50b15e935e510021f528bb9292451"
    },
    {
      "key": "029a03e",
      "nodeTitle": "npc_base2",
      "sourceText": "Il sole sulla neve è molto forte. Abbiamo bisogno di proteggere gli occhi.",
      "sourceEnText": "The sun on the snow is very bright. We need eye protection.",
      "audioFile": "fr_08_029a03e.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 4153,
      "updatedAt": "2026-03-15T12:34:56Z",
      "textHash": "264ce1f27dae4df0f4af74acca3f55e7840e09915efd4f4f6bcde8a431d1a582"
    },
    {
      "key": "029f39c",
      "nodeTitle": "item_backpack",
      "sourceText": "Ora possiamo lasciare il campo base e iniziare l'avventura!",
      "sourceEnText": "Now we can exit the base camp and start the adventure!",
      "audioFile": "fr_08_029f39c.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3265,
      "updatedAt": "2026-03-15T12:34:45Z",
      "textHash": "176bfb254e5f35a0a4bdb54d0a06bea326fe76069d5a58540cc032cf1aea6312"
    },
    {
      "key": "02a2ea9",
      "nodeTitle": "item_sunglasses",
      "sourceText": "Neve e ghiaccio riflettono la luce solare intensa.",
      "sourceEnText": "Snow and ice reflect bright sunlight.",
      "audioFile": "fr_08_02a2ea9.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2795,
      "updatedAt": "2026-03-15T12:35:01Z",
      "textHash": "97cad720fabd03658555baed07161b2c7c0cbb16af98b8d1b1049fc77401aa40"
    },
    {
      "key": "02a3874",
      "nodeTitle": "snowman",
      "sourceText": "No, resto qui",
      "sourceEnText": "No, I stay here",
      "audioFile": "fr_08_02a3874.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 1045,
      "updatedAt": "2026-03-15T12:35:33Z",
      "textHash": "2b62a28cfa2ba2ea553076432653d8ed57f714ef3ec5738d141e86f5acf431e1"
    },
    {
      "key": "02c9805",
      "nodeTitle": "activity_3_done",
      "sourceText": "Apri il forziere per prendere i ramponi!",
      "sourceEnText": "Open the chest to get crampons!",
      "audioFile": "fr_08_02c9805.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2142,
      "updatedAt": "2026-03-15T12:35:09Z",
      "textHash": "d58953653c82b638a3da7e582dfa6adb80d98608f3aaa9c813ec4cfaf71bf6ec"
    },
    {
      "key": "030fa1c",
      "nodeTitle": "npc_base4",
      "sourceText": "Ce l'hai fatta! Siamo in cima al Monte Bianco.",
      "sourceEnText": "You made it! We are at the top of Mont Blanc.",
      "audioFile": "fr_08_030fa1c.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2717,
      "updatedAt": "2026-03-15T12:35:12Z",
      "textHash": "356c4892fe55e1f7dcdead226c7f3e4c1e64f33ad2f5ddf6207c04f49ce80996"
    },
    {
      "key": "035e68a",
      "nodeTitle": "snowman",
      "sourceText": "Campo base 4",
      "sourceEnText": "Basecamp 4",
      "audioFile": "fr_08_035e68a.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 1097,
      "updatedAt": "2026-03-15T12:35:32Z",
      "textHash": "bf2849b04aa356d2185b272bc5c3753b6093bc1d0facfc91a693c5fecde1ab57"
    },
    {
      "key": "0371d31",
      "nodeTitle": "spawned_alps_climber",
      "sourceText": "Scalare con una guida è più sicuro.",
      "sourceEnText": "Climbing with a guide is safer.",
      "audioFile": "fr_08_0371d31.mp3",
      "voiceProfile": "francesco",
      "actorId": "ADULT_F",
      "durationMs": 1881,
      "updatedAt": "2026-03-15T12:35:46Z",
      "textHash": "ffb88376702a65baaf6e858430abe0329fa36fc458a0d84d4c667933b6558a4c"
    },
    {
      "key": "038d1bc",
      "nodeTitle": "item_rope",
      "sourceText": "La corda aiuta gli scalatori a rimanere al sicuro su ghiaccio e roccia.",
      "sourceEnText": "The rope helps climbers stay safe on ice and rock.",
      "audioFile": "fr_08_038d1bc.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3788,
      "updatedAt": "2026-03-15T12:35:11Z",
      "textHash": "0a4de73843809ea867dc638c3a3841d7effc1c1d4963c887a7aeccb534fbc010"
    },
    {
      "key": "03db010",
      "nodeTitle": "npc_swiss",
      "sourceText": "La Svizzera si trova a nord del Monte Bianco.",
      "sourceEnText": "Switzerland is north of Mont Blanc.",
      "audioFile": "fr_08_03db010.mp3",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2429,
      "updatedAt": "2026-03-15T16:41:53Z",
      "textHash": "0c6461d711b57b5df9e3a952b6704f4e830edce32dc7de754acfe9397526e9c7"
    },
    {
      "key": "03dd802",
      "nodeTitle": "npc_base1",
      "sourceText": "Ti manca il cappotto!",
      "sourceEnText": "You are missing the coat!",
      "audioFile": "fr_08_03dd802.mp3",
      "voiceProfile": "francesco",
