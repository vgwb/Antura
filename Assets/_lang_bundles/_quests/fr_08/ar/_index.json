    },
    {
      "key": "b1_q",
      "nodeTitle": "npc_base1",
      "sourceText": "كيف نحمي آذاننا عندما تكون الرياح قوية؟",
      "sourceEnText": "How do we protect the ears when the wind is strong?",
      "audioFile": "fr_08_b1_q.mp3",
      "voiceProfile": "haytham",
      "actorId": "Default",
      "durationMs": 2952,
      "updatedAt": "2026-03-15T12:26:02Z",
