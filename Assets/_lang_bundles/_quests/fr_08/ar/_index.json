    },
    {
      "key": "chest_locked",
      "nodeTitle": "chest_intro",
      "sourceText": "إنه مغلق. ربما تحتاج إلى مفتاح.",
      "sourceEnText": "It's locked. Maybe you need a key.",
      "audioFile": "fr_08_chest_locked.mp3",
      "voiceProfile": "haytham",
      "actorId": "Default",
      "durationMs": 2847,
      "updatedAt": "2026-03-15T12:25:56Z",
      "textHash": "3aba473f7f13bf6b0bbb7b268e0d89e545baaa1734f1675152cb3d97fad9342e"
    },
    {
      "key": "comebacklater",
      "nodeTitle": "question_alps",
      "sourceText": "عد لاحقاً!",
      "sourceEnText": "Come back later!",
      "audioFile": "fr_08_comebacklater.mp3",
      "voiceProfile": "haytham",
      "actorId": "Default",
