    },
    {
      "key": "correct",
      "nodeTitle": "question_alps",
      "sourceText": "صحيح!",
      "sourceEnText": "Correct!",
      "audioFile": "fr_08_correct.mp3",
      "voiceProfile": "haytham",
      "actorId": "Default",
      "durationMs": 940,
      "updatedAt": "2026-03-15T12:26:29Z",
      "textHash": "3e0ec24b49deb0628449820405c6b5a0060df18e66350a6d560e104049b22262"
    },
    {
      "key": "dontknow",
      "nodeTitle": "question_alps",
      "sourceText": "لا أعرف",
      "sourceEnText": "I don't know",
      "audioFile": "fr_08_dontknow.mp3",
      "voiceProfile": "haytham",
      "actorId": "Default",
      "durationMs": 810,
      "updatedAt": "2026-03-15T18:58:46Z",
