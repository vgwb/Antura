    },
    {
      "key": "b1_1",
      "nodeTitle": "npc_base1",
      "sourceText": "بدأت الرياح تهب. أذناي بحاجة إلى الحماية!",
      "sourceEnText": "The wind is starting to blow. My ears need protection!",
      "audioFile": "fr_08_b1_1.mp3",
      "voiceProfile": "haytham",
      "actorId": "Default",
      "durationMs": 4101,
      "updatedAt": "2026-03-15T12:26:01Z",
