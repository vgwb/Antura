    },
    {
      "key": "0c18060",
      "nodeTitle": "snowman",
      "sourceText": "Segítségre van szükséged a hegy megmászásához?",
      "sourceEnText": "Do you need help to climb the mountain?",
      "audioFile": "fr_08_0c18060.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 3030,
      "updatedAt": "2026-03-15T12:34:11Z",
