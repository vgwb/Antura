    },
    {
      "key": "0c18c08",
      "nodeTitle": "npc_base3",
      "sourceText": "Hiányzik a köteled!",
      "sourceEnText": "You are missing the rope!",
      "audioFile": "fr_08_0c18c08.mp3",
      "voiceProfile": "shelley",
