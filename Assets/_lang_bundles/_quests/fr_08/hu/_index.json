    },
    {
      "key": "0f4644b",
      "nodeTitle": "npc_intro",
      "sourceText": "Másszuk meg a Mont Blanc-t.",
      "sourceEnText": "Let's climb Mont Blanc.",
      "audioFile": "fr_08_0f4644b.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
