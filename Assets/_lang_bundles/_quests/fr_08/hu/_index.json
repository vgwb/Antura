    },
    {
      "key": "0e83480",
      "nodeTitle": "activity_1_done",
      "sourceText": "Nyisd ki a ládát, hogy meleg sapkát kapj!",
      "sourceEnText": "Open the chest to get a warm hat!",
      "audioFile": "fr_08_0e83480.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
