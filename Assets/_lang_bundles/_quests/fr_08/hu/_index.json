    },
    {
      "key": "0d01879",
      "nodeTitle": "item_gloves",
      "sourceText": "A hideg kezek megnehezítik a mászást.",
      "sourceEnText": "Cold hands make climbing hard.",
      "audioFile": "fr_08_0d01879.mp3",
      "voiceProfile": "shelley",
