    },
    {
      "key": "0d23529",
      "nodeTitle": "npc_france",
      "sourceText": "Franciaország Mont Blanc-tól nyugatra található.",
      "sourceEnText": "France is west of Mont Blanc.",
      "audioFile": "fr_08_0d23529.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2978,
      "updatedAt": "2026-03-15T16:41:43Z",
