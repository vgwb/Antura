    },
    {
      "key": "07f2699",
      "nodeTitle": "npc_intro",
      "sourceText": "Találd meg az összes mászófelszerelést és ismerd meg a három közeli országot!",
      "sourceEnText": "Find all the climbing gear and learn about the three nearby countries!",
      "audioFile": "fr_08_07f2699.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 4754,
