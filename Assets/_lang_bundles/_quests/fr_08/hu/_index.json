    },
    {
      "key": "0f4c405",
      "nodeTitle": "snowman",
      "sourceText": "Igen",
      "sourceEnText": "Yes",
      "audioFile": "fr_08_0f4c405.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 627,
      "updatedAt": "2026-03-15T12:34:12Z",
      "textHash": "a932728137a975ea6b07b6250776390aa3ff7ddd8e7ab77e7b065afdd2db64b8"
    },
    {
      "key": "0fdc3cb",
      "nodeTitle": "activity_2_done",
      "sourceText": "Nyisd ki a ládát, hogy napszemüveget kapj!",
      "sourceEnText": "Open the chest to get sunglasses!",
      "audioFile": "fr_08_0fdc3cb.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2194,
      "updatedAt": "2026-03-15T12:33:42Z",
      "textHash": "bdfa3bbd3552cf3af723e0d3d7562cccb44bfe39a556f31c66967f70e83e5031"
    },
    {
      "key": "b1_1",
      "nodeTitle": "npc_base1",
      "sourceText": "Fújni kezd a szél. Védeni kell a füleimet!",
      "sourceEnText": "The wind is starting to blow. My ears need protection!",
      "audioFile": "fr_08_b1_1.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2664,
      "updatedAt": "2026-03-15T12:33:32Z",
      "textHash": "9d06ba267b4ac65f414769db722e8a8344b86ede14ddba4f8ada424fffde5e51"
    },
    {
      "key": "b1_q",
      "nodeTitle": "npc_base1",
      "sourceText": "Hogyan védjük a fülünket erős szélben?",
      "sourceEnText": "How do we protect the ears when the wind is strong?",
      "audioFile": "fr_08_b1_q.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2299,
      "updatedAt": "2026-03-15T12:33:32Z",
      "textHash": "02d4901640f30abe76fdad5727389275ad59b9616d58abe96bffe63f6f85fff7"
    },
    {
      "key": "chest_locked",
      "nodeTitle": "chest_intro",
      "sourceText": "Zárva van. Talán kulcsra van szükséged.",
      "sourceEnText": "It's locked. Maybe you need a key.",
      "audioFile": "fr_08_chest_locked.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2560,
      "updatedAt": "2026-03-15T12:33:27Z",
      "textHash": "dace0692ab66c2bab600eb38e2012da76bed5e95840d6b7ed006fce4d52ef31b"
    },
    {
      "key": "comebacklater",
      "nodeTitle": "question_alps",
      "sourceText": "Gyere vissza később!",
      "sourceEnText": "Come back later!",
      "audioFile": "fr_08_comebacklater.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 1411,
      "updatedAt": "2026-03-15T18:58:56Z",
      "textHash": "70b839038a3e21bae3e6036819ffa0c0563f4258d91a99ab7d07b0dda5a2e88a"
    },
    {
      "key": "correct",
      "nodeTitle": "question_alps",
      "sourceText": "Helyes!",
      "sourceEnText": "Correct!",
      "audioFile": "fr_08_correct.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 862,
      "updatedAt": "2026-03-15T12:33:59Z",
      "textHash": "4a5dc940caa9c272c063d7e3fc892e21fdf882f45f42c1e581436ba135f83221"
    },
    {
      "key": "dontknow",
      "nodeTitle": "question_alps",
      "sourceText": "Nem tudom",
      "sourceEnText": "I don't know",
      "audioFile": "fr_08_dontknow.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 758,
      "updatedAt": "2026-03-15T18:58:56Z",
      "textHash": "099c47eff0972328fa4832ed702e7410bb3558aae798c50b3f03b1f856e1f501"
    },
    {
      "key": "end_1",
      "nodeTitle": "quest_end",
      "sourceText": "Hihetetlen! Elérted a Mont Blanc csúcsát. 4807 méter magas!",
      "sourceEnText": "Amazing! You reached the top of Mont Blanc. It is 4807 meters high!",
      "audioFile": "fr_08_end_1.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 4336,
      "updatedAt": "2026-03-15T12:33:17Z",
      "textHash": "269159c6822368722a32dac09e508132596506dbc0b5bfff8107f9236c9eb865"
    },
    {
      "key": "end_2",
      "nodeTitle": "quest_end",
      "sourceText": "Az Alpok tele vannak magas, gyönyörű hegyekkel.",
      "sourceEnText": "The Alps are full of tall, beautiful mountains.",
      "audioFile": "fr_08_end_2.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2847,
      "updatedAt": "2026-03-15T12:33:17Z",
      "textHash": "9a6f90bb9dbc9dd6311110ac113b3a71e3a5212057ed77b8d2ecc157adddb02b"
    },
    {
      "key": "fr08_b2_chest",
      "nodeTitle": "chest_base2",
      "sourceText": "Nyitható! Napszemüveg van benne.",
      "sourceEnText": "It opens! It has sunglasses inside.",
      "audioFile": "fr_08_fr08_b2_chest.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2194,
      "updatedAt": "2026-03-15T12:33:43Z",
      "textHash": "7fd6237e1542f7214cffdfa6efc8b58625cf29ed9670514d09736f7fc588ffef"
    },
    {
      "key": "fr08_b2_help",
      "nodeTitle": "npc_base2",
      "sourceText": "Ha elakadsz, a hóember segíthet!",
      "sourceEnText": "If you get stuck, the snowman can help!",
      "audioFile": "fr_08_fr08_b2_help.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2194,
      "updatedAt": "2026-03-15T12:33:38Z",
      "textHash": "bbf968863fdaf331e7e312c507a94a9ae9d80949c40ba3a59ec4c28075b1af7b"
    },
    {
      "key": "fr08_marmot_2",
      "nodeTitle": "marmot",
      "sourceText": "Egész télen a hó alatt alszom. Ezt hívják téli álomnak!",
      "sourceEnText": "I sleep all winter under the snow. This is called hibernation!",
      "audioFile": "fr_08_fr08_marmot_2.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 3265,
      "updatedAt": "2026-03-15T12:34:16Z",
      "textHash": "8eef6faa310149891043181459d85ba681a70042bb93f03879201881473ac58c"
    },
    {
      "key": "fr08_marmot_3",
      "nodeTitle": "marmot",
      "sourceText": "Imádok alpesi virágokat és füvet enni. Nyami!",
      "sourceEnText": "I love eating alpine flowers and grass. Yum!",
      "audioFile": "fr_08_fr08_marmot_3.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2900,
      "updatedAt": "2026-03-15T12:34:17Z",
      "textHash": "20881d45c4e6653faece250b794fe1f2b4b12371a8b36b44b39e52aebd605dfa"
    },
    {
      "key": "fr08_marmot_4",
      "nodeTitle": "marmot",
      "sourceText": "Ne törődj velem, csak napozom ezen a meleg sziklán.",
      "sourceEnText": "Don't mind me, I'm just sunbathing on this warm rock.",
      "audioFile": "fr_08_fr08_marmot_4.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2847,
      "updatedAt": "2026-03-15T12:34:17Z",
      "textHash": "1a66f87b1b169b21704b65c31b159a6af0047caafa34e5edb5e0e7345f7c78ec"
    },
    {
      "key": "keep_looking",
      "nodeTitle": "npc_base2",
      "sourceText": "Keress tovább. Még mindig szükségünk van az összes felszerelésre.",
      "sourceEnText": "Keep looking. We still need all the gear.",
      "audioFile": "fr_08_keep_looking.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 4336,
      "updatedAt": "2026-03-15T12:33:41Z",
      "textHash": "27fe2190c8dae804c1cd77780dd1169faf53fd2c9e60ad2e0a897e754de64762"
    },
    {
      "key": "post_1",
