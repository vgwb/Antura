    },
    {
      "key": "0e23f1f",
      "nodeTitle": "item_coat",
      "sourceText": "Ez a kabát melegen tart szélben és hóban.",
      "sourceEnText": "This coat keeps you warm in wind and snow.",
      "audioFile": "fr_08_0e23f1f.mp3",
      "voiceProfile": "shelley",
