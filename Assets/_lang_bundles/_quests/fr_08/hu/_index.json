    },
    {
      "key": "0b50050",
      "nodeTitle": "npc_base3",
      "sourceText": "Hágóvasak",
      "sourceEnText": "Crampons",
      "audioFile": "fr_08_0b50050.mp3",
      "voiceProfile": "shelley",
