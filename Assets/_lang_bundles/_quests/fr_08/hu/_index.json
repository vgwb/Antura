    },
    {
      "key": "0dbac73",
      "nodeTitle": "spawned_hiker",
      "sourceText": "A túrázáshoz itt jó cipő kell.",
      "sourceEnText": "Hiking here needs good boots.",
      "audioFile": "fr_08_0dbac73.mp3",
      "voiceProfile": "shelley",
