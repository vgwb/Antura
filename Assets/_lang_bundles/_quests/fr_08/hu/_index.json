    },
    {
      "key": "0c1f006",
      "nodeTitle": "chest_intro",
      "sourceText": "Nyitható! Egy hátizsák van benne.",
      "sourceEnText": "It opens! It contains a backpack.",
      "audioFile": "fr_08_0c1f006.mp3",
      "voiceProfile": "shelley",
      "actorId": "Default",
      "durationMs": 2011,
      "updatedAt": "2026-03-15T12:33:26Z",
