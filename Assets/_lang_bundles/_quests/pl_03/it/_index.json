    {
      "key": "chest_locked",
      "nodeTitle": "chest_river_sign",
      "sourceText": "Il baule è chiuso a chiave.",
      "sourceEnText": "The chest is locked.",
      "audioFile": "pl_03_chest_locked.ogg",
