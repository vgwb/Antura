    {
      "key": "chest_opens",
      "nodeTitle": "chest_boat_barge",
      "sourceText": "Si apre il baule. Trovi una foto!",
      "sourceEnText": "The chest opens. You find a photo!",
      "audioFile": "pl_03_chest_opens.ogg",
      "voiceProfile": "francesco",
