      "textHash": "b42568d6bedae73d4072ae6a1d68ce0e7efbc091038a5eeb0a172a5dcd97dbf6"
    },
    {
      "key": "sign_3",
      "nodeTitle": "npc_river_sign",
      "sourceText": "Cosa ci dicono le linee bianche ondulate?",
      "sourceEnText": "What do the white wavy lines tell us?",
      "audioFile": "pl_03_sign_3.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2183,
