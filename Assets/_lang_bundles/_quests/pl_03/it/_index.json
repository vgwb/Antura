    {
      "key": "chest_minigame",
      "nodeTitle": "chest_boat_barge",
      "sourceText": "Gioca a un minigioco per aprire lo scrigno!",
      "sourceEnText": "Play a mini game to open the chest!",
      "audioFile": "pl_03_chest_minigame.ogg",
      "voiceProfile": "francesco",
