    {
      "key": "train_4",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Sì! Deve essere abbastanza resistente per i treni pesanti.",
      "sourceEnText": "Yes! It must be strong enough for the heavy trains.",
      "audioFile": "pl_03_train_4.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3251,
      "updatedAt": "2026-03-03T20:36:07Z",
