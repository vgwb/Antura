    },
    {
      "key": "go_back",
      "nodeTitle": "task_find_photos_done",
      "sourceText": "Torna indietro e parla con la guida.",
      "sourceEnText": "Go back and talk to the guide.",
      "audioFile": "pl_03_go_back.ogg",
      "voiceProfile": "francesco",
      "actorId": "SENIOR_M",
      "durationMs": 1904,
      "updatedAt": "2026-03-03T20:35:13Z",
      "textHash": "bc6884e6cd28ad9ed1c2d68d3a548afa4f036e04fcdf9451c87c52d96355b788"
    },
    {
      "key": "house_1",
      "nodeTitle": "npc_boat_house",
      "sourceText": "A Breslavia, alcuni chiamano il fiume la loro \"strada di casa\".",
      "sourceEnText": "In Wrocław, some people call the river their \"home street.\"",
      "audioFile": "pl_03_house_1.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3297,
      "updatedAt": "2026-03-03T20:36:15Z",
      "textHash": "f79ff0d52f8f6dd7f69246fc89d3ab0c1426428f2335f4b2dfff4172a251f369"
    },
    {
      "key": "house_2",
      "nodeTitle": "npc_boat_house",
      "sourceText": "Anche i nani adorerebbero una casa galleggiante!",
      "sourceEnText": "Even the dwarves would love a floating house!",
      "audioFile": "pl_03_house_2.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2554,
      "updatedAt": "2026-03-03T20:36:17Z",
      "textHash": "8dc483ec46a7b263f74f2842e2086e357f6f6a8347336c0b514c446480fdae19"
    },
    {
