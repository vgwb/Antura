    },
    {
      "key": "train_2",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Perché i ponti ferroviari sono fatti di acciaio così pesante?",
      "sourceEnText": "Why are train bridges made of such heavy steel?",
