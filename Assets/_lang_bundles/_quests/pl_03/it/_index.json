    },
    {
      "key": "redz_5",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Esatto! Questo ponte gigante è sorretto da corde robuste. Le auto lo usano per spostarsi in città.",
      "sourceEnText": "Correct! Strong ropes hold this giant bridge. Cars use it to drive around the city.",
      "audioFile": "pl_03_redz_5.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 5666,
      "updatedAt": "2026-03-03T20:33:35Z",
      "textHash": "05f894ea56b98c61ea898586a14ce266f850446a825a4fb2d5b414eb254068e9"
    },
    {
      "key": "redz_6",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Magneti e magia",
      "sourceEnText": "Magnets and Magic",
      "audioFile": "pl_03_redz_6.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
