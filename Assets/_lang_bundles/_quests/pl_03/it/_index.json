    },
    {
      "key": "prot_5",
      "nodeTitle": "protagonist",
      "sourceText": "Aiuto! Antura pensava che la mia guida di Breslavia fosse un osso!",
      "sourceEnText": "Help! Antura thought my Wrocław Guide was a bone!",
      "audioFile": "pl_03_prot_5.ogg",
      "voiceProfile": "francesco",
      "actorId": "SENIOR_M",
      "durationMs": 3901,
