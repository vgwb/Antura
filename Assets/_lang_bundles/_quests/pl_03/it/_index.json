    {
      "key": "end_1",
      "nodeTitle": "quest_end",
      "sourceText": "Abbiamo imparato a conoscere i diversi tipi di ponti.",
      "sourceEnText": "We learned about different types of bridges.",
      "audioFile": "pl_03_end_1.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2740,
      "updatedAt": "2026-03-03T20:35:44Z",
      "textHash": "12216543e68ea161b952e7ba86d2291e3822890a3fc3d73624c3538f891d2bb4"
    },
    {
      "key": "end_2",
      "nodeTitle": "quest_end",
      "sourceText": "Abbiamo imparato a conoscere i diversi tipi di imbarcazioni.",
      "sourceEnText": "We learned about different types of boats.",
      "audioFile": "pl_03_end_2.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3065,
      "updatedAt": "2026-03-03T20:35:42Z",
      "textHash": "ee979605273340abcd0a33103a2e26322d5009853dc0461ec1833b51a68fceee"
    },
    {
      "key": "end_3",
      "nodeTitle": "quest_end",
      "sourceText": "Abbiamo esplorato il fiume ODRA.",
      "sourceEnText": "We explored the ODRA RIVER.",
      "audioFile": "pl_03_end_3.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 1811,
      "updatedAt": "2026-03-03T20:35:40Z",
      "textHash": "9a555170522a65112cc0dc548a8681b1ef4735e2594bdfe3459aaafbafc24dcf"
    },
    {
      "key": "fail_redz",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Sembra magia, ma in realtà è ingegneria!",
      "sourceEnText": "It looks like magic, but it's actually engineering!",
      "audioFile": "pl_03_fail_redz.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2508,
      "updatedAt": "2026-03-03T20:33:31Z",
      "textHash": "8de45e47d54831a9644b2b06840f2ab2c3c15ae8450142befa231d04cb37d97c"
    },
    {
      "key": "fail_tour",
      "nodeTitle": "npc_boat_people",
      "sourceText": "Non siamo ancora sott'acqua! Riprova.",
      "sourceEnText": "We aren't underwater yet! Try again.",
      "audioFile": "pl_03_fail_tour.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 3576,
      "updatedAt": "2026-03-03T20:36:41Z",
      "textHash": "33b64300b75b2dcf17d7acf74cb7980741e87f0a496b37c1439c531501d4e812"
    },
    {
      "key": "fail_train",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Sono rumorosi, ma non è per questo!",
      "sourceEnText": "They are loud, but that's not why!",
      "audioFile": "pl_03_fail_train.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2183,
      "updatedAt": "2026-03-03T20:36:11Z",
      "textHash": "9ea1685c5dd758effe7014c139b26cfe0b79736b44645a4a335d200d87e0cef0"
    },
    {
      "key": "fail_tum",
      "nodeTitle": "npc_tumski_bridge",
      "sourceText": "Non sarebbe molto romantico! Riprova.",
      "sourceEnText": "That would not be very romantic! Try again.",
      "audioFile": "pl_03_fail_tum.ogg",
      "voiceProfile": "francesco",
      "actorId": "Default",
      "durationMs": 2415,
      "updatedAt": "2026-03-03T20:33:47Z",
      "textHash": "7f97019320a114795eb819e742e2e44e1f7dbab0720f9c032775c4194f36185c"
    },
    {
      "key": "found_photos",
      "nodeTitle": "task_find_photos_done",
      "sourceText": "Hai trovato tutte le foto!",
      "sourceEnText": "You found all the photos!",
      "audioFile": "pl_03_found_photos.ogg",
      "voiceProfile": "francesco",
      "actorId": "SENIOR_M",
      "durationMs": 1347,
      "updatedAt": "2026-03-03T20:35:15Z",
