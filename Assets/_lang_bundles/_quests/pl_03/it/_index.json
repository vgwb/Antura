    },
    {
      "key": "prot_6",
      "nodeTitle": "protagonist",
      "sourceText": "Le pagine sono sparse in giro. Riesci a ritrovarle?",
      "sourceEnText": "The pages are lost around. Can you find them?",
      "audioFile": "pl_03_prot_6.ogg",
      "voiceProfile": "francesco",
      "actorId": "SENIOR_M",
