    },
    {
      "key": "end_2",
      "nodeTitle": "quest_end",
      "sourceText": "Wir haben etwas über verschiedene Bootstypen gelernt.",
      "sourceEnText": "We learned about different types of boats.",
      "audioFile": "pl_03_end_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3065,
