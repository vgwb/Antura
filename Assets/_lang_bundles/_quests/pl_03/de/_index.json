      "key": "found_photos",
      "nodeTitle": "task_find_photos_done",
      "sourceText": "Du hast alle Fotos gefunden!",
      "sourceEnText": "You found all the photos!",
      "audioFile": "pl_03_found_photos.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 1950,
      "updatedAt": "2026-03-03T20:29:51Z",
