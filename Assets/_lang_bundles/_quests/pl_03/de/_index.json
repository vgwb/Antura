    },
    {
      "key": "end_3",
      "nodeTitle": "quest_end",
      "sourceText": "Wir erkundeten den Fluss Oder.",
      "sourceEnText": "We explored the ODRA RIVER.",
      "audioFile": "pl_03_end_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2276,
      "updatedAt": "2026-03-03T20:30:23Z",
      "textHash": "30d653377e002866ca5acf0cd8278bfd3c21f26f94fe3dd0776ee28aae02cfe4"
    },
    {
      "key": "fail_redz",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Es sieht aus wie Magie, ist aber in Wirklichkeit Ingenieurskunst!",
      "sourceEnText": "It looks like magic, but it's actually engineering!",
      "audioFile": "pl_03_fail_redz.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4690,
      "updatedAt": "2026-03-03T20:27:18Z",
      "textHash": "78c7d8c7892ec89890173e6ab05455dfbdf8f4fd72de273f6e0a4deeea0e37a3"
    },
    {
      "key": "fail_tour",
      "nodeTitle": "npc_boat_people",
      "sourceText": "Wir sind noch nicht unter Wasser! Versuch es erneut.",
      "sourceEnText": "We aren't underwater yet! Try again.",
      "audioFile": "pl_03_fail_tour.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2972,
      "updatedAt": "2026-03-03T20:31:46Z",
      "textHash": "dff72827025044c88ff48e7def2f791fe1af3b6361030b6fc9504e546ccc9ddd"
    },
    {
      "key": "fail_train",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Sie sind laut, aber das ist nicht der Grund!",
      "sourceEnText": "They are loud, but that's not why!",
      "audioFile": "pl_03_fail_train.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2554,
      "updatedAt": "2026-03-03T20:31:01Z",
      "textHash": "4848237d1516c909be0c69b7e45e569571a145b17aa799992f3467ed9ec9ad05"
    },
    {
      "key": "fail_tum",
      "nodeTitle": "npc_tumski_bridge",
      "sourceText": "Das wäre nicht sehr romantisch! Versuch es noch einmal.",
      "sourceEnText": "That would not be very romantic! Try again.",
      "audioFile": "pl_03_fail_tum.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3483,
      "updatedAt": "2026-03-03T20:27:42Z",
