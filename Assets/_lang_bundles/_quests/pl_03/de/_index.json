    },
    {
      "key": "tour_5",
      "nodeTitle": "npc_boat_people",
      "sourceText": "Ein Periskop",
      "sourceEnText": "A periscope",
      "audioFile": "pl_03_tour_5.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1300,
