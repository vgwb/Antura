    {
      "key": "006ab27",
      "nodeTitle": "protagonist",
      "sourceText": "Du bist tapfer! Aber ich vermisse trotzdem Fotos von unseren Flusswundern.",
      "sourceEnText": "You are brave! But I still miss photos of our river wonders.",
      "audioFile": "pl_03_006ab27.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 5480,
      "updatedAt": "2026-03-03T20:30:10Z",
      "textHash": "c6ad45f16b396984800f797ad42edb6c9fc7e992ea3f88e54835853f5b18821f"
    },
    {
      "key": "0265d07",
      "nodeTitle": "post_quest_activity",
      "sourceText": "Zeichne eine einfache Karte deiner Reise.",
      "sourceEnText": "Draw a simple MAP of your journey.",
      "audioFile": "pl_03_0265d07.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2694,
      "updatedAt": "2026-03-03T20:30:20Z",
      "textHash": "01c48105fa2bbe06ec5addb68d67e8d72dd102031a97dc76fc7e79794f47593f"
    },
    {
      "key": "02a257c",
      "nodeTitle": "quest_end",
      "sourceText": "Gut gemacht!",
      "sourceEnText": "Well done!",
      "audioFile": "pl_03_02a257c.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1115,
      "updatedAt": "2026-03-03T20:30:33Z",
      "textHash": "b7231fa6390dc9dffa0b2922e859341dd32c57a2476e19685d6d945e333abf4e"
    },
    {
      "key": "03ea48b",
      "nodeTitle": "protagonist",
      "sourceText": "Du machst das gut!",
      "sourceEnText": "You are doing well!",
      "audioFile": "pl_03_03ea48b.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 1486,
      "updatedAt": "2026-03-03T20:30:00Z",
      "textHash": "2f9ab0505487e4f160f81e80337e7d8c5bb3e3e5eaa360ad2fe4586bea3e4820"
    },
    {
      "key": "0577d80",
      "nodeTitle": "spawned_tourist",
      "sourceText": "So viele Brücken in dieser Stadt.",
      "sourceEnText": "So many BRIDGES in this city.",
      "audioFile": "pl_03_0577d80.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 1811,
      "updatedAt": "2026-03-03T20:32:19Z",
      "textHash": "987e866171a76b2124fd353a0628d25344a99f116447d694ed72d588aeb153f0"
    },
    {
      "key": "07ff8c5",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Ich liebe Pierogi!",
      "sourceEnText": "I love Pierogi!",
      "audioFile": "pl_03_07ff8c5.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 1161,
      "updatedAt": "2026-03-03T20:32:26Z",
      "textHash": "a9cc4c32974d1679a11b6b3da660d85bd6068364ee169f324fd8219f0a61162d"
    },
    {
      "key": "089ea37",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Breslau ist wirklich wunderschön.",
      "sourceEnText": "Wroclaw is really beautiful.",
      "audioFile": "pl_03_089ea37.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 2043,
      "updatedAt": "2026-03-03T20:32:24Z",
      "textHash": "26e06d8103ca60f941bb985b45dc778bbb2ea0053905adaa4ed38f69c42ad82d"
    },
    {
      "key": "0bfcb05",
      "nodeTitle": "protagonist",
      "sourceText": "Falls Sie sie nicht finden können, benutzen Sie die Karte!",
      "sourceEnText": "If you can't find them, use the map!",
      "audioFile": "pl_03_0bfcb05.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 3529,
      "updatedAt": "2026-03-03T20:30:03Z",
      "textHash": "8c4c0a161cb2f878a1ed9847f039c2f82c902b1b8a46c8ca4c4d7ea43d8f9c1f"
    },
    {
      "key": "0f36b7f",
      "nodeTitle": "spawned_kayak",
      "sourceText": "Ich möchte ein kleines Kajak fahren.",
      "sourceEnText": "I want to ride a small KAYAK.",
      "audioFile": "pl_03_0f36b7f.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 1950,
      "updatedAt": "2026-03-03T20:32:14Z",
      "textHash": "8b870a38c7cccdb6c45f2f7318bb39b5a904903dee9cf357d041a9d3b634fb10"
    },
    {
      "key": "barge_1",
      "nodeTitle": "npc_boat_barge",
      "sourceText": "Seit Jahrhunderten transportieren Lastkähne (Barki) Kohle und Sand auf der Oder.",
      "sourceEnText": "Barges (Barki) have carried coal and sand on the Odra for centuries.",
      "audioFile": "pl_03_barge_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 5387,
      "updatedAt": "2026-03-03T20:31:53Z",
      "textHash": "001751fe93acb826d9da1fd5eeb6519b74de5311e088eb6d5d914a79f7f0a78f"
    },
    {
      "key": "barge_2",
      "nodeTitle": "npc_boat_barge",
      "sourceText": "Ein Lastkahn ist sehr flach. Warum?",
      "sourceEnText": "A barge is very flat. Why?",
      "audioFile": "pl_03_barge_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2322,
      "updatedAt": "2026-03-03T20:31:56Z",
      "textHash": "9b93af3da056684482c9692712a032224ba16c886463d2476d617ad0285d117f"
    },
    {
      "key": "barge_3",
      "nodeTitle": "npc_boat_barge",
      "sourceText": "Auch in flachem Wasser können schwere Dinge getragen werden.",
      "sourceEnText": "To carry heavy things even when the water is not deep.",
      "audioFile": "pl_03_barge_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3437,
      "updatedAt": "2026-03-03T20:31:59Z",
      "textHash": "4941b5806030464dd791e21a8356629aee22991cab614b32d8d7fe7eea719c6a"
    },
    {
      "key": "barge_4",
      "nodeTitle": "npc_boat_barge",
      "sourceText": "Genau! Es ist ein LKW, der schwimmt.",
      "sourceEnText": "Exactly! It's a truck that floats.",
      "audioFile": "pl_03_barge_4.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2508,
      "updatedAt": "2026-03-03T20:32:03Z",
      "textHash": "97e0276c39ee26421000e6d7cc17caa77ff2c53c676782abdfde13cb9a72aef6"
    },
    {
      "key": "barge_5",
      "nodeTitle": "npc_boat_barge",
      "sourceText": "So kann es sich vor Zwergen verstecken.",
      "sourceEnText": "So it can hide from dwarves",
      "audioFile": "pl_03_barge_5.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2136,
      "updatedAt": "2026-03-03T20:32:05Z",
      "textHash": "ea1c066e054ff5cb3dcad97f8a39ad931a95b4adb3e8713bf988f624b7234d39"
    },
    {
      "key": "ch_house1",
      "nodeTitle": "chest_boat_house",
      "sourceText": "Repariert die Fenster des schwimmenden Hauses!",
      "sourceEnText": "Fix the windows on the floating house!",
      "audioFile": "pl_03_ch_house1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2926,
      "updatedAt": "2026-03-03T20:31:25Z",
      "textHash": "6eaa499ba1c18465ae224ee9c8469643144df8e4f6d1e7e9dc19615f75d26831"
    },
    {
      "key": "ch_house2",
      "nodeTitle": "chest_boat_house",
      "sourceText": "Ein gemütliches Zuhause an der Oder! Foto gesammelt.",
      "sourceEnText": "A cozy home on the Odra! Photo collected.",
      "audioFile": "pl_03_ch_house2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3437,
      "updatedAt": "2026-03-03T20:31:28Z",
      "textHash": "47f7e93e5e1442584ce15b2e811d9dbdfab5c8eab2b5a2cbaba133dce786ce95"
    },
    {
      "key": "ch_map1",
      "nodeTitle": "chest_odra_map",
      "sourceText": "Beweise, dass du weißt, wo der Fluss entlangfließt!",
      "sourceEnText": "Prove you know where the river flows!",
      "audioFile": "pl_03_ch_map1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3065,
      "updatedAt": "2026-03-03T20:28:12Z",
      "textHash": "cf28e04cece36d188a256a6bd2a5b3e6906313d1a587bc4b860b1bcb911c170f"
    },
    {
      "key": "ch_map2",
      "nodeTitle": "chest_odra_map",
      "sourceText": "Die Karte ist wieder da! Sie zeigt, wie die Oder in die Ostsee mündet.",
      "sourceEnText": "The map is back! It shows the Odra flowing into the Baltic Sea.",
      "audioFile": "pl_03_ch_map2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4598,
      "updatedAt": "2026-03-03T20:28:10Z",
      "textHash": "3f28819a59ee8a16813954c31f774bdf49d4bd6b966fe8a9a76c6fd869f7f765"
    },
    {
      "key": "ch_redz1",
      "nodeTitle": "chest_redzinski_bridge",
      "sourceText": "Den höchsten Strommast in Breslau wiederaufbauen!",
      "sourceEnText": "Rebuild the tallest pylon in Wrocław!",
      "audioFile": "pl_03_ch_redz1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3529,
      "updatedAt": "2026-03-03T20:30:42Z",
      "textHash": "2c1138f96e1d561d64f09155b9076213c14d6b0c17eb590a145279691fa080a1"
    },
    {
      "key": "ch_sign1",
      "nodeTitle": "chest_river_sign",
      "sourceText": "Antura hat das Schild mit Schlamm bedeckt! Wisch es sauber, um die Wellen zu sehen.",
      "sourceEnText": "Antura covered the sign in mud! Wipe it clean to see the waves.",
      "audioFile": "pl_03_ch_sign1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4551,
      "updatedAt": "2026-03-03T20:28:42Z",
      "textHash": "5ed1cc49a23b87385317f27c6615a78ec58e2d064f3640e5ecf9458066fbdced"
    },
    {
      "key": "ch_sign2",
      "nodeTitle": "chest_river_sign",
      "sourceText": "Super gemacht! Jetzt weißt du immer, wann du in Europa einen Fluss überquerst.",
      "sourceEnText": "Great job! Now you'll always know when you're crossing a river in Europe.",
      "audioFile": "pl_03_ch_sign2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 5016,
      "updatedAt": "2026-03-03T20:28:39Z",
      "textHash": "c0f972a188e5988a109a216b0f6d262285de69b2b46224431e9ebc554812e772"
    },
    {
      "key": "ch_tour1",
      "nodeTitle": "chest_boat_people",
      "sourceText": "Findet die auf dem Deck versteckten Touristen!",
      "sourceEnText": "Find the tourists hidden on the deck!",
      "audioFile": "pl_03_ch_tour1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2694,
      "updatedAt": "2026-03-03T20:31:49Z",
      "textHash": "a1772cf77f1d74d7186ff65752529e4a6d75f2f3f59d43a64af8b80c1f104b13"
    },
    {
      "key": "ch_train1",
      "nodeTitle": "chest_bridge_train",
      "sourceText": "Ordne die schweren Kisten den Bahngleisen zu!",
      "sourceEnText": "Match the heavy boxes to the train tracks!",
      "audioFile": "pl_03_ch_train1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2786,
      "updatedAt": "2026-03-03T20:31:04Z",
      "textHash": "c978cad8ef7c6b096dffec4375b77a1ab4b4ac64a087a3d88f5e00641e2df26c"
    },
    {
      "key": "ch_tum1",
      "nodeTitle": "chest_tumski_bridge",
      "sourceText": "Entferne den Rost von dieser alten Eisenbrücke!",
      "sourceEnText": "Clean the rust off this old iron bridge!",
      "audioFile": "pl_03_ch_tum1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3065,
      "updatedAt": "2026-03-03T20:27:39Z",
