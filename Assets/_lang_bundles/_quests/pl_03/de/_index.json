    },
    {
      "key": "house_4",
      "nodeTitle": "npc_boat_house",
      "sourceText": "Der Fluss Oder",
      "sourceEnText": "The River Odra",
      "audioFile": "pl_03_house_4.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1858,
      "updatedAt": "2026-03-03T20:31:17Z",
      "textHash": "52257970f9a53e0a17b9aa780d3566d3796b1306b107856a6e2e8c20330a7ee4"
    },
    {
      "key": "house_6",
      "nodeTitle": "npc_boat_house",
      "sourceText": "Ein Dachwald",
      "sourceEnText": "A rooftop forest",
      "audioFile": "pl_03_house_6.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1115,
      "updatedAt": "2026-03-03T20:31:20Z",
      "textHash": "8eacc9944808547720d8e820a273342e6d8a4d4cfe694eb70900421eb51e542f"
    },
    {
      "key": "kayak_2",
      "nodeTitle": "spawned_kayak",
      "sourceText": "Kajaks eignen sich hervorragend zur Erkundung der Natur!",
      "sourceEnText": "Kayaks are great for exploring nature!",
      "audioFile": "pl_03_kayak_2.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 3483,
      "updatedAt": "2026-03-03T20:32:16Z",
      "textHash": "b01c2a7447819c0eb05a129d09ca2f5a0398fed4a8adff5f0dae2a4054b1c856"
    },
    {
      "key": "kayak_3",
      "nodeTitle": "spawned_kayak",
      "sourceText": "Paddeln macht Spaß und ist ein gutes Training!",
      "sourceEnText": "Paddling is fun and good exercise!",
      "audioFile": "pl_03_kayak_3.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 2508,
      "updatedAt": "2026-03-03T20:32:17Z",
      "textHash": "c5f81331f5a60a6f52e8b7e001337f6939169caeba0d5863e164eff3fe15fdf2"
    },
    {
      "key": "map_1",
      "nodeTitle": "npc_odra_map",
      "sourceText": "Die Oder ist Polens zweitlängster Fluss.",
      "sourceEnText": "The Odra is Poland's second longest river.",
      "audioFile": "pl_03_map_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2601,
      "updatedAt": "2026-03-03T20:28:30Z",
      "textHash": "244cfe799b1325d702424e84e3d578e3a436af76d2b105c3a1f9fb6525e2cb08"
    },
    {
      "key": "map_2",
      "nodeTitle": "npc_odra_map",
      "sourceText": "Fließt die Oder in die Berge oder ins Meer?",
      "sourceEnText": "Does the Odra flow into the mountains or the sea?",
      "audioFile": "pl_03_map_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2508,
      "updatedAt": "2026-03-03T20:28:27Z",
      "textHash": "aaa501f18131aac85ccd43a3ad78517a13ed2ea0fdb9882b15238e6a549d2eaa"
    },
    {
      "key": "map_3",
      "nodeTitle": "npc_odra_map",
      "sourceText": "Die Ostsee",
      "sourceEnText": "The Baltic Sea",
      "audioFile": "pl_03_map_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1115,
      "updatedAt": "2026-03-03T20:28:22Z",
      "textHash": "7051fdf61491f8c1c28579e7832c4a7dc51c31e09c1754436678252e950bcb8d"
    },
    {
      "key": "map_4",
      "nodeTitle": "npc_odra_map",
      "sourceText": "Richtig! Es fließt den ganzen Weg nach Norden.",
      "sourceEnText": "Correct! It flows all the way to the north.",
      "audioFile": "pl_03_map_4.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3669,
      "updatedAt": "2026-03-03T20:28:18Z",
      "textHash": "10c00ddb72066e760cc20ab0069eecd2e87e66ceab7c5a2ae88daa2e1a226d8a"
    },
    {
      "key": "map_5",
      "nodeTitle": "npc_odra_map",
      "sourceText": "Das Mittelmeer",
      "sourceEnText": "The Mediterranean Sea",
      "audioFile": "pl_03_map_5.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1393,
      "updatedAt": "2026-03-03T20:28:15Z",
      "textHash": "7a1cef97ba4db930a8c033ded97ffe0a4ef51e1a5d5ed5df137f941e48d4f0ec"
    },
    {
      "key": "prot_1",
      "nodeTitle": "protagonist",
      "sourceText": "Dziękuję! Du hast alle meine Fotos gefunden!",
      "sourceEnText": "Dziękuję! You found all my photos!",
      "audioFile": "pl_03_prot_1.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 2879,
      "updatedAt": "2026-03-03T20:30:16Z",
      "textHash": "dc487809192eb1c21d417421bb6da08a268d4a1911166acb181d8747723f2f0e"
    },
    {
      "key": "prot_2",
      "nodeTitle": "protagonist",
      "sourceText": "Nun kann ich den Besuch fortsetzen. Eine letzte Frage...",
      "sourceEnText": "Now I can continue the visit. One last question...",
      "audioFile": "pl_03_prot_2.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 3622,
      "updatedAt": "2026-03-03T20:30:13Z",
      "textHash": "92ee6305a62e3e3a1826d7d3aead48e1d5e72bc53e1cab8ba779ad9978a191b1"
    },
    {
      "key": "prot_4",
      "nodeTitle": "protagonist",
      "sourceText": "Sucht nach den Truhen! Die Leute am Fluss bewachen sie.",
      "sourceEnText": "Look for the chests! The people by the river watch over them.",
      "audioFile": "pl_03_prot_4.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 3622,
      "updatedAt": "2026-03-03T20:30:06Z",
      "textHash": "4bdb61c518ace031ca4ca5d6a568acbcb7f0b212bd4a1a23ebecef454f7434a5"
    },
    {
      "key": "prot_5",
      "nodeTitle": "protagonist",
      "sourceText": "Hilfe! Antura dachte, mein Breslau-Reiseführer sei ein Knochen!",
      "sourceEnText": "Help! Antura thought my Wrocław Guide was a bone!",
      "audioFile": "pl_03_prot_5.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 4319,
      "updatedAt": "2026-03-03T20:29:57Z",
      "textHash": "b47414024dde64aaeabdb2e7282d604378ab818c9048e7876f5d1c15d8f99231"
    },
    {
      "key": "prot_6",
      "nodeTitle": "protagonist",
      "sourceText": "Die Seiten sind überall verstreut. Kannst du sie finden?",
      "sourceEnText": "The pages are lost around. Can you find them?",
      "audioFile": "pl_03_prot_6.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 3204,
      "updatedAt": "2026-03-03T20:29:54Z",
      "textHash": "f151ca5642dc21c71b9c6da10c03a7564ded769731ddfaca660988a1d0db7551"
    },
    {
      "key": "quiz1_fail1",
      "nodeTitle": "final_quiz",
      "sourceText": "Hmm... das ist viel zu weit südlich!",
      "sourceEnText": "Hmm... that's much too far south!",
      "audioFile": "pl_03_quiz1_fail1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2461,
      "updatedAt": "2026-03-03T20:29:33Z",
      "textHash": "ddbaa3c0a275deefc511fb5b78b55af88febce6485b4bb3962a27ec6e635f2d0"
    },
    {
      "key": "quiz1_fail2",
      "nodeTitle": "final_quiz",
      "sourceText": "Nicht ganz. Die Oder fließt nach Norden, nicht nach Süden!",
      "sourceEnText": "Not quite. The Odra heads North, not South!",
      "audioFile": "pl_03_quiz1_fail2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3576,
      "updatedAt": "2026-03-03T20:29:27Z",
      "textHash": "ac178fccce67f7e124cc6d07afcf2cf7463e9e2bac2e3a3c66016c0b326cf948"
    },
    {
      "key": "quiz1_hint",
      "nodeTitle": "final_quiz",
      "sourceText": "Keine Sorge! Schau dir die blaue Linie auf der Karte an.",
      "sourceEnText": "No worries! Look at the blue line on the map.",
      "audioFile": "pl_03_quiz1_hint.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3669,
      "updatedAt": "2026-03-03T20:29:21Z",
      "textHash": "ed7108832c8711160f21ba599a310e700dad7b6d1298e2c55e8375f682ceb677"
    },
    {
      "key": "quiz1_intro",
      "nodeTitle": "final_quiz",
      "sourceText": "Die Oder ist ein langer Fluss. Weißt du noch, wo all das Wasser am Ende landet?",
      "sourceEnText": "The Odra is a long river. Do you remember where all that water ends up?",
      "audioFile": "pl_03_quiz1_intro.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 5062,
      "updatedAt": "2026-03-03T20:29:45Z",
      "textHash": "7e51a17806b0d151a505301055eaf043760237784e4ed3a85a4a500df0e18f6b"
    },
    {
      "key": "quiz1_ok",
      "nodeTitle": "final_quiz",
      "sourceText": "Tak! Richtig! Die Oder fließt nordwärts durch Polen und mündet in die Ostsee.",
      "sourceEnText": "Tak! Correct! The Odra flows north across Poland and into the Baltic Sea.",
      "audioFile": "pl_03_quiz1_ok.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 5805,
      "updatedAt": "2026-03-03T20:29:39Z",
      "textHash": "a4db84753074442035d07cf75d70d71b439e2bffee684bcf97237f71a4de7b87"
    },
    {
      "key": "quiz2_a1",
      "nodeTitle": "final_quiz_2",
      "sourceText": "Nein, die Weichsel ist länger.",
      "sourceEnText": "No, the Wisła is longer",
      "audioFile": "pl_03_quiz2_a1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1672,
      "updatedAt": "2026-03-03T20:29:15Z",
      "textHash": "cd8c6107a2bc75e3e6db5ae4fe9954fa31f710a34087ba3f4c37a076aa7a496d"
    },
    {
      "key": "quiz2_a2",
      "nodeTitle": "final_quiz_2",
      "sourceText": "Ja, es ist das längste",
      "sourceEnText": "Yes, it is the longest",
      "audioFile": "pl_03_quiz2_a2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1672,
      "updatedAt": "2026-03-03T20:29:09Z",
      "textHash": "1e53024ed2b3b3229fe15db1cdafad9bd9aaa758e72aed3e307f828ae812980b"
    },
    {
      "key": "quiz2_fail",
      "nodeTitle": "final_quiz_2",
      "sourceText": "Es ist sehr groß, aber es gibt einen Fluss, der noch länger ist.",
      "sourceEnText": "It is very big, but there is one river that is even longer.",
      "audioFile": "pl_03_quiz2_fail.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3669,
      "updatedAt": "2026-03-03T20:29:07Z",
      "textHash": "e81ba51117e8337862174324f06f2df6e2f87f5b8eb6bfab9919461bd9432106"
    },
    {
      "key": "quiz2_intro",
      "nodeTitle": "final_quiz_2",
      "sourceText": "Ist die Oder der *längste* Fluss in Polen?",
      "sourceEnText": "Is Odra the longest river in Poland?",
      "audioFile": "pl_03_quiz2_intro.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2601,
      "updatedAt": "2026-03-03T20:29:18Z",
      "textHash": "f4864586b573f5ed2065932a6c56defb8028b2a471449819fb9400b9a0d681ea"
    },
    {
      "key": "quiz2_ok",
      "nodeTitle": "final_quiz_2",
      "sourceText": "Perfekt! Die Weichsel ist die längste, die Oder die zweitlängste.",
      "sourceEnText": "Perfect! The Wisła is number one, Odra is the second longest.",
      "audioFile": "pl_03_quiz2_ok.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4458,
      "updatedAt": "2026-03-03T20:29:12Z",
      "textHash": "1a5623b8cec668c3333a2400234041096d72e1596557cda0718d3cbeae0bea32"
    },
    {
      "key": "quiz_a1",
      "nodeTitle": "final_quiz",
      "sourceText": "Die Ostsee",
      "sourceEnText": "The Baltic Sea",
      "audioFile": "pl_03_quiz_a1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1161,
      "updatedAt": "2026-03-03T20:29:42Z",
      "textHash": "7051fdf61491f8c1c28579e7832c4a7dc51c31e09c1754436678252e950bcb8d"
    },
    {
      "key": "quiz_a2",
      "nodeTitle": "final_quiz",
      "sourceText": "Das Mittelmeer",
      "sourceEnText": "The Mediterranean Sea",
      "audioFile": "pl_03_quiz_a2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1440,
      "updatedAt": "2026-03-03T20:29:36Z",
      "textHash": "7a1cef97ba4db930a8c033ded97ffe0a4ef51e1a5d5ed5df137f941e48d4f0ec"
    },
    {
      "key": "quiz_a3",
      "nodeTitle": "final_quiz",
      "sourceText": "Das Schwarze Meer",
      "sourceEnText": "The Black Sea",
      "audioFile": "pl_03_quiz_a3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1486,
      "updatedAt": "2026-03-03T20:29:30Z",
      "textHash": "305760c031450c1b69163c91ce5e1402a337c982fc0cca4223c6db596174a6c4"
    },
    {
      "key": "redz_1",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Die Rędziński-Brücke ist die höchste und längste Brücke Polens.",
      "sourceEnText": "The Rędziński Bridge is the tallest and longest in Poland.",
      "audioFile": "pl_03_redz_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4040,
      "updatedAt": "2026-03-03T20:27:36Z",
      "textHash": "57bbbffe16dc08ae0818b93c8a3065b519fac19021c92884ef9dc62e2c8c961f"
    },
    {
      "key": "redz_2",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Sie ist 122 Meter hoch. Höher als die Kathedrale!",
      "sourceEnText": "It is 122 meters tall. Higher than the Cathedral!",
      "audioFile": "pl_03_redz_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4133,
      "updatedAt": "2026-03-03T20:27:33Z",
      "textHash": "a3637f8e916106f03939357fa6f1e5f8fb9f3e784bba38e5d6d80086280ea480"
    },
    {
      "key": "redz_3",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Was hält diese gewaltige Brücke zusammen?",
      "sourceEnText": "What holds this massive bridge up?",
      "audioFile": "pl_03_redz_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2368,
      "updatedAt": "2026-03-03T20:27:30Z",
      "textHash": "759544319c5913b6621625e69f08372005dc4eb0eb4ec7202dee65c900d80ad3"
    },
    {
      "key": "redz_4",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Stahlseile",
      "sourceEnText": "Steel cables",
      "audioFile": "pl_03_redz_4.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1068,
      "updatedAt": "2026-03-03T20:27:27Z",
      "textHash": "fc4c1b9fd14682f6aea98ed90cd1bbbb0034b44def13148fe748e01669e85b8f"
    },
    {
      "key": "redz_5",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Richtig! Starke Seile halten diese riesige Brücke. Autos nutzen sie, um durch die Stadt zu fahren.",
      "sourceEnText": "Correct! Strong ropes hold this giant bridge. Cars use it to drive around the city.",
      "audioFile": "pl_03_redz_5.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 6780,
      "updatedAt": "2026-03-03T20:27:24Z",
      "textHash": "47445ff49f0293c56093e1d67568f33454c0ae35ab8266a64e464a85cb845b8c"
    },
    {
      "key": "redz_6",
      "nodeTitle": "npc_redzinski_bridge",
      "sourceText": "Magnete und Magie",
      "sourceEnText": "Magnets and Magic",
      "audioFile": "pl_03_redz_6.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1347,
      "updatedAt": "2026-03-03T20:27:21Z",
      "textHash": "ee711d1e2abfe8e33928ba9dd46ad86c423b0556510e09968d54192c08df7ac5"
    },
    {
      "key": "sign_1",
      "nodeTitle": "npc_river_sign",
      "sourceText": "Schauen Sie sich das große blaue Schild in der Nähe der Brücke an.",
      "sourceEnText": "Look at the big blue sign near the bridge.",
      "audioFile": "pl_03_sign_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4040,
      "updatedAt": "2026-03-03T20:29:04Z",
      "textHash": "4a5684f510bdcb2d243a1e91c9302803a15fb445aa28c9dae73460339c207454"
    },
    {
      "key": "sign_3",
      "nodeTitle": "npc_river_sign",
      "sourceText": "Was sagen uns die weißen Wellenlinien?",
      "sourceEnText": "What do the white wavy lines tell us?",
      "audioFile": "pl_03_sign_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 2554,
      "updatedAt": "2026-03-03T20:29:00Z",
      "textHash": "db089c5c572e621b1cb92a0ac1d6ac0f35463913a418e04f594f8fb14df78e0d"
    },
    {
      "key": "sign_4",
      "nodeTitle": "npc_river_sign",
      "sourceText": "Hier fließt ein Fluss.",
      "sourceEnText": "There is a river flowing here",
      "audioFile": "pl_03_sign_4.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1672,
      "updatedAt": "2026-03-03T20:28:57Z",
      "textHash": "18e6f120c88fa15c73eaf6859a16fbea1f544f6ac9ab8fa50d89c2854147d87f"
    },
    {
      "key": "sign_5",
      "nodeTitle": "npc_river_sign",
      "sourceText": "Tak! Diese blauen Wellen sind das universelle Symbol für einen Fluss.",
      "sourceEnText": "Tak! Those blue waves are the universal sign for a river.",
      "audioFile": "pl_03_sign_5.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4783,
      "updatedAt": "2026-03-03T20:28:54Z",
      "textHash": "c794278e98fb5f24fd3411f1dc9f57fac1328f6159964f6dea394ce701319a2f"
    },
    {
      "key": "sign_6",
      "nodeTitle": "npc_river_sign",
      "sourceText": "Dort bewegt sich die Brücke",
      "sourceEnText": "There bridge moves",
      "audioFile": "pl_03_sign_6.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1625,
      "updatedAt": "2026-03-03T20:28:50Z",
      "textHash": "03ab4edfdb1460170320987af85907715851a3cbfad71cf31d51360b787ce290"
    },
    {
      "key": "start_1",
      "nodeTitle": "quest_start",
      "sourceText": "Wir befinden uns in Breslau, der „Stadt der hundert Brücken“.",
      "sourceEnText": "We are in Wrocław, the \"City of a Hundred Bridges\".",
      "audioFile": "pl_03_start_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3808,
      "updatedAt": "2026-03-03T20:30:39Z",
      "textHash": "7bcafa701091c684fb8430840c5e05b9c7ce48fffe67750560d383422a04ec3c"
    },
    {
      "key": "start_2",
      "nodeTitle": "quest_start",
      "sourceText": "Heute erkunden wir den Fluss, die Brücken und die Boote.",
      "sourceEnText": "Today we will explore the river, bridges and boats.",
      "audioFile": "pl_03_start_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3529,
      "updatedAt": "2026-03-03T20:30:36Z",
      "textHash": "f9d44860e95bba0a5cd4a13e78911e443415ab380a48bf5ea9040e68f3739211"
    },
    {
      "key": "tour_1",
      "nodeTitle": "npc_boat_people",
      "sourceText": "Mit Touristenbooten können Besucher den Zoo und die Kathedrale besichtigen.",
      "sourceEnText": "Tourist boats take people to see the Zoo and the Cathedral.",
      "audioFile": "pl_03_tour_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4551,
      "updatedAt": "2026-03-03T20:31:31Z",
      "textHash": "df0511de8a56846c32c4b11be7c2d0be4db21537d5b831656696151b65158b7e"
    },
    {
      "key": "tour_2",
      "nodeTitle": "npc_boat_people",
      "sourceText": "Womit besichtigen die Menschen auf diesen Booten die Sehenswürdigkeiten?",
      "sourceEnText": "What do the people on these boats use to see the sights?",
