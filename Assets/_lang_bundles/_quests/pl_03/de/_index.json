      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4272,
      "updatedAt": "2026-03-03T20:31:34Z",
      "textHash": "04f89488ae4689b70318b93877c8c9afff5291e632a09503fab30cce02893b0a"
    },
    {
      "key": "tour_3",
      "nodeTitle": "npc_boat_people",
      "sourceText": "Ihre Augen und Kameras",
      "sourceEnText": "Their eyes and cameras",
      "audioFile": "pl_03_tour_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1533,
