    },
    {
      "key": "tourist_4",
      "nodeTitle": "spawned_tourist",
      "sourceText": "Die Kathedraleninsel ist nachts zauberhaft.",
      "sourceEnText": "The Cathedral island is magical at night.",
      "audioFile": "pl_03_tourist_4.ogg",
      "voiceProfile": "johnny",
      "actorId": "KID_M",
      "durationMs": 2740,
      "updatedAt": "2026-03-03T20:32:28Z",
      "textHash": "3c0d7e7d7e256b151466c6576ca0d31f21c5335381519188fb7ae69506e1ded0"
    },
    {
      "key": "train_1",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Seit über 150 Jahren überqueren Züge die Oder in Breslau.",
      "sourceEnText": "Trains have been crossing the Odra in Wrocław for over 150 years.",
      "audioFile": "pl_03_train_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4180,
      "updatedAt": "2026-03-03T20:30:46Z",
      "textHash": "dee25dfd2f0b8a65a72f65749462a006697593029ff353c828cd738651432455"
    },
    {
      "key": "train_2",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Warum werden Eisenbahnbrücken aus so schwerem Stahl gefertigt?",
      "sourceEnText": "Why are train bridges made of such heavy steel?",
      "audioFile": "pl_03_train_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3855,
      "updatedAt": "2026-03-03T20:30:48Z",
      "textHash": "491453c66664415b8e6467189a4dda320763ae1f685b91fd80b28f61b991010c"
    },
    {
      "key": "train_3",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Weil Züge sehr schwer sind",
      "sourceEnText": "Because trains are very heavy",
      "audioFile": "pl_03_train_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1672,
      "updatedAt": "2026-03-03T20:30:52Z",
      "textHash": "ceadada264f7400fd85f910c0b423c04300489a54762a100c78ffc38340249b6"
    },
    {
      "key": "train_4",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "Ja! Es muss stark genug für die schweren Züge sein.",
      "sourceEnText": "Yes! It must be strong enough for the heavy trains.",
      "audioFile": "pl_03_train_4.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3251,
      "updatedAt": "2026-03-03T20:30:55Z",
      "textHash": "c5a3337fa8661d8fcd54cf2b9f8dcd51bbc64325af666c6d6dab353d464c7e25"
    },
    {
      "key": "train_5",
      "nodeTitle": "npc_bridge_train",
      "sourceText": "einen lauten Knall erzeugen",
      "sourceEnText": "To make a loud noise",
      "audioFile": "pl_03_train_5.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 1858,
      "updatedAt": "2026-03-03T20:30:58Z",
