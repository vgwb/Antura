    {
      "key": "house_1",
      "nodeTitle": "npc_boat_house",
      "sourceText": "In Breslau nennen manche Menschen den Fluss ihre „Heimatstraße“.",
      "sourceEnText": "In Wrocław, some people call the river their \"home street.\"",
      "audioFile": "pl_03_house_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4087,
      "updatedAt": "2026-03-03T20:31:08Z",
      "textHash": "6089f11d7eb89b47425fdef65ec846c10bcc54a21708626055983d94b95aea6d"
    },
    {
      "key": "house_2",
      "nodeTitle": "npc_boat_house",
      "sourceText": "Sogar die Zwerge würden ein schwimmendes Haus lieben!",
      "sourceEnText": "Even the dwarves would love a floating house!",
      "audioFile": "pl_03_house_2.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3065,
      "updatedAt": "2026-03-03T20:31:11Z",
      "textHash": "3af4ab76793196e8b0990de99a6118e9c221bd04a2fde4e79f8d0b9133fa0bd7"
    },
    {
      "key": "house_3",
      "nodeTitle": "npc_boat_house",
      "sourceText": "Wenn man auf einem Hausboot lebt, was nutzt man dann als Garten?",
      "sourceEnText": "If you live on a houseboat, what do you use for a backyard?",
      "audioFile": "pl_03_house_3.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3390,
      "updatedAt": "2026-03-03T20:31:14Z",
