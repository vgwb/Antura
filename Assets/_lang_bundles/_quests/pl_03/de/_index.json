    },
    {
      "key": "tum_1",
      "nodeTitle": "npc_tumski_bridge",
      "sourceText": "Das ist die Tumski-Brücke. Sie führt in den ältesten Teil der Stadt.",
      "sourceEnText": "This is the Tumski Bridge. It goes to the oldest part of the city.",
      "audioFile": "pl_03_tum_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 4412,
      "updatedAt": "2026-03-03T20:28:06Z",
      "textHash": "b2657e3b843577e802e33fdb3eb883a6171a5ebde1e9eebad8a78b4eaa030997"
    },
    {
      "key": "tum_2",
      "nodeTitle": "npc_tumski_bridge",
      "sourceText": "Jeden Abend zündet ein Mann hier die 102 Gaslaternen von Hand an!",
      "sourceEnText": "Every evening, a man lights the 102 gas lanterns here by hand!",
      "audioFile": "pl_03_tum_2.ogg",
