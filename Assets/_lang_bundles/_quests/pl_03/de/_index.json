    },
    {
      "key": "go_back",
      "nodeTitle": "task_find_photos_done",
      "sourceText": "Geh zurück und sprich mit dem Reiseleiter.",
      "sourceEnText": "Go back and talk to the guide.",
      "audioFile": "pl_03_go_back.ogg",
      "voiceProfile": "alice",
      "actorId": "SENIOR_M",
      "durationMs": 2322,
      "updatedAt": "2026-03-03T20:29:48Z",
      "textHash": "52033f73b496be4a56ffc4448bd2643df8783638a5cb1d8f4ea8c1fa81fe27dd"
