    {
      "key": "end_1",
      "nodeTitle": "quest_end",
      "sourceText": "Wir haben etwas über verschiedene Brückentypen gelernt.",
      "sourceEnText": "We learned about different types of bridges.",
      "audioFile": "pl_03_end_1.ogg",
      "voiceProfile": "alice",
      "actorId": "Default",
      "durationMs": 3111,
      "updatedAt": "2026-03-03T20:30:30Z",
