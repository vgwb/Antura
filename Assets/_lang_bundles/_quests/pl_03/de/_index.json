    {
      "key": "tum_5",
      "nodeTitle": "npc_tumski_bridge",
      "sourceText": "Ja! Allerdings sind sie sehr schwer und werden entfernt!",
      "sourceEnText": "Yes! Though they are very heavy and will be removed!",
