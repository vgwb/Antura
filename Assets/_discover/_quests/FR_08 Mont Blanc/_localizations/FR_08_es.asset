%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "\xA1Bienvenidos a los Alpes franceses!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "Hoy ascenderemos al Mont Blanc. Es la monta\xF1a m\xE1s alta de
      los Alpes."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "\xA1Incre\xEDble! Has llegado a la cima del Mont Blanc. \xA1Tiene
      4807 metros de altura!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "Los Alpes est\xE1n llenos de monta\xF1as altas y hermosas."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: "\xA1Dibuja el Mont Blanc y las tres banderas en tu cuaderno!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "Veo que tienes la mochila. \xA1Ahora puedes irte!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: Vamos a escalar el Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "\xA1Encuentra todo el equipo de escalada y aprende sobre los tres
      pa\xEDses vecinos!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: Vuelve cuando termines la tarea.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "\xA1Socorro! Soy gu\xEDa de monta\xF1a. \xA1Un perro azul se ha
      llevado nuestro equipo de escalada!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: "Vimos al perro correr monta\xF1a arriba."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: Por favor, explore el Mont Blanc y encuentre nuestro equipo.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: Antes de ir, necesitas una mochila.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: "\xA1B\xFAscalo por ah\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "\xA1Se abre! Contiene una mochila."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "Est\xE1 cerrado con llave. Quiz\xE1s necesites una llave."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: Esta mochila puede contener comida, agua y un mapa.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "\xA1Ahora podemos abandonar el campamento base y comenzar la aventura!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "\xA1Ya est\xE1s listo para escalar!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "Si est\xE1s bloqueado, \xA1el mu\xF1eco de nieve puede ayudarte!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: "\xA1Te falta el abrigo!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "Empieza a soplar el viento. \xA1Necesito proteger mis o\xEDdos!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "\xBFC\xF3mo podemos proteger nuestros o\xEDdos cuando hace mucho
      viento?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "\xA1Abre el cofre para conseguir un gorro calentito!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "\xA1Se abre! Contiene algunos equipos."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: Este abrigo te mantiene abrigado en caso de viento y nieve.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: Un gorro abrigado mantiene la cabeza caliente.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: "Tambi\xE9n ayuda cuando hace fr\xEDo."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "\xA1Ahora puedes continuar el ascenso!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "Si te quedas atascado, \xA1el mu\xF1eco de nieve te puede ayudar!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: "\xA1Te faltan los guantes!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "El sol brilla con mucha intensidad sobre la nieve. Necesitamos
      protecci\xF3n para los ojos."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "\xBFQu\xE9 protege tus ojos de la nieve brillante y del sol?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "Sigue buscando. Todav\xEDa necesitamos todo el equipo."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "\xA1Abre el cofre para conseguir gafas de sol!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "\xA1Se abre! Tiene gafas de sol dentro."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: Los guantes mantienen los dedos calientes y secos.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "Las manos fr\xEDas dificultan la escalada."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: La nieve y el hielo reflejan la luz brillante del sol.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: Las gafas de sol protegen tus ojos.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "\xA1Ya tienes el equipo para hielo! \xA1Un \xFAltimo esfuerzo para
      llegar a la cima!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: "\xA1Te falta la cuerda!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: Para caminar sobre el hielo de los glaciares, necesitamos equipo
      especial.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "\xBFQu\xE9 te pones en las botas para caminar sobre hielo sin resbalar?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: Crampones
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "\xA1Correcto! \xDAsalos para mantener el equilibrio."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: Aletas
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "\xA1No! \xA1No est\xE1s nadando! Int\xE9ntalo de nuevo."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "\xA1Abre el cofre para sacar los crampones!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: "Estos elementos te ayudar\xE1n a caminar con seguridad sobre el
      hielo."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: La cuerda ayuda a los escaladores a mantenerse seguros sobre hielo
      y roca.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: "\xA1Lo lograste! Estamos en la cima del Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: Esta cima tiene 4807 metros de altura.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: "Respondamos tres preguntas sobre la monta\xF1a antes del partido
      de la bandera."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "\xBFEn qu\xE9 cordillera se encuentra el Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: Los Alpes
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: "\xA1Correcto!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: Los Pirineos
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: "No del todo. Int\xE9ntalo de nuevo."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: Los Apeninos
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: "\xBFQu\xE9 altura tiene el Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: 4807 metros
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: 3705 metros
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: 5016 metros
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: "\xBFQu\xE9 pa\xEDses se pueden ver desde aqu\xED?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: Francia, Italia y Suiza
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: "\xA1Correcto! Coloquemos las banderas."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: "Francia, Espa\xF1a y Alemania"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: "No del todo. \xA1Est\xE1n un poco lejos!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: Francia se encuentra al oeste del Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: Italia se encuentra al este del Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: "Suiza est\xE1 al norte del Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: "\xBFNecesitas ayuda para escalar la monta\xF1a?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: "S\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: Campo base 1
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: Campo base 2
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: Campo base 3
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: Campo base 4
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: "No, me quedo aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: "Duermo todo el invierno bajo la nieve. \xA1A esto se le llama hibernaci\xF3n!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: "Me encanta comer flores y hierbas alpinas. \xA1Qu\xE9 rico!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: "No me hagan caso, solo estoy tomando el sol en esta roca c\xE1lida."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: "\xA1Encontraste una bufanda abrigada!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: Una bufanda protege del viento en el cuello.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: "\xA1Me encantan las monta\xF1as!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: "\xA1El Mont Blanc es la monta\xF1a m\xE1s alta de los Alpes!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: "\xA1Espero ver una marmota!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: "\xA1No olvides traer ropa de abrigo!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "Las monta\xF1as pueden ser peligrosas, \xA1as\xED que ten cuidado!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "Hacer senderismo aqu\xED requiere buenas botas."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: "El viento puede cambiar r\xE1pidamente."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: Cuando hay hielo, sigo la cuerda que marca el camino.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: "Ese glaciar parece un r\xEDo congelado."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: Me encanta escalar en los Alpes.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: Los crampones me ayudan a caminar sobre hielo duro.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: "Escalar con un gu\xEDa es m\xE1s seguro."
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173380
    m_Localized: "No s\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173381
    m_Localized: "\xA1Vuelve m\xE1s tarde!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
