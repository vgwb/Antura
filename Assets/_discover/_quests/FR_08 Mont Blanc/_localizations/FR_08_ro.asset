%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_ro
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: ro
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "Bine a\u021Bi venit \xEEn Alpii francezi!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "Ast\u0103zi urc\u0103m pe Mont Blanc. Este cel mai \xEEnalt munte
      din Alpi."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "Uimitor! Ai ajuns \xEEn v\xE2rful Mont Blanc. Are 4807 metri \xEEn\u0103l\u021Bime!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "Alpii sunt plini de mun\u021Bi \xEEnal\u021Bi \u0219i frumo\u0219i."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: "Deseneaz\u0103 Mont Blanc \u0219i cele trei steaguri \xEEn caietul
      t\u0103u!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "V\u0103d c\u0103 ai rucsacul. Acum po\u021Bi pleca!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: "Hai s\u0103 urc\u0103m pe Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "G\u0103se\u0219te tot echipamentul de alpinism \u0219i afl\u0103
      mai multe despre cele trei \u021B\u0103ri din apropiere!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: "Revino c\xE2nd termini treaba."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "Ajutor! Sunt ghid montan. Un c\xE2ine albastru ne-a luat echipamentul
      de alpinism!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: "L-am v\u0103zut pe c\xE2ine alerg\xE2nd pe munte."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "Te rug\u0103m s\u0103 explorezi Mont Blanc \u0219i s\u0103 g\u0103se\u0219ti
      echipamentul nostru."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "\xCEnainte de a merge, ai nevoie de un rucsac."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: "Caut\u0103-l \xEEn jur!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "Se deschide! Con\u021Bine un rucsac."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "E \xEEncuiat. Poate ai nevoie de o cheie."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "Acest rucsac poate transporta m\xE2ncare, ap\u0103 \u0219i o hart\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "Acum putem ie\u0219i din tab\u0103ra de baz\u0103 \u0219i \xEEncepe
      aventura!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "Acum e\u0219ti gata s\u0103 urci!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "Dac\u0103 e\u0219ti blocat, omul de z\u0103pad\u0103 te poate ajuta!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: "\xCE\u021Bi lipse\u0219te haina!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "V\xE2ntul \xEEncepe s\u0103 bat\u0103. Urechile mele au nevoie
      de protec\u021Bie!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "Cum ne protej\u0103m urechile c\xE2nd bate v\xE2ntul puternic?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "Deschide cuf\u0103rul ca s\u0103 iei o c\u0103ciul\u0103 c\u0103lduroas\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "Se deschide! Con\u021Bine ni\u0219te echipamente."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: "Aceast\u0103 hain\u0103 te \u021Bine de cald \xEEn v\xE2nt \u0219i
      z\u0103pad\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: "O c\u0103ciul\u0103 c\u0103lduroas\u0103 \xEE\u021Bi \u021Bine
      capul cald."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: "De asemenea, ajut\u0103 c\xE2nd v\xE2ntul este rece."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "Acum po\u021Bi continua urcu\u0219ul!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "Dac\u0103 te blochezi, omul de z\u0103pad\u0103 te poate ajuta!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: "\xCE\u021Bi lipsesc m\u0103nu\u0219ile!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "Soarele pe z\u0103pad\u0103 este foarte puternic. Avem nevoie de
      protec\u021Bie pentru ochi."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "Ce \xEE\u021Bi protejeaz\u0103 ochii de z\u0103pada \u0219i soarele
      str\u0103lucitor?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "Continu\u0103 s\u0103 cau\u021Bi. \xCEnc\u0103 avem nevoie de tot
      echipamentul."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "Deschide cuf\u0103rul ca s\u0103 iei ochelari de soare!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "Se deschide! Are ochelari de soare \xEEn\u0103untru."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: "M\u0103nu\u0219ile \u021Bin degetele calde \u0219i uscate."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "M\xE2inile reci \xEEngreuneaz\u0103 alpinismul."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: "Z\u0103pada \u0219i ghea\u021Ba reflect\u0103 lumina puternic\u0103
      a soarelui."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "Ochelarii de soare v\u0103 protejeaz\u0103 ochii."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "Ai echipamentul de ghea\u021B\u0103. \xCEnc\u0103 o \xEEmpingere
      p\xE2n\u0103 \xEEn v\xE2rf!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: "\xCE\u021Bi lipse\u0219te coarda!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "Ca s\u0103 mergem pe ghea\u021Ba glaciar\u0103, avem nevoie de
      echipament special."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "Ce \xEE\u021Bi pui \xEEn ghete ca s\u0103 mergi pe ghea\u021B\u0103
      \u0219i s\u0103 nu aluneci?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: Crampoane
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "Corect! Folose\u0219te-le ca s\u0103 r\u0103m\xE2i stabil."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: "\xCEnot\u0103toare"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "Nu! Nu \xEEno\u021Bi! \xCEncearc\u0103 din nou."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "Deschide cuf\u0103rul ca s\u0103 iei col\u021Bari!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: "Acestea te ajut\u0103 s\u0103 mergi \xEEn siguran\u021B\u0103 pe
      ghea\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: "Coarda \xEEi ajut\u0103 pe alpini\u0219ti s\u0103 r\u0103m\xE2n\u0103
      \xEEn siguran\u021B\u0103 pe ghea\u021B\u0103 \u0219i st\xE2nc\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: "Ai reu\u0219it! Suntem \xEEn v\xE2rful Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: "Acest v\xE2rf are o \xEEn\u0103l\u021Bime de 4807 metri."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: "Hai s\u0103 r\u0103spundem la trei \xEEntreb\u0103ri despre munte
      \xEEnainte de jocul cu steagul."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "\xCEn ce lan\u021B muntos se afl\u0103 Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: Alpii
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: Corecta!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: Pirineii
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: "Nu chiar. \xCEncearc\u0103 din nou."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: Apeninii
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: "C\xE2t de \xEEnalt este Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: 4807 metri
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: 3705 metri
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: 5016 metri
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: "Ce \u021B\u0103ri po\u021Bi vedea de aici?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: "Fran\u021Ba, Italia \u0219i Elve\u021Bia"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: "Corect! S\u0103 a\u0219ez\u0103m steagurile."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: "Fran\u021Ba, Spania \u0219i Germania"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: "Nu chiar. Sunt pu\u021Bin cam prea departe!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: "Fran\u021Ba se afl\u0103 la vest de Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: "Italia se afl\u0103 la est de Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: "Elve\u021Bia se afl\u0103 la nord de Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: "Ai nevoie de ajutor ca s\u0103 urci muntele?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: Da
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: "Tab\u0103ra de baz\u0103 1"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: "Tab\u0103ra de baz\u0103 2"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: "Tab\u0103ra de baz\u0103 3"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: "Tab\u0103ra de baz\u0103 4"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: "Nu, eu r\u0103m\xE2n aici"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: "Dorm toat\u0103 iarna sub z\u0103pad\u0103. Asta se nume\u0219te
      hibernare!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: "\xCEmi place s\u0103 m\u0103n\xE2nc flori alpine \u0219i iarb\u0103.
      Poft\u0103 bun\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: "Nu m\u0103 b\u0103ga \xEEn seam\u0103, doar m\u0103 bronzez pe
      aceast\u0103 st\xE2nc\u0103 cald\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: "Ai g\u0103sit o e\u0219arf\u0103 c\u0103lduroas\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: "O e\u0219arf\u0103 \xEE\u021Bi blocheaz\u0103 v\xE2ntul la g\xE2t."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: "Iubesc mun\u021Bii!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: "Mont Blanc este cel mai \xEEnalt munte din Alpi!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: "Sper s\u0103 v\u0103d o marmot\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: "Nu uita s\u0103 aduci haine groase!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "Mun\u021Bii pot fi periculo\u0219i, a\u0219a c\u0103 fi\u021Bi
      aten\u021Bi!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "Drume\u021Biile aici necesit\u0103 bocanci buni."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: "V\xE2ntul se poate schimba rapid."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: "Urmez linia fr\xE2nghiei c\xE2nd este ghea\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: "Ghe\u021Barul acela arat\u0103 ca un r\xE2u \xEEnghe\u021Bat."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: "\xCEmi place s\u0103 fac alpinism \xEEn Alpi."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: "Crampoanele m\u0103 ajut\u0103 s\u0103 merg pe ghea\u021B\u0103
      tare."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: Alpinismul cu un ghid este mai sigur.
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173380
    m_Localized: "Nu \u0219tiu"
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173381
    m_Localized: "Revino mai t\xE2rziu!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
