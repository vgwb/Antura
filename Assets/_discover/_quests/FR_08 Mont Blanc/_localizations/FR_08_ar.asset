  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "\u0623\u0647\u0644\u0627\u064B \u0628\u0643\u0645 \u0641\u064A
      \u062C\u0628\u0627\u0644 \u0627\u0644\u0623\u0644\u0628 \u0627\u0644\u0641\u0631\u0646\u0633\u064A\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "\u0627\u0644\u064A\u0648\u0645 \u0646\u062A\u0633\u0644\u0642 \u062C\u0628\u0644
      \u0645\u0648\u0646\u062A \u0628\u0644\u0627\u0646\u0643. \u0625\u0646\u0647
      \u0623\u0639\u0644\u0649 \u062C\u0628\u0644 \u0641\u064A \u062C\u0628\u0627\u0644
      \u0627\u0644\u0623\u0644\u0628."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "\u0631\u0627\u0626\u0639! \u0644\u0642\u062F \u0648\u0635\u0644\u062A
      \u0625\u0644\u0649 \u0642\u0645\u0629 \u0645\u0648\u0646\u062A \u0628\u0644\u0627\u0646\u0643.
      \u064A\u0628\u0644\u063A \u0627\u0631\u062A\u0641\u0627\u0639\u0647\u0627 4807
      \u0623\u0645\u062A\u0627\u0631!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "\u062C\u0628\u0627\u0644 \u0627\u0644\u0623\u0644\u0628 \u0645\u0644\u064A\u0626\u0629
      \u0628\u0627\u0644\u062C\u0628\u0627\u0644 \u0627\u0644\u0634\u0627\u0647\u0642\u0629
      \u0648\u0627\u0644\u062C\u0645\u064A\u0644\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: "\u0627\u0631\u0633\u0645 \u062C\u0628\u0644 \u0645\u0648\u0646\u062A
      \u0628\u0644\u0627\u0646\u0643 \u0648\u0627\u0644\u0623\u0639\u0644\u0627\u0645
      \u0627\u0644\u062B\u0644\u0627\u062B\u0629 \u0641\u064A \u062F\u0641\u062A\u0631
      \u0645\u0644\u0627\u062D\u0638\u0627\u062A\u0643!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "\u0623\u0631\u0649 \u0623\u0646 \u0644\u062F\u064A\u0643 \u062D\u0642\u064A\u0628\u0629
      \u0627\u0644\u0638\u0647\u0631. \u064A\u0645\u0643\u0646\u0643 \u0627\u0644\u0630\u0647\u0627\u0628
      \u0627\u0644\u0622\u0646!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: "\u0647\u064A\u0627 \u0628\u0646\u0627 \u0646\u062A\u0633\u0644\u0642
      \u062C\u0628\u0644 \u0645\u0648\u0646\u062A \u0628\u0644\u0627\u0646\u0643."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "\u0627\u0639\u062B\u0631 \u0639\u0644\u0649 \u062C\u0645\u064A\u0639
      \u0645\u0639\u062F\u0627\u062A \u0627\u0644\u062A\u0633\u0644\u0642 \u0648\u062A\u0639\u0631\u0641
      \u0639\u0644\u0649 \u0627\u0644\u062F\u0648\u0644 \u0627\u0644\u062B\u0644\u0627\u062B
      \u0627\u0644\u0645\u062C\u0627\u0648\u0631\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: "\u0639\u062F \u0639\u0646\u062F\u0645\u0627 \u062A\u0646\u062A\u0647\u064A
      \u0645\u0646 \u0627\u0644\u0645\u0647\u0645\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "\u0627\u0644\u0646\u062C\u062F\u0629! \u0623\u0646\u0627 \u0645\u0631\u0634\u062F
      \u062C\u0628\u0644\u064A. \u0643\u0644\u0628 \u0623\u0632\u0631\u0642 \u0623\u062E\u0630
      \u0645\u0639\u062F\u0627\u062A \u0627\u0644\u062A\u0633\u0644\u0642 \u0627\u0644\u062E\u0627\u0635\u0629
      \u0628\u0646\u0627!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: "\u0631\u0623\u064A\u0646\u0627 \u0627\u0644\u0643\u0644\u0628 \u064A\u0631\u0643\u0636
      \u0635\u0639\u0648\u062F\u0627\u064B \u0625\u0644\u0649 \u0627\u0644\u062C\u0628\u0644."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "\u062A\u0641\u0636\u0644\u0648\u0627 \u0628\u0627\u0633\u062A\u0643\u0634\u0627\u0641
      \u0645\u0648\u0646\u062A \u0628\u0644\u0627\u0646\u0643 \u0648\u0627\u0628\u062D\u062B\u0648\u0627
      \u0639\u0646 \u0645\u0639\u062F\u0627\u062A\u0646\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "\u0642\u0628\u0644 \u0627\u0644\u0630\u0647\u0627\u0628\u060C \u0633\u062A\u062D\u062A\u0627\u062C
      \u0625\u0644\u0649 \u062D\u0642\u064A\u0628\u0629 \u0638\u0647\u0631."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: "\u0627\u0628\u062D\u062B \u0639\u0646\u0647 \u0641\u064A \u0643\u0644
      \u0645\u0643\u0627\u0646!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "\u064A\u0641\u062A\u062D! \u0648\u064A\u062D\u062A\u0648\u064A
      \u0639\u0644\u0649 \u062D\u0642\u064A\u0628\u0629 \u0638\u0647\u0631."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "\u0625\u0646\u0647 \u0645\u063A\u0644\u0642. \u0631\u0628\u0645\u0627
      \u062A\u062D\u062A\u0627\u062C \u0625\u0644\u0649 \u0645\u0641\u062A\u0627\u062D."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "\u064A\u0645\u0643\u0646 \u0644\u0647\u0630\u0647 \u0627\u0644\u062D\u0642\u064A\u0628\u0629
      \u062D\u0645\u0644 \u0627\u0644\u0637\u0639\u0627\u0645 \u0648\u0627\u0644\u0645\u0627\u0621
      \u0648\u0627\u0644\u062E\u0631\u064A\u0637\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "\u0627\u0644\u0622\u0646 \u064A\u0645\u0643\u0646\u0646\u0627 \u0627\u0644\u062E\u0631\u0648\u062C
      \u0645\u0646 \u0627\u0644\u0645\u0639\u0633\u0643\u0631 \u0627\u0644\u0623\u0633\u0627\u0633\u064A
      \u0648\u0628\u062F\u0621 \u0627\u0644\u0645\u063A\u0627\u0645\u0631\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "\u0623\u0646\u062A \u0627\u0644\u0622\u0646 \u062C\u0627\u0647\u0632
      \u0644\u0644\u062A\u0633\u0644\u0642!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "\u0625\u0630\u0627 \u0643\u0646\u062A \u062A\u0648\u0627\u062C\u0647
      \u0645\u0634\u0643\u0644\u0629\u060C \u064A\u0645\u0643\u0646 \u0644\u0631\u062C\u0644
      \u0627\u0644\u062B\u0644\u062C \u0645\u0633\u0627\u0639\u062F\u062A\u0643!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: "\u0623\u0646\u062A \u062A\u0641\u062A\u0642\u062F \u0627\u0644\u0645\u0639\u0637\u0641!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "\u0628\u062F\u0623\u062A \u0627\u0644\u0631\u064A\u0627\u062D \u062A\u0647\u0628.
      \u0623\u0630\u0646\u0627\u064A \u0628\u062D\u0627\u062C\u0629 \u0625\u0644\u0649
      \u0627\u0644\u062D\u0645\u0627\u064A\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "\u0643\u064A\u0641 \u0646\u062D\u0645\u064A \u0622\u0630\u0627\u0646\u0646\u0627
      \u0639\u0646\u062F\u0645\u0627 \u062A\u0643\u0648\u0646 \u0627\u0644\u0631\u064A\u0627\u062D
      \u0642\u0648\u064A\u0629\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "\u0627\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642
      \u0644\u062A\u062D\u0635\u0644 \u0639\u0644\u0649 \u0642\u0628\u0639\u0629
      \u062F\u0627\u0641\u0626\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "\u064A\u0641\u062A\u062D! \u064A\u062D\u062A\u0648\u064A \u0639\u0644\u0649
      \u0628\u0639\u0636 \u0627\u0644\u0645\u0639\u062F\u0627\u062A."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: "\u0647\u0630\u0627 \u0627\u0644\u0645\u0639\u0637\u0641 \u064A\u062D\u0627\u0641\u0638
      \u0639\u0644\u0649 \u062F\u0641\u0626\u0643 \u0641\u064A \u0627\u0644\u0631\u064A\u0627\u062D
      \u0648\u0627\u0644\u062B\u0644\u0648\u062C."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: "\u0642\u0628\u0639\u0629 \u062F\u0627\u0641\u0626\u0629 \u062A\u062D\u0627\u0641\u0638
      \u0639\u0644\u0649 \u062F\u0641\u0621 \u0631\u0623\u0633\u0643."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: "\u0643\u0645\u0627 \u0623\u0646\u0647 \u0645\u0641\u064A\u062F
      \u0639\u0646\u062F\u0645\u0627 \u062A\u0643\u0648\u0646 \u0627\u0644\u0631\u064A\u0627\u062D
      \u0628\u0627\u0631\u062F\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "\u0648\u0627\u0644\u0622\u0646 \u064A\u0645\u0643\u0646\u0643 \u0645\u0648\u0627\u0635\u0644\u0629
      \u0627\u0644\u0635\u0639\u0648\u062F!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "\u0625\u0630\u0627 \u0639\u0644\u0642\u062A \u0641\u064A \u0645\u0643\u0627\u0646
      \u0645\u0627\u060C \u064A\u0645\u0643\u0646 \u0644\u0631\u062C\u0644 \u0627\u0644\u062B\u0644\u062C
      \u0623\u0646 \u064A\u0633\u0627\u0639\u062F\u0643!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: "\u0623\u0646\u062A \u062A\u0641\u062A\u0642\u062F \u0627\u0644\u0642\u0641\u0627\u0632\u0627\u062A!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "\u0627\u0644\u0634\u0645\u0633 \u0633\u0627\u0637\u0639\u0629 \u062C\u062F\u0627\u064B
      \u0639\u0644\u0649 \u0627\u0644\u062B\u0644\u062C. \u0646\u062D\u062A\u0627\u062C
      \u0625\u0644\u0649 \u062D\u0645\u0627\u064A\u0629 \u0623\u0639\u064A\u0646\u0646\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "\u0645\u0627 \u0627\u0644\u0630\u064A \u064A\u062D\u0645\u064A
      \u0639\u064A\u0646\u064A\u0643 \u0645\u0646 \u0627\u0644\u062B\u0644\u062C
      \u0627\u0644\u0633\u0627\u0637\u0639 \u0648\u0627\u0644\u0634\u0645\u0633\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "\u0627\u0633\u062A\u0645\u0631\u0648\u0627 \u0641\u064A \u0627\u0644\u0628\u062D\u062B.
      \u0645\u0627 \u0632\u0644\u0646\u0627 \u0628\u062D\u0627\u062C\u0629 \u0625\u0644\u0649
      \u062C\u0645\u064A\u0639 \u0627\u0644\u0645\u0639\u062F\u0627\u062A."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "\u0627\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642
      \u0644\u062A\u062D\u0635\u0644 \u0639\u0644\u0649 \u0646\u0638\u0627\u0631\u0629
      \u0634\u0645\u0633\u064A\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "\u064A\u0641\u062A\u062D! \u064A\u0648\u062C\u062F \u0628\u062F\u0627\u062E\u0644\u0647
      \u0646\u0638\u0627\u0631\u0627\u062A \u0634\u0645\u0633\u064A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: "\u062A\u062D\u0627\u0641\u0638 \u0627\u0644\u0642\u0641\u0627\u0632\u0627\u062A
      \u0639\u0644\u0649 \u062F\u0641\u0621 \u0648\u062C\u0641\u0627\u0641 \u0627\u0644\u0623\u0635\u0627\u0628\u0639."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "\u0628\u0631\u0648\u062F\u0629 \u0627\u0644\u064A\u062F\u064A\u0646
      \u062A\u062C\u0639\u0644 \u0627\u0644\u062A\u0633\u0644\u0642 \u0635\u0639\u0628\u0627\u064B."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: "\u064A\u0639\u0643\u0633 \u0627\u0644\u062B\u0644\u062C \u0648\u0627\u0644\u062C\u0644\u064A\u062F
      \u0636\u0648\u0621 \u0627\u0644\u0634\u0645\u0633 \u0627\u0644\u0633\u0627\u0637\u0639."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "\u0627\u0644\u0646\u0638\u0627\u0631\u0627\u062A \u0627\u0644\u0634\u0645\u0633\u064A\u0629
      \u062A\u062D\u0645\u064A \u0639\u064A\u0646\u064A\u0643."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "\u0644\u062F\u064A\u0643 \u0645\u0639\u062F\u0627\u062A \u0627\u0644\u062C\u0644\u064A\u062F.
      \u062F\u0641\u0639\u0629 \u0623\u062E\u064A\u0631\u0629 \u0646\u062D\u0648
      \u0627\u0644\u0642\u0645\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: "\u0623\u0646\u062A \u062A\u0641\u062A\u0642\u062F \u0627\u0644\u062D\u0628\u0644!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "\u0644\u0644\u0645\u0634\u064A \u0639\u0644\u0649 \u062C\u0644\u064A\u062F
      \u0627\u0644\u0623\u0646\u0647\u0627\u0631 \u0627\u0644\u062C\u0644\u064A\u062F\u064A\u0629\u060C
      \u0646\u062D\u062A\u0627\u062C \u0625\u0644\u0649 \u0645\u0639\u062F\u0627\u062A
      \u062E\u0627\u0635\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "\u0645\u0627\u0630\u0627 \u062A\u0636\u0639 \u0639\u0644\u0649
      \u062D\u0630\u0627\u0626\u0643 \u0644\u062A\u062A\u0645\u0643\u0646 \u0645\u0646
      \u0627\u0644\u0645\u0634\u064A \u0639\u0644\u0649 \u0627\u0644\u062C\u0644\u064A\u062F
      \u062F\u0648\u0646 \u0623\u0646 \u062A\u0646\u0632\u0644\u0642\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: "\u0627\u0644\u0645\u0631\u0627\u0628\u0637"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "\u0635\u062D\u064A\u062D! \u0627\u0633\u062A\u062E\u062F\u0645\u0647\u0627
      \u0644\u0644\u062D\u0641\u0627\u0638 \u0639\u0644\u0649 \u062B\u0628\u0627\u062A\u0643."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: "\u0627\u0644\u0632\u0639\u0627\u0646\u0641"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "\u0644\u0627! \u0623\u0646\u062A \u0644\u0627 \u062A\u0633\u0628\u062D!
      \u062D\u0627\u0648\u0644 \u0645\u0631\u0629 \u0623\u062E\u0631\u0649."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "\u0627\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642
