%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_hu
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: hu
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk a Francia Alpokban!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "Ma megm\xE1sztuk a Mont Blanc-ot, Eur\xF3pa legmagasabb hegy\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "Hihetetlen! El\xE9rted a Mont Blanc cs\xFAcs\xE1t. 4807 m\xE9ter
      magas!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "Az Alpok tele vannak magas, gy\xF6ny\xF6r\u0171 hegyekkel."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: "Rajzold le a f\xFCzetedbe a Mont Blanc-t \xE9s a h\xE1rom z\xE1szl\xF3t!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "L\xE1tom, n\xE1lad van a h\xE1tizs\xE1k. Most m\xE1r mehetsz!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: "M\xE1sszuk meg a Mont Blanc-t."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "\xC9s tal\xE1ld meg az \xF6sszes m\xE1sz\xF3felszerel\xE9st!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: Gyere vissza, ha befejezted a feladatot.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "Seg\xEDts\xE9g! Hegyi vezet\u0151 vagyok. Egy k\xE9k kutya elvitte
      a m\xE1sz\xF3felszerel\xE9s\xFCnket!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: "L\xE1ttuk a kuty\xE1t felfutni a hegyre."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "Fedezd fel a Mont Blanc-t \xE9s keresd fel felszerel\xE9s\xFCnket!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "Indul\xE1s el\u0151tt sz\xFCks\xE9ged lesz egy h\xE1tizs\xE1kra."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: "N\xE9zz k\xF6r\xFCl \xE9rte!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "Nyithat\xF3! Egy h\xE1tizs\xE1k van benne."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "Z\xE1rva van. Tal\xE1n kulcsra van sz\xFCks\xE9ged."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "Ez a h\xE1tizs\xE1k \xE9lelmiszert, vizet \xE9s t\xE9rk\xE9pet
      is k\xE9pes sz\xE1ll\xEDtani."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "Most m\xE1r elhagyhatjuk az alapt\xE1bort \xE9s elkezdhetj\xFCk
      a kalandot!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "Most m\xE1r k\xE9szen \xE1llsz a m\xE1sz\xE1sra!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "Ha elakadt\xE1l, a h\xF3ember seg\xEDthet!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: "Hi\xE1nyzik a kab\xE1tod!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "F\xFAjni kezd a sz\xE9l. V\xE9deni kell a f\xFCleimet!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "Hogyan v\xE9dj\xFCk a f\xFCl\xFCnket er\u0151s sz\xE9lben?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "Nyisd ki a l\xE1d\xE1t, hogy meleg sapk\xE1t kapj!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "Ny\xEDlik! Van benne valami felszerel\xE9s."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: "Ez a kab\xE1t melegen tart sz\xE9lben \xE9s h\xF3ban."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: Egy meleg sapka melegen tartja a fejed.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: "Az is seg\xEDt, ha hideg a sz\xE9l."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "Most m\xE1r folytathatod a m\xE1sz\xE1st!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "Ha elakadsz, a h\xF3ember seg\xEDthet!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: "Hi\xE1nyzik a keszty\u0171d!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "A nap nagyon f\xE9nyesen s\xFCt a havon. Szemv\xE9delemre van sz\xFCks\xE9g\xFCnk."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "Mi seg\xEDt megv\xE9deni a szemedet a f\xE9nyes h\xF3t\xF3l \xE9s
      a napt\xF3l?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "Keress tov\xE1bb. M\xE9g mindig sz\xFCks\xE9g\xFCnk van az \xF6sszes
      felszerel\xE9sre."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "Nyisd ki a l\xE1d\xE1t, hogy napszem\xFCveget kapj!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "Nyithat\xF3! Napszem\xFCveg van benne."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: "A keszty\u0171k melegen \xE9s sz\xE1razon tartj\xE1k az ujjakat."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "A hideg kezek megnehez\xEDtik a m\xE1sz\xE1st."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: "A h\xF3 \xE9s a j\xE9g visszaveri a ragyog\xF3 napf\xE9nyt."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "A napszem\xFCveg v\xE9di a szemed."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "Megvan a j\xE9gfelszerel\xE9s. Egy utols\xF3 l\xF6k\xE9s a cs\xFAcsra!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: "Hi\xE1nyzik a k\xF6teled!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "A gleccserek j\xE9g\xE9n val\xF3 j\xE1r\xE1shoz speci\xE1lis felszerel\xE9sre
      van sz\xFCks\xE9g\xFCnk."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "Mit kell felvenni a csizm\xE1dra, hogy ne cs\xFAssz el a j\xE9gen?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: "H\xE1g\xF3vasak"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "Helyes! Haszn\xE1ld \u0151ket, hogy stabil maradj."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: "Ujjb\xE9k\xE1k"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "Nem! Nem \xFAszol! Pr\xF3b\xE1ld \xFAjra."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "Nyisd ki a mellkast, hogy h\xE1g\xF3vasakat kapj!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: "Ezek seg\xEDtenek biztons\xE1gosan k\xF6zlekedni a j\xE9gen."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: "A k\xF6t\xE9l seg\xEDt a hegym\xE1sz\xF3knak biztons\xE1gban maradni
      j\xE9gen \xE9s szikl\xE1n."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: "Siker\xFClt! A Mont Blanc tetej\xE9n vagyunk."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: "Ez a cs\xFAcs 4807 m\xE9ter magas."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: "V\xE1laszoljunk h\xE1rom hegyi k\xE9rd\xE9sre a z\xE1szl\xF3kih\xEDv\xE1s
      el\u0151tt."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "Melyik hegys\xE9gben tal\xE1lhat\xF3 a Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: Az Alpok
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: Helyes!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: A Pireneusok
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: "Nem eg\xE9szen. Pr\xF3b\xE1ld \xFAjra."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: Az Appenninek
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: Milyen magas a Mont Blanc?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: "4807 m\xE9ter"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: "3705 m\xE9ter"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: "5016 m\xE9ter"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: "Mely orsz\xE1gokat lehet innen l\xE1tni?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: "Franciaorsz\xE1g, Olaszorsz\xE1g \xE9s Sv\xE1jc"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: "Rendben! Helyezz\xFCk el a z\xE1szl\xF3kat."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: "Franciaorsz\xE1g, Spanyolorsz\xE1g \xE9s N\xE9metorsz\xE1g"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: "Nem eg\xE9szen. Ezek egy kicsit t\xFAl messze vannak!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: "Mont Blanc-t\xF3l nyugatra Franciaorsz\xE1g tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: "Mont Blanc-t\xF3l keletre tal\xE1lhat\xF3 Olaszorsz\xE1g."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: "A Mont Blanc-t\xF3l \xE9szakra Sv\xE1jc tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: "Seg\xEDts\xE9gre van sz\xFCks\xE9ged a hegy megm\xE1sz\xE1s\xE1hoz?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: Igen
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: "1. alapt\xE1bor"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: "2. alapt\xE1bor"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: "3. alapt\xE1bor"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: "4. alapt\xE1bor"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: Nem, itt maradok
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: "Eg\xE9sz t\xE9len a h\xF3 alatt alszom. Ezt h\xEDvj\xE1k t\xE9li
      \xE1lomnak!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: "Im\xE1dok alpesi vir\xE1gokat \xE9s f\xFCvet enni. Nyami!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: "Ne t\xF6r\u0151dj velem, csak napozom ezen a meleg szikl\xE1n."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: "Tal\xE1lt\xE1l egy meleg s\xE1lat!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: "Egy s\xE1l v\xE9d a sz\xE9lt\u0151l a nyakadban."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: "Im\xE1dom a hegyeket!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: A Mont Blanc az Alpok legmagasabb hegye!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: "Rem\xE9lem, l\xE1tok majd egy mormot\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: "Ne felejts el meleg ruh\xE1t hozni!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "A hegyek vesz\xE9lyesek lehetnek, vigy\xE1zz magadra!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "A t\xFAr\xE1z\xE1shoz itt j\xF3 cip\u0151 kell."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: "A sz\xE9l gyorsan v\xE1ltozhat."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: "K\xF6vetem a k\xF6telet, amikor jeges."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: "Ez a gleccser \xFAgy n\xE9z ki, mint egy befagyott foly\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: "Im\xE1dok m\xE1szni az Alpokban."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: "A h\xE1g\xF3vas seg\xEDt kem\xE9ny j\xE9gen j\xE1rni."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: "Az idegenvezet\u0151vel val\xF3 m\xE1sz\xE1s biztons\xE1gosabb."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
