MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_uk
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: uk
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "\u041B\u0430\u0441\u043A\u0430\u0432\u043E \u043F\u0440\u043E\u0441\u0438\u043C\u043E
      \u0434\u043E \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u044C\u043A\u0438\u0445
      \u0410\u043B\u044C\u043F!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "\u0421\u044C\u043E\u0433\u043E\u0434\u043D\u0456 \u043C\u0438 \u043F\u0456\u0434\u043D\u0456\u043C\u0430\u0454\u043C\u043E\u0441\u044F
      \u043D\u0430 \u041C\u043E\u043D\u0431\u043B\u0430\u043D. \u0426\u0435 \u043D\u0430\u0439\u0432\u0438\u0449\u0430
      \u0433\u043E\u0440\u0430 \u0432 \u0410\u043B\u044C\u043F\u0430\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "\u041D\u0435\u0439\u043C\u043E\u0432\u0456\u0440\u043D\u043E! \u0412\u0438
      \u0434\u043E\u0441\u044F\u0433\u043B\u0438 \u0432\u0435\u0440\u0448\u0438\u043D\u0438
      \u041C\u043E\u043D\u0431\u043B\u0430\u043D\u0443. \u0419\u043E\u0433\u043E
      \u0432\u0438\u0441\u043E\u0442\u0430 4807 \u043C\u0435\u0442\u0440\u0456\u0432!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "\u0410\u043B\u044C\u043F\u0438 \u043F\u043E\u0432\u043D\u0456 \u0432\u0438\u0441\u043E\u043A\u0438\u0445,
      \u043A\u0440\u0430\u0441\u0438\u0432\u0438\u0445 \u0433\u0456\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: "\u041D\u0430\u043C\u0430\u043B\u044E\u0439 \u041C\u043E\u043D\u0431\u043B\u0430\u043D
      \u0442\u0430 \u0442\u0440\u0438 \u043F\u0440\u0430\u043F\u043E\u0440\u0438
      \u0443 \u0441\u0432\u043E\u0454\u043C\u0443 \u0437\u043E\u0448\u0438\u0442\u0456!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "\u0411\u0430\u0447\u0443, \u0443 \u0442\u0435\u0431\u0435 \u0454
      \u0440\u044E\u043A\u0437\u0430\u043A. \u0422\u0435\u043F\u0435\u0440 \u043C\u043E\u0436\u0435\u0448
      \u0439\u0442\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: "\u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u043F\u0456\u0434\u043D\u0456\u043C\u0435\u043C\u043E\u0441\u044F
      \u043D\u0430 \u041C\u043E\u043D\u0431\u043B\u0430\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u0443\u0441\u0435
      \u0441\u043F\u043E\u0440\u044F\u0434\u0436\u0435\u043D\u043D\u044F \u0434\u043B\u044F
      \u0441\u043A\u0435\u043B\u0435\u043B\u0430\u0437\u0456\u043D\u043D\u044F \u0442\u0430
      \u0434\u0456\u0437\u043D\u0430\u0439\u0442\u0435\u0441\u044F \u043F\u0440\u043E
      \u0442\u0440\u0438 \u0441\u0443\u0441\u0456\u0434\u043D\u0456 \u043A\u0440\u0430\u0457\u043D\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: "\u041F\u043E\u0432\u0435\u0440\u043D\u0438\u0441\u044F, \u043A\u043E\u043B\u0438
      \u0437\u0430\u043A\u0456\u043D\u0447\u0438\u0448 \u0437\u0430\u0432\u0434\u0430\u043D\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "\u0414\u043E\u043F\u043E\u043C\u043E\u0436\u0456\u0442\u044C! \u042F
      \u0433\u0456\u0440\u0441\u044C\u043A\u0438\u0439 \u0433\u0456\u0434. \u0421\u0438\u043D\u0456\u0439
      \u0441\u043E\u0431\u0430\u043A\u0430 \u0437\u0430\u0431\u0440\u0430\u0432 \u043D\u0430\u0448\u0435
      \u0430\u043B\u044C\u043F\u0456\u043D\u0456\u0441\u0442\u0441\u044C\u043A\u0435
      \u0441\u043F\u043E\u0440\u044F\u0434\u0436\u0435\u043D\u043D\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: "\u041C\u0438 \u0431\u0430\u0447\u0438\u043B\u0438, \u044F\u043A
      \u0441\u043E\u0431\u0430\u043A\u0430 \u0431\u0456\u0433 \u043D\u0430 \u0433\u043E\u0440\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "\u0411\u0443\u0434\u044C \u043B\u0430\u0441\u043A\u0430, \u0434\u043E\u0441\u043B\u0456\u0434\u0456\u0442\u044C
      \u041C\u043E\u043D\u0431\u043B\u0430\u043D \u0442\u0430 \u0437\u043D\u0430\u0439\u0434\u0456\u0442\u044C
      \u043D\u0430\u0448\u0435 \u0441\u043F\u043E\u0440\u044F\u0434\u0436\u0435\u043D\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "\u041F\u0435\u0440\u0448 \u043D\u0456\u0436 \u0432\u0438\u0440\u0443\u0448\u0430\u0442\u0438,
      \u0432\u0430\u043C \u0437\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F
      \u0440\u044E\u043A\u0437\u0430\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: "\u0428\u0443\u043A\u0430\u0439 \u043D\u0430\u0432\u043A\u043E\u043B\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0432\u0430\u0454\u0442\u044C\u0441\u044F!
      \u0423 \u043D\u044C\u043E\u043C\u0443 \u0440\u044E\u043A\u0437\u0430\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "\u0412\u043E\u043D\u043E \u0437\u0430\u043C\u043A\u043D\u0435\u043D\u0435.
      \u041C\u043E\u0436\u043B\u0438\u0432\u043E, \u0442\u043E\u0431\u0456 \u043F\u043E\u0442\u0440\u0456\u0431\u0435\u043D
      \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "\u0426\u0435\u0439 \u0440\u044E\u043A\u0437\u0430\u043A \u043C\u043E\u0436\u0435
      \u043C\u0456\u0441\u0442\u0438\u0442\u0438 \u0457\u0436\u0443, \u0432\u043E\u0434\u0443
      \u0442\u0430 \u043A\u0430\u0440\u0442\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "\u0422\u0435\u043F\u0435\u0440 \u043C\u0438 \u043C\u043E\u0436\u0435\u043C\u043E
      \u0432\u0438\u0439\u0442\u0438 \u0437 \u0431\u0430\u0437\u043E\u0432\u043E\u0433\u043E
      \u0442\u0430\u0431\u043E\u0440\u0443 \u0442\u0430 \u0440\u043E\u0437\u043F\u043E\u0447\u0430\u0442\u0438
      \u043F\u0440\u0438\u0433\u043E\u0434\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "\u0422\u0435\u043F\u0435\u0440 \u0432\u0438 \u0433\u043E\u0442\u043E\u0432\u0456
      \u0434\u043E \u0441\u0445\u043E\u0434\u0436\u0435\u043D\u043D\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "\u042F\u043A\u0449\u043E \u0432\u0438 \u0437\u0430\u0441\u0442\u0440\u044F\u0433\u043B\u0438,
      \u0441\u043D\u0456\u0433\u043E\u0432\u0438\u043A \u043C\u043E\u0436\u0435 \u0434\u043E\u043F\u043E\u043C\u043E\u0433\u0442\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: "\u0422\u043E\u0431\u0456 \u043D\u0435 \u0432\u0438\u0441\u0442\u0430\u0447\u0430\u0454
      \u043F\u0430\u043B\u044C\u0442\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "\u0412\u0456\u0442\u0435\u0440 \u043F\u043E\u0447\u0438\u043D\u0430\u0454
      \u0434\u0443\u0442\u0438. \u041C\u043E\u0457 \u0432\u0443\u0445\u0430 \u043F\u043E\u0442\u0440\u0435\u0431\u0443\u044E\u0442\u044C
      \u0437\u0430\u0445\u0438\u0441\u0442\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "\u042F\u043A \u0437\u0430\u0445\u0438\u0441\u0442\u0438\u0442\u0438
      \u0432\u0443\u0445\u0430, \u043A\u043E\u043B\u0438 \u0441\u0438\u043B\u044C\u043D\u0438\u0439
      \u0432\u0456\u0442\u0435\u0440?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0439 \u0441\u043A\u0440\u0438\u043D\u044E,
      \u0449\u043E\u0431 \u0434\u0456\u0441\u0442\u0430\u0442\u0438 \u0442\u0435\u043F\u043B\u0443
      \u0448\u0430\u043F\u043A\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0432\u0430\u0454\u0442\u044C\u0441\u044F!
      \u0422\u0430\u043C \u0454 \u0434\u0435\u044F\u043A\u0435 \u043E\u0431\u043B\u0430\u0434\u043D\u0430\u043D\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: "\u0426\u0435 \u043F\u0430\u043B\u044C\u0442\u043E \u0437\u0456\u0433\u0440\u0456\u0454
      \u0432\u0430\u0441 \u0443 \u0432\u0456\u0442\u0435\u0440 \u0442\u0430 \u0441\u043D\u0456\u0433."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: "\u0422\u0435\u043F\u043B\u0430 \u0448\u0430\u043F\u043A\u0430 \u0437\u0456\u0433\u0440\u0456\u0454
      \u0432\u0430\u0448\u0443 \u0433\u043E\u043B\u043E\u0432\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: "\u0426\u0435 \u0442\u0430\u043A\u043E\u0436 \u0434\u043E\u043F\u043E\u043C\u0430\u0433\u0430\u0454,
      \u043A\u043E\u043B\u0438 \u0434\u043C\u0435 \u0445\u043E\u043B\u043E\u0434\u043D\u0438\u0439
      \u0432\u0456\u0442\u0435\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "\u0422\u0435\u043F\u0435\u0440 \u043C\u043E\u0436\u043D\u0430 \u043F\u0440\u043E\u0434\u043E\u0432\u0436\u0443\u0432\u0430\u0442\u0438
      \u043F\u0456\u0434\u0439\u043E\u043C!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "\u042F\u043A\u0449\u043E \u0432\u0438 \u0437\u0430\u0441\u0442\u0440\u044F\u0433\u043D\u0435\u0442\u0435,
      \u0441\u043D\u0456\u0433\u043E\u0432\u0438\u043A \u043C\u043E\u0436\u0435 \u0434\u043E\u043F\u043E\u043C\u043E\u0433\u0442\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: "\u0422\u043E\u0431\u0456 \u0431\u0440\u0430\u043A\u0443\u0454 \u0440\u0443\u043A\u0430\u0432\u0438\u0447\u043E\u043A!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "\u0421\u043E\u043D\u0446\u0435 \u043D\u0430 \u0441\u043D\u0456\u0433\u0443
      \u0434\u0443\u0436\u0435 \u044F\u0441\u043A\u0440\u0430\u0432\u0435. \u041D\u0430\u043C
      \u043F\u043E\u0442\u0440\u0456\u0431\u0435\u043D \u0437\u0430\u0445\u0438\u0441\u0442
      \u0434\u043B\u044F \u043E\u0447\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "\u0429\u043E \u0437\u0430\u0445\u0438\u0449\u0430\u0454 \u0432\u0430\u0448\u0456
      \u043E\u0447\u0456 \u0432\u0456\u0434 \u044F\u0441\u043A\u0440\u0430\u0432\u043E\u0433\u043E
      \u0441\u043D\u0456\u0433\u0443 \u0442\u0430 \u0441\u043E\u043D\u0446\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "\u041F\u0440\u043E\u0434\u043E\u0432\u0436\u0443\u0439\u0442\u0435
      \u0448\u0443\u043A\u0430\u0442\u0438. \u041D\u0430\u043C \u0432\u0441\u0435
      \u0449\u0435 \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u0435 \u0432\u0441\u0435
      \u0441\u043F\u043E\u0440\u044F\u0434\u0436\u0435\u043D\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0439 \u0441\u043A\u0440\u0438\u043D\u044E,
      \u0449\u043E\u0431 \u0434\u0456\u0441\u0442\u0430\u0442\u0438 \u0441\u043E\u043D\u0446\u0435\u0437\u0430\u0445\u0438\u0441\u043D\u0456
      \u043E\u043A\u0443\u043B\u044F\u0440\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0432\u0430\u0454\u0442\u044C\u0441\u044F!
      \u0412\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0456 \u0454 \u0441\u043E\u043D\u0446\u0435\u0437\u0430\u0445\u0438\u0441\u043D\u0456
      \u043E\u043A\u0443\u043B\u044F\u0440\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: "\u0420\u0443\u043A\u0430\u0432\u0438\u0447\u043A\u0438 \u0437\u0431\u0435\u0440\u0456\u0433\u0430\u044E\u0442\u044C
      \u043F\u0430\u043B\u044C\u0446\u0456 \u0442\u0435\u043F\u043B\u0438\u043C\u0438
      \u0442\u0430 \u0441\u0443\u0445\u0438\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "\u0425\u043E\u043B\u043E\u0434\u043D\u0456 \u0440\u0443\u043A\u0438
      \u0443\u0441\u043A\u043B\u0430\u0434\u043D\u044E\u044E\u0442\u044C \u0441\u043A\u0435\u043B\u0435\u043B\u0430\u0437\u0456\u043D\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: "\u0421\u043D\u0456\u0433 \u0456 \u043B\u0456\u0434 \u0432\u0456\u0434\u0431\u0438\u0432\u0430\u044E\u0442\u044C
      \u044F\u0441\u043A\u0440\u0430\u0432\u0435 \u0441\u043E\u043D\u044F\u0447\u043D\u0435
      \u0441\u0432\u0456\u0442\u043B\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "\u0421\u043E\u043D\u044F\u0447\u043D\u0456 \u043E\u043A\u0443\u043B\u044F\u0440\u0438
      \u0437\u0430\u0445\u0438\u0449\u0430\u044E\u0442\u044C \u0432\u0430\u0448\u0456
      \u043E\u0447\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "\u0423 \u0432\u0430\u0441 \u0454 \u043B\u044C\u043E\u0434\u043E\u0432\u0435
      \u0441\u043F\u043E\u0440\u044F\u0434\u0436\u0435\u043D\u043D\u044F. \u041E\u0441\u0442\u0430\u043D\u043D\u0456\u0439
      \u043F\u043E\u0448\u0442\u043E\u0432\u0445 \u0434\u043E \u0432\u0435\u0440\u0448\u0438\u043D\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: "\u0422\u043E\u0431\u0456 \u0431\u0440\u0430\u043A\u0443\u0454 \u043C\u043E\u0442\u0443\u0437\u043A\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "\u0429\u043E\u0431 \u0445\u043E\u0434\u0438\u0442\u0438 \u043F\u043E
      \u043B\u044C\u043E\u0434\u043E\u0432\u0438\u043A\u043E\u0432\u043E\u043C\u0443
      \u043B\u044C\u043E\u0434\u0443, \u043D\u0430\u043C \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u0435
      \u0441\u043F\u0435\u0446\u0456\u0430\u043B\u044C\u043D\u0435 \u0441\u043F\u043E\u0440\u044F\u0434\u0436\u0435\u043D\u043D\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "\u0429\u043E \u043E\u0434\u044F\u0433\u0430\u0442\u0438 \u043D\u0430
      \u0447\u0435\u0440\u0435\u0432\u0438\u043A\u0438, \u0449\u043E\u0431 \u0445\u043E\u0434\u0438\u0442\u0438
      \u043F\u043E \u043B\u044C\u043E\u0434\u0443 \u0456 \u043D\u0435 \u043A\u043E\u0432\u0437\u0430\u0442\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: "\u041A\u0440\u0430\u043C\u043F\u043E\u043D\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "\u041F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E! \u0412\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0439\u0442\u0435
      \u0457\u0445, \u0449\u043E\u0431 \u0437\u0430\u043B\u0438\u0448\u0430\u0442\u0438\u0441\u044F
      \u043D\u0430 \u043C\u0456\u0441\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: "\u041B\u0430\u0441\u0442\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "\u041D\u0456! \u0422\u0438 \u043D\u0435 \u043F\u043B\u0430\u0432\u0430\u0454\u0448!
      \u0421\u043F\u0440\u043E\u0431\u0443\u0439 \u0449\u0435 \u0440\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0439 \u0441\u043A\u0440\u0438\u043D\u044E,
      \u0449\u043E\u0431 \u0434\u0456\u0441\u0442\u0430\u0442\u0438 \u043A\u0456\u0448\u043A\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: "\u0412\u043E\u043D\u0438 \u0434\u043E\u043F\u043E\u043C\u043E\u0436\u0443\u0442\u044C
      \u0432\u0430\u043C \u0431\u0435\u0437\u043F\u0435\u0447\u043D\u043E \u0445\u043E\u0434\u0438\u0442\u0438
      \u043F\u043E \u043B\u044C\u043E\u0434\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: "\u041C\u043E\u0442\u0443\u0437\u043A\u0430 \u0434\u043E\u043F\u043E\u043C\u0430\u0433\u0430\u0454
      \u0430\u043B\u044C\u043F\u0456\u043D\u0456\u0441\u0442\u0430\u043C \u0437\u0430\u043B\u0438\u0448\u0430\u0442\u0438\u0441\u044F
      \u0432 \u0431\u0435\u0437\u043F\u0435\u0446\u0456 \u043D\u0430 \u043B\u044C\u043E\u0434\u0443
      \u0442\u0430 \u0441\u043A\u0435\u043B\u044F\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: "\u0412\u0438 \u0432\u043F\u043E\u0440\u0430\u043B\u0438\u0441\u044F!
      \u041C\u0438 \u043D\u0430 \u0432\u0435\u0440\u0448\u0438\u043D\u0456 \u041C\u043E\u043D\u0431\u043B\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: "\u0426\u044F \u0432\u0435\u0440\u0448\u0438\u043D\u0430 \u043C\u0430\u0454
      \u0432\u0438\u0441\u043E\u0442\u0443 4807 \u043C\u0435\u0442\u0440\u0456\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: "\u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u043C\u043E
      \u043D\u0430 \u0442\u0440\u0438 \u0433\u0456\u0440\u0441\u044C\u043A\u0456
      \u0437\u0430\u043F\u0438\u0442\u0430\u043D\u043D\u044F \u043F\u0435\u0440\u0435\u0434
      \u0433\u0440\u043E\u044E \u0437 \u043F\u0440\u0430\u043F\u043E\u0440\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "\u0423 \u044F\u043A\u043E\u043C\u0443 \u0433\u0456\u0440\u0441\u044C\u043A\u043E\u043C\u0443
      \u0445\u0440\u0435\u0431\u0442\u0456 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u041C\u043E\u043D\u0431\u043B\u0430\u043D?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: "\u0410\u043B\u044C\u043F\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: "\u041F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: "\u041F\u0456\u0440\u0435\u043D\u0435\u0457"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: "\u041D\u0435 \u0437\u043E\u0432\u0441\u0456\u043C. \u0421\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
      \u0449\u0435 \u0440\u0430\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: "\u0410\u043F\u0435\u043D\u043D\u0456\u043D\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: "\u042F\u043A\u0430 \u0432\u0438\u0441\u043E\u0442\u0430 \u041C\u043E\u043D\u0431\u043B\u0430\u043D\u0443?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: "4807 \u043C\u0435\u0442\u0440\u0456\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: "3705 \u043C\u0435\u0442\u0440\u0456\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: "5016 \u043C\u0435\u0442\u0440\u0456\u0432"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: "\u042F\u043A\u0456 \u043A\u0440\u0430\u0457\u043D\u0438 \u043C\u043E\u0436\u043D\u0430
      \u043F\u043E\u0431\u0430\u0447\u0438\u0442\u0438 \u0437\u0432\u0456\u0434\u0441\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: "\u0424\u0440\u0430\u043D\u0446\u0456\u044F, \u0406\u0442\u0430\u043B\u0456\u044F
      \u0442\u0430 \u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0456\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: "\u041F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E! \u0414\u0430\u0432\u0430\u0439\u0442\u0435
      \u0440\u043E\u0437\u043C\u0456\u0441\u0442\u0438\u043C\u043E \u043F\u0440\u0430\u043F\u043E\u0440\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: "\u0424\u0440\u0430\u043D\u0446\u0456\u044F, \u0406\u0441\u043F\u0430\u043D\u0456\u044F
      \u0442\u0430 \u041D\u0456\u043C\u0435\u0447\u0447\u0438\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: "\u041D\u0435 \u0437\u043E\u0432\u0441\u0456\u043C. \u0426\u0435
      \u0442\u0440\u043E\u0445\u0438 \u0437\u0430\u043D\u0430\u0434\u0442\u043E \u0434\u0430\u043B\u0435\u043A\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: "\u0424\u0440\u0430\u043D\u0446\u0456\u044F \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u043D\u0430 \u0437\u0430\u0445\u0456\u0434 \u0432\u0456\u0434 \u041C\u043E\u043D\u0431\u043B\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: "\u0406\u0442\u0430\u043B\u0456\u044F \u0440\u043E\u0437\u0442\u0430\u0448\u043E\u0432\u0430\u043D\u0430
      \u043D\u0430 \u0441\u0445\u0456\u0434 \u0432\u0456\u0434 \u041C\u043E\u043D\u0431\u043B\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: "\u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0456\u044F \u0440\u043E\u0437\u0442\u0430\u0448\u043E\u0432\u0430\u043D\u0430
      \u043D\u0430 \u043F\u0456\u0432\u043D\u0456\u0447 \u0432\u0456\u0434 \u041C\u043E\u043D\u0431\u043B\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: "\u0422\u043E\u0431\u0456 \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u0430
      \u0434\u043E\u043F\u043E\u043C\u043E\u0433\u0430, \u0449\u043E\u0431 \u043F\u0456\u0434\u043D\u044F\u0442\u0438\u0441\u044F
      \u043D\u0430 \u0433\u043E\u0440\u0443?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: "\u0422\u0430\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: "\u0411\u0430\u0437\u043E\u0432\u0438\u0439 \u0442\u0430\u0431\u0456\u0440
      1"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: "\u0411\u0430\u0437\u043E\u0432\u0438\u0439 \u0442\u0430\u0431\u0456\u0440
      2"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: "\u0411\u0430\u0437\u043E\u0432\u0438\u0439 \u0442\u0430\u0431\u0456\u0440
      3"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: "\u0411\u0430\u0437\u043E\u0432\u0438\u0439 \u0442\u0430\u0431\u0456\u0440
      4"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: "\u041D\u0456, \u044F \u0437\u0430\u043B\u0438\u0448\u0430\u044E\u0441\u044F
      \u0442\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: "\u042F \u0441\u043F\u043B\u044E \u0432\u0441\u044E \u0437\u0438\u043C\u0443
      \u043F\u0456\u0434 \u0441\u043D\u0456\u0433\u043E\u043C. \u0426\u0435 \u043D\u0430\u0437\u0438\u0432\u0430\u0454\u0442\u044C\u0441\u044F
      \u0437\u0438\u043C\u043E\u0432\u0430 \u0441\u043F\u043B\u044F\u0447\u043A\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: "\u042F \u043B\u044E\u0431\u043B\u044E \u0457\u0441\u0442\u0438
      \u0430\u043B\u044C\u043F\u0456\u0439\u0441\u044C\u043A\u0456 \u043A\u0432\u0456\u0442\u0438
      \u0442\u0430 \u0442\u0440\u0430\u0432\u0443. \u041D\u044F\u043C!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: "\u041D\u0435 \u0437\u0432\u0435\u0440\u0442\u0430\u0439\u0442\u0435
      \u043D\u0430 \u043C\u0435\u043D\u0435 \u0443\u0432\u0430\u0433\u0438, \u044F
      \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u0441\u043C\u0430\u0433\u0430\u044E
      \u043D\u0430 \u0446\u044C\u043E\u043C\u0443 \u0442\u0435\u043F\u043B\u043E\u043C\u0443
      \u043A\u0430\u043C\u0435\u043D\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: "\u0422\u0438 \u0437\u043D\u0430\u0439\u0448\u043E\u0432 \u0442\u0435\u043F\u043B\u0438\u0439
      \u0448\u0430\u0440\u0444!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: "\u0428\u0430\u0440\u0444 \u0431\u043B\u043E\u043A\u0443\u0454 \u0432\u0456\u0442\u0435\u0440
      \u043D\u0430 \u0432\u0430\u0448\u0456\u0439 \u0448\u0438\u0457."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: "\u042F \u043B\u044E\u0431\u043B\u044E \u0433\u043E\u0440\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: "\u041C\u043E\u043D\u0431\u043B\u0430\u043D \u2014 \u043D\u0430\u0439\u0432\u0438\u0449\u0430
      \u0433\u043E\u0440\u0430 \u0432 \u0410\u043B\u044C\u043F\u0430\u0445!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: "\u0421\u043F\u043E\u0434\u0456\u0432\u0430\u044E\u0441\u044F \u043F\u043E\u0431\u0430\u0447\u0438\u0442\u0438
      \u0431\u0430\u0431\u0430\u043A\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: "\u041D\u0435 \u0437\u0430\u0431\u0443\u0434\u044C\u0442\u0435 \u0432\u0437\u044F\u0442\u0438
      \u0442\u0435\u043F\u043B\u0438\u0439 \u043E\u0434\u044F\u0433!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "\u0413\u043E\u0440\u0438 \u043C\u043E\u0436\u0443\u0442\u044C \u0431\u0443\u0442\u0438
      \u043D\u0435\u0431\u0435\u0437\u043F\u0435\u0447\u043D\u0438\u043C\u0438, \u0442\u043E\u0436
      \u0431\u0443\u0434\u044C\u0442\u0435 \u043E\u0431\u0435\u0440\u0435\u0436\u043D\u0456!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "\u0414\u043B\u044F \u043F\u043E\u0445\u043E\u0434\u0456\u0432 \u0442\u0443\u0442
      \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u0456 \u0433\u0430\u0440\u043D\u0456
      \u0447\u0435\u0440\u0435\u0432\u0438\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: "\u0412\u0456\u0442\u0435\u0440 \u043C\u043E\u0436\u0435 \u0448\u0432\u0438\u0434\u043A\u043E
      \u0437\u043C\u0456\u043D\u044E\u0432\u0430\u0442\u0438\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: "\u042F \u0439\u0434\u0443 \u043F\u043E \u043C\u043E\u0442\u0443\u0437\u0446\u0456,
      \u043A\u043E\u043B\u0438 \u043E\u0436\u0435\u043B\u0435\u0434\u0438\u0446\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: "\u0422\u043E\u0439 \u043B\u044C\u043E\u0434\u043E\u0432\u0438\u043A
      \u0441\u0445\u043E\u0436\u0438\u0439 \u043D\u0430 \u0437\u0430\u043C\u0435\u0440\u0437\u043B\u0443
      \u0440\u0456\u0447\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: "\u042F \u043B\u044E\u0431\u043B\u044E \u0441\u043A\u0435\u043B\u0435\u043B\u0430\u0437\u0456\u043D\u043D\u044F
      \u0432 \u0410\u043B\u044C\u043F\u0430\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: "\u041A\u0456\u0448\u043A\u0438 \u0434\u043E\u043F\u043E\u043C\u0430\u0433\u0430\u044E\u0442\u044C
      \u043C\u0435\u043D\u0456 \u0445\u043E\u0434\u0438\u0442\u0438 \u043F\u043E
      \u0442\u0432\u0435\u0440\u0434\u043E\u043C\u0443 \u043B\u044C\u043E\u0434\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: "\u0421\u0445\u043E\u0434\u0436\u0435\u043D\u043D\u044F \u0437 \u0433\u0456\u0434\u043E\u043C
      \u0431\u0435\u0437\u043F\u0435\u0447\u043D\u0456\u0448\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173380
    m_Localized: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E"
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173381
    m_Localized: "\u041F\u043E\u0432\u0435\u0440\u0442\u0430\u0439\u0441\u044F \u043F\u0456\u0437\u043D\u0456\u0448\u0435!"
