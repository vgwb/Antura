--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 164361134080
    m_Localized: the highest mountain in Europe
    m_Metadata:
      m_Items: []
  - m_Id: 164365328384
    m_Localized: and put the 3 flags correctly
    m_Metadata:
      m_Items: []
  - m_Id: 164365328385
    m_Localized: Find the French flag.
    m_Metadata:
      m_Items: []
  - m_Id: 164365328386
    m_Localized: Find the Italian flag.
    m_Metadata:
      m_Items: []
  - m_Id: 164365328387
    m_Localized: Find the Swiss flag.
    m_Metadata:
      m_Items: []
  - m_Id: 1506273043406848
    m_Localized: You have to go up the Mont Blanc
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102208
    m_Localized: The game is complete! Congratulations!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102209
    m_Localized: Did you like it?
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102210
    m_Localized: Now draw your favourite mountain?
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102211
    m_Localized: I love the mountains!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102212
    m_Localized: The Alps are beautiful!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102213
    m_Localized: Mont Blanc is the highest mountain in Europe!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102214
    m_Localized: I want to climb Mont Blanc one day!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102215
    m_Localized: I hope to see a marmot!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102216
    m_Localized: The view from the summit must be amazing!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102217
    m_Localized: Don't forget to bring warm clothes!
    m_Metadata:
      m_Items: []
  - m_Id: 2247271147102218
    m_Localized: Mountains can be dangerous, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2283290420568064
    m_Localized: Now draw your favourite mountain?
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707042
    m_Localized: Climbing with a guide is safer.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707041
    m_Localized: Crampons help me on hard ice.
    m_Metadata:
      m_Items: []
  - m_Id: 2307782198943746
    m_Localized: Now draw your favourite mountain?
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707040
    m_Localized: Summit soon! I can feel the sun.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707039
    m_Localized: The Alps are my playground.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707038
    m_Localized: That glacier looks like a frozen river.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707037
    m_Localized: I follow the rope line when it is icy.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707036
    m_Localized: The wind can change fast.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707035
    m_Localized: Hiking here needs good boots.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707034
    m_Localized: Mountains can be dangerous, be careful!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707033
    m_Localized: Don't forget to bring warm clothes!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707032
    m_Localized: The view from the summit must be amazing!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707031
    m_Localized: I hope to see a marmot!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707030
    m_Localized: I want to climb Mont Blanc one day!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707029
    m_Localized: Mont Blanc is the highest mountain in Europe!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707028
    m_Localized: The Alps are beautiful!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707027
    m_Localized: I love the mountains!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707026
    m_Localized: Glasses protect your eyes.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707025
    m_Localized: Snow and ice reflect bright sun.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707024
    m_Localized: Tuck it so it will not flap.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707023
    m_Localized: A scarf blocks wind on your neck.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707022
    m_Localized: Always clip it correctly.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707021
    m_Localized: The rope helps climbers stay safe on ice and rock.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707020
    m_Localized: Wear it even in bright sun.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707019
    m_Localized: A warm hat keeps heat from leaving your head.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707018
    m_Localized: Cold hands make climbing hard.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707017
    m_Localized: Gloves keep fingers warm and dry.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707016
    m_Localized: Always zip it up high.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707015
    m_Localized: This coat keeps your body warm in wind and snow.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707014
    m_Localized: It keeps hands free while hiking.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707013
    m_Localized: This backpack carries food, water and a map.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707012
    m_Localized: Why don't you draw Mont Blanc with the three flags.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707011
    m_Localized: Brave mountain explorer!
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707010
    m_Localized: You got ready with warm gear.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707009
    m_Localized: You placed all three flags.
    m_Metadata:
      m_Items: []
  - m_Id: 2382741713707008
    m_Localized: You reached Mont Blanc and learned summit facts!
    m_Metadata:
      m_Items: []
  - m_Id: 8769525095849984
    m_Localized: Welcome to the Mont Blanc!
    m_Metadata:
      m_Items: []
  - m_Id: 64215225064787968
    m_Localized: Welcome to the Mont Blanc!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922976743424
    m_Localized: Welcome to the French Alps!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714944
    m_Localized: Today we climb Mont Blanc, the highest mountain in Western Europe.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714945
    m_Localized: Amazing! You reached the summit of Mont Blanc at 4807m!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714946
    m_Localized: You braved the wind, the snow, and the ice.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714947
    m_Localized: Draw a snowy mountain in your notebook!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714948
    m_Localized: You are ready for the summit!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714949
    m_Localized: Keep climbing! The air is getting colder.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714950
    m_Localized: Help! I am a mountain guide, but a blue dog took our climbing gear!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714951
    m_Localized: The gear is scattered at different bases up the mountain.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714952
    m_Localized: Can you find all 7 items so we can reach the top?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714953
    m_Localized: You found all the gear!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714954
    m_Localized: Meet me at the summit!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714955
    m_Localized: The wind is starting to blow. It is cold!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714956
    m_Localized: How do we stay warm when the wind is strong?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714957
    m_Localized: Wear a thick coat
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714958
    m_Localized: Yes! Open the chest to get the gear.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714959
    m_Localized: Wear a swimsuit
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714960
    m_Localized: No, you would freeze! Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714961
    m_Localized: You look much warmer now!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714962
    m_Localized: Solve the puzzle to open the chest!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714963
    m_Localized: You found the Coat and the Scarf!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714964
    m_Localized: Look at all this snow! People love to ski here.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714965
    m_Localized: Which parts of your body get cold first in the snow?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714966
    m_Localized: Hands and head
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714967
    m_Localized: Correct! You need protection.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714968
    m_Localized: Your elbows
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714969
    m_Localized: Not usually! Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714970
    m_Localized: Enjoy the snow!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714971
    m_Localized: Solve the puzzle to reach the gear!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714972
    m_Localized: You found the Gloves and the Hat!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714973
    m_Localized: We are walking on a glacier! It is a river of ice.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714974
    m_Localized: The sun is very bright on the white ice. What do you need?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714975
    m_Localized: Sunglasses and Crampons
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714976
    m_Localized: Yes! Sunglasses for your eyes and crampons for the ice.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714977
    m_Localized: An umbrella
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714978
    m_Localized: That won't help you walk on ice! Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714979
    m_Localized: The view is beautiful, isn't it?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714980
    m_Localized: Open the chest with this activity!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714981
    m_Localized: You found the Sunglasses and the Crampons!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714982
    m_Localized: Almost at the summit! The path is steep.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714983
    m_Localized: Climbers use this to stay safe and connected. What is it?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714984
    m_Localized: A strong rope
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714985
    m_Localized: Perfect! This is the last piece.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714986
    m_Localized: A piece of string
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714987
    m_Localized: Too weak! Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714988
    m_Localized: See you at the top!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714989
    m_Localized: Last puzzle before the peak!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714990
    m_Localized: You found the Rope!
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714991
    m_Localized: We are at 4807 meters! Look at the view.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714992
    m_Localized: Which countries can you see from here?
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714993
    m_Localized: France, Italy, and Switzerland
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714994
    m_Localized: Correct! Let's place the flags.
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714995
    m_Localized: France, Spain, and Germany
    m_Metadata:
      m_Items: []
  - m_Id: 68247922997714996
    m_Localized: Not quite. Those are a bit too far!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
