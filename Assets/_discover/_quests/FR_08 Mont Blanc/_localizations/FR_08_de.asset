--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_de
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "Willkommen in den franz\xF6sischen Alpen!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "Heute besteigen wir den Mont Blanc. Er ist der h\xF6chste Berg
      der Alpen."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: Wahnsinn! Du hast den Gipfel des Mont Blanc erreicht. Er ist 4807
      Meter hoch!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "Die Alpen sind voller hoher, wundersch\xF6ner Berge."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: Zeichne den Mont Blanc und die drei Flaggen in dein Notizbuch!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: Ich sehe, du hast den Rucksack. Jetzt kannst du gehen!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: Lasst uns den Mont Blanc besteigen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "Finde die gesamte Kletterausr\xFCstung und lerne die drei Nachbarl\xE4nder
      kennen!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: Komm wieder, wenn du die Aufgabe erledigt hast.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "Hilfe! Ich bin Bergf\xFChrer. Ein blauer Hund hat unsere Kletterausr\xFCstung
      gestohlen!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: Wir sahen den Hund den Berg hinauflaufen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "Erkunden Sie Mont Blanc und entdecken Sie unsere Ausr\xFCstung."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "Bevor du losf\xE4hrst, brauchst du einen Rucksack."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: Halte danach Ausschau!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "Es l\xE4sst sich \xF6ffnen! Darin befindet sich ein Rucksack."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "Es ist verschlossen. Vielleicht brauchen Sie einen Schl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "Dieser Rucksack bietet Platz f\xFCr Essen, Wasser und eine Karte."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "Jetzt k\xF6nnen wir das Basislager verlassen und das Abenteuer
      beginnen!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: Du bist nun bereit zum Klettern!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: Wenn du nicht weiterkommst, kann dir der Schneemann helfen!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: Dir fehlt der Mantel!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: Der Wind frischt auf. Meine Ohren brauchen Schutz!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "Wie k\xF6nnen wir unsere Ohren bei starkem Wind sch\xFCtzen?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "\xD6ffne die Truhe, um eine warme M\xFCtze zu erhalten!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "Es \xF6ffnet sich! Es enth\xE4lt einige Ausr\xFCstungsgegenst\xE4nde."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: "Dieser Mantel h\xE4lt Sie bei Wind und Schnee warm."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: "Eine warme M\xFCtze h\xE4lt den Kopf warm."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: Es hilft auch bei kaltem Wind.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "Nun k\xF6nnen Sie den Aufstieg fortsetzen!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: Wenn du nicht weiterkommst, kann dir der Schneemann helfen!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: Du hast die Handschuhe vergessen!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: Die Sonne scheint sehr hell auf den Schnee. Wir brauchen einen Augenschutz.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "Was sch\xFCtzt Ihre Augen vor hellem Schnee und Sonnenschein?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "Sucht weiter. Wir brauchen noch die gesamte Ausr\xFCstung."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "\xD6ffne die Truhe, um eine Sonnenbrille zu erhalten!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "Es l\xE4sst sich \xF6ffnen! Darin befindet sich eine Sonnenbrille."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: Handschuhe halten die Finger warm und trocken.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "Kalte H\xE4nde erschweren das Klettern."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: Schnee und Eis reflektieren helles Sonnenlicht.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "Sonnenbrillen sch\xFCtzen Ihre Augen."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "Du hast die Eisausr\xFCstung. Nur noch ein letzter Kraftakt bis
      zum Gipfel!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: Dir fehlt das Seil!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "Um auf Gletschereis zu laufen, ben\xF6tigen wir spezielle Ausr\xFCstung."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "Was zieht man an seine Stiefel, um auf Eis laufen zu k\xF6nnen
      und nicht auszurutschen?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: Steigeisen
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: Richtig! Benutze sie, um das Gleichgewicht zu halten.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: Flipper
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: Nein! Du schwimmst nicht! Versuch es noch einmal.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "\xD6ffne die Truhe, um Steigeisen zu erhalten!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: Diese helfen Ihnen, sicher auf Eis zu gehen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: Das Seil hilft Kletterern, auf Eis und Fels sicher zu bleiben.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: Du hast es geschafft! Wir sind auf dem Gipfel des Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: Dieser Gipfel ist 4807 Meter hoch.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: Lasst uns vor dem Flaggenspiel drei Fragen zum Thema Berge beantworten.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "Zu welchem \u200B\u200BGebirge geh\xF6rt der Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: Die Alpen
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: Richtig!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: "Die Pyren\xE4en"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: Nicht ganz. Versuchen Sie es noch einmal.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: Die Apenninen
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: Wie hoch ist der Mont Blanc?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: 4807 Meter
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: 3705 Meter
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: 5016 Meter
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: "Welche L\xE4nder kann man von hier aus sehen?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: Frankreich, Italien und die Schweiz
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: Richtig! Platzieren wir die Flaggen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: Frankreich, Spanien und Deutschland
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: Nicht ganz. Die sind ein bisschen zu weit weg!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: Frankreich liegt westlich des Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: "Italien liegt \xF6stlich des Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: "Die Schweiz liegt n\xF6rdlich des Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: "Ben\xF6tigen Sie Hilfe beim Besteigen des Berges?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: Ja
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: Basislager 1
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: Basislager 2
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: Basislager 3
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: Basislager 4
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: Nein, ich bleibe hier.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: Ich schlafe den ganzen Winter unter dem Schnee. Das nennt man Winterschlaf!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: "Ich esse unheimlich gerne Alpenblumen und Gr\xE4ser. Lecker!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: Beachtet mich nicht, ich sonne mich nur auf diesem warmen Felsen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: Du hast einen warmen Schal gefunden!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: "Ein Schal sch\xFCtzt Ihren Nacken vor Wind."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: Ich liebe die Berge!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: "Der Mont Blanc ist der h\xF6chste Berg der Alpen!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: Ich hoffe, ein Murmeltier zu sehen!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: Vergessen Sie nicht, warme Kleidung mitzubringen!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "Gebirge k\xF6nnen gef\xE4hrlich sein, also seid vorsichtig!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "Zum Wandern hier ben\xF6tigt man gute Wanderschuhe."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: Der Wind kann schnell drehen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: Bei Eis folge ich der Absperrung.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: Dieser Gletscher sieht aus wie ein zugefrorener Fluss.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: Ich liebe das Klettern in den Alpen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: Steigeisen helfen mir, auf hartem Eis zu gehen.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: "Klettern mit einem Bergf\xFChrer ist sicherer."
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173380
    m_Localized: "Ich wei\xDF nicht"
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173381
    m_Localized: "Komm sp\xE4ter wieder!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
