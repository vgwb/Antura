%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_pl
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: pl
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: Witamy w Alpach Francuskich!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: "Dzisiaj wspinamy si\u0119 na Mont Blanc. To najwy\u017Cszy szczyt
      Alp."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "Niesamowite! Dotar\u0142e\u015B na szczyt Mont Blanc. Ma 4807 metr\xF3w
      wysoko\u015Bci!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: "Alpy s\u0105 pe\u0142ne wysokich, pi\u0119knych g\xF3r."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: Narysuj Mont Blanc i trzy flagi w swoim zeszycie!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "Widz\u0119, \u017Ce masz plecak. Mo\u017Cesz i\u015B\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: "Wejd\u017Amy na Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "Znajd\u017A ca\u0142y sprz\u0119t wspinaczkowy i dowiedz si\u0119
      wi\u0119cej o trzech pobliskich krajach!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: "Wr\xF3\u0107, gdy sko\u0144czysz zadanie."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "Ratunku! Jestem przewodnikiem g\xF3rskim. Niebieski pies zabra\u0142
      nasz sprz\u0119t wspinaczkowy!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: "Widzieli\u015Bmy psa wbiegaj\u0105cego na g\xF3r\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "Zapraszamy do eksploracji Mont Blanc i zapoznania si\u0119 z naszym
      sprz\u0119tem."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "Przed wyjazdem b\u0119dziesz potrzebowa\u0107 plecaka."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: "Rozejrzyj si\u0119 dooko\u0142a!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "Otwiera si\u0119! Jest w nim plecak."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "Jest zamkni\u0119te. Mo\u017Ce potrzebujesz klucza."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "W tym plecaku mo\u017Cna przenosi\u0107 jedzenie, wod\u0119 i map\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: "Teraz mo\u017Cemy opu\u015Bci\u0107 ob\xF3z bazowy i rozpocz\u0105\u0107
      przygod\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "Jeste\u015B teraz gotowy do wspinaczki!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "Je\u015Bli masz blokad\u0119, ba\u0142wan mo\u017Ce Ci pom\xF3c!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: "Brakuje Ci p\u0142aszcza!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "Zaczyna wia\u0107 wiatr. Moje uszy potrzebuj\u0105 ochrony!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "Jak chroni\u0107 uszy, gdy wieje silny wiatr?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: "Otw\xF3rz skrzyni\u0119 i wyjmij ciep\u0142\u0105 czapk\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "Otwiera si\u0119! Zawiera troch\u0119 sprz\u0119tu."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: "Ten p\u0142aszcz zapewni Ci ciep\u0142o w czasie wiatru i \u015Bniegu."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: "Ciep\u0142a czapka utrzymuje ciep\u0142o g\u0142owy."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: "Pomaga r\xF3wnie\u017C, gdy wieje zimny wiatr."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: "Teraz mo\u017Cesz kontynuowa\u0107 wspinaczk\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "Je\u015Bli utkniesz, ba\u0142wan mo\u017Ce Ci pom\xF3c!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: "Brakuje Ci r\u0119kawiczek!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "S\u0142o\u0144ce mocno \u015Bwieci na \u015Bniegu. Potrzebujemy
      ochrony oczu."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "Co chroni Twoje oczy przed jaskrawym \u015Bniegiem i s\u0142o\u0144cem?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "Szukaj dalej. Nadal potrzebujemy ca\u0142ego sprz\u0119tu."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: "Otw\xF3rz skrzyni\u0119 i wyjmij okulary przeciws\u0142oneczne!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "Otwiera si\u0119! W \u015Brodku s\u0105 okulary przeciws\u0142oneczne."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: "R\u0119kawiczki utrzymuj\u0105 palce w cieple i sucho\u015Bci."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: "Zimne r\u0119ce utrudniaj\u0105 wspinaczk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: "\u015Anieg i l\xF3d odbijaj\u0105 jasne \u015Bwiat\u0142o s\u0142oneczne."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "Okulary przeciws\u0142oneczne chroni\u0105 oczy."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "Masz sprz\u0119t lodowy. Ostatni atak na szczyt!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: Brakuje ci liny!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "Aby chodzi\u0107 po lodowcu, potrzebujemy specjalnego sprz\u0119tu."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: "Co zak\u0142adasz do but\xF3w, \u017Ceby chodzi\u0107 po lodzie
      i si\u0119 nie \u015Blizga\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: Raki
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "Dobrze! U\u017Cyj ich, \u017Ceby utrzyma\u0107 r\xF3wnowag\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: "P\u0142etwy"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "Nie! Nie p\u0142ywasz! Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: "Otw\xF3rz skrzyni\u0119, aby wyj\u0105\u0107 raki!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: "Pomagaj\u0105 bezpiecznie chodzi\u0107 po lodzie."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: "Lina pomaga wspinaczom zachowa\u0107 bezpiecze\u0144stwo na lodzie
      i ska\u0142ach."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: "Uda\u0142o si\u0119! Jeste\u015Bmy na szczycie Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: "Wysoko\u015B\u0107 tego szczytu wynosi 4807 metr\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: "Przed gr\u0105 o flag\u0119 odpowiedzmy na trzy pytania dotycz\u0105ce
      g\xF3r."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "W jakim pa\u015Bmie g\xF3rskim znajduje si\u0119 Mont Blanc?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: Alpy
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: "Prawid\u0142owy!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: Pireneje
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: "Nie do ko\u0144ca. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: Apeniny
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: Jak wysoki jest Mont Blanc?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: "4807 metr\xF3w"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: "3705 metr\xF3w"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: "5016 metr\xF3w"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: "Jakie kraje wida\u0107 st\u0105d?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: "Francja, W\u0142ochy i Szwajcaria"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: "Dobrze! Rozwie\u015Bmy flagi."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: Francja, Hiszpania i Niemcy
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: "Nie do ko\u0144ca. To troch\u0119 za daleko!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: "Francja le\u017Cy na zach\xF3d od Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: "W\u0142ochy le\u017C\u0105 na wsch\xF3d od Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: "Szwajcaria le\u017Cy na p\xF3\u0142noc od Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: "Potrzebujesz pomocy we wspi\u0119ciu si\u0119 na g\xF3r\u0119?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: Tak
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: Baza 1
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: Baza 2
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: Baza 3
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: Baza 4
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: "Nie, zostaj\u0119 tutaj"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: "Ca\u0142\u0105 zim\u0119 \u015Bpi\u0119 pod \u015Bniegiem. To si\u0119
      nazywa hibernacja!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: "Uwielbiam je\u015B\u0107 alpejskie kwiaty i traw\u0119. Pycha!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: "Nie zwracajcie na mnie uwagi, po prostu opalam si\u0119 na tej
      ciep\u0142ej skale."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: "Znalaz\u0142e\u015B ciep\u0142y szalik!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: Szalik chroni przed wiatrem na szyi.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: "Uwielbiam g\xF3ry!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: "Mont Blanc jest najwy\u017Csz\u0105 g\xF3r\u0105 w Alpach!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: "Mam nadziej\u0119 zobaczy\u0107 \u015Bwistaka!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: "Nie zapomnij zabra\u0107 ciep\u0142ych ubra\u0144!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "G\xF3ry mog\u0105 by\u0107 niebezpieczne, wi\u0119c b\u0105d\u017A
      ostro\u017Cny!"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "Do pieszych w\u0119dr\xF3wek tutaj potrzebne s\u0105 dobre buty."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: "Wiatr mo\u017Ce si\u0119 szybko zmieni\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: "Gdy jest \u015Blisko, pod\u0105\u017Cam za lin\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: "Ten lodowiec wygl\u0105da jak zamarzni\u0119ta rzeka."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: "Uwielbiam wspinaczk\u0119 w Alpach."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: "Raki pomagaj\u0105 mi chodzi\u0107 po twardym lodzie."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: Wspinaczka z przewodnikiem jest bezpieczniejsza.
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173380
    m_Localized: Nie wiem
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173381
    m_Localized: "Wr\xF3\u0107 p\xF3\u017Aniej!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
