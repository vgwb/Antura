%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_08_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: e1642aa48b6aa44aa987ba377a044cc2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 70723632840564736
    m_Localized: "Bienvenue dans les Alpes fran\xE7aises !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564737
    m_Localized: Aujourd'hui, nous gravissons le Mont Blanc. C'est le plus haut sommet
      des Alpes.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564738
    m_Localized: "Incroyable ! Vous avez atteint le sommet du Mont Blanc. Il culmine
      \xE0 4807 m\xE8tres !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564739
    m_Localized: Les Alpes regorgent de hautes et magnifiques montagnes.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564740
    m_Localized: Dessine le Mont Blanc et les trois drapeaux dans ton cahier !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564741
    m_Localized: "Je vois que tu as le sac \xE0 dos. Maintenant, tu peux y aller
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564742
    m_Localized: Escaladons le Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564743
    m_Localized: "Trouvez tout le mat\xE9riel d'escalade et d\xE9couvrez les trois
      pays voisins !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564744
    m_Localized: "Revenez lorsque vous aurez termin\xE9 la t\xE2che."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564745
    m_Localized: "Au secours ! Je suis guide de montagne. Un chien bleu a emport\xE9
      notre mat\xE9riel d'escalade !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564746
    m_Localized: Nous avons vu le chien courir en haut de la montagne.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564747
    m_Localized: "Explorez le Mont Blanc et d\xE9couvrez notre \xE9quipement."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564748
    m_Localized: "Avant de partir, il vous faut un sac \xE0 dos."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564749
    m_Localized: Cherchez-le !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564750
    m_Localized: "Il s'ouvre ! Il contient un sac \xE0 dos."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564751
    m_Localized: "C'est ferm\xE9 \xE0 cl\xE9. Il vous faut peut-\xEAtre une cl\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564752
    m_Localized: "Ce sac \xE0 dos peut contenir de la nourriture, de l'eau et une
      carte."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564753
    m_Localized: Nous pouvons maintenant quitter le camp de base et commencer l'aventure
      !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564754
    m_Localized: "Vous \xEAtes maintenant pr\xEAt \xE0 grimper !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564755
    m_Localized: "Si vous \xEAtes bloqu\xE9, le bonhomme de neige peut vous aider
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564756
    m_Localized: Il vous manque le manteau !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564757
    m_Localized: "Le vent commence \xE0 se lever. J'ai besoin de prot\xE9ger mes
      oreilles !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564758
    m_Localized: "Comment prot\xE9ger ses oreilles par grand vent ?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564759
    m_Localized: Ouvrez le coffre pour trouver un bonnet chaud !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564760
    m_Localized: "\xC7a s'ouvre ! \xC7a contient du mat\xE9riel."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564762
    m_Localized: Ce manteau vous garde au chaud par temps venteux et neigeux.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564763
    m_Localized: "Un chapeau chaud garde votre t\xEAte au chaud."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564764
    m_Localized: Cela aide aussi lorsque le vent est froid.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564765
    m_Localized: Vous pouvez maintenant poursuivre l'ascension !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564767
    m_Localized: "Si vous \xEAtes bloqu\xE9, le bonhomme de neige peut vous aider
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564768
    m_Localized: Il vous manque les gants !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564769
    m_Localized: "Le soleil brille tr\xE8s fort sur la neige. Nous avons besoin de
      protections oculaires."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564770
    m_Localized: "Qu'est-ce qui prot\xE8ge vos yeux de la neige et du soleil \xE9clatants
      ?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564771
    m_Localized: "Continuez les recherches. Nous avons encore besoin de tout le mat\xE9riel."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564772
    m_Localized: Ouvrez le coffre pour obtenir des lunettes de soleil !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564773
    m_Localized: "\xC7a s'ouvre ! Il y a des lunettes de soleil \xE0 l'int\xE9rieur."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564775
    m_Localized: Les gants gardent les doigts au chaud et au sec.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564776
    m_Localized: Les mains froides rendent l'escalade difficile.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564777
    m_Localized: "La neige et la glace refl\xE8tent la lumi\xE8re vive du soleil."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564778
    m_Localized: "Les lunettes de soleil prot\xE8gent vos yeux."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564779
    m_Localized: "Vous avez l'\xE9quipement de glace. Un dernier effort pour atteindre
      le sommet !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564780
    m_Localized: Il vous manque la corde !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564781
    m_Localized: "Pour marcher sur la glace d'un glacier, nous avons besoin d'un
      \xE9quipement sp\xE9cial."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564782
    m_Localized: Que met-on sur ses bottes pour marcher sur la glace sans glisser
      ?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564783
    m_Localized: Crampons
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564784
    m_Localized: "Exact ! Utilisez-les pour garder l'\xE9quilibre."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564785
    m_Localized: Palmes
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564786
    m_Localized: "Non ! Vous ne nagez pas ! R\xE9essayez."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564787
    m_Localized: Ouvrez le coffre pour obtenir des crampons !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564790
    m_Localized: "Ces accessoires vous aident \xE0 marcher en toute s\xE9curit\xE9
      sur la glace."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564791
    m_Localized: "La corde permet aux grimpeurs de rester en s\xE9curit\xE9 sur la
      glace et les rochers."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564792
    m_Localized: "Vous avez r\xE9ussi ! Nous sommes au sommet du Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564793
    m_Localized: "Ce sommet culmine \xE0 4807 m\xE8tres d'altitude."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564794
    m_Localized: "R\xE9pondons \xE0 trois questions sur la montagne avant le match
      du drapeau."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564795
    m_Localized: "Dans quelle cha\xEEne de montagnes se situe le Mont Blanc ?"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564796
    m_Localized: Les Alpes
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564797
    m_Localized: Correct!
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564798
    m_Localized: "Les Pyr\xE9n\xE9es"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564799
    m_Localized: "Pas tout \xE0 fait. R\xE9essayez."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564800
    m_Localized: Les Apennins
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564802
    m_Localized: Quelle est la hauteur du Mont Blanc ?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564803
    m_Localized: "4807 m\xE8tres"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564805
    m_Localized: "3705 m\xE8tres"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564807
    m_Localized: "5016 m\xE8tres"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564809
    m_Localized: Quels pays peut-on voir d'ici ?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564810
    m_Localized: France, Italie et Suisse
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564811
    m_Localized: "Exact ! Pla\xE7ons les drapeaux."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564812
    m_Localized: France, Espagne et Allemagne
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564813
    m_Localized: "Pas tout \xE0 fait. C'est un peu trop loin !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564814
    m_Localized: "La France se situe \xE0 l'ouest du Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564815
    m_Localized: "L'Italie se situe \xE0 l'est du Mont Blanc."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564816
    m_Localized: La Suisse se situe au nord du Mont Blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564817
    m_Localized: Avez-vous besoin d'aide pour gravir la montagne ?
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564818
    m_Localized: Oui
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564819
    m_Localized: Camp de base 1
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564820
    m_Localized: Camp de base 2
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564821
    m_Localized: Camp de base 3
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564822
    m_Localized: Camp de base 4
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564823
    m_Localized: Non, je reste ici
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564824
    m_Localized: Je dors tout l'hiver sous la neige. C'est ce qu'on appelle l'hibernation
      !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564825
    m_Localized: J'adore manger des fleurs et des herbes alpines. Miam !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564826
    m_Localized: "Ne faites pas attention \xE0 moi, je prends juste un bain de soleil
      sur ce rocher chaud."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564827
    m_Localized: "Tu as trouv\xE9 une \xE9charpe bien chaude !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564829
    m_Localized: "Une \xE9charpe prot\xE8ge votre cou du vent."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564830
    m_Localized: J'adore les montagnes !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564831
    m_Localized: Le Mont Blanc est la plus haute montagne des Alpes !
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564832
    m_Localized: "J'esp\xE8re voir une marmotte !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564833
    m_Localized: "N'oubliez pas d'apporter des v\xEAtements chauds !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564834
    m_Localized: "Les montagnes peuvent \xEAtre dangereuses, alors soyez prudents
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564835
    m_Localized: "Il faut de bonnes chaussures pour faire de la randonn\xE9e ici."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564836
    m_Localized: Le vent peut changer rapidement.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564837
    m_Localized: "Je suis la corde lorsqu'elle est verglac\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564838
    m_Localized: "Ce glacier ressemble \xE0 une rivi\xE8re gel\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564839
    m_Localized: J'adore l'escalade dans les Alpes.
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564840
    m_Localized: "Les crampons m'aident \xE0 marcher sur la glace dure."
    m_Metadata:
      m_Items: []
  - m_Id: 70723632840564841
    m_Localized: "Grimper avec un guide est plus s\xFBr."
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173380
    m_Localized: Je ne sais pas
    m_Metadata:
      m_Items: []
  - m_Id: 70826283859173381
    m_Localized: Revenez plus tard !
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
