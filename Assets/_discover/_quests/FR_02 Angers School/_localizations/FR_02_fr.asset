%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_02_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: a33cf71e477044299aba778db3c07af9, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 102163800064
    m_Localized: "Bienvenue \xE0 Angers ! Angers est une ville situ\xE9e \xE0 l'Ouest
      de la France. Aujourd'hui, c'est le premier jour d'\xE9cole ! C'est la rentr\xE9e
      des classes! "
    m_Metadata:
      m_Items: []
  - m_Id: 102167994368
    m_Localized: "La rentr\xE9e est toujours en septembre. Tu as 10 ans et tu rentres
      en classe de CM2."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994369
    m_Localized: "Cherche ton \xE9cole et ta classe !"
    m_Metadata:
      m_Items: []
  - m_Id: 102167994370
    m_Localized: "Bienvenue ! C'est une \xE9cole maternelle. C'est une \xE9cole pour
      les enfants de 3 \xE0 5 ans. Il y a trois classe en maternelle: la classe des
      petits, la classe des moyens et les grands."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994371
    m_Localized: "Tu es trop \xE2g\xE9. L'\xE9cole \xE9l\xE9mentaire est \xE0 juste
      \xE0 c\xF4t\xE9. Les \xE9l\xE8ves ont entre 6 et 10 ans."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994372
    m_Localized: "Bonjour ! Bienvenue ! Tu as trouv\xE9 ton \xE9cole. Tu es \xE0
      l'\xE9cole \xE9l\xE9mentaire. Il y a 5 classes: CP, CE1, CE2, CM1 et CM2."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994373
    m_Localized: "Mais tu as oubli\xE9 de prendre ton cartable."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994374
    m_Localized: Tu as besoin de ta trousse, de tes crayons, de tes cahiers et de
      livres.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994375
    m_Localized: "Bonjour ! Ici c'est le coll\xE8ge. Les \xE9l\xE8ves ont entre 11
      et 14 ans."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994376
    m_Localized: "Apr\xE8s le CM2, on entre au coll\xE8ge. Les \xE9l\xE8ves entrent
      au coll\xE8ge \xE0 11 ans. Ils entrent en 6\xE8me."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994377
    m_Localized: "Il y a quatre classe au coll\xE8ge: la 6\xE8me, la 5\xE8me, la
      4\xE8me et la 3 \xE8me."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994378
    m_Localized: "Les \xE9l\xE8ves s'appellent des lyc\xE9ens. Il y a trois classes
      au lyc\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994379
    m_Localized: "Tu es trop jeune pour entrer au coll\xE8ge ou au lyc\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994380
    m_Localized: "Bonjour ! J'ai trouv\xE9 un cartable."
    m_Metadata:
      m_Items: []
  - m_Id: 13528238370709505
    m_Localized: Va demander aux personnes autour de toi.
    m_Metadata:
      m_Items: []
  - m_Id: 13528238370709504
    m_Localized: "Peut-\xEAtre que quelqu'un a pris ton livre."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994384
    m_Localized: "Et voil\xE0 ! Entre dans la salle de classe. "
    m_Metadata:
      m_Items: []
  - m_Id: 102167994385
    m_Localized: Entre ! Ta classe est au bout du couloir.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994386
    m_Localized: Cherche ta classe.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994387
    m_Localized: C'est la classe de CP.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994388
    m_Localized: "Les enfants commencent l\u2019\xE9cole primaire \xE0 6 ans en CP."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994389
    m_Localized: "Ce n'est pas ta classe. Tu as 10 ans. Tu es donc en CM2.\_"
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370887
    m_Localized: "D\xE9sol\xE9 ! Ce n'est pas la bonne r\xE9ponse. Essaie encore."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994391
    m_Localized: 'C''est la classe de CE1. '
    m_Metadata:
      m_Items: []
  - m_Id: 102167994392
    m_Localized: Le CE1 n'est pas ta classe. Tu es en CM2. Essaie encore!!
    m_Metadata:
      m_Items: []
  - m_Id: 102167994393
    m_Localized: Bonjour ! Ici c'est la classe de CE2.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994394
    m_Localized: "Les \xE9l\xE8ves ont 8 ans."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994395
    m_Localized: Ce n'est pas ta classe !
    m_Metadata:
      m_Items: []
  - m_Id: 102167994397
    m_Localized: "Le CM1 est la classe apr\xE8s le CE2."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994398
    m_Localized: Ta classe est toute proche !
    m_Metadata:
      m_Items: []
  - m_Id: 102167994399
    m_Localized: "Et voil\xE0 ! Voici ta classe. Bienvenue en CM2 !"
    m_Metadata:
      m_Items: []
  - m_Id: 102167994400
    m_Localized: "Installe toi \xE0 ta table."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994401
    m_Localized: Prends ta trousse et ton cahier.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994402
    m_Localized: "La ma\xEEtresse et le ma\xEEtre sont l\xE0 pour t'aider \xE0 apprendre."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994403
    m_Localized: "Tu vas faire des math\xE9matiques. Tu vas apprendre \xE0 compter,
      calculer."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994404
    m_Localized: "Remets dans l'ordre les lettres de l'alphabet pour \xE9crire le
      mot ECOLE."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994405
    m_Localized: "Bravo ! tu as r\xE9ussi! "
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370886
    m_Localized: 'Tiens! '
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370885
    m_Localized: Bravo!
    m_Metadata:
      m_Items: []
  - m_Id: 102167994408
    m_Localized: "Bravo! Tu as \xE9cris le mot ECOLE. Tu peux entrer dans l'\xE9cole."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994409
    m_Localized: "Tu peux t'installer \xE0 ta place. Voici ta table et ta chaise."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994410
    m_Localized: Cherche ton cartable et reviens ensuite me voir.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994411
    m_Localized: "Bonjour ! Le midi, tu peux manger \xE0 la cantine ou \xE0 la maison."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994412
    m_Localized: Regarde le menu de la cantine.
    m_Metadata:
      m_Items: []
  - m_Id: 102167994413
    m_Localized: "\xC0 l\u2019\xE9cole, tout le monde est le bienvenu: les filles
      et les gar\xE7ons,"
    m_Metadata:
      m_Items: []
  - m_Id: 102167994414
    m_Localized: peu importe leurs croyances.
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370884
    m_Localized: Remets les classes dans l'ordre.
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370883
    m_Localized: "Mais d\u2019abord, il faut le gagner !"
    m_Metadata:
      m_Items: []
  - m_Id: 960066824298496
    m_Localized: "Trouve ton \xE9cole !"
    m_Metadata:
      m_Items: []
  - m_Id: 960066878824448
    m_Localized: Trouve ta classe.
    m_Metadata:
      m_Items: []
  - m_Id: 960066878824449
    m_Localized: "Tu as trouv\xE9 ton \xE9cole !"
    m_Metadata:
      m_Items: []
  - m_Id: 960066878824450
    m_Localized: "Trouve ton cartable pour pouvoir aller \xE0 l'\xE9cole."
    m_Metadata:
      m_Items: []
  - m_Id: 1998423988363264
    m_Localized: "Ce n'est pas tout \xE0 fait exact. Essaie encore!"
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370882
    m_Localized: "C'est peut-\xEAtre ton livre ?"
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370881
    m_Localized: "Ces livres sont utiles quand on apprend \xE0 lire. On apprend avec
      ces livres l'alphabet et les lettres."
    m_Metadata:
      m_Items: []
  - m_Id: 9280941621370880
    m_Localized: "Maintenant, cherche ton \xE9cole !"
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660224
    m_Localized: "Le jeu est termin\xE9 ! F\xE9licitations !"
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660225
    m_Localized: "C'est la rentr\xE9e!"
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660226
    m_Localized: Dessine ta classe.
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660227
    m_Localized: "Bon app\xE9tit!"
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660228
    m_Localized: "Le matin et l'apr\xE8s-midi, il y a une r\xE9cr\xE9ation. Pendant
      la r\xE9cr\xE9ation, les enfants jouent sur la cour."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660229
    m_Localized: J'aime dessiner et colorier.
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660230
    m_Localized: J'aime la musique et chanter avec ma classe.
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660231
    m_Localized: "J'aime les math\xE9matiques car j'adore faire des calculs."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660232
    m_Localized: "Je joue au football avec mes copains sur la cour de r\xE9cr\xE9ation."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660233
    m_Localized: "J'adore faire du sport avec ma classe. Parfois, on va \xE0 la piscine."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660234
    m_Localized: "En France, l'\xE9cole commence en septembre et se termine en juin."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660235
    m_Localized: "Il y a des vacances dans l\u2019ann\xE9e scolaire."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660236
    m_Localized: "A l'\xE9cole, on apprend \xE0 lire, \xE9crire, compter et parler
      de nouvelles langues."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660237
    m_Localized: "L'\xE9cole commence vers 8H30 et se termine vers 16H30. Le mercredi
      apr\xE8s-midi, on reste \xE0 la maison. Le samedi et le dimanche, il n'y a
      pas d'\xE9cole."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660238
    m_Localized: "Le midi, on peut manger \xE0 la cantine ou renter manger \xE0 la
      maison."
    m_Metadata:
      m_Items: []
  - m_Id: 2479185556660239
    m_Localized: "A l'\xE9cole, on apprend \xE0 lire et \xE9crire."
    m_Metadata:
      m_Items: []
  - m_Id: 102167994396
    m_Localized: Bonjour ! Ici c'est la classe des CM1.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
