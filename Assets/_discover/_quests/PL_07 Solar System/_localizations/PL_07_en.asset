%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_07_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 213edffcac825413dbaa1676194baa28, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 245659328512
    m_Localized: "Welcome to TORU\u0143 in POLAND."
    m_Metadata:
      m_Items: []
  - m_Id: 245659328513
    m_Localized: COPERNICUS was born here.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328514
    m_Localized: ANTURA is stuck in his house!
    m_Metadata:
      m_Items: []
  - m_Id: 245659328515
    m_Localized: Let's ask COPERNICUS for help.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328516
    m_Localized: Hello! I am NICOLAUS COPERNICUS.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328517
    m_Localized: I can help you rescue ANTURA.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328518
    m_Localized: First, fix my SOLAR SYSTEM map.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328519
    m_Localized: Help with planets
    m_Metadata:
      m_Items: []
  - m_Id: 245659328520
    m_Localized: Done
    m_Metadata:
      m_Items: []
  - m_Id: 245659328521
    m_Localized: Well done!
    m_Metadata:
      m_Items: []
  - m_Id: 245659328522
    m_Localized: Long ago, people put EARTH in the center.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328523
    m_Localized: I found the SUN is in the center.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328524
    m_Localized: Here is a 3D SOLAR SYSTEM.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328525
    m_Localized: It spins in the hall.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328526
    m_Localized: Find PLANETS to add them here.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328527
    m_Localized: Clean the TELESCOPE.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328528
    m_Localized: Learn the parts
    m_Metadata:
      m_Items: []
  - m_Id: 245659328529
    m_Localized: A TELESCOPE helps us see far.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328530
    m_Localized: It has a LENS and an EYEPIECE.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328531
    m_Localized: A PLANETARIUM shows the sky indoors.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328532
    m_Localized: Match the parts
    m_Metadata:
      m_Items: []
  - m_Id: 245659328533
    m_Localized: Piano memory
    m_Metadata:
      m_Items: []
  - m_Id: 245659328534
    m_Localized: Music helps memory.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328535
    m_Localized: Play the PLANET order tune.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328536
    m_Localized: Play
    m_Metadata:
      m_Items: []
  - m_Id: 245659328537
    m_Localized: Find PLANETS
    m_Metadata:
      m_Items: []
  - m_Id: 245659328538
    m_Localized: Let's visit each PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328539
    m_Localized: They appear in the model when found.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328540
    m_Localized: Start with MERCURY
    m_Metadata:
      m_Items: []
  - m_Id: 245659328541
    m_Localized: MERCURY is closest to the SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328542
    m_Localized: It goes around very fast.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328543
    m_Localized: VENUS is very hot.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328544
    m_Localized: Thick clouds cover it.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328545
    m_Localized: EARTH is our home.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328546
    m_Localized: It has land, air, and seas.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328547
    m_Localized: MARS is red and dusty.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328548
    m_Localized: It has big volcanoes.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328549
    m_Localized: 'Next: JUPITER'
    m_Metadata:
      m_Items: []
  - m_Id: 245659328550
    m_Localized: JUPITER is the biggest PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328551
    m_Localized: It has a Great Red Spot.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328552
    m_Localized: Next is SATURN
    m_Metadata:
      m_Items: []
  - m_Id: 245659328553
    m_Localized: SATURN has bright RINGS.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328554
    m_Localized: Many MOONS orbit it.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328555
    m_Localized: Next is URANUS
    m_Metadata:
      m_Items: []
  - m_Id: 245659328556
    m_Localized: URANUS spins on its side.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328557
    m_Localized: "It looks blue\u2011green."
    m_Metadata:
      m_Items: []
  - m_Id: 245659328558
    m_Localized: NEPTUNE is far and windy.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328559
    m_Localized: It is deep blue.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328560
    m_Localized: You found all 8 PLANETS.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328561
    m_Localized: The model is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328562
    m_Localized: Now rescue ANTURA!
    m_Metadata:
      m_Items: []
  - m_Id: 245659328563
    m_Localized: ANTURA is free!
    m_Metadata:
      m_Items: []
  - m_Id: 245659328564
    m_Localized: Thank you for your help.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328565
    m_Localized: Remember that the SUN is in the center.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328566
    m_Localized: Final Quiz
    m_Metadata:
      m_Items: []
  - m_Id: 245659328567
    m_Localized: Answer the questions.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328568
    m_Localized: Tap the best choice.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328569
    m_Localized: You helped COPERNICUS.
    m_Metadata:
      m_Items: []
  - m_Id: 245659328570
    m_Localized: The SOLAR SYSTEM is complete!
    m_Metadata:
      m_Items: []
  - m_Id: 2252327552540672
    m_Localized: This quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 2252327552540673
    m_Localized: Today we learned about the SOLAR SYSTEM.
    m_Metadata:
      m_Items: []
  - m_Id: 2252327552540674
    m_Localized: And knew that the SUN is in the center.
    m_Metadata:
      m_Items: []
  - m_Id: 2252327552540675
    m_Localized: Why don't you draw the Solar System?
    m_Metadata:
      m_Items: []
  - m_Id: 2387894302924805
    m_Localized: Well done!
    m_Metadata:
      m_Items: []
  - m_Id: 2288346482073600
    m_Localized: Why don't you draw the Solar System?
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119112
    m_Localized: the MOON is our satellite.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119111
    m_Localized: Planets move around SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 2312838298198018
    m_Localized: The SUN is in the center.
    m_Metadata:
      m_Items: []
  - m_Id: 2312838298198019
    m_Localized: Draw the 8 PLANETS.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795200
    m_Localized: 'Write first letters: M V E M J S U N.'
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795201
    m_Localized: Circle the SUN in center.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795202
    m_Localized: Show it to a friend.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894302924802
    m_Localized: Draw the 8 PLANETS with the SUN in center.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795204
    m_Localized: 'title: spawned_child'
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795205
    m_Localized: 'position: 900,1400'
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795206
    m_Localized: 'group: Spawned'
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795207
    m_Localized: 'actor: KID_M'
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795208
    m_Localized: ---
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795209
    m_Localized: I saw blue NEPTUNE.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795210
    m_Localized: Rings on SATURN shine.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795211
    m_Localized: Planets move around SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795212
    m_Localized: EARTH spins so fast.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795213
    m_Localized: Old house of COPERNICUS.
    m_Metadata:
      m_Items: []
  - m_Id: 2381802495795214
    m_Localized: Telescope glass is clean.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119110
    m_Localized: Rings on SATURN shine.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119109
    m_Localized: I saw blue NEPTUNE.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119108
    m_Localized: ---
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119107
    m_Localized: 'actor: KID_M'
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119106
    m_Localized: 'group: Spawned'
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119105
    m_Localized: 'position: 900,1400'
    m_Metadata:
      m_Items: []
  - m_Id: 2387894307119104
    m_Localized: 'title: spawned_child'
    m_Metadata:
      m_Items: []
  - m_Id: 2387894302924804
    m_Localized: Now we can see the planets better.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894302924803
    m_Localized: Great job cleaning the lens!
    m_Metadata:
      m_Items: []
  - m_Id: 2387894302924801
    m_Localized: Today we learned the SOLAR SYSTEM.
    m_Metadata:
      m_Items: []
  - m_Id: 2387894302924800
    m_Localized: Great work on this quest.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665077440512
    m_Localized: Welcome to TORUN in POLAND.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909504
    m_Localized: NICOLAUS COPERNICUS was born here.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909505
    m_Localized: ANTURA sneaked into his model room!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909506
    m_Localized: Let's ask COPERNICUS for help.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909507
    m_Localized: Great work!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909508
    m_Localized: Today we learned the 8 PLANETS of the SOLAR SYSTEM.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909509
    m_Localized: Draw the 7 PLANETS around the SUN in order.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909510
    m_Localized: Hello! I am NICOLAUS COPERNICUS.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909511
    m_Localized: ANTURA is trapped in my model room!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909512
    m_Localized: Help me fix the SOLAR SYSTEM model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909513
    m_Localized: I will tell you about each PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909514
    m_Localized: Let's fix it!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665173909515
    m_Localized: "First \u2014 can you put the PLANETS in order?"
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103808
    m_Localized: All 8, from the SUN outward!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103809
    m_Localized: I will try!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103810
    m_Localized: Well done!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103811
    m_Localized: The SUN is at the center.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103812
    m_Localized: Long ago, people put EARTH in the center.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103813
    m_Localized: I proved the SUN should be there!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103814
    m_Localized: Now let's visit each PLANET and collect its treasures.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103815
    m_Localized: Start with MERCURY
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103816
    m_Localized: MERCURY is the closest PLANET to the SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103817
    m_Localized: It has no air and is covered in CRATERS.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103818
    m_Localized: The SUN bakes its rocks red-hot!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103819
    m_Localized: Find the 1 SUN-HEATED ROCK to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103820
    m_Localized: Great! MERCURY is now in the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103821
    m_Localized: 'Next: VENUS'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103822
    m_Localized: VENUS is the second PLANET from the SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103823
    m_Localized: It is wrapped in thick, hot CLOUDS.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103824
    m_Localized: It is the hottest PLANET of all!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103825
    m_Localized: Find 2 HOT CLOUDS to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103826
    m_Localized: Well done! VENUS joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103827
    m_Localized: 'Next: EARTH'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103828
    m_Localized: EARTH is the third PLANET from the SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103829
    m_Localized: "It is our home \u2014 full of WATER and LIFE."
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103830
    m_Localized: No other PLANET has OCEANS like ours!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103831
    m_Localized: Find 3 WATER DROPS to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103832
    m_Localized: Wonderful! EARTH joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103833
    m_Localized: 'Next: MARS'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103834
    m_Localized: MARS is the fourth PLANET from the SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103835
    m_Localized: Its surface is covered in red DUST and rocks.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103836
    m_Localized: It has the tallest VOLCANO in the SOLAR SYSTEM!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103837
    m_Localized: Find 4 RED DUST GRAINS to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103838
    m_Localized: Excellent! MARS joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103839
    m_Localized: 'Next: JUPITER'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103840
    m_Localized: JUPITER is the fifth PLANET and the biggest!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103841
    m_Localized: It has a giant STORM called the Great Red Spot.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103842
    m_Localized: It has at least 95 MOONS!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103843
    m_Localized: Find 5 STORM BOLTS to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103844
    m_Localized: Amazing! JUPITER joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103845
    m_Localized: 'Next: SATURN'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103846
    m_Localized: SATURN is the sixth PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103847
    m_Localized: It has beautiful RINGS made of ice and rock.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103848
    m_Localized: Its rings stretch thousands of kilometers wide!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103849
    m_Localized: Find 6 RING FRAGMENTS to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103850
    m_Localized: Beautiful! SATURN joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103851
    m_Localized: 'Next: URANUS'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103852
    m_Localized: URANUS is the seventh PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103853
    m_Localized: It is an icy blue-green GIANT.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103854
    m_Localized: "It spins on its side \u2014 like a rolling ball!"
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103855
    m_Localized: Find 7 ICE CRYSTALS to add it to the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103856
    m_Localized: Incredible! URANUS joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103857
    m_Localized: Now for the last PLANET!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103858
    m_Localized: "Ah \u2014 one more! I am an old SAILOR."
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103859
    m_Localized: NEPTUNE is the farthest PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103860
    m_Localized: It is deep blue and has the strongest WINDS in the SOLAR SYSTEM.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103861
    m_Localized: Its biggest MOON is called TRITON.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103862
    m_Localized: Can you match the NEPTUNE facts?
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103863
    m_Localized: Well done! NEPTUNE joins the model.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103864
    m_Localized: Now the model is complete!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103865
    m_Localized: You placed all 8 PLANETS in the model!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103866
    m_Localized: Now the SOLAR SYSTEM is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103867
    m_Localized: "The SUN is in the center \u2014 just as I discovered!"
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103868
    m_Localized: Now let's rescue ANTURA!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103869
    m_Localized: ANTURA is free!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103870
    m_Localized: He was hiding behind NEPTUNE's model!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103871
    m_Localized: Thank you for your help!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103872
    m_Localized: 'Remember: the SUN is at the center.'
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103873
    m_Localized: EARTH is the third PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103874
    m_Localized: Let's test what you learned!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103875
    m_Localized: What is at the center of the SOLAR SYSTEM?
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103876
    m_Localized: The SUN
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103877
    m_Localized: The EARTH
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103878
    m_Localized: "No \u2014 the SUN is in the center!"
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103879
    m_Localized: Which PLANET is closest to the SUN?
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103880
    m_Localized: MERCURY
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103881
    m_Localized: VENUS
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103882
    m_Localized: "VENUS is second \u2014 MERCURY is first!"
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103883
    m_Localized: Which PLANET has beautiful RINGS?
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103884
    m_Localized: SATURN
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103885
    m_Localized: JUPITER
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103886
    m_Localized: "JUPITER has storms \u2014 SATURN has RINGS!"
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103887
    m_Localized: You know the SOLAR SYSTEM!
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103888
    m_Localized: SATURN has rings around it.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103889
    m_Localized: NEPTUNE is the farthest PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103890
    m_Localized: MERCURY is closest to the SUN.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103891
    m_Localized: EARTH is the third PLANET.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103892
    m_Localized: NEPTUNE has the strongest WINDS.
    m_Metadata:
      m_Items: []
  - m_Id: 83512665178103893
    m_Localized: MARS is red and dusty.
    m_Metadata:
      m_Items: []
