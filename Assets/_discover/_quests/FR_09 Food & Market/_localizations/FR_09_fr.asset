  m_TableData:
  - m_Id: 125433798656
    m_Localized: "Bienvenue dans la ville de Marseille. Marseille est une ville situ\xE9e
      au bord de la Mer M\xE9diterran\xE9e. Marseille se situe dans le Sud de la
      France."
    m_Metadata:
      m_Items: []
  - m_Id: 125433798657
    m_Localized: "Bonjour ! Je suis boulanger. Je vends du pain et des g\xE2teaux."
    m_Metadata:
      m_Items: []
  - m_Id: 125433798658
    m_Localized: "Chaque jour, je me l\xE8ve t\xF4t pour faire du pain, pr\xE9prarer
      des g\xE2teaux et des croissants."
    m_Metadata:
      m_Items: []
  - m_Id: 125433798660
