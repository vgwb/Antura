--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_03_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: 91f7e04a176bf428ea7f4aab88304585, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 2398309875441664
    m_Localized: "Bienvenue \xE0 Nantes. A Nantes, il y a le mus\xE9e Jules Verne
      ! Va d\xE9couvrir le mus\xE9e Jules Verne!  "
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441665
    m_Localized: Maintenant, tu connais Jules Verne et ses LIVRES !
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441672
    m_Localized: "Voici Jules Verne. C'\xE9tait un \xC9CRIVAIN."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441673
    m_Localized: "Jules Verne est n\xE9 ici, \xE0 Nantes."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441674
    m_Localized: Voici une carte de Nantes.
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441677
    m_Localized: "Ce livre s'appelle \xAB Le tour du monde en 80 jours \xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441683
    m_Localized: "Une fus\xE9e pousse fort pour partir de la Terre."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441685
    m_Localized: "Ce livre s'appelle \xAB Vingt mille lieues sous les mers \xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441687
    m_Localized: Un sous-marin va sous l'eau.
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441691
    m_Localized: "Un BALLON monte gr\xE2ce \xE0 l'AIR chaud."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441692
    m_Localized: Il avance avec le VENT.
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441693
    m_Localized: J'adore lire des LIVRES !
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441694
    m_Localized: "Jules Verne a invent\xE9 les histoires de science-fiction."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441695
    m_Localized: "Jules Verne a \xE9crit beaucoup de livres !"
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441696
    m_Localized: Ses livres sont lus dans beaucoup de langues !
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441697
    m_Localized: J'aime l'histoire sur le MONDE.
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441699
    m_Localized: Je veux faire un tour en ballon un jour.
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441700
    m_Localized: "La fus\xE9e va vite vers la LUNE."
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441701
    m_Localized: Il montre beaucoup de lieux sur TERRE.
    m_Metadata:
      m_Items: []
  - m_Id: 2398309875441708
    m_Localized: "Beaucoup des id\xE9es de Jules Verne sont vraies maintenant."
    m_Metadata:
      m_Items: []
  - m_Id: 2398349255761920
    m_Localized: Le sous-marin Nautilus est incroyable.
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252736
    m_Localized: "Qui est Jules Verne ?  Et o\xF9 a-t-il voyag\xE9 ?"
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252737
    m_Localized: Savez-vous qui est Jules Verne ?
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252738
    m_Localized: "Oui, c'est un \xC9CRIVAIN !"
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252739
    m_Localized: Non, qui est-ce ?
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252740
    m_Localized: "Jules Verne \xE9tait un \xE9crivain fran\xE7ais. Il est n\xE9 pr\xE8s
      d'ici."
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252741
    m_Localized: "Il a \xE9crit des livres d'aventure tr\xE8s connus."
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252743
    m_Localized: "Nous avons un PROBL\xC8ME !"
    m_Metadata:
      m_Items: []
  - m_Id: 28754274107252744
    m_Localized: "Un dr\xF4le de chien bleu est entr\xE9 dans le mus\xE9e et a fait
      des b\xEAtises !"
    m_Metadata:
      m_Items: []
  - m_Id: 29108564554407936
    m_Localized: "En classe, tu peux DESSINER un SOUS-MARIN ou une FUS\xC9E !"
    m_Metadata:
      m_Items: []
  - m_Id: 29449511649665024
    m_Localized: "Quel d\xE9sordre devant le mus\xE9e !"
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612544
    m_Localized: "Si tu vas \xE0 Nantes avec tes parents, va au MUS\xC9E Jules Verne
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612545
    m_Localized: "Merci d'avoir nettoy\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612546
    m_Localized: "Le mus\xE9e est maintenant ouvert ! Va voir le guide du mus\xE9e
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612547
    m_Localized: "Ce chien bleu courait et il a fait des b\xEAtises !"
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612548
    m_Localized: "Je ne peux pas ouvrir le MUS\xC9E avec tous ces papiers par terre."
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612549
    m_Localized: "Aidez-moi \xE0 nettoyer le trottoir !"
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612550
    m_Localized: "Bravo ! Retourne voir le monsieur \xE0 la porte du mus\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 29451373941612551
    m_Localized: "Merci ! Le MUS\xC9E est maintenant pr\xEAt."
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169344
    m_Localized: "La qu\xEAte est termin\xE9e ! F\xE9licitations !"
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169345
    m_Localized: "Peux-tu aider \xE0 nettoyer le MUS\xC9E ?"
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169346
    m_Localized: "Jules Verne serait tr\xE8s content de toi !"
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169347
    m_Localized: Mets ensemble les LIVRES avec leurs TRANSPORTS !
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169348
    m_Localized: C'est bien. Tu n'as pas fini, continue !
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169349
    m_Localized: "Nous avons un autre PROBL\xC8ME !"
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169350
    m_Localized: "Les transports ne sont plus l\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169351
    m_Localized: "Va voir le gardien de la premi\xE8re salle."
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169352
    m_Localized: Bravo ! Tu as mis tous les LIVRES avec leurs TRANSPORTS.
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169353
    m_Localized: "Maintenant, Tout est pr\xEAt pour les visiteurs !"
    m_Metadata:
      m_Items: []
  - m_Id: 29490495578169354
    m_Localized: "Parfait. Le mus\xE9e est maintenant propre ! Va voir le GUIDE DU
      MUS\xC9E."
    m_Metadata:
      m_Items: []
  - m_Id: 29498754787696640
    m_Localized: "Tu as trouv\xE9 le SOUS-MARIN !"
    m_Metadata:
      m_Items: []
  - m_Id: 29498754787696641
    m_Localized: "Peux-tu le r\xE9parer, s'il te pla\xEEt ?"
    m_Metadata:
      m_Items: []
  - m_Id: 29498754787696642
    m_Localized: Au secours ! Le Nautilus a disparu !
    m_Metadata:
      m_Items: []
  - m_Id: 29498754787696643
    m_Localized: Trouve le SOUS-MARIN
    m_Metadata:
      m_Items: []
  - m_Id: 29498754787696644
    m_Localized: "Tu as r\xE9par\xE9 le sous-marin ! Merci !"
    m_Metadata:
      m_Items: []
  - m_Id: 29498754787696645
    m_Localized: Va maintenant au gardien suivant.
    m_Metadata:
      m_Items: []
  - m_Id: 29501744894435328
    m_Localized: "Super ! Maintenant, donne-le \xE0 son gardien."
    m_Metadata:
      m_Items: []
  - m_Id: 29724990315159552
    m_Localized: "Tu as trouv\xE9 la MONTGOLFI\xC8RE ! On l'appelle aussi un ballon."
    m_Metadata:
      m_Items: []
  - m_Id: 29724990315159554
    m_Localized: Au secours ! Il manque quelque chose !
    m_Metadata:
      m_Items: []
  - m_Id: 29724990315159555
    m_Localized: Trouve le ballon.
    m_Metadata:
      m_Items: []
  - m_Id: 29724990315159558
    m_Localized: "Ce livre s'appelle \xAB Cinq semaines en ballon \xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 29724990315159559
    m_Localized: "Un BALLON monte car l'AIR chaud est l\xE9ger."
    m_Metadata:
      m_Items: []
  - m_Id: 29735032657534976
    m_Localized: "Mais il est CASS\xC9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 29735032657534977
    m_Localized: Reviens me voir plus tard.
    m_Metadata:
      m_Items: []
  - m_Id: 29743951194873856
    m_Localized: Un sous-marin va sous la mer.
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068165
    m_Localized: "Tu as trouv\xE9 le TRAIN !"
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068168
    m_Localized: Au secours ! Nous avons perdu le TRAIN !
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068169
    m_Localized: "Trouve le vieux train \xE0 vapeur"
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068174
    m_Localized: Un train avance sur des rails.
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068175
    m_Localized: Ce vieux train utilisait la vapeur pour avancer.
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068176
    m_Localized: Avec les trains on allait plus vite.
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068177
    m_Localized: "Tu as trouv\xE9 la FUS\xC9E !"
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068180
    m_Localized: Au secours ! Notre plus belle machine a disparu !
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068181
    m_Localized: "Trouve la FUS\xC9E"
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068184
    m_Localized: "Va voir le GUIDE DU MUS\xC9E !"
    m_Metadata:
      m_Items: []
  - m_Id: 29743951199068186
    m_Localized: "Ceci est une FUS\xC9E."
    m_Metadata:
      m_Items: []
  - m_Id: 29748868638826511
    m_Localized: "Tu as trouv\xE9 tous les transports !"
    m_Metadata:
      m_Items: []
  - m_Id: 29750743886979072
    m_Localized: Si tu ne le trouves pas, VA VOIR LA CARTE
    m_Metadata:
      m_Items: []
  - m_Id: 29753348373602310
    m_Localized: "Il y a tr\xE8s longtemps, Jules Verne a imagin\xE9 les FUS\xC9ES
      et les VOYAGES dans l'espace."
    m_Metadata:
      m_Items: []
  - m_Id: 29753348373602311
    m_Localized: "L'histoire parle d'un tr\xE8s gros CANON qui lance la FUS\xC9E."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
