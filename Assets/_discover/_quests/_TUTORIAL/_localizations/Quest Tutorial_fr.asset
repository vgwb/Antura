--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Quest Tutorial_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: ae41e5e4247e344ca96ed7e41e10f4e2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 12476731452547093
    m_Localized: "Utilise les ascenceurs pour te d\xE9placer rapidement !"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547092
    m_Localized: Voyons si tu as compris.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547091
    m_Localized: "Cette ic\xF4ne indique o\xF9 aller."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547090
    m_Localized: Essaie de pousser cette balle.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547089
    m_Localized: "Explore tous les objets qui ont cette ic\xF4ne."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547088
    m_Localized: Ce bouton ouvre la carte !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547087
    m_Localized: "Attrape tous les biscuits que tu trouves. Ils peuvent \xEAtre utiles."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547085
    m_Localized: Utilise ce bouton pour sauter
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547084
    m_Localized: Appuie sur la touche ESPACE ou sur ce bouton pour sauter.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547083
    m_Localized: Ou appuie sur la touche ESPACE.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547082
    m_Localized: Utilise ce bouton pour parler ou interagir
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547081
    m_Localized: "Utilise ton doigt droit pour d\xE9placer la cam\xE9ra."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547080
    m_Localized: "Appuie sur le bouton de la souris pour d\xE9placer la cam\xE9ra."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547079
    m_Localized: Va parler  au personnage suivant !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547078
    m_Localized: Utilise ton doigt gauche pour marcher.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547077
    m_Localized: Utilise les touches WASD pour marcher.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547094
    m_Localized: Fais attention de ne pas tomber dans l'eau !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547076
    m_Localized: Utilise ce bouton pour voir la photo ou le dessin.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547075
    m_Localized: "Utilise ce bouton pour \xE9couter les dialogues."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547074
    m_Localized: "Touche ce texte pour le r\xE9\xE9couter."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547072
    m_Localized: Bienvenue dans le tutoriel !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547095
    m_Localized: "Ces lettres de l'alphabet sont anim\xE9es. Elles t'apprendront
      de nouveaux mots!"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547096
    m_Localized: "Va voir les diff\xE9rents personnages. Ils t'aideront et t'expliqueront 
      plein de choses!"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547097
    m_Localized: "Ceci est une CARTE. Elle poss\xE8de des connaissances et des pouvoirs.
      Collectionne-les toutes\_!"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547098
    m_Localized: Oui. C'est toi ! En jouant jusqu'au bout, tu pourras changer ton
      look !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547099
    m_Localized: "Voici notre ami Antura. Il t'accompagnera dans ton aventure\_!"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547100
    m_Localized: C'est ton inventaire. Clique sur un objet pour l'utiliser.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547101
    m_Localized: "Voici la progression du jeu. Si tu gagnes, alors tu auras des \xE9toiles. "
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547102
    m_Localized: Ce panneau indique ce que tu dois faire.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547103
    m_Localized: "Ce symbole indique o\xF9 aller."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547104
    m_Localized: Essaie ce jeu.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547105
    m_Localized: "Tu dois nettoyer l'\xE9cran sans toucher le chien Antura !"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547106
    m_Localized: "Pour nettoyer tu utilises ton doigt sur l'\xE9cran ou la souris."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547107
    m_Localized: 'Voici le jeu du puzzle. '
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547108
    m_Localized: "Reconstitue le puzzle \xE0 l'aide des diff\xE9rents morceaux."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547109
    m_Localized: "=AI(\"Remplis une valeur appropri\xE9e pour cette cellule en fonction
      du contexte de la table\")"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547110
    m_Localized: Essaie maintenant le jeu du memory !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547111
    m_Localized: Trouve les cartes identiques.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547112
    m_Localized: "Avec ce jeu, tu dois travailler ta m\xE9moire."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547113
    m_Localized: Essaie ce jeu d'association de paires !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547114
    m_Localized: Associe les cartes similaires.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547115
    m_Localized: "Bravo ! tu as trouv\xE9 les cartes qui vont ensemble."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547116
    m_Localized: Dans ce jeu, tu vas compter l'argent!
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547117
    m_Localized: "Tu vas donner des pi\xE8ces et des billets.."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547118
    m_Localized: En France on utilise une monnaie qui s'appelle l'euro.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547119
    m_Localized: "Dans ce jeu, tu vas remettre dans l'ordre des \xE9l\xE9ments."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547120
    m_Localized: "Remets les \xE9l\xE9ments dans le bon ordre."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547121
    m_Localized: "=AI(\"Remplis une valeur appropri\xE9e pour cette cellule en fonction
      du contexte de la table\")"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547122
    m_Localized: Voici le tutoriel de base.
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547123
    m_Localized: "Tu peux maintenant explorer les diff\xE9rentes villes de France. "
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547125
    m_Localized: " On se retrouve vite pour une premi\xE8re aventure! \xC0 bient\xF4t
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547126
    m_Localized: "Il y a bien plus \xE0 d\xE9couvrir \xE0 Antura."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547127
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547128
    m_Localized: 'Tu peux refaire ce tutoriel quand tu veux. '
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547129
    m_Localized: "Demande \xE0 ton ma\xEEtre ou ta ma\xEEtresse de t'aider."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547130
    m_Localized: "Il y a des secrets \xE0 explorer dans ce niveau."
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547131
    m_Localized: Et un ascenceur pour voyager sur ce gratte-ciel !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547132
    m_Localized: Bonjour!
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547133
    m_Localized: As-tu vu Antura ?
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547134
    m_Localized: J'ai perdu mon cookie !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547135
    m_Localized: "Des cookies sont cach\xE9s partout\_! Trouve-les\_!"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547136
    m_Localized: J'adore utiliser les ascenceurs pour voyager !
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547137
    m_Localized: "Parle \xE0 tous les perosnnages que tu vas rencontrer !"
    m_Metadata:
      m_Items: []
  - m_Id: 12476731452547138
    m_Localized: Explore la France !
    m_Metadata:
      m_Items: []
  - m_Id: 12476748359786496
    m_Localized: Oui
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913856
    m_Localized: Tu veux rejouer ?
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913857
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913858
    m_Localized: "C'est tr\xE8s facile"
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913859
    m_Localized: C'est facile.
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913860
    m_Localized: C'est difficile.
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913861
    m_Localized: C'est merveilleux de voir la ville d'ici !
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913862
    m_Localized: J'aimerais voyager partout dans le monde !
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913863
    m_Localized: "J'adore les jeux vid\xE9o !"
    m_Metadata:
      m_Items: []
  - m_Id: 12722196785913864
    m_Localized: Tu veux jouer avec moi?
    m_Metadata:
      m_Items: []
  - m_Id: 21423128595914753
    m_Localized: Super ! Tu as ouvert le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 21423128595914752
    m_Localized: Monte les escaliers et ouvre ce coffre
    m_Metadata:
      m_Items: []
  - m_Id: 12761926495887360
    m_Localized: "Tu es pr\xEAt \xE0 jouer ?"
    m_Metadata:
      m_Items: []
  - m_Id: 21734111575007232
    m_Localized: "Trouve la cl\xE9 et ouvre la porte !"
    m_Metadata:
      m_Items: []
  - m_Id: 21734111575007233
    m_Localized: "La cl\xE9 ouvre la porte"
    m_Metadata:
      m_Items: []
  - m_Id: 21734111575007234
    m_Localized: "La porte est verrouill\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 46847715634569216
    m_Localized: Si vous souhaitez sortir, rendez-vous sur ce portail.
    m_Metadata:
      m_Items: []
  - m_Id: 46847715647152128
    m_Localized: "Voulez-vous quitter ce tutoriel\_?"
    m_Metadata:
      m_Items: []
  - m_Id: 46847715647152129
    m_Localized: Oui, sortie
    m_Metadata:
      m_Items: []
  - m_Id: 46847715647152130
    m_Localized: Non, restez ici.
    m_Metadata:
      m_Items: []
  - m_Id: 15022681131835392
    m_Localized: "=AI(\"Remplis une valeur appropri\xE9e pour cette cellule en fonction
      du contexte de la table\")"
