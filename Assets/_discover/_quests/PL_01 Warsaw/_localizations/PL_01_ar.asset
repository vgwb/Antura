  m_TableData:
  - m_Id: 11445436669952
    m_Localized: "\u0623\u0647\u0644\u0627\u064B \u0628\u0643\u0645 \u0641\u064A
      \u0648\u0627\u0631\u0633\u0648\u060C \u0639\u0627\u0635\u0645\u0629 \u0628\u0648\u0644\u0646\u062F\u0627!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "\u0639\u0645\u0644 \u0631\u0627\u0626\u0639. \u0644\u0642\u062F
      \u0623\u0639\u062F\u062A \u062A\u062C\u0645\u064A\u0639 \u0633\u064A\u0641
      \u062D\u0648\u0631\u064A\u0629 \u0627\u0644\u0628\u062D\u0631!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "\u0623\u0639\u0637\u062A\u0643 \u062D\u0648\u0631\u064A\u0629 \u0627\u0644\u0628\u062D\u0631
      \u0627\u0644\u0642\u0637\u0639\u0629 \u0627\u0644\u0623\u0648\u0644\u0649."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "\u0648\u0642\u062F\u0651\u0645 \u0644\u0643\u0645 \u0648\u0627\u0631\u0632
      \u0648\u0633\u0627\u0648\u0627 \u0627\u0644\u0642\u0637\u0639\u0629 \u0627\u0644\u062B\u0627\u0646\u064A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "\u0623\u0639\u0637\u0627\u0643 \u0627\u0644\u0645\u0644\u0643 \u0633\u064A\u063A\u064A\u0633\u0645\u0648\u0646\u062F
      \u0627\u0644\u0642\u0637\u0639\u0629 \u0627\u0644\u062B\u0627\u0644\u062B\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: "\u0641\u064A \u0627\u0644\u0628\u0631\u0644\u0645\u0627\u0646\u060C
      \u0648\u062C\u062F\u062A \u0627\u0644\u0642\u0637\u0639\u0629 \u0627\u0644\u0631\u0627\u0628\u0639\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "\u0623\u0639\u0637\u0627\u0643 \u0634\u0648\u0628\u0627\u0646 \u0627\u0644\u0642\u0637\u0639\u0629
      \u0627\u0644\u062E\u0627\u0645\u0633\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "\u0641\u064A \u0627\u0644\u0642\u0635\u0631\u060C \u0633\u0627\u0639\u062F\u062A
      \u0645\u0627\u0631\u064A\u0627 \u0648\u0639\u062B\u0631\u062A \u0639\u0644\u0649
      \u0627\u0644\u0642\u0637\u0639\u0629 \u0627\u0644\u0633\u0627\u062F\u0633\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "\u0641\u064A \u0627\u0644\u0645\u0644\u0639\u0628\u060C \u062C\u0645\u0639\u062A
      \u0627\u0644\u0642\u0637\u0639\u0629 \u0627\u0644\u0623\u062E\u064A\u0631\u0629."
    m_Metadata:
      m_Items: []
