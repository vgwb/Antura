  - m_Id: 11445440864256
    m_Localized: "\u0627\u0628\u0642\u064E \u0647\u0646\u0627"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: "\u0645\u0631\u062D\u0628\u0627\u064B. \u0647\u0644 \u062A\u0639\u0631\u0641
      \u0623\u064A\u0646 \u0646\u062D\u0646\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: "\u0641\u064A \u062A\u0648\u0631\u0648\u0646"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: "\u0641\u064A \u0648\u0627\u0631\u0633\u0648"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "\u0646\u0639\u0645! \u0627\u0633\u062A\u0645\u0639 \u062C\u064A\u062F\u0627\u064B
      \u0648\u0627\u0642\u0631\u0623 \u0627\u0644\u062D\u0648\u0627\u0631 \u0641\u064A
      \u0647\u0630\u0647 \u0627\u0644\u0644\u0639\u0628\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "\u0644\u062F\u064A\u0646\u0627 \u0645\u0634\u0643\u0644\u0629 \u064A\u062C\u0628
      \u062D\u0644\u0647\u0627. \u0627\u0630\u0647\u0628 \u0625\u0644\u0649 \u062D\u0648\u0631\u064A\u0629
      \u0627\u0644\u0628\u062D\u0631!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: "\u0641\u064A \u0641\u0631\u0648\u062A\u0633\u0648\u0627\u0641"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: "\u0644\u0627 \u0623\u0639\u0631\u0641"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: "\u0646\u062D\u0646 \u0641\u064A \u0648\u0633\u0637 \u0627\u0644\u0645\u062F\u064A\u0646\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "\u0644\u0642\u062F \u062C\u0645\u0639\u062A \u0643\u0644 \u0642\u0637\u0639
      \u0627\u0644\u0633\u064A\u0641! \u0627\u0644\u0622\u0646 \u064A\u0645\u0643\u0646\u0646\u064A
      \u0623\u0646 \u0623\u062C\u0639\u0644\u0647 \u0643\u0627\u0645\u0644\u0627\u064B
      \u0645\u0631\u0629 \u0623\u062E\u0631\u0649!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "\u062A\u064F\u0639\u062F \u062D\u0648\u0631\u064A\u0629 \u0627\u0644\u0628\u062D\u0631
      \u0631\u0645\u0632\u0627\u064B \u0644\u0645\u062F\u064A\u0646\u0629 \u0648\u0627\u0631\u0633\u0648
      \u0648\u062A\u062D\u0645\u064A\u0647\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: "\u0648\u0627\u0644\u0622\u0646 \u062F\u0639\u0648\u0646\u0627 \u0646\u0631\u0649
      \u0645\u0627 \u062A\u062A\u0630\u0643\u0631\u0648\u0646\u0647 \u0645\u0646
      \u0647\u0630\u0647 \u0627\u0644\u0645\u063A\u0627\u0645\u0631\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "\u0627\u0633\u062A\u0643\u0634\u0641 \u0648\u0627\u0631\u0633\u0648
      \u0648\u0627\u0639\u062B\u0631 \u0639\u0644\u0649 \u062C\u0645\u064A\u0639
      \u0623\u062C\u0632\u0627\u0621 \u0627\u0644\u0633\u064A\u0641!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: "\u0627\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "\u0642\u0627\u0645 \u0623\u0646\u062A\u0648\u0631\u0627 \u0628\u062A\u062D\u0637\u064A\u0645
      \u0627\u0644\u0633\u064A\u0641 \u0625\u0644\u0649 7 \u0642\u0637\u0639 \u0648\u0648\u0636\u0639
      \u0643\u0644 \u0642\u0637\u0639\u0629 \u0641\u064A \u0635\u0646\u062F\u0648\u0642
      \u0641\u064A \u0645\u0643\u0627\u0646 \u0645\u0627 \u0641\u064A \u0648\u0627\u0631\u0633\u0648!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: "\u062A\u062D\u062F\u062B \u0625\u0644\u0649 \u062C\u0645\u064A\u0639
      \u0627\u0644\u0623\u0634\u062E\u0627\u0635 \u0630\u0648\u064A \u0627\u0644\u0628\u0634\u0631\u0629
      \u0627\u0644\u062D\u0645\u0631\u0627\u0621."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "\u0648\u0627\u062D\u0635\u0644 \u0639\u0644\u0649 \u062C\u0645\u064A\u0639
      \u0627\u0644\u0645\u0641\u0627\u062A\u064A\u062D \u0644\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "\u062A\u064F\u0633\u0645\u0649 \u062D\u0648\u0631\u064A\u0629 \u0648\u0627\u0631\u0633\u0648
      \u0628\u0627\u0633\u0645 \u0633\u064A\u0631\u064A\u0646\u0643\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "\u0647\u064A \u0646\u0635\u0641 \u0627\u0645\u0631\u0623\u0629
      \u0648\u0646\u0635\u0641 \u0633\u0645\u0643\u0629\u060C \u0648\u062A\u062D\u0645\u0644
      \u0633\u064A\u0641\u0627\u064B \u0648\u062F\u0631\u0639\u0627\u064B."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "\u0623\u0630\u0647\u0628 \u0639\u0627\u062F\u0629\u064B \u0628\u0627\u0644\u062A\u0631\u0627\u0645."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "\u0625\u0644\u064A\u0643 \u0645\u0641\u062A\u0627\u062D!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: "\u0623\u062D\u0628 \u0627\u0644\u0630\u0647\u0627\u0628 \u0628\u0627\u0644\u0633\u064A\u0627\u0631\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "\u0623\u062D\u0628 \u0627\u0644\u062F\u0631\u0627\u062C\u0627\u062A\u060C
      \u0644\u0630\u0644\u0643 \u0623\u062A\u0646\u0642\u0644 \u0628\u0627\u0644\u062F\u0631\u0627\u062C\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: "\u0623\u062D\u0628 \u0627\u0644\u0633\u0641\u0631 \u0628\u0627\u0644\u0642\u0637\u0627\u0631."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: "\u0623\u0639\u062A\u0642\u062F \u0623\u0646 \u0627\u0644\u062D\u0627\u0641\u0644\u0629
      \u0647\u064A \u0627\u0644\u0623\u0641\u0636\u0644."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "\u0644\u0642\u062F \u0648\u062C\u062F\u062A \u062C\u0645\u064A\u0639
      \u0627\u0644\u0645\u0641\u0627\u062A\u064A\u062D! \u0627\u0644\u0622\u0646
      \u0627\u0630\u0647\u0628 \u0648\u0627\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: "\u0627\u0644\u0635\u0646\u062F\u0648\u0642 \u0641\u0627\u0631\u063A."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "\u0644\u0641\u062A\u062D \u0627\u0644\u0635\u0646\u062F\u0648\u0642\u060C
      \u0639\u0644\u064A\u0643 \u062D\u0644 \u0647\u0630\u0627 \u0627\u0644\u0644\u063A\u0632!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "\u0625\u0646\u0647 \u0645\u063A\u0644\u0642. \u0623\u0646\u062A
      \u0628\u062D\u0627\u062C\u0629 \u0625\u0644\u0649 \u062C\u0645\u064A\u0639
      \u0627\u0644\u0645\u0641\u0627\u062A\u064A\u062D!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "\u0644\u0642\u062F \u0648\u062C\u062F\u062A \u0642\u0637\u0639\u0629
      \u0645\u0646 \u0627\u0644\u0633\u064A\u0641!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: "\u062D\u0627\u0648\u0644 \u062B\u0627\u0646\u064A\u0629!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: "\u0627\u0630\u0647\u0628 \u0625\u0644\u0649 \u062A\u0645\u062B\u0627\u0644
      \u0627\u0644\u062D\u0631\u0628 \u0648\u0633\u0627\u0648\u0627 \u0639\u0644\u0649
      \u0636\u0641\u0627\u0641 \u0646\u0647\u0631 \u0641\u064A\u0633\u062A\u0644\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: "\u0648\u0627\u0631\u0633 \u0648\u0633\u0627\u0648\u0627 \u0634\u062E\u0635\u064A\u062A\u0627\u0646
      \u0645\u0646 \u0623\u0633\u0637\u0648\u0631\u0629 \u0642\u062F\u064A\u0645\u0629
      \u0639\u0646 \u0648\u0627\u0631\u0633\u0648."
    m_Metadata:
