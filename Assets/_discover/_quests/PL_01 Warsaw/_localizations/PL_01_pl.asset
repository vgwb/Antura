%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_pl
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: pl
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: Witamy w Warszawie, stolicy Polski!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "\u015Awietna robota. Z\u0142o\u017Cy\u0142e\u015B miecz Syreny!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "Syrena da\u0142a ci pierwszy kawa\u0142ek."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "Wars i Sawa dali ci drugi utw\xF3r."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "Kr\xF3l Zygmunt da\u0142 ci trzeci\u0105 cz\u0119\u015B\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: "W Parlamencie znalaz\u0142e\u015B czwarty element."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "Chopin da\u0142 ci pi\u0105ty utw\xF3r."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "W Pa\u0142acu pomog\u0142e\u015B Marii i znalaz\u0142e\u015B sz\xF3sty
      element."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "Na stadionie zebra\u0142e\u015B ostatni kawa\u0142ek."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: Narysuj swoje ulubione miejsce w Warszawie!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: Jakie kolory ma flaga Polski?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: Niebieski i czerwony.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: "Jeste\u015B pewien?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: "Bia\u0142o-czerwony."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: "Prawid\u0142owy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: "Zielony i bia\u0142y."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: "Kim by\u0142 Chopin?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: "Pi\u0142karz."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: "Kr\xF3l."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: Kompozytor.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "Czym jest rzeka Wis\u0142a?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: "Pa\u0142ac."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: Rzeka.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: "Dobrze. Wiesz wystarczaj\u0105co du\u017Co o Warszawie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: "Nie odpowiedzia\u0142e\u015B poprawnie na wszystkie pytania. Spr\xF3buj
      ponownie!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "Dok\u0105d chcesz i\u015B\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: Centrum
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlament
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: "Pa\u0142ac Kultury"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Stadion
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: "Zosta\u0144 tutaj"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: "Cze\u015B\u0107. Czy wiesz gdzie jeste\u015Bmy?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: W Toruniu
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: W Warszawie
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "Tak! Zawsze uwa\u017Cnie s\u0142uchaj i czytaj dialogi w tej grze."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "Mamy problem do rozwi\u0105zania. Id\u017A do Syrenki!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: "We Wroc\u0142awiu"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: Nie wiem
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: "Jeste\u015Bmy w centrum miasta."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "Zebra\u0142e\u015B wszystkie cz\u0119\u015Bci miecza! Teraz mog\u0119
      go znowu z\u0142o\u017Cy\u0107 w ca\u0142o\u015B\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "Syrena jest symbolem Warszawy i strze\u017Ce miasta."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: "Zobaczmy teraz, co zapami\u0119tali\u015Bcie z tej przygody."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "Zwiedzaj Warszaw\u0119 i znajd\u017A wszystkie cz\u0119\u015Bci
      miecza!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "Antura z\u0142ama\u0142 miecz na 7 cz\u0119\u015Bci i zamkn\u0105\u0142
      ka\u017Cd\u0105 z nich w skrzyni w Warszawie!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: "Porozmawiaj ze wszystkimi czerwonymi lud\u017Ami."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "I zdob\u0105d\u017A wszystkie klucze, aby otworzy\u0107 skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "Warszawska Syrenka nazywana jest Syrenk\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "Jest w po\u0142owie kobiet\u0105, w po\u0142owie ryb\u0105, nosi
      miecz i tarcz\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "Zwykle je\u017Cd\u017C\u0119 tramwajem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: Oto klucz dla Ciebie!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: "Lubi\u0119 je\u017Adzi\u0107 samochodem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "Lubi\u0119 rowery, wi\u0119c je\u017Cd\u017C\u0119 rowerem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: "Uwielbiam podr\xF3\u017Cowa\u0107 poci\u0105giem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: "My\u015Bl\u0119, \u017Ce autobus jest najlepszy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "Znalaz\u0142e\u015B wszystkie klucze! Teraz otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: Skrzynia jest pusta.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "Aby otworzy\u0107 skrzyni\u0119, rozwi\u0105\u017C t\u0119 zagadk\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "Jest zamkni\u0119te. Potrzebujesz wszystkich kluczy!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "Znalaz\u0142e\u015B cz\u0119\u015B\u0107 miecza!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: "Spr\xF3buj ponownie!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: "Udaj si\u0119 do pomnika Warsa i Sawy nad Wis\u0142\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: Wars i Sawa to bohaterowie starej legendy o Warszawie.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: "Ludzie m\xF3wi\u0105, \u017Ce ich imiona s\u0105 ukryte w nazwie
      \u201EWarszawa\u201D."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: "Rzeka Wis\u0142a przep\u0142ywa przez Warszaw\u0119 a\u017C do
      Morza Ba\u0142tyckiego."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: Skrzynia jest otwarta. Kontynuuj!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: "Jestem Wars. Nasz pomnik stoi nad Wis\u0142\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Porozmawiaj z niebieskimi lud\u017Ami nad rzek\u0105 i dowiedz
      si\u0119 wi\u0119cej o naszym mie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: "Wis\u0142a jest najd\u0142u\u017Csz\u0105 rzek\u0105 w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: "Wars i Sawa s\u0105 postaciami ze starej legendy o Warszawie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "Rzeka Wis\u0142a p\u0142ynie a\u017C do Morza Ba\u0142tyckiego."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: "Udaj si\u0119 na Rynek Starego Miasta i porozmawiaj z kr\xF3lem
      Zygmuntem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: "Na placu zn\xF3w zapanowa\u0142 spok\xF3j. Id\u017A dalej i znajd\u017A
      reszt\u0119 miecza!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: "Porozmawiaj z \u017C\xF3\u0142tymi lud\u017Ami na placu i dowiedz
      si\u0119 czego\u015B o naszej historii."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "W 1596 roku kr\xF3l Zygmunt III Waza przeni\xF3s\u0142 stolic\u0119
      Polski z Krakowa do Warszawy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "Jego kolumna na Placu Zamkowym jest jednym z najstarszych pomnik\xF3w
      w Warszawie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: "Zamek Kr\xF3lewski stoi tu\u017C obok kolumny."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: "Zosta\u0142 zniszczony w czasie II wojny \u015Bwiatowej i p\xF3\u017Aniej
      odbudowany."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "Kr\xF3l Zygmunt przeni\xF3s\u0142 stolic\u0119 z Krakowa do Warszawy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: Ta kolumna stoi na placu od bardzo dawna.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: "Zamek Kr\xF3lewski znajduje si\u0119 tu\u017C obok kolumny."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: Dzisiaj prawo w Polsce stanowi parlament.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: "Kontynuuj na wsch\xF3d do Izby Parlamentu."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: "Jeste\u015Bmy przed Parlamentem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: "Flaga jest ju\u017C gotowa. Id\u017A dalej i znajd\u017A reszt\u0119
      miecza!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: Witamy w Sejmie Rzeczypospolitej Polskiej.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: "Porozmawiaj z lud\u017Ami w kolorach czerwonym i \u017C\xF3\u0142tym,
      aby dowiedzie\u0107 si\u0119 wi\u0119cej o naszej fladze i prawach."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: Polski parlament to Sejm i Senat.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: "Spotyka si\u0119 w Warszawie i uchwala prawa dla Polski."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "Pa\u0142ac Prezydencki znajduje si\u0119 nieopodal na Krakowskim
      Przedmie\u015Bciu."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: To tutaj pracuje Prezydent Polski.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: "Polska flaga jest bia\u0142a na g\xF3rze i czerwona na dole."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: "Sejm jest miejscem, w kt\xF3rym ludzie stanowi\u0105 prawo w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: "Konstytucja 3 Maja jest wa\u017Cnym dniem w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: "\u015Awi\u0119to Niepodleg\u0142o\u015Bci w Polsce przypada 11
      listopada."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: "Konstytucja 3 Maja jest wa\u017Cnym dniem w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: Kontynuuj do Pomnika Chopina.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: "Jeste\u015Bmy w Parku Chopina."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: "Parlament nadal potrzebuje twojej pomocy. Udaj si\u0119 tam najpierw."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "Melodia zosta\u0142a przywr\xF3cona. Skrzynia jest twoja."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: "Porozmawiaj z zielonymi lud\u017Ami dooko\u0142a i dowiedz si\u0119
      czego\u015B o Chopinie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: "Fryderyk Chopin urodzi\u0142 si\u0119 pod Warszaw\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "Jest jednym z najs\u0142ynniejszych kompozytor\xF3w na \u015Bwiecie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Pomnik ten stoi w \u0141azienkach Kr\xF3lewskich w Warszawie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: "Chopin urodzi\u0142 si\u0119 w 1810 roku pod Warszaw\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: "Napisa\u0142 s\u0142ynn\u0105 muzyk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: "Latem w ka\u017Cd\u0105 niedziel\u0119 odbywaj\u0105 si\u0119 tutaj
      darmowe koncerty."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Pomnik ten stoi w \u0141azienkach Kr\xF3lewskich w Warszawie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: "Chopin by\u0142 polskim kompozytorem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: "Dobra pr\xF3ba! Wr\xF3\u0107 i zagraj melodi\u0119 jeszcze raz."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: "Teraz udaj si\u0119 do Pa\u0142acu Kultury i Nauki."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: "Jeste\u015Bmy w Pa\u0142acu Kultury."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Znalaz\u0142e\u015B m\xF3j portfel. Skrzynia jest otwarta. Dzi\u0119kuj\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: "Porozmawiaj z fioletowymi lud\u017Ami w pobli\u017Cu Pa\u0142acu."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "Pa\u0142ac Kultury i Nauki jest najwy\u017Cszym budynkiem w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "Zbudowano go w latach 50. XX wieku, a z jego szczytu roztacza si\u0119
      wspania\u0142y widok."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie by\u0142a polsk\u0105 naukowcem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: "By\u0142a pierwsz\u0105 kobiet\u0105, kt\xF3ra otrzyma\u0142a Nagrod\u0119
      Nobla. Otrzyma\u0142a ich dwie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Maria Sk\u0142odowska-Curie urodzi\u0142a si\u0119 w Warszawie
      w 1867 roku."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: "By\u0142a pierwsz\u0105 kobiet\u0105, kt\xF3ra otrzyma\u0142a Nagrod\u0119
      Nobla."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: "Z\u0142oty jest walut\u0105 u\u017Cywan\u0105 w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie by\u0142a wielkim polskim naukowcem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: "Przejd\u017A przez rzek\u0119 i udaj si\u0119 na Stadion Narodowy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: "Jeste\u015Bmy na stadionie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: "\u015Awietna robota na stadionie! Wr\xF3\u0107 do Syrenki ze wszystkimi
      elementami."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: "Otw\xF3rz skrzyni\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: Jestem Robert Lewandowski. Witamy na Stadionie Narodowym!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: "Porozmawiaj z niebieskimi lud\u017Ami na stadionie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: "Stadion Narodowy po\u0142o\u017Cony jest na prawym brzegu Wis\u0142y."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: "Stadion otwarto w 2012 roku i odbywa\u0142y si\u0119 na nim wa\u017Cne
      mecze pi\u0142ki no\u017Cnej."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski jest jednym z najs\u0142ynniejszych polskich
      pi\u0142karzy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: "Strzeli\u0142 wiele bramek dla swoich dru\u017Cyn i dla Polski."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: "Stadion Narodowy zosta\u0142 otwarty w 2012 roku."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: "Pi\u0142ka no\u017Cna jest jednym z najpopularniejszych sport\xF3w
      w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: "Lewandowski strzeli\u0142 wiele goli dla Polski."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "Mazurek D\u0105browskiego jest hymnem Polski."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: "Pi\u0142ka no\u017Cna jest tu jednym z najpopularniejszych sport\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: "Pi\u0142k\u0105 nazywamy to, co zawodnicy kopi\u0105 przez boisko."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: Celem jest zdobycie gola przez graczy.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "Boisko do pi\u0142ki no\u017Cnej to miejsce, na kt\xF3rym rozgrywany
      jest mecz."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "Mazurek D\u0105browskiego jest hymnem Polski."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "Si\xF3dmy element miecza jest tw\xF3j! Masz wszystkie siedem element\xF3w!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: "Wr\xF3\u0107 do Syreny i z\u0142\xF3\u017C miecz na nowo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: "Przez Warszaw\u0119 przep\u0142ywa rzeka Wis\u0142a."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: Syrena jest symbolem miasta.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: "Chopin by\u0142 znanym polskim kompozytorem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "Kr\xF3l Zygmunt przeni\xF3s\u0142 stolic\u0119 do Warszawy."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: Prawo jest stanowione w parlamencie.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: "Flaga Polski jest bia\u0142o-czerwona."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie by\u0142a naukowcem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: "Dzie\u0144 Niepodleg\u0142o\u015Bci przypada 11 listopada."
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "Opowiedz\u0105 Ci, jak ludzie podr\xF3\u017Cuj\u0105 po mie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: "Dowiedz si\u0119 wi\u0119cej o nauce i z\u0142otym."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
