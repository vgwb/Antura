%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: "Bienvenue \xE0 Varsovie, la capitale de la Pologne !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "Excellent travail ! Vous avez reconstitu\xE9 l'\xE9p\xE9e de la
      sir\xE8ne !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "La sir\xE8ne t'a donn\xE9 le premier morceau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "Wars et Sawa vous ont donn\xE9 la deuxi\xE8me pi\xE8ce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "Le roi Sigismond vous a donn\xE9 le troisi\xE8me morceau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: "Au Parlement, vous avez trouv\xE9 la quatri\xE8me pi\xE8ce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "Chopin vous a donn\xE9 le cinqui\xE8me morceau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "Au palais, vous avez aid\xE9 Maria et trouv\xE9 la sixi\xE8me pi\xE8ce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "Au stade, vous avez r\xE9cup\xE9r\xE9 la derni\xE8re pi\xE8ce."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: "Dessine ton endroit pr\xE9f\xE9r\xE9 \xE0 Varsovie !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: Quelles sont les couleurs du drapeau polonais ?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: Bleu et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: "Es-tu s\xFBr?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: Blanc et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: Correct.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: Vert et blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: "Qui \xE9tait Chopin ?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: Un joueur de football.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: Un roi.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: Un compositeur.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "Qu'est-ce que la rivi\xE8re Wis\u0142a ?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: Un palais.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Un stade.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: "Une rivi\xE8re."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: Bravo. Vous en savez assez sur Varsovie.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: "Vous n'avez pas r\xE9pondu correctement \xE0 toutes les questions.
      R\xE9essayez !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "O\xF9 veux-tu aller ?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: Centre
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlement
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: Palais de la Culture
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Stade
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: Restez ici
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: "Bonjour. Savez-vous o\xF9 nous sommes ?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: "\xC0 Torun"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: "\xC0 Varsovie"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "Oui ! \xC9coutez attentivement et lisez toujours les dialogues
      dans ce jeu."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "Nous avons un probl\xE8me \xE0 r\xE9soudre. Allez voir la Sir\xE8ne
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: "\xC0 Wroclaw"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: Je ne sais pas
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: Nous sommes en centre-ville.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "Tu as rassembl\xE9 tous les morceaux de l'\xE9p\xE9e ! Maintenant,
      je peux la reconstituer !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "La sir\xE8ne est un symbole de Varsovie et prot\xE8ge la ville."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: Voyons maintenant ce dont vous vous souvenez de cette aventure.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "Explorez Varsovie et retrouvez tous les morceaux de l'\xE9p\xE9e
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "Antura a bris\xE9 l'\xE9p\xE9e en 7 morceaux et a enferm\xE9 chacun
      d'eux dans un coffre \xE0 travers Varsovie !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: "Parlez \xE0 tous les rouges."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "Et r\xE9cup\xE9rez toutes les cl\xE9s pour ouvrir le coffre !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "La sir\xE8ne de Varsovie s'appelle la Syrenka."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "Elle est mi-femme, mi-poisson, et porte une \xE9p\xE9e et un bouclier."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "Je prends g\xE9n\xE9ralement le tram."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "Voici une cl\xE9 pour vous !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: "J'aime me d\xE9placer en voiture."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "J'aime les v\xE9los, donc je me d\xE9place \xE0 v\xE9lo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: J'adore voyager en train.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: Je pense que le bus est la meilleure solution.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "Vous avez trouv\xE9 toutes les cl\xE9s ! Maintenant, ouvrez le
      coffre !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: Le coffre est vide.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "Pour ouvrir le coffre, r\xE9solvez cette \xE9nigme !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "C'est verrouill\xE9. Il vous faut toutes les cl\xE9s !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "Vous avez trouv\xE9 un morceau de l'\xE9p\xE9e !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: "Essayer \xE0 nouveau!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: "Rendez-vous \xE0 la statue de Wars et Sawa, au bord de la rivi\xE8re
      Vistule."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: "Wars et Sawa sont des personnages d'une vieille l\xE9gende sur
      Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: "Certains disent que leurs noms sont cach\xE9s \xE0 l'int\xE9rieur
      du nom \xAB\_Varsovie\_\xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: "La rivi\xE8re Vistule traverse Varsovie jusqu'\xE0 la mer Baltique."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: Le coffre est ouvert. Continuez !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: Je suis Wars. Notre statue se dresse au bord de la Vistule.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Parlez aux personnes en bleu au bord de la rivi\xE8re et apprenez-en
      plus sur notre ville."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: La Vistule est le plus long fleuve de Pologne.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: "Wars et Sawa sont issus d'une vieille l\xE9gende sur Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "La rivi\xE8re Vistule se jette dans la mer Baltique."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: Rendez-vous sur la place de la vieille ville et parlez au roi Sigismond.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: "La place est de nouveau calme. Continuez et trouvez le reste de
      l'\xE9p\xE9e !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: Parlez aux personnes en jaune sur la place et apprenez-en plus sur
      notre histoire.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "Le roi Sigismond III Vasa a transf\xE9r\xE9 la capitale de la Pologne
      de Cracovie \xE0 Varsovie en 1596."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "Sa colonne sur la place du Ch\xE2teau est l'un des plus anciens
      monuments de Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: "Le ch\xE2teau royal se dresse juste \xE0 c\xF4t\xE9 de la colonne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: "Il fut d\xE9truit pendant la Seconde Guerre mondiale et reconstruit
      par la suite."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "Le roi Sigismond a transf\xE9r\xE9 la capitale de Cracovie \xE0
      Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: "Cette colonne se dresse sur la place depuis tr\xE8s longtemps."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: "Le ch\xE2teau royal se trouve juste \xE0 c\xF4t\xE9 de la colonne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: Aujourd'hui, c'est le Parlement qui fait les lois en Pologne.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: Continuez vers l'est jusqu'au Parlement.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: Nous sommes devant le Parlement.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: "Le drapeau est tri\xE9. Continuez et trouvez le reste de l'\xE9p\xE9e
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: Bienvenue au Parlement polonais.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: Discutez avec les personnes en rouge et en jaune pour en apprendre
      davantage sur notre drapeau et nos lois.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: "Le parlement polonais s'appelle la Sejm et le S\xE9nat."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: "Elle se r\xE9unit \xE0 Varsovie et \xE9labore les lois pour la
      Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "Le palais pr\xE9sidentiel se trouve \xE0 proximit\xE9, sur Krakowskie
      Przedmie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: "C'est l\xE0 que travaille le pr\xE9sident de la Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: Le drapeau polonais est blanc en haut et rouge en bas.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: "La Di\xE8te (Sejm) est l'assembl\xE9e qui \xE9labore les lois en
      Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: La Constitution du 3 mai est une date importante en Pologne.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: "La f\xEAte nationale polonaise est c\xE9l\xE9br\xE9e le 11 novembre."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: La Constitution du 3 mai est une date importante en Pologne.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: Continuez jusqu'au monument Chopin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: Nous sommes au parc Chopin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: Le Parlement a encore besoin de votre aide. Allez-y en premier.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "La m\xE9lodie est r\xE9tablie. Le coffre est \xE0 vous."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: "Parlez aux \xE9cologistes autour de vous et renseignez-vous sur
      Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: "Fr\xE9d\xE9ric Chopin est n\xE9 pr\xE8s de Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "Il est l'un des compositeurs les plus c\xE9l\xE8bres au monde."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Ce monument se trouve dans le parc \u0141azienki \xE0 Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: "Chopin est n\xE9 pr\xE8s de Varsovie en 1810."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: "Il a compos\xE9 des musiques c\xE9l\xE8bres."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: "Des concerts gratuits sont organis\xE9s ici tous les dimanches
      d'\xE9t\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Ce monument se trouve dans le parc \u0141azienki \xE0 Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: "Chopin \xE9tait un compositeur polonais."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: "Bien essay\xE9 ! Reviens et rejoue la m\xE9lodie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: Maintenant, rendez-vous au Palais de la Culture et de la Science.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: Nous sommes au Palais de la Culture.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Vous avez trouv\xE9 mon portefeuille. Le coffre est ouvert. Merci
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: Parlez aux personnes en violet autour du Palais.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "Le Palais de la Culture et de la Science est le plus haut b\xE2timent
      de Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "Il a \xE9t\xE9 construit dans les ann\xE9es 1950 et offre une vue
      imprenable depuis son sommet."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie \xE9tait une scientifique polonaise."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: "Elle fut la premi\xE8re femme \xE0 remporter un prix Nobel, et
      elle en a remport\xE9 deux."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Maria Sk\u0142odowska-Curie est n\xE9e \xE0 Varsovie en 1867."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: "Elle fut la premi\xE8re femme \xE0 remporter un prix Nobel."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: "Le z\u0142oty est la monnaie utilis\xE9e en Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie \xE9tait une grande scientifique polonaise."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: "Traversez la rivi\xE8re et rendez-vous au Stade national."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: Nous sommes au stade.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: "Super boulot au stade ! Retourne \xE0 la Sir\xE8ne avec toutes
      les pi\xE8ces."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: Ouvrez le coffre !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: Je suis Robert Lewandowski. Bienvenue au Stade national !
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: Parlez aux personnes en bleu autour du stade.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: Le Stade national se dresse sur la rive droite de la Vistule.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: Il a ouvert ses portes en 2012 et a accueilli de grands matchs de
      football.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski est l'un des footballeurs polonais les plus
      c\xE9l\xE8bres."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: "Il a marqu\xE9 de nombreux buts pour ses \xE9quipes et pour la
      Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: Le Stade national a ouvert ses portes en 2012.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: Le football est l'un des sports les plus populaires en Pologne.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: "Lewandowski a marqu\xE9 de nombreux buts pour la Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "Le Mazurek D\u0105browskiego est l'hymne national de la Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: Le football est l'un des sports les plus populaires ici.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: Le ballon est ce que les joueurs envoient au pied sur le terrain.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: "Le but est l'endroit o\xF9 les joueurs tentent de marquer."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "Le terrain de football est le lieu o\xF9 se d\xE9roule le match."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "Mazurek D\u0105browskiego est l'hymne national de la Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "La septi\xE8me pi\xE8ce d'\xE9p\xE9e est \xE0 vous ! Vous avez
      les 7 pi\xE8ces !"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: "Retournez voir la Sir\xE8ne et r\xE9assemblez l'\xE9p\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: "La rivi\xE8re Vistule traverse Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: "La sir\xE8ne est un symbole de la ville."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: "Chopin \xE9tait un c\xE9l\xE8bre compositeur polonais."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "Le roi Sigismond a transf\xE9r\xE9 la capitale \xE0 Varsovie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: "C'est au Parlement que les lois sont \xE9labor\xE9es."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: Le drapeau polonais est blanc et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie \xE9tait une scientifique."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: "La f\xEAte de l'ind\xE9pendance est le 11 novembre."
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "Ils vous expliqueront comment les gens se d\xE9placent en ville."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: "D\xE9couvrez la science et le z\u0142oty."
    m_Metadata:
      m_Items: []
