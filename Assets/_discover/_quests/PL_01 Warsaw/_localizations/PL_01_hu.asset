%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_hu
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: hu
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk Vars\xF3ban, Lengyelorsz\xE1g f\u0151v\xE1ros\xE1ban!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "Nagyszer\u0171 munka. \xDAjra \xF6sszeraktad a sell\u0151 kardj\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "A sell\u0151 adta neked az els\u0151 darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "A Wars \xE9s Sawa adta neked a m\xE1sodik darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "Zsigmond kir\xE1ly neked adta a harmadik darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: "A Parlamentben megtal\xE1ltad a negyedik darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "Chopin adta neked az \xF6t\xF6dik darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "A Palot\xE1ban seg\xEDtett\xE9l Mari\xE1nak \xE9s megtal\xE1ltad
      a hatodik darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "A stadionban begy\u0171jt\xF6tted az utols\xF3 darabot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: "Rajzold le a kedvenc vars\xF3i helyedet!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: "Milyen sz\xEDnek vannak a lengyel z\xE1szl\xF3n?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: "K\xE9k \xE9s piros."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: Biztos vagy benne?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: "Feh\xE9r \xE9s piros."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: Helyes.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: "Z\xF6ld \xE9s feh\xE9r."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: Ki volt Chopin?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: Egy futballista.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: "Egy kir\xE1ly."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: "Egy zeneszerz\u0151."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "Mi a Visztula foly\xF3?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: Egy palota.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Egy stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: "Egy foly\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: "Sz\xE9p munka. Eleget tudsz Vars\xF3r\xF3l."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: "Nem v\xE1laszolt\xE1l helyesen minden k\xE9rd\xE9sre. Pr\xF3b\xE1ld
      \xFAjra!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "Hov\xE1 akarsz menni?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: "K\xF6zpont"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlament
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: "Kult\xFArpalota"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Stadion
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: Maradj itt
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: Szia. Tudod, hol vagyunk?
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: "Toru\u0144ban"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: "Vars\xF3ban"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "Igen! Ebben a j\xE1t\xE9kban mindig figyelmesen figyelj \xE9s olvasd
      el a p\xE1rbesz\xE9deket."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "Van egy megoldand\xF3 probl\xE9m\xE1nk. Menj a sell\u0151h\xF6z!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: "Wroc\u0142awban"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: Nem tudom
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: "A v\xE1rosk\xF6zpontban vagyunk."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "\xD6sszegy\u0171jt\xF6tted a kard \xF6sszes darabj\xE1t! Most m\xE1r
      \xFAjra eg\xE9ssz\xE9 tehetem!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "A sell\u0151 Vars\xF3 jelk\xE9pe \xE9s v\xE9delmez\u0151je."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: "Most pedig n\xE9zz\xFCk, mire eml\xE9kszel ebb\u0151l a kalandb\xF3l."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "Fedezd fel Vars\xF3t \xE9s tal\xE1ld meg a kard \xF6sszes darabj\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "Antura h\xE9t darabra t\xF6rte a kardot, \xE9s mindegyiket egy
      l\xE1d\xE1ba z\xE1rta Vars\xF3 t\xFAloldal\xE1n!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: "Besz\xE9lj az \xF6sszes v\xF6r\xF6s emberrel."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "\xC9s szerezd meg az \xF6sszes kulcsot a l\xE1da kinyit\xE1s\xE1hoz!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "A vars\xF3i sell\u0151t Syrenka n\xE9ven ismerik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "F\xE9lig n\u0151, f\xE9lig hal, kardot \xE9s pajzsot hord a kez\xE9ben."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "\xC1ltal\xE1ban villamossal j\xE1rok."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "Itt egy kulcs a sz\xE1modra!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: "Szeretek aut\xF3val j\xE1rni."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "Szeretek biciklizni, ez\xE9rt biciklivel j\xE1rok."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: "Im\xE1dok vonattal utazni."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: Szerintem a busz a legjobb.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "Megtal\xE1ltad az \xF6sszes kulcsot! Most nyisd ki a l\xE1d\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: "A mellkas \xFCres."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "A l\xE1da kinyit\xE1s\xE1hoz oldd meg ezt a rejtv\xE9nyt!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "Z\xE1rva van. Minden kulcsra sz\xFCks\xE9ged van!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "Tal\xE1lt\xE1l egy darabot a kardb\xF3l!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: "Pr\xF3b\xE1ld \xFAjra!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: "Menj el a H\xE1bor\xFAk \xE9s Sawa szoborhoz a Visztula foly\xF3n\xE1l."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: "A Wars \xE9s a Sawa egy r\xE9gi vars\xF3i legenda szerepl\u0151i."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: "Azt mondj\xE1k, hogy a nev\xFCk a \"Warszawa\" n\xE9vben rejlik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: "A Visztula foly\xF3 Vars\xF3n kereszt\xFCl folyik eg\xE9szen a
      Balti-tengerig."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: "A mellkas nyitva van. Csak \xEDgy tov\xE1bb!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: "\xC9n vagyok a H\xE1bor\xFAk. Szoborunk a Visztula foly\xF3 partj\xE1n
      \xE1ll."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Besz\xE9lgess a foly\xF3parti k\xE9k emberekkel, \xE9s ismerd meg
      a v\xE1rosunkat."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: "A Visztula foly\xF3 Lengyelorsz\xE1g leghosszabb foly\xF3ja."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: "A h\xE1bor\xFAk \xE9s a Sawa egy r\xE9gi vars\xF3i legend\xE1b\xF3l
      sz\xE1rmaznak."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "A Visztula foly\xF3 eg\xE9szen a Balti-tengerig folyik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: "Menj az \xD3v\xE1ros t\xE9rre \xE9s besz\xE9lj Zsigmond kir\xE1llyal."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: "A t\xE9r ism\xE9t b\xE9k\xE9s. Menj tov\xE1bb, \xE9s keresd meg
      a kard t\xF6bbi r\xE9sz\xE9t!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: "Besz\xE9lgess a t\xE9ren l\xE9v\u0151 s\xE1rga emberekkel, \xE9s
      ismerd meg a t\xF6rt\xE9nelm\xFCnket."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "III. Zsigmond kir\xE1ly 1596-ban Krakk\xF3b\xF3l Vars\xF3ba helyezte
      \xE1t Lengyelorsz\xE1g f\u0151v\xE1ros\xE1t."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "A V\xE1r t\xE9ren \xE1ll\xF3 oszlopa Vars\xF3 egyik legr\xE9gebbi
      eml\xE9km\u0171ve."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: "A kir\xE1lyi v\xE1r k\xF6zvetlen\xFCl az oszlop mellett \xE1ll."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: "A m\xE1sodik vil\xE1gh\xE1bor\xFAban elpusztult, majd k\xE9s\u0151bb
      \xFAjj\xE1\xE9p\xEDtett\xE9k."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "Zsigmond kir\xE1ly Krakk\xF3b\xF3l Vars\xF3ba helyezte \xE1t a
      f\u0151v\xE1rost."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: "Ez az oszlop m\xE1r nagyon r\xE9g\xF3ta \xE1ll a t\xE9ren."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: "A kir\xE1lyi v\xE1r k\xF6zvetlen\xFCl az oszlop mellett tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: "Ma a parlament alkotja meg a lengyel t\xF6rv\xE9nyeket."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: "Folytassa utj\xE1t kelet fel\xE9 a Parlamenthez."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: "A Parlament el\u0151tt \xE1llunk."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: "A z\xE1szl\xF3 rendezve. Menj tov\xE1bb, \xE9s keresd meg a kard
      t\xF6bbi r\xE9sz\xE9t is!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk a lengyel parlamentben."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: "Besz\xE9lj a piros \xE9s s\xE1rga emberekkel, hogy t\xF6bbet megtudj
      a z\xE1szl\xF3nkr\xF3l \xE9s a t\xF6rv\xE9nyeinkr\u0151l."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: "A lengyel parlamentet Szejmnek \xE9s Szen\xE1tusnak nevezik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: "Vars\xF3ban \xFCl\xE9sezik \xE9s t\xF6rv\xE9nyeket alkot Lengyelorsz\xE1g
      sz\xE1m\xE1ra."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "Az eln\xF6ki palota a Krakowskie Przedmie\u015Bcie k\xF6zel\xE9ben
      tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: "Itt dolgozik a lengyel eln\xF6k."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: "A lengyel z\xE1szl\xF3 fel\xFCl feh\xE9r, alul piros."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: "A Szejm az a hely, ahol az emberek t\xF6rv\xE9nyeket hoznak Lengyelorsz\xE1gban."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: "A m\xE1jus 3-i alkotm\xE1ny fontos nap Lengyelorsz\xE1gban."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: "Lengyelorsz\xE1gban november 11-\xE9n van a f\xFCggetlens\xE9g
      napja."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: "A m\xE1jus 3-i alkotm\xE1ny fontos nap Lengyelorsz\xE1gban."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: "Tov\xE1bb a Chopin-eml\xE9km\u0171h\xF6z."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: A Chopin parkban vagyunk.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: "A Parlamentnek tov\xE1bbra is sz\xFCks\xE9ge van a seg\xEDts\xE9gedre.
      El\u0151sz\xF6r menj oda."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "A dallam helyre\xE1llt. A l\xE1da a ti\xE9d."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: "Besz\xE9lgess a k\xF6rny\xE9kbeli z\xF6ld emberekkel, \xE9s ismerd
      meg Chopint."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: "Fryderyk Chopin Vars\xF3 k\xF6zel\xE9ben sz\xFCletett."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "\u0150 a vil\xE1g egyik legh\xEDresebb zeneszerz\u0151je."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Ez az eml\xE9km\u0171 a vars\xF3i \u0141azienki parkban \xE1ll."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: "Chopin 1810-ben sz\xFCletett Vars\xF3 k\xF6zel\xE9ben."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: "H\xEDres zen\xE9t \xEDrt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: "Ny\xE1ron minden vas\xE1rnap ingyenes koncerteket tartanak itt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Ez az eml\xE9km\u0171 a vars\xF3i \u0141azienki parkban \xE1ll."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: "Chopin lengyel zeneszerz\u0151 volt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: "J\xF3 pr\xF3b\xE1lkoz\xE1s! Gyere vissza, \xE9s j\xE1tsszd el \xFAjra
      a dallamot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: "Most menj a Kult\xFAra \xE9s Tudom\xE1ny Palot\xE1j\xE1ba."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: "A Kult\xFArpalot\xE1ban vagyunk."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Megtal\xE1ltad a p\xE9nzt\xE1rc\xE1mat. A l\xE1da nyitva van. K\xF6sz\xF6n\xF6m!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: "Besz\xE9lj a palota k\xF6r\xFCli lila emberekkel."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "A Kult\xFAra \xE9s Tudom\xE1ny Palot\xE1ja Lengyelorsz\xE1g legmagasabb
      \xE9p\xFClete."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "Az 1950-es \xE9vekben \xE9p\xFClt, \xE9s fel\xFClr\u0151l gy\xF6ny\xF6r\u0171
      kil\xE1t\xE1s ny\xEDlik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie lengyel tud\xF3s volt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: "\u0150 volt az els\u0151 n\u0151, aki Nobel-d\xEDjat nyert, \xE9s
      kett\u0151t is nyert."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Maria Sk\u0142odowska-Curie 1867-ben sz\xFCletett Vars\xF3ban."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: "\u0150 volt az els\u0151 n\u0151, aki Nobel-d\xEDjat nyert."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: "A z\u0142oty a Lengyelorsz\xE1gban haszn\xE1lt p\xE9nznem."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie nagyszer\u0171 lengyel tud\xF3s volt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: "Menj \xE1t a foly\xF3n, \xE9s menj a Nemzeti Stadionba."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: A stadionban vagyunk.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: "Nagyszer\u0171 munka a stadionban! T\xE9rj vissza a sell\u0151h\xF6z
      az \xF6sszes darabbal egy\xFCtt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: Nyisd ki a mellkast!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: "Robert Lewandowski vagyok. \xDCdv\xF6zl\xF6m a Nemzeti Stadionban!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: "Besz\xE9lj a stadion k\xF6r\xFCli k\xE9k emberekkel."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: "A Nemzeti Stadion a Visztula jobb partj\xE1n \xE1ll."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: "2012-ben ny\xEDlt meg, \xE9s nagy futballmeccseknek adott otthont."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski Lengyelorsz\xE1g egyik legh\xEDresebb labdar\xFAg\xF3ja."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: "Sok g\xF3lt szerzett a csapatainak \xE9s Lengyelorsz\xE1gnak is."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: "A Nemzeti Stadion 2012-ben ny\xEDlt meg."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: "A futball az egyik legn\xE9pszer\u0171bb sport Lengyelorsz\xE1gban."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: "Lewandowski sok g\xF3lt szerzett Lengyelorsz\xE1g sz\xEDneiben."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "A Mazurek D\u0105browskiego Lengyelorsz\xE1g nemzeti himnusza."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: "A futball az egyik legn\xE9pszer\u0171bb sport\xE1g itt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: "A labda az, amit a j\xE1t\xE9kosok \xE1tr\xFAgnak a p\xE1ly\xE1n."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: "A g\xF3l az, ahol a j\xE1t\xE9kosok megpr\xF3b\xE1lnak pontot szerezni."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "A futballp\xE1lya az a hely, ahol a m\xE9rk\u0151z\xE9st j\xE1tssz\xE1k."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "A Mazurek D\u0105browskiego Lengyelorsz\xE1g nemzeti himnusza."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "A hetedik karddarab a ti\xE9d! Mind a 7 darab megvan!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: "T\xE9rj vissza a sell\u0151h\xF6z, \xE9s szereld \xF6ssze \xFAjra
      a kardot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: "A Visztula foly\xF3 Vars\xF3n kereszt\xFCl folyik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: "A sell\u0151 a v\xE1ros jelk\xE9pe."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: "Chopin h\xEDres lengyel zeneszerz\u0151 volt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "Zsigmond kir\xE1ly Vars\xF3ba helyezte \xE1t a f\u0151v\xE1rost."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: "A Parlament az a hely, ahol a t\xF6rv\xE9nyeket hozz\xE1k."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: "A lengyel z\xE1szl\xF3 feh\xE9r \xE9s piros."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie tud\xF3s volt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: "A f\xFCggetlens\xE9g napja november 11-\xE9n van."
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "El fogj\xE1k mondani, hogyan k\xF6zlekednek az emberek a v\xE1rosban."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: "Ismerd meg a tudom\xE1nyt \xE9s a z\u0142oty-t."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
