%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_it
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: it
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: Benvenuti a Varsavia, la capitale della Polonia!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: Ottimo lavoro! Hai riassemblato la spada della Sirena!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: La Sirena ti ha dato il primo pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: Wars e Sawa ti hanno dato il secondo pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: Re Sigismondo ti ha dato il terzo pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: In Parlamento hai trovato il quarto pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: Chopin ti ha dato il quinto pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: Al palazzo hai aiutato Maria e hai ritrovato il sesto pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: Allo stadio hai raccolto l'ultimo pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: Disegna il tuo luogo preferito a Varsavia!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: Quali sono i colori della bandiera polacca?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: Blu e rosso.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: Sei sicuro?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: Bianco e rosso.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: Corretto.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: Verde e bianco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: Chi era Chopin?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: Un giocatore di calcio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: Un re.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: Un compositore.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "Cos'\xE8 il fiume Wis\u0142a?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: Un palazzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Uno stadio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: Un fiume.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: Ottimo lavoro. Conosci bene Varsavia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: Non hai risposto correttamente a tutte le domande. Riprova!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: Dove vuoi andare?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: Centro
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlamento
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: Palazzo della Cultura
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Stadio
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: Resta qui
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: Ciao. Sai dove ci troviamo?
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: A Torun
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: A Varsavia
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "S\xEC! Ascolta sempre attentamente e leggi i dialoghi in questo
      gioco."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: Abbiamo un problema da risolvere. Vai dalla Sirena!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: A Breslavia
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: Non lo so
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: "Ci troviamo nel centro della citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: Hai raccolto tutti i pezzi della spada! Ora posso ricomporla!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "La sirena \xE8 un simbolo di Varsavia e protegge la citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: Ora vediamo cosa ricordi di questa avventura.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: Esplora Varsavia e trova tutti i pezzi della spada!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "Antura spezz\xF2 la spada in 7 pezzi e rinchiuse ciascuno di essi
      in uno scrigno in giro per Varsavia!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: Parla con tutte le persone rosse.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: E procurati tutte le chiavi per aprire lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: La siepe di Varsavia si chiama Syrenka.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "\xC8 met\xE0 donna e met\xE0 pesce, e porta con s\xE9 una spada
      e uno scudo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: Di solito prendo il tram.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: Ecco una chiave per te!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: Mi piace andare in macchina.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: Mi piacciono le biciclette, quindi mi sposto in bicicletta.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: Adoro viaggiare in treno.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: Penso che l'autobus sia il mezzo migliore.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: Hai trovato tutte le chiavi! Ora vai ad aprire lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: "La cassa \xE8 vuota."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: Per aprire lo scrigno, risolvi questo enigma!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "\xC8 chiuso a chiave. Servono tutte le chiavi!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: Hai trovato un frammento della spada!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: Riprova!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: Recatevi alla statua di Wars e Sawa presso il fiume Vistola.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: Guerra e Sawa sono personaggi di un'antica leggenda ambientata a
      Varsavia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: Si dice che i loro nomi siano nascosti all'interno del nome "Varsavia".
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: Il fiume Vistola attraversa Varsavia e sfocia nel Mar Baltico.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: "Lo scrigno \xE8 aperto. Continua!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: Io sono la Guerra. La nostra statua si erge sulle rive del fiume
      Vistola.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Parla con le persone vestite di blu in riva al fiume e scopri di
      pi\xF9 sulla nostra citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: "Il fiume Vistola \xE8 il fiume pi\xF9 lungo della Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: Le guerre e Sawa provengono da un'antica leggenda su Varsavia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "Il fiume Wis\u0142a scorre fino al Mar Baltico."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: "Recatevi nella Piazza della Citt\xE0 Vecchia e parlate con il re
      Sigismondo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: "La piazza \xE8 di nuovo tranquilla. Continuate ad andare avanti
      e trovate il resto della spada!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: Parla con le persone vestite di giallo nella piazza e scopri la
      nostra storia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "Nel 1596, il re Sigismondo III Vasa trasfer\xEC la capitale della
      Polonia da Cracovia a Varsavia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "La sua colonna in Piazza del Castello \xE8 uno dei monumenti pi\xF9
      antichi di Varsavia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: Il Castello Reale sorge proprio accanto alla colonna.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: Fu distrutta durante la seconda guerra mondiale e ricostruita in
      seguito.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "Il re Sigismondo trasfer\xEC la capitale da Cracovia a Varsavia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: Questa colonna si erge nella piazza da moltissimo tempo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: Il Castello Reale si trova proprio accanto alla colonna.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: Oggi, il Parlamento emana le leggi per la Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: Proseguite verso est fino al Parlamento.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: Ci troviamo di fronte al Parlamento.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: "La bandiera \xE8 stata recuperata. Continuate a cercare e trovate
      il resto della spada!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: Benvenuti al Parlamento polacco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: Parla con le persone vestite di rosso e giallo per conoscere la
      nostra bandiera e le nostre leggi.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: Il parlamento polacco si chiama Sejm e Senato.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: Si riunisce a Varsavia e promulga le leggi per la Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "Il Palazzo Presidenziale si trova vicino a Krakowskie Przedmie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: "\xC8 l\xEC che lavora il Presidente della Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: "La bandiera polacca \xE8 bianca nella parte superiore e rossa in
      quella inferiore."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: "Il Sejm \xE8 il parlamento polacco dove vengono promulgate le leggi."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: "La Costituzione del 3 maggio \xE8 una data importante in Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: In Polonia, la festa dell'indipendenza si celebra l'11 novembre.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: "La Costituzione del 3 maggio \xE8 una data importante in Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: Proseguite fino al monumento a Chopin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: Ci troviamo al Parco Chopin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: "Il Parlamento ha ancora bisogno del tuo aiuto. Vai prima l\xEC."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "La melodia \xE8 stata ripristinata. Il forziere \xE8 tuo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: "Parla con le persone che vivono in campagna e scopri di pi\xF9
      su Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: Fryderyk Chopin nacque nei pressi di Varsavia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "\xC8 uno dei compositori pi\xF9 famosi al mondo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Questo monumento si trova nel Parco \u0141azienki a Varsavia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: Chopin nacque vicino a Varsavia nel 1810.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: Ha scritto musica famosa.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: Qui si tengono concerti gratuiti ogni domenica d'estate.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Questo monumento si trova nel Parco \u0141azienki a Varsavia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: Chopin era un compositore polacco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: Ottimo tentativo! Torna e suona di nuovo la melodia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: Ora recatevi al Palazzo della Cultura e della Scienza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: Ci troviamo al Palazzo della Cultura.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Hai trovato il mio portafoglio. Il forziere \xE8 aperto. Grazie!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: Parla con le persone vestite di viola che si trovano intorno al
      Palazzo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "Il Palazzo della Cultura e della Scienza \xE8 l'edificio pi\xF9
      alto della Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "\xC8 stata costruita negli anni '50 e offre una vista magnifica
      dalla cima."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie era una scienziata polacca."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: "\xC8 stata la prima donna a vincere un premio Nobel, e ne ha vinti
      due."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Maria Sk\u0142odowska-Curie nacque a Varsavia nel 1867."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: "\xC8 stata la prima donna a vincere un premio Nobel."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: "Lo zloty \xE8 la valuta utilizzata in Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie \xE8 stata una grande scienziata polacca."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: Attraversa il fiume e vai allo Stadio Nazionale.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: Siamo allo stadio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: Ottimo lavoro allo stadio! Tornate alla Sirena con tutti i pezzi.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: Apri lo scrigno!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: Sono Robert Lewandowski. Benvenuti allo Stadio Nazionale!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: Parla con le persone vestite di blu che si trovano intorno allo
      stadio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: Lo Stadio Nazionale sorge sulla riva destra della Vistola.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: "\xC8 stato inaugurato nel 2012 e ha ospitato importanti partite
      di calcio."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski \xE8 uno dei calciatori polacchi pi\xF9 famosi."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: Ha segnato molti gol per le sue squadre e per la Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: "Lo Stadio Nazionale \xE8 stato inaugurato nel 2012."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: "Il calcio \xE8 uno degli sport pi\xF9 popolari in Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: Lewandowski ha segnato molti gol per la Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "Il Mazurek D\u0105browskiego \xE8 l'inno nazionale della Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: "Il calcio \xE8 uno degli sport pi\xF9 popolari praticati qui."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: "La palla \xE8 ci\xF2 che i giocatori calcia attraverso il campo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: "La porta \xE8 il luogo in cui i giocatori cercano di segnare."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "Il campo da calcio \xE8 il luogo in cui si gioca la partita."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "Mazurek D\u0105browskiego \xE8 l'inno nazionale della Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "Il settimo pezzo della spada \xE8 tuo! Hai tutti e 7 i pezzi!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: Torna dalla Sirena e riassembla la spada.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: Il fiume Vistola attraversa Varsavia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: "La sirena \xE8 un simbolo della citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: Chopin fu un famoso compositore polacco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "Il re Sigismondo trasfer\xEC la capitale a Varsavia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: "Il Parlamento \xE8 il luogo in cui vengono promulgate le leggi."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: "La bandiera polacca \xE8 bianca e rossa."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie era una scienziata."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: Il Giorno dell'Indipendenza cade l'11 novembre.
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "Vi racconteranno come le persone si spostano in citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: "Scopri di pi\xF9 sulla scienza e sullo z\u0142oty."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
