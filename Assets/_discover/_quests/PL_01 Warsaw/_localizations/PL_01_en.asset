      m_Items: []
  - m_Id: 83574578343829527
    m_Localized: My chest is open now.
    m_Metadata:
      m_Items: []
  - m_Id: 83574578343829528
    m_Localized: Continue east to the Houses of Parliament.
    m_Metadata:
      m_Items: []
  - m_Id: 83574578343829529
    m_Localized: Please visit King Sigismund first.
    m_Metadata:
      m_Items: []
  - m_Id: 83574578343829530
    m_Localized: You fixed the flag and have the sword. The chest is yours.
    m_Metadata:
      m_Items: []
  - m_Id: 83574578343829531
    m_Localized: Welcome to the Polish Houses of Parliament. Important laws are made
