    m_Metadata:
      m_Items: []
  - m_Id: 86116720429752376
    m_Localized: You found my wallet. The chest is open. Thank you!
    m_Metadata:
      m_Items: []
  - m_Id: 86116720429752377
    m_Localized: "I am Maria Sk\u0142odowska-Curie. I am a Polish scientist and this
      grand building fits my story."
    m_Metadata:
      m_Items: []
  - m_Id: 86116720429752378
    m_Localized: Not yet. Where should I look?
    m_Metadata:
      m_Items: []
  - m_Id: 86116720429752379
    m_Localized: I was a Polish scientist.
    m_Metadata:
      m_Items: []
  - m_Id: 86116720429752380
    m_Localized: "The z\u0142oty is the currency used in Poland."
    m_Metadata:
      m_Items: []
  - m_Id: 86116720429752381
    m_Localized: The sixth sword piece is yours!
    m_Metadata:
