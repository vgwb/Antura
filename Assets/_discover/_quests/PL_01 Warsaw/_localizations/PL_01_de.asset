%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_de
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: Willkommen in Warschau, der Hauptstadt Polens!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "Gro\xDFartige Arbeit! Du hast das Schwert der Meerjungfrau wieder
      zusammengesetzt!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "Die Meerjungfrau gab dir das erste St\xFCck."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "Wars und Sawa haben dir das zweite St\xFCck geliefert."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "K\xF6nig Sigismund gab dir das dritte St\xFCck."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: Im Parlament fanden Sie das vierte Puzzleteil.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "Chopin hat dir das f\xFCnfte St\xFCck gegeben."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: Im Palast hast du Maria geholfen und das sechste Puzzleteil gefunden.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: Im Stadion hast du das letzte Teil eingesammelt.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: Zeichne deinen Lieblingsort in Warschau!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: Welche Farben hat die polnische Flagge?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: Blau und rot.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: Bist du sicher?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: "Wei\xDF und rot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: Richtig.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: "Gr\xFCn und wei\xDF."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: Wer war Chopin?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: "Ein Fu\xDFballspieler."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: "Ein K\xF6nig."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: Ein Komponist.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: Was ist die Weichsel?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: Ein Palast.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Ein Stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: Ein Fluss.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: "Gut gemacht. Du wei\xDFt genug \xFCber Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: Sie haben nicht alle Fragen richtig beantwortet. Versuchen Sie es
      erneut!
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "Wohin m\xF6chtest du reisen?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: Center
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlament
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: Kulturpalast
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Stadion
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: Bleiben Sie hier.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: Hallo. Wissen Sie, wo wir sind?
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: In Torun
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: In Warschau
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "Ja! H\xF6rt in diesem Spiel immer genau zu und lest die Dialoge."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "Wir haben ein Problem zu l\xF6sen. Geht zur Meerjungfrau!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: In Breslau
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: "Ich wei\xDF nicht"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: Wir befinden uns im Stadtzentrum.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: Du hast alle Teile des Schwertes gefunden! Jetzt kann ich es wieder
      zusammensetzen!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "Die Meerjungfrau ist ein Symbol Warschaus und besch\xFCtzt die
      Stadt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: Nun wollen wir mal sehen, was ihr von diesem Abenteuer in Erinnerung
      habt.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: Erkunde Warschau und finde alle Teile des Schwertes!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: Antura zerbrach das Schwert in 7 Teile und schloss jedes einzelne
      in einer Truhe in ganz Warschau ein!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: Sprich mit allen roten Leuten.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "Und besorge dir alle Schl\xFCssel, um die Truhe zu \xF6ffnen!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "Die Meerjungfrau von Warschau hei\xDFt Syrenka."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "Sie ist halb Frau, halb Fisch und tr\xE4gt ein Schwert und einen
      Schild."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "Ich fahre normalerweise mit der Stra\xDFenbahn."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "Hier ist ein Schl\xFCssel f\xFCr Sie!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: Ich fahre gerne mit dem Auto.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "Ich mag Fahrr\xE4der, deshalb fahre ich mit dem Fahrrad."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: Ich fahre sehr gerne mit dem Zug.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: Ich denke, der Bus ist die beste Option.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "Du hast alle Schl\xFCssel gefunden! Jetzt \xF6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: Die Truhe ist leer.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "Um die Truhe zu \xF6ffnen, musst du dieses R\xE4tsel l\xF6sen!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "Es ist verschlossen. Sie ben\xF6tigen alle Schl\xFCssel!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "Du hast ein St\xFCck des Schwertes gefunden!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: Versuchen Sie es erneut!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: Besuchen Sie das Wars-und-Sawa-Denkmal am Ufer der Weichsel.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: "Wars und Sawa sind Figuren aus einer alten Legende \xFCber Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: "Man sagt, ihre Namen seien im Namen \u201EWarszawa\u201C verborgen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: "Die Weichsel flie\xDFt durch Warschau bis zur Ostsee."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: Die Truhe ist offen. Weiter geht's!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: Ich bin der Krieg. Unsere Statue steht am Ufer der Weichsel.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Unterhalte dich mit den blauen Leuten am Flussufer und erfahre
      mehr \xFCber unsere Stadt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: "Die Weichsel ist der l\xE4ngste Fluss Polens."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: "Wars und Sawa stammen aus einer alten Legende \xFCber Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "Die Weichsel flie\xDFt bis zur Ostsee."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: "Geh zum Altstadtplatz und sprich mit K\xF6nig Sigismund."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: Der Platz ist wieder friedlich. Geht weiter und findet den Rest
      des Schwertes!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: "Sprechen Sie mit den gelben Leuten auf dem Platz und erfahren Sie
      mehr \xFCber unsere Geschichte."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "K\xF6nig Sigismund III. Wasa verlegte 1596 die Hauptstadt Polens
      von Krakau nach Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "Seine S\xE4ule auf dem Schlossplatz ist eines der \xE4ltesten Denkm\xE4ler
      Warschaus."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: "Das k\xF6nigliche Schloss steht direkt neben der S\xE4ule."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: "Es wurde im Zweiten Weltkrieg zerst\xF6rt und sp\xE4ter wieder
      aufgebaut."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "K\xF6nig Sigismund verlegte die Hauptstadt von Krakau nach Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: "Diese S\xE4ule steht schon sehr lange auf dem Platz."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: "Das k\xF6nigliche Schloss befindet sich direkt neben der S\xE4ule."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: "Heute erl\xE4sst das Parlament die Gesetze f\xFCr Polen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: "Weiter geht es Richtung Osten zum Parlamentsgeb\xE4ude."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: Wir befinden uns vor dem Parlament.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: Die Flagge ist sortiert. Mach weiter und finde den Rest des Schwertes!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: Willkommen im polnischen Parlament.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: "Sprich mit den rot und gelb gekleideten Personen, um mehr \xFCber
      unsere Flagge und unsere Gesetze zu erfahren."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: "Das polnische Parlament hei\xDFt Sejm und Senat."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: "Es tagt in Warschau und erl\xE4sst Gesetze f\xFCr Polen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "Der Pr\xE4sidentenpalast liegt in der N\xE4he der Krakowskie Przedmie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: "Dort arbeitet der Pr\xE4sident von Polen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: "Die polnische Flagge ist oben wei\xDF und unten rot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: Der Sejm ist das Parlament von Polen, in dem die Gesetze erlassen
      werden.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: Der Verfassungstag vom 3. Mai ist ein wichtiger Tag in Polen.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: "Der Unabh\xE4ngigkeitstag in Polen ist am 11. November."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: Der Verfassungstag vom 3. Mai ist ein wichtiger Tag in Polen.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: Weiter zum Chopin-Denkmal.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: Wir befinden uns im Chopin-Park.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: Das Parlament braucht weiterhin Ihre Hilfe. Gehen Sie zuerst dorthin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "Die Melodie ist wiederhergestellt. Die Truhe geh\xF6rt dir."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: "Unterhalte dich mit den gr\xFCnen Leuten in deiner Umgebung und
      lerne etwas \xFCber Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: "Fryderyk Chopin wurde in der N\xE4he von Warschau geboren."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "Er ist einer der ber\xFChmtesten Komponisten der Welt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Dieses Denkmal steht im \u0141azienki-Park in Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: "Chopin wurde 1810 in der N\xE4he von Warschau geboren."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: "Er komponierte ber\xFChmte Musik."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: Hier finden im Sommer jeden Sonntag kostenlose Konzerte statt.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Dieses Denkmal steht im \u0141azienki-Park in Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: Chopin war ein polnischer Komponist.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: "Guter Versuch! Komm zur\xFCck und spiel die Melodie noch einmal."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: Gehen Sie nun zum Palast der Kultur und Wissenschaft.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: Wir befinden uns im Kulturpalast.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Sie haben meine Geldb\xF6rse gefunden. Die Truhe ist offen. Vielen
      Dank!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: Sprich mit den lilafarbenen Leuten rund um den Palast.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "Der Kultur- und Wissenschaftspalast ist das h\xF6chste Geb\xE4ude
      Polens."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "Es wurde in den 1950er Jahren erbaut und bietet von oben eine gro\xDFartige
      Aussicht."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie war eine polnische Wissenschaftlerin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: Sie war die erste Frau, die einen Nobelpreis gewann, und sie gewann
      sogar zwei.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Maria Sk\u0142odowska-Curie wurde 1867 in Warschau geboren."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: Sie war die erste Frau, die einen Nobelpreis gewann.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: "Der Z\u0142oty ist die W\xE4hrung in Polen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie war eine gro\xDFe polnische Wissenschaftlerin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: "\xDCberquert den Fluss und geht zum Nationalstadion."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: Wir sind im Stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: "Gro\xDFartige Leistung im Stadion! Kehre mit allen Teilen zur Meerjungfrau
      zur\xFCck."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: "\xD6ffne die Truhe!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: Ich bin Robert Lewandowski. Willkommen im Nationalstadion!
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: Sprechen Sie mit den blauen Leuten rund um das Stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: Das Nationalstadion steht am rechten Ufer der Weichsel.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: "Es wurde 2012 er\xF6ffnet und war Austragungsort gro\xDFer Fu\xDFballspiele."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski ist einer der bekanntesten Fu\xDFballspieler
      Polens."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: "Er hat viele Tore f\xFCr seine Mannschaften und f\xFCr Polen erzielt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: "Das Nationalstadion wurde 2012 er\xF6ffnet."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: "Fu\xDFball ist eine der beliebtesten Sportarten in Polen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: "Lewandowski hat viele Tore f\xFCr Polen erzielt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "Der Mazurek D\u0105browskiego ist die Nationalhymne Polens."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: "Fu\xDFball ist eine der beliebtesten Sportarten, die hier gespielt
      werden."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: "Der Ball ist das, was die Spieler \xFCber das Spielfeld kicken."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: Das Tor ist der Bereich, in dem die Spieler versuchen, ein Tor zu
      erzielen.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "Das Fu\xDFballfeld ist der Ort, an dem das Spiel stattfindet."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "Mazurek D\u0105browskiego ist die polnische Nationalhymne."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "Das siebte Schwertteil geh\xF6rt dir! Du hast alle 7 Teile!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: "Kehre zur Meerjungfrau zur\xFCck und setze das Schwert wieder zusammen."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: "Die Weichsel flie\xDFt durch Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: Die Meerjungfrau ist ein Symbol der Stadt.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: "Chopin war ein ber\xFChmter polnischer Komponist."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "K\xF6nig Sigismund verlegte die Hauptstadt nach Warschau."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: Im Parlament werden die Gesetze gemacht.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: "Die polnische Flagge ist wei\xDF und rot."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie war Wissenschaftlerin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: "Der Unabh\xE4ngigkeitstag ist am 11. November."
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "Sie werden Ihnen erkl\xE4ren, wie sich die Menschen in der Stadt
      fortbewegen."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: "Lerne etwas \xFCber Wissenschaft und den Z\u0142oty."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
