  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_uk
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: uk
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: "\u041B\u0430\u0441\u043A\u0430\u0432\u043E \u043F\u0440\u043E\u0441\u0438\u043C\u043E
      \u0434\u043E \u0412\u0430\u0440\u0448\u0430\u0432\u0438, \u0441\u0442\u043E\u043B\u0438\u0446\u0456
      \u041F\u043E\u043B\u044C\u0449\u0456!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "\u0427\u0443\u0434\u043E\u0432\u0430 \u0440\u043E\u0431\u043E\u0442\u0430.
      \u0412\u0438 \u0437\u0456\u0431\u0440\u0430\u043B\u0438 \u043C\u0435\u0447
      \u0420\u0443\u0441\u0430\u043B\u043A\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "\u0420\u0443\u0441\u0430\u043B\u043A\u0430 \u0434\u0430\u043B\u0430
      \u0442\u043E\u0431\u0456 \u043F\u0435\u0440\u0448\u0438\u0439 \u0448\u043C\u0430\u0442\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "\u0412\u043E\u0440\u0441 \u0456 \u0421\u0430\u0432\u0430 \u0434\u0430\u043B\u0438
      \u0442\u043E\u0431\u0456 \u0434\u0440\u0443\u0433\u0438\u0439 \u0448\u043C\u0430\u0442\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "\u041A\u043E\u0440\u043E\u043B\u044C \u0421\u0438\u0433\u0456\u0437\u043C\u0443\u043D\u0434
      \u0434\u0430\u0432 \u0442\u043E\u0431\u0456 \u0442\u0440\u0435\u0442\u0456\u0439
      \u0448\u043C\u0430\u0442\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: "\u0423 \u041F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0456
      \u0432\u0438 \u0437\u043D\u0430\u0439\u0448\u043B\u0438 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u0438\u0439
      \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "\u0428\u043E\u043F\u0435\u043D \u0434\u0430\u0432 \u0442\u043E\u0431\u0456
      \u043F'\u044F\u0442\u0438\u0439 \u0442\u0432\u0456\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "\u0423 \u043F\u0430\u043B\u0430\u0446\u0456 \u0442\u0438 \u0434\u043E\u043F\u043E\u043C\u0456\u0433
      \u041C\u0430\u0440\u0456\u0457 \u0442\u0430 \u0437\u043D\u0430\u0439\u0448\u043E\u0432
      \u0448\u043E\u0441\u0442\u0438\u0439 \u0448\u043C\u0430\u0442\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "\u041D\u0430 \u0441\u0442\u0430\u0434\u0456\u043E\u043D\u0456 \u0442\u0438
      \u0437\u0456\u0431\u0440\u0430\u0432 \u043E\u0441\u0442\u0430\u043D\u043D\u0456\u0439
      \u0448\u043C\u0430\u0442\u043E\u0447\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: "\u041D\u0430\u043C\u0430\u043B\u044E\u0439 \u0441\u0432\u043E\u0454
      \u0443\u043B\u044E\u0431\u043B\u0435\u043D\u0435 \u043C\u0456\u0441\u0446\u0435
      \u0443 \u0412\u0430\u0440\u0448\u0430\u0432\u0456!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: "\u042F\u043A\u0456 \u043A\u043E\u043B\u044C\u043E\u0440\u0438 \u043D\u0430
      \u043F\u043E\u043B\u044C\u0441\u044C\u043A\u043E\u043C\u0443 \u043F\u0440\u0430\u043F\u043E\u0440\u0456?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: "\u0421\u0438\u043D\u0456\u0439 \u0442\u0430 \u0447\u0435\u0440\u0432\u043E\u043D\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: "\u0412\u0438 \u0432\u043F\u0435\u0432\u043D\u0435\u043D\u0456?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: "\u0411\u0456\u043B\u0438\u0439 \u0442\u0430 \u0447\u0435\u0440\u0432\u043E\u043D\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: "\u041F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: "\u0417\u0435\u043B\u0435\u043D\u0438\u0439 \u0442\u0430 \u0431\u0456\u043B\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: "\u0425\u0442\u043E \u0431\u0443\u0432 \u0428\u043E\u043F\u0435\u043D?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: "\u0424\u0443\u0442\u0431\u043E\u043B\u0456\u0441\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: "\u041A\u043E\u0440\u043E\u043B\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: "\u041A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "\u0429\u043E \u0442\u0430\u043A\u0435 \u0440\u0456\u0447\u043A\u0430
      \u0412\u0456\u0441\u043B\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: "\u041F\u0430\u043B\u0430\u0446."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: "\u0421\u0442\u0430\u0434\u0456\u043E\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: "\u0420\u0456\u0447\u043A\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: "\u041C\u043E\u043B\u043E\u0434\u0435\u0446\u044C. \u0422\u0438
      \u0434\u043E\u0441\u0442\u0430\u0442\u043D\u044C\u043E \u0437\u043D\u0430\u0454\u0448
      \u043F\u0440\u043E \u0412\u0430\u0440\u0448\u0430\u0432\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: "\u0412\u0438 \u043D\u0435 \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u043B\u0438
      \u043D\u0430 \u0432\u0441\u0456 \u0437\u0430\u043F\u0438\u0442\u0430\u043D\u043D\u044F
      \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E. \u0421\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
      \u0449\u0435 \u0440\u0430\u0437!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "\u041A\u0443\u0434\u0438 \u0442\u0438 \u0445\u043E\u0447\u0435\u0448
      \u043F\u0456\u0442\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: "\u0426\u0435\u043D\u0442\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: "\u041F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: "\u0428\u043E\u043F\u0435\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: "\u041F\u0430\u043B\u0430\u0446 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: "\u0421\u0442\u0430\u0434\u0456\u043E\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: "\u0417\u0430\u043B\u0438\u0448\u0430\u0439\u0442\u0435\u0441\u044F
      \u0442\u0443\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: "\u041F\u0440\u0438\u0432\u0456\u0442. \u0412\u0438 \u0437\u043D\u0430\u0454\u0442\u0435,
      \u0434\u0435 \u043C\u0438 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: "\u0423 \u0422\u043E\u0440\u0443\u043D\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: "\u0423 \u0412\u0430\u0440\u0448\u0430\u0432\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "\u0422\u0430\u043A! \u0417\u0430\u0432\u0436\u0434\u0438 \u0443\u0432\u0430\u0436\u043D\u043E
      \u0441\u043B\u0443\u0445\u0430\u0439\u0442\u0435 \u0442\u0430 \u0447\u0438\u0442\u0430\u0439\u0442\u0435
      \u0434\u0456\u0430\u043B\u043E\u0433\u0438 \u0432 \u0446\u0456\u0439 \u0433\u0440\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "\u041D\u0430\u043C \u043F\u043E\u0442\u0440\u0456\u0431\u043D\u043E
      \u0432\u0438\u0440\u0456\u0448\u0438\u0442\u0438 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443.
      \u0406\u0434\u0456\u0442\u044C \u0434\u043E \u0420\u0443\u0441\u0430\u043B\u043A\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: "\u0423 \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: "\u041C\u0438 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u044F
      \u0432 \u0446\u0435\u043D\u0442\u0440\u0456 \u043C\u0456\u0441\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "\u0422\u0438 \u0437\u0456\u0431\u0440\u0430\u0432 \u0443\u0441\u0456
      \u0447\u0430\u0441\u0442\u0438\u043D\u0438 \u043C\u0435\u0447\u0430! \u0422\u0435\u043F\u0435\u0440
      \u044F \u043C\u043E\u0436\u0443 \u0437\u0440\u043E\u0431\u0438\u0442\u0438
      \u0439\u043E\u0433\u043E \u0446\u0456\u043B\u0438\u043C!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "\u0420\u0443\u0441\u0430\u043B\u043A\u0430 \u0454 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
      \u0412\u0430\u0440\u0448\u0430\u0432\u0438 \u0442\u0430 \u0437\u0430\u0445\u0438\u0449\u0430\u0454
      \u043C\u0456\u0441\u0442\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: "\u0410 \u0442\u0435\u043F\u0435\u0440 \u0434\u0430\u0432\u0430\u0439\u0442\u0435
      \u043F\u0435\u0440\u0435\u0432\u0456\u0440\u0438\u043C\u043E, \u0449\u043E
      \u0432\u0438 \u043F\u0430\u043C'\u044F\u0442\u0430\u0454\u0442\u0435 \u0437
      \u0446\u0456\u0454\u0457 \u043F\u0440\u0438\u0433\u043E\u0434\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "\u0414\u043E\u0441\u043B\u0456\u0434\u0456\u0442\u044C \u0412\u0430\u0440\u0448\u0430\u0432\u0443
      \u0442\u0430 \u0437\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u0443\u0441\u0456
      \u0447\u0430\u0441\u0442\u0438\u043D\u0438 \u043C\u0435\u0447\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: "\u0412\u0456\u0434\u043A\u0440\u0438\u0439 \u0441\u043A\u0440\u0438\u043D\u044E!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "\u0410\u043D\u0442\u0443\u0440\u0430 \u0437\u043B\u0430\u043C\u0430\u0432
      \u043C\u0435\u0447 \u043D\u0430 7 \u0447\u0430\u0441\u0442\u0438\u043D \u0456
      \u0437\u0430\u043C\u043A\u043D\u0443\u0432 \u043A\u043E\u0436\u0435\u043D \u0443
      \u0441\u043A\u0440\u0438\u043D\u0456 \u043F\u043E \u0442\u043E\u0439 \u0431\u0456\u043A
      \u0412\u0430\u0440\u0448\u0430\u0432\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: "\u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0456\u0442\u044C \u0437
      \u0443\u0441\u0456\u043C\u0430 \u0447\u0435\u0440\u0432\u043E\u043D\u0438\u043C\u0438
      \u043B\u044E\u0434\u044C\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "\u0406 \u0437\u0431\u0435\u0440\u0438 \u0432\u0441\u0456 \u043A\u043B\u044E\u0447\u0456,
      \u0449\u043E\u0431 \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u0438 \u0441\u043A\u0440\u0438\u043D\u044E!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "\u0412\u0430\u0440\u0448\u0430\u0432\u0441\u044C\u043A\u0443 \u0440\u0443\u0441\u0430\u043B\u043A\u0443
      \u043D\u0430\u0437\u0438\u0432\u0430\u044E\u0442\u044C \u0421\u0438\u0440\u0435\u043D\u043A\u043E\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "\u0412\u043E\u043D\u0430 \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
      \u0436\u0456\u043D\u043A\u0430, \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
      \u0440\u0438\u0431\u0430, \u0456 \u043D\u043E\u0441\u0438\u0442\u044C \u043C\u0435\u0447
      \u0456 \u0449\u0438\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "\u042F \u0437\u0430\u0437\u0432\u0438\u0447\u0430\u0439 \u0457\u0436\u0434\u0436\u0443
      \u0442\u0440\u0430\u043C\u0432\u0430\u0454\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "\u041E\u0441\u044C \u0442\u043E\u0431\u0456 \u043A\u043B\u044E\u0447\u0438\u043A!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: "\u041C\u0435\u043D\u0456 \u043F\u043E\u0434\u043E\u0431\u0430\u0454\u0442\u044C\u0441\u044F
      \u0457\u0437\u0434\u0438\u0442\u0438 \u043D\u0430 \u043C\u0430\u0448\u0438\u043D\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "\u042F \u043B\u044E\u0431\u043B\u044E \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0438,
      \u0442\u043E\u043C\u0443 \u0457\u0436\u0434\u0436\u0443 \u043D\u0430 \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: "\u042F \u043B\u044E\u0431\u043B\u044E \u0457\u0437\u0434\u0438\u0442\u0438
      \u043F\u043E\u0457\u0437\u0434\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: "\u042F \u0432\u0432\u0430\u0436\u0430\u044E, \u0449\u043E \u0430\u0432\u0442\u043E\u0431\u0443\u0441
      \u043D\u0430\u0439\u043A\u0440\u0430\u0449\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "\u0422\u0438 \u0437\u043D\u0430\u0439\u0448\u043E\u0432 \u0443\u0441\u0456
      \u043A\u043B\u044E\u0447\u0456! \u0410 \u0442\u0435\u043F\u0435\u0440 \u0432\u0456\u0434\u043A\u0440\u0438\u0439
      \u0441\u043A\u0440\u0438\u043D\u044E!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
