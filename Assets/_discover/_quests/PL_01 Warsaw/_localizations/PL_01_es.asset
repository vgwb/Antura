%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: "\xA1Bienvenidos a Varsovia, la capital de Polonia!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "\xA1Excelente trabajo! \xA1Has vuelto a armar la espada de la Sirena!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: La sirena te dio la primera pieza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: Wars y Sawa te dieron la segunda pieza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: El rey Segismundo te dio la tercera pieza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: En el Parlamento, encontraste la cuarta pieza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: Chopin te dio la quinta pieza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "En el Palacio, ayudaste a Mar\xEDa y encontraste la sexta pieza."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "En el estadio, recogiste la \xFAltima pieza."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: "\xA1Dibuja tu lugar favorito de Varsovia!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: "\xBFQu\xE9 colores tiene la bandera polaca?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: Azul y rojo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: "\xBFEst\xE1 seguro?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: Blanco y rojo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: Correcto.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: Verde y blanco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: "\xBFQui\xE9n fue Chopin?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: "Un jugador de f\xFAtbol."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: Un rey.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: Un compositor.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "\xBFQu\xE9 es el r\xEDo V\xEDstula?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: Un palacio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Un estadio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: "Un r\xEDo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: Bien hecho. Sabes bastante sobre Varsovia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: "No has respondido correctamente a todas las preguntas. \xA1Int\xE9ntalo
      de nuevo!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "\xBFAd\xF3nde quieres ir?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: Centro
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlamento
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: Palacio de la Cultura
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Estadio
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: "Qu\xE9date aqu\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: "Hola. \xBFSabes d\xF3nde estamos?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: "En Toru\u0144"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: En Varsovia
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "\xA1S\xED! Siempre escucha con atenci\xF3n y lee los di\xE1logos
      en este juego."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "Tenemos un problema que resolver. \xA1Ve a la Sirena!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: En Breslavia
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: "No s\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: Estamos en el centro de la ciudad.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "\xA1Has recogido todos los pedazos de la espada! \xA1Ahora puedo
      volver a armarla!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "La Sirena es un s\xEDmbolo de Varsovia y protege la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: "Ahora veamos qu\xE9 recuerdas de esta aventura."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "\xA1Explora Varsovia y encuentra todas las piezas de la espada!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "Antura rompi\xF3 la espada en 7 pedazos y guard\xF3 cada uno en
      un cofre en distintos puntos de Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: Habla con toda la gente roja.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "\xA1Y consigue todas las llaves para abrir el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: La sirena de Varsovia se llama Syrenka.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: Es mitad mujer, mitad pez, y lleva una espada y un escudo.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: "Normalmente voy en tranv\xEDa."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "\xA1Aqu\xED tienes una llave!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: Me gusta ir en coche.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "Me gustan las bicicletas, as\xED que me desplazo en bicicleta."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: Me encanta viajar en tren.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: "Creo que el autob\xFAs es la mejor opci\xF3n."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "\xA1Encontraste todas las llaves! \xA1Ahora ve a abrir el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: "El cofre est\xE1 vac\xEDo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "\xA1Para abrir el cofre, resuelve este acertijo!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "Est\xE1 cerrado con llave. \xA1Necesitas todas las llaves!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "\xA1Encontraste un trozo de la espada!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: "\xA1Intentar otra vez!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: "Visita la estatua de Wars y Sawa junto al r\xEDo V\xEDstula."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: Wars y Sawa son personajes de una antigua leyenda sobre Varsovia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: "La gente dice que sus nombres est\xE1n ocultos dentro del nombre
      \"Varsovia\"."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: "El r\xEDo V\xEDstula atraviesa Varsovia y desemboca en el mar B\xE1ltico."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: "El cofre est\xE1 abierto. \xA1Sigue adelante!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: "Yo soy las Guerras. Nuestra estatua se encuentra junto al r\xEDo
      V\xEDstula."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Habla con la gente azul junto al r\xEDo y aprende sobre nuestra
      ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: "El r\xEDo V\xEDstula es el r\xEDo m\xE1s largo de Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: Wars y Sawa provienen de una antigua leyenda sobre Varsovia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "El r\xEDo V\xEDstula desemboca en el mar B\xE1ltico."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: "Dir\xEDgete a la Plaza de la Ciudad Vieja y habla con el rey Segismundo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: "La plaza vuelve a estar en paz. \xA1Sigue adelante y encuentra
      el resto de la espada!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: Habla con la gente amarilla en la plaza y aprende sobre nuestra
      historia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "El rey Segismundo III Vasa traslad\xF3 la capital de Polonia de
      Cracovia a Varsovia en 1596."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "Su columna en la Plaza del Castillo es uno de los monumentos m\xE1s
      antiguos de Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: El Castillo Real se encuentra justo al lado de la columna.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: Fue destruido durante la Segunda Guerra Mundial y reconstruido posteriormente.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "El rey Segismundo traslad\xF3 la capital de Cracovia a Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: Esta columna lleva mucho tiempo en la plaza.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: "El Castillo Real est\xE1 justo al lado de la columna."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: "Hoy en d\xEDa, el Parlamento elabora las leyes de Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: "Contin\xFAe hacia el este hasta el Parlamento."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: Estamos frente al Parlamento.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: "La bandera est\xE1 lista. \xA1Sigue adelante y encuentra el resto
      de la espada!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: Bienvenidos al Parlamento polaco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: Habla con la gente de rojo y amarillo para aprender sobre nuestra
      bandera y nuestras leyes.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: El parlamento polaco se llama Sejm y el Senado.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: "Se re\xFAne en Varsovia y elabora leyes para Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "El Palacio Presidencial est\xE1 cerca, en Krakowskie Przedmie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: Es donde trabaja el Presidente de Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: La bandera polaca es blanca en la parte superior y roja en la inferior.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: "En Polonia, el Sejm es el \xF3rgano donde se elaboran las leyes."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: "La Constituci\xF3n del 3 de mayo es un d\xEDa importante en Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: "El D\xEDa de la Independencia en Polonia se celebra el 11 de noviembre."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: "La Constituci\xF3n del 3 de mayo es un d\xEDa importante en Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: "Contin\xFAe hasta el Monumento a Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: Estamos en el Parque Chopin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: "El Parlamento a\xFAn necesita tu ayuda. Acude all\xED primero."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "La melod\xEDa ha sido restaurada. El cofre es tuyo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: Habla con la gente ecologista que te rodea y aprende sobre Chopin.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: "Fryderyk Chopin naci\xF3 cerca de Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "Es uno de los compositores m\xE1s famosos del mundo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Este monumento se encuentra en el parque \u0141azienki de Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: "Chopin naci\xF3 cerca de Varsovia en 1810."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: "\xC9l compuso m\xFAsica famosa."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: "Aqu\xED hay conciertos gratuitos todos los domingos durante el
      verano."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Este monumento se encuentra en el parque \u0141azienki de Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: Chopin fue un compositor polaco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: "\xA1Buen intento! Vuelve y toca la melod\xEDa otra vez."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: "Ahora dir\xEDgete al Palacio de la Cultura y la Ciencia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: Estamos en el Palacio de la Cultura.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Encontraste mi billetera. El cofre est\xE1 abierto. \xA1Gracias!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: "Habla con la gente de color p\xFArpura que hay alrededor del Palacio."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "El Palacio de la Cultura y la Ciencia es el edificio m\xE1s alto
      de Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "Fue construida en la d\xE9cada de 1950 y tiene una vista magn\xEDfica
      desde la cima."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie fue una cient\xEDfica polaca."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: "Fue la primera mujer en ganar un Premio Nobel, y gan\xF3 dos."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Mar\xEDa Sk\u0142odowska-Curie naci\xF3 en Varsovia en 1867."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: Fue la primera mujer en ganar un Premio Nobel.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: El zloty es la moneda que se utiliza en Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie fue una gran cient\xEDfica polaca."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: "Cruza el r\xEDo y dir\xEDgete al Estadio Nacional."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: Estamos en el estadio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: "\xA1Excelente trabajo en el estadio! Regresen a la Sirena con todas
      las piezas."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: "\xA1Abre el cofre!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: "Soy Robert Lewandowski. \xA1Bienvenidos al Estadio Nacional!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: Habla con la gente de azul que hay alrededor del estadio.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: "El Estadio Nacional se encuentra en la margen derecha del r\xEDo
      V\xEDstula."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: "Se inaugur\xF3 en 2012 y alberg\xF3 importantes partidos de f\xFAtbol."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski es uno de los futbolistas m\xE1s famosos de
      Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: Ha marcado muchos goles para sus equipos y para Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: "El Estadio Nacional se inaugur\xF3 en 2012."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: "El f\xFAtbol es uno de los deportes m\xE1s populares en Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: Lewandowski ha marcado muchos goles para Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "El Mazurek D\u0105browskiego es el himno nacional de Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: "El f\xFAtbol es uno de los deportes m\xE1s populares que se practican
      aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: "El bal\xF3n es lo que los jugadores patean a trav\xE9s del campo."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: "La porter\xEDa es donde los jugadores intentan marcar."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "El campo de f\xFAtbol es el lugar donde se juega el partido."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "Mazurek D\u0105browskiego es el himno nacional de Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "\xA1La s\xE9ptima pieza de la espada es tuya! \xA1Tienes las 7
      piezas!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: Regresa con la Sirena y vuelve a armar la espada.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: "El r\xEDo V\xEDstula atraviesa Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: "La Sirena es un s\xEDmbolo de la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: Chopin fue un famoso compositor polaco.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "El rey Segismundo traslad\xF3 la capital a Varsovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: El Parlamento es donde se elaboran las leyes.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: La bandera polaca es blanca y roja.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie era una cient\xEDfica."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: "El D\xEDa de la Independencia es el 11 de noviembre."
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "Te explicar\xE1n c\xF3mo se desplaza la gente por la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: Aprende sobre la ciencia y el zloty.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
