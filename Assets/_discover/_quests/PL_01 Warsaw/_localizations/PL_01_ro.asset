%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_01_ro
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: ro
  m_SharedData: {fileID: 11400000, guid: c018dfc9d6a864c6aaf78f095114d1ed, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 11445436669952
    m_Localized: "Bine a\u021Bi venit la Var\u0219ovia, capitala Poloniei!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669953
    m_Localized: "Treab\u0103 excelent\u0103. Ai reasamblat sabia Sirenei!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669954
    m_Localized: "Sirena \u021Bi-a dat prima pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669955
    m_Localized: "Wars \u0219i Sawa \u021Bi-au dat a doua pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669956
    m_Localized: "Regele Sigismund \u021Bi-a dat a treia pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669957
    m_Localized: "La Parlament, a\u021Bi g\u0103sit a patra pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669958
    m_Localized: "Chopin \u021Bi-a dat a cincea pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669959
    m_Localized: "La Palat, ai ajutat-o \u200B\u200Bpe Maria \u0219i ai g\u0103sit
      a \u0219asea pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669960
    m_Localized: "La stadion, ai adunat ultima pies\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669961
    m_Localized: "Deseneaz\u0103 locul t\u0103u preferat din Var\u0219ovia!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669962
    m_Localized: Ce culori sunt pe steagul Poloniei?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669963
    m_Localized: "Albastru \u0219i ro\u0219u."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669964
    m_Localized: "E\u0219ti sigur/\u0103?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669965
    m_Localized: "Alb \u0219i ro\u0219u."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669966
    m_Localized: Corecta.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669967
    m_Localized: "Verde \u0219i alb."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669969
    m_Localized: Cine a fost Chopin?
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669970
    m_Localized: "Un juc\u0103tor de fotbal."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669972
    m_Localized: Un rege.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669974
    m_Localized: Un compozitor.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669976
    m_Localized: "Ce este r\xE2ul Vis\u0142a?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669977
    m_Localized: Un palat.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669979
    m_Localized: Un stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669981
    m_Localized: "Un r\xE2u."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669983
    m_Localized: "Bravo. \u0218tii destule despre Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669984
    m_Localized: "Nu ai r\u0103spuns corect la toate \xEEntreb\u0103rile. \xCEncearc\u0103
      din nou!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669985
    m_Localized: "Unde vrei s\u0103 mergi?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669986
    m_Localized: Centru
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669987
    m_Localized: Parlament
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669988
    m_Localized: Chopin
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669989
    m_Localized: Palatul Culturii
    m_Metadata:
      m_Items: []
  - m_Id: 11445436669990
    m_Localized: Stadion
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864256
    m_Localized: "R\u0103m\xE2i aici"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864257
    m_Localized: "Salut. \u0218tii unde suntem?"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864258
    m_Localized: "\xCEn Toru\u0144"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864259
    m_Localized: "\xCEn Var\u0219ovia"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864260
    m_Localized: "Da! Ascult\u0103 \xEEntotdeauna cu aten\u021Bie \u0219i cite\u0219te
      dialogul din acest joc."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864261
    m_Localized: "Avem o problem\u0103 de rezolvat. Du-te la Siren\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864262
    m_Localized: "\xCEn Wroc\u0142aw"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864263
    m_Localized: "Nu \u0219tiu"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864264
    m_Localized: "Suntem \xEEn centrul ora\u0219ului."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864265
    m_Localized: "Ai adunat toate buc\u0103\u021Bile sabiei! Acum o pot face \xEEntreag\u0103
      din nou!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864266
    m_Localized: "Sirena este un simbol al Var\u0219oviei \u0219i protejeaz\u0103
      ora\u0219ul."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864267
    m_Localized: "Acum s\u0103 vedem ce v\u0103 aminti\u021Bi din aceast\u0103 aventur\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864268
    m_Localized: "Exploreaz\u0103 Var\u0219ovia \u0219i g\u0103se\u0219te toate piesele
      sabiei!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864269
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864270
    m_Localized: "Antura a rupt sabia \xEEn 7 buc\u0103\u021Bi \u0219i le-a \xEEncuiat
      pe fiecare \xEEntr-un cuf\u0103r din Var\u0219ovia!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864271
    m_Localized: "Vorbe\u0219te cu to\u021Bi oamenii ro\u0219ii."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864273
    m_Localized: "\u0218i ia toate cheile pentru a deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864274
    m_Localized: "Sirena din Var\u0219ovia se nume\u0219te Syrenka."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864275
    m_Localized: "Este pe jum\u0103tate femeie, pe jum\u0103tate pe\u0219te \u0219i
      poart\u0103 o sabie \u0219i un scut."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864276
    m_Localized: De obicei merg cu tramvaiul.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864277
    m_Localized: "Iat\u0103 o cheie pentru tine!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864278
    m_Localized: "\xCEmi place s\u0103 merg cu ma\u0219ina."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864280
    m_Localized: "\xCEmi plac bicicletele, a\u0219a c\u0103 merg cu bicicleta."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864282
    m_Localized: "\xCEmi place s\u0103 merg cu trenul."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864284
    m_Localized: "Cred c\u0103 autobuzul e cel mai bun."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864286
    m_Localized: "Ai g\u0103sit toate cheile! Acum du-te \u0219i deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864287
    m_Localized: "Cuf\u0103rul este gol."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864288
    m_Localized: "Pentru a deschide cuf\u0103rul, rezolv\u0103 acest puzzle!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864289
    m_Localized: "Este \xEEncuiat. Ai nevoie de toate cheile!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864290
    m_Localized: "Ai g\u0103sit o bucat\u0103 din sabie!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864291
    m_Localized: "\xCEncearc\u0103 din nou!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864292
    m_Localized: "Merge\u021Bi la statuia Wars and Sawa de l\xE2ng\u0103 r\xE2ul
      Vis\u0142a."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864293
    m_Localized: "Wars \u0219i Sawa sunt personaje dintr-o veche legend\u0103 despre
      Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864294
    m_Localized: "Oamenii spun c\u0103 numele lor sunt ascunse \xEEn numele \u201EVar\u0219ovia\u201D."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864295
    m_Localized: "R\xE2ul Vis\u0142a curge prin Var\u0219ovia p\xE2n\u0103 la Marea
      Baltic\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864296
    m_Localized: "Cuf\u0103rul este deschis. Continu\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864297
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864298
    m_Localized: "Eu sunt R\u0103zboi. Statuia noastr\u0103 se afl\u0103 l\xE2ng\u0103
      r\xE2ul Vistula."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864299
    m_Localized: "Vorbe\u0219te cu oamenii alba\u0219tri de l\xE2ng\u0103 r\xE2u
      \u0219i afl\u0103 mai multe despre ora\u0219ul nostru."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864300
    m_Localized: "R\xE2ul Vis\u0142a este cel mai lung r\xE2u din Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864302
    m_Localized: "R\u0103zboaiele \u0219i Sawa provin dintr-o veche legend\u0103
      despre Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864304
    m_Localized: "R\xE2ul Visla curge p\xE2n\u0103 la Marea Baltic\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864312
    m_Localized: "Du-te \xEEn Pia\u021Ba Ora\u0219ului Vechi \u0219i vorbe\u0219te
      cu Regele Sigismund."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864313
    m_Localized: "Pia\u021Ba este din nou lini\u0219tit\u0103. Continu\u0103 \u0219i
      g\u0103se\u0219te restul sabiei!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864314
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864315
    m_Localized: "Vorbe\u0219te cu oamenii galbeni din pia\u021B\u0103 \u0219i afl\u0103
      despre istoria noastr\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864316
    m_Localized: "Regele Sigismund al III-lea Vasa a mutat capitala Poloniei de la
      Cracovia la Var\u0219ovia \xEEn 1596."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864317
    m_Localized: "Coloana sa din Pia\u021Ba Castelului este unul dintre cele mai
      vechi monumente din Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864318
    m_Localized: "Castelul Regal se afl\u0103 chiar l\xE2ng\u0103 coloan\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864319
    m_Localized: "A fost distrus\u0103 \xEEn al Doilea R\u0103zboi Mondial \u0219i
      reconstruit\u0103 ulterior."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864320
    m_Localized: "Regele Sigismund a mutat capitala de la Cracovia la Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864322
    m_Localized: "Aceast\u0103 coloan\u0103 a stat \xEEn pia\u021B\u0103 mult timp."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864324
    m_Localized: "Castelul Regal este chiar l\xE2ng\u0103 coloan\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864326
    m_Localized: "Ast\u0103zi, Parlamentul face legile pentru Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864334
    m_Localized: "Continua\u021Bi spre est p\xE2n\u0103 la Palatul Parlamentului."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864335
    m_Localized: "Suntem \xEEn fa\u021Ba Parlamentului."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864336
    m_Localized: "Steagul e rezolvat. Continu\u0103 \u0219i g\u0103se\u0219te restul
      sabiei!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864337
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864338
    m_Localized: "Bine a\u021Bi venit \xEEn Parlamentul Polonez."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864339
    m_Localized: "Vorbe\u0219te cu oamenii ro\u0219ii \u0219i galbeni ca s\u0103
      afli despre steagul \u0219i legile noastre."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864340
    m_Localized: "Parlamentul polonez se nume\u0219te Sejm \u0219i Senat."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864341
    m_Localized: "Se \xEEntrune\u0219te la Var\u0219ovia \u0219i adopt\u0103 legi
      pentru Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864342
    m_Localized: "Palatul Preziden\u021Bial este \xEEn apropiere, pe Krakowskie Przedmie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864343
    m_Localized: "Acolo \xEE\u0219i desf\u0103\u0219oar\u0103 activitatea pre\u0219edintele
      Poloniei."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864344
    m_Localized: "Steagul Poloniei este alb deasupra \u0219i ro\u0219u dedesubt."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864346
    m_Localized: "Sejm este locul unde oamenii fac legile \xEEn Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864348
    m_Localized: "Constitu\u021Bia din 3 mai este o zi important\u0103 \xEEn Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864350
    m_Localized: "Ziua Independen\u021Bei \xEEn Polonia este pe 11 noiembrie."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864356
    m_Localized: "Constitu\u021Bia din 3 mai este o zi important\u0103 \xEEn Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864359
    m_Localized: "Continua\u021Bi spre Monumentul lui Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864360
    m_Localized: "Suntem \xEEn Parcul Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864361
    m_Localized: "Parlamentul are nevoie \xEEn continuare de ajutorul dumneavoastr\u0103.
      Merge\u021Bi acolo mai \xEEnt\xE2i."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864362
    m_Localized: "Melodia este restaurat\u0103. Cuf\u0103rul este al t\u0103u."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864363
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864364
    m_Localized: "Vorbe\u0219te cu oamenii verzi din jur \u0219i \xEEnva\u021B\u0103
      despre Chopin."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864365
    m_Localized: "Fryderyk Chopin s-a n\u0103scut l\xE2ng\u0103 Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864366
    m_Localized: "El este unul dintre cei mai faimo\u0219i compozitori din lume."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864367
    m_Localized: "Acest monument se afl\u0103 \xEEn parcul \u0141azienki din Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864368
    m_Localized: "Chopin s-a n\u0103scut l\xE2ng\u0103 Var\u0219ovia \xEEn 1810."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864370
    m_Localized: "A scris muzic\u0103 celebr\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864372
    m_Localized: "\xCEn fiecare duminic\u0103 de var\u0103, aici au loc concerte
      gratuite."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864374
    m_Localized: "Acest monument se afl\u0103 \xEEn parcul \u0141azienki din Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864380
    m_Localized: Chopin a fost un compozitor polonez.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864382
    m_Localized: "Bun\u0103 \xEEncercare! Revino \u0219i c\xE2nt\u0103 melodia din
      nou."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864383
    m_Localized: "Acum merge\u021Bi la Palatul Culturii \u0219i \u0218tiin\u021Bei."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864384
    m_Localized: Suntem la Palatul Culturii.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864385
    m_Localized: "Mi-ai g\u0103sit portofelul. Cuf\u0103rul e deschis. Mul\u021Bumesc!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864386
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864387
    m_Localized: "Vorbe\u0219te cu oamenii mov din jurul Palatului."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864389
    m_Localized: "Palatul Culturii \u0219i \u0218tiin\u021Bei este cea mai \xEEnalt\u0103
      cl\u0103dire din Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864390
    m_Localized: "A fost construit\u0103 \xEEn anii 1950 \u0219i are o priveli\u0219te
      minunat\u0103 de sus."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864391
    m_Localized: "Maria Sk\u0142odowska-Curie a fost un om de \u0219tiin\u021B\u0103
      polonez."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864392
    m_Localized: "A fost prima femeie care a c\xE2\u0219tigat un Premiu Nobel \u0219i
      a c\xE2\u0219tigat dou\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864393
    m_Localized: "Maria Sk\u0142odowska-Curie s-a n\u0103scut la Var\u0219ovia \xEEn
      1867."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864395
    m_Localized: "Ea a fost prima femeie care a c\xE2\u0219tigat Premiul Nobel."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864397
    m_Localized: "Zlotul este moneda folosit\u0103 \xEEn Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864403
    m_Localized: "Maria Sk\u0142odowska-Curie a fost un mare om de \u0219tiin\u021B\u0103
      polonez."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864406
    m_Localized: "Traverseaz\u0103 r\xE2ul \u0219i mergi la Stadionul Na\u021Bional."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864407
    m_Localized: Suntem la stadion.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864408
    m_Localized: "Treab\u0103 bun\u0103 la stadion! \xCEntoarce-te la Siren\u0103
      cu toate piesele."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864409
    m_Localized: "Deschide cuf\u0103rul!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864410
    m_Localized: "Sunt Robert Lewandowski. Bine a\u021Bi venit pe Stadionul Na\u021Bional!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864411
    m_Localized: "Vorbe\u0219te cu oamenii alba\u0219tri din jurul stadionului."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864412
    m_Localized: "Stadionul Na\u021Bional se afl\u0103 pe malul drept al r\xE2ului
      Vis\u0142a."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864413
    m_Localized: "A fost deschis \xEEn 2012 \u0219i a g\u0103zduit meciuri importante
      de fotbal."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864414
    m_Localized: "Robert Lewandowski este unul dintre cei mai faimo\u0219i fotbali\u0219ti
      polonezi."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864415
    m_Localized: "A marcat multe goluri pentru echipele sale \u0219i pentru Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864416
    m_Localized: "Stadionul Na\u021Bional a fost deschis \xEEn 2012."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864418
    m_Localized: Fotbalul este unul dintre cele mai populare sporturi din Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864420
    m_Localized: Lewandowski a marcat multe goluri pentru Polonia.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864422
    m_Localized: "Mazurek D\u0105browskiego este imnul na\u021Bional al Poloniei."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864428
    m_Localized: Fotbalul este unul dintre cele mai populare sporturi practicate
      aici.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864429
    m_Localized: "Mingea este ceea ce juc\u0103torii \u0219uteaz\u0103 pe teren."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864430
    m_Localized: "Golul este locul unde juc\u0103torii \xEEncearc\u0103 s\u0103 marcheze."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864431
    m_Localized: "Terenul de fotbal este locul unde se joac\u0103 meciul."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864432
    m_Localized: "Mazurek D\u0105browskiego este imnul na\u021Bional al Poloniei."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864433
    m_Localized: "A \u0219aptea pies\u0103 de sabie este a ta! Ai toate cele 7 piese!"
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864434
    m_Localized: "\xCEntoarce-te la Siren\u0103 \u0219i reasambleaz\u0103 sabia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864436
    m_Localized: "R\xE2ul Vis\u0142a curge prin Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864437
    m_Localized: "Sirena este un simbol al ora\u0219ului."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864438
    m_Localized: Chopin a fost un celebru compozitor polonez.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864439
    m_Localized: "Regele Sigismund a mutat capitala la Var\u0219ovia."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864440
    m_Localized: Parlamentul este locul unde se fac legile.
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864441
    m_Localized: "Steagul Poloniei este alb \u0219i ro\u0219u."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864442
    m_Localized: "Maria Sk\u0142odowska-Curie a fost om de \u0219tiin\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 11445440864443
    m_Localized: "Ziua Independen\u021Bei este pe 11 noiembrie."
    m_Metadata:
      m_Items: []
  - m_Id: 14242244714503
    m_Localized: "\xCE\u021Bi vor spune cum c\u0103l\u0103toresc oamenii prin ora\u0219."
    m_Metadata:
      m_Items: []
  - m_Id: 14242248908812
    m_Localized: "\xCEnva\u021B\u0103 despre \u0219tiin\u021B\u0103 \u0219i zloty."
    m_Metadata:
      m_Items: []
