    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241493
    m_Localized: accidenti a quel Leonardo
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241494
    m_Localized: "dove l'avr\xE0 mai messa"
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241495
    m_Localized: "ciao scusa cos'\xE8 successo?"
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241496
    m_Localized: Leonardo mi ha nascosto le chiavi di casa
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241497
    m_Localized: senza quelle non posso andare a casa
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241498
    m_Localized: mi puoi aiutare a trovarle?
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241499
    m_Localized: va bene
    m_Metadata:
      m_Items: []
  - m_Id: 4552340459241500
    m_Localized: mi ha dato solo un indizio di dove l'ha nascosta
    m_Metadata:
      m_Items: []
  - m_Id: 4875263048409088
    m_Localized: sistema gli orologi della macchina
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906560
    m_Localized: stiamo facendo degli esperimenti per viaggiare nel tempo
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906561
    m_Localized: vuoi aiutarci a sistemare le ultime modifiche?
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906562
    m_Localized: si che emozione
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906563
    m_Localized: no
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906564
    m_Localized: allora cercheremo qualcun' altro
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906565
    m_Localized: allora aggiusta la data di dove andremo
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906566
    m_Localized: grazie adesso andiamo a vedere il Rinascimento
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906567
    m_Localized: Ecco la carta che ti mancava
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906568
    m_Localized: raccogli la colomba bianca e portamela
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906569
    m_Localized: "ti aiuter\xF2 a cercare leonardo"
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906570
    m_Localized: grazie mille
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906571
    m_Localized: Leonardo si trova dentro la mia bottega
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906572
    m_Localized: "\xE8 quella qui dietro entra pure"
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906573
    m_Localized: ciao piccolo gattino che ci fai qui?
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906574
    m_Localized: raccogli la colomba bianca e portamela
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906575
    m_Localized: "ti aiuter\xF2 a cercare leonardo"
