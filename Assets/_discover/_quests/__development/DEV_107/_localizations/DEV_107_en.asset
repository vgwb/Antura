  - m_Id: 2897013405376516
    m_Localized: allora aggiusta la data di dove andremo
    m_Metadata:
      m_Items: []
  - m_Id: 2897013405376517
    m_Localized: grazie adesso andiamo a vedere il Rinascimento
    m_Metadata:
      m_Items: []
  - m_Id: 2897013405376518
    m_Localized: Ecco la carta che ti mancava
    m_Metadata:
      m_Items: []
  - m_Id: 3088433278369792
    m_Localized: grazie mille
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729920
    m_Localized: Leonardo si trova dentro la mia bottega
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729921
    m_Localized: "\xE8 quella qui dietro entra pure"
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729922
    m_Localized: ciao piccolo gattino che ci fai qui?
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729923
    m_Localized: conosci Leonardo Da Vinci?
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729924
    m_Localized: "si che lo conosco \xE8 un mio allievo"
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729925
    m_Localized: se vuoi incontrarlo devi prima aiutarmi
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729926
    m_Localized: va bene
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729927
    m_Localized: trovami un uccello
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729928
    m_Localized: deve essere bianco mi serve come modello per la mia opera
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729929
    m_Localized: miao
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729930
    m_Localized: sei un gatto molto strano
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729931
    m_Localized: miao
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729932
    m_Localized: sei un gatto effettivamente
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729933
    m_Localized: non esistono gatti parlanti
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729934
    m_Localized: bravo adesso portamela qui
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729935
    m_Localized: qui nessuno capisce il mio genio
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729936
    m_Localized: il maestro ci sta usando per le sue opere
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729937
    m_Localized: noi le facciamo e lui si prende i meriti
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729938
    m_Localized: oh ciao piccolo gattino che cosa ci fai qui?
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729939
    m_Localized: mi serve il tuo aiuto
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729940
    m_Localized: qui nessuno capisce il mio genio
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729941
    m_Localized: il maestro ci sta usando per le sue opere
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729942
    m_Localized: noi le facciamo e lui si prende i meriti
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729943
    m_Localized: oh ciao piccolo gattino che cosa ci fai qui?
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729944
    m_Localized: mi serve il tuo aiuto
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729945
    m_Localized: prima di aiutarti devi riuscire a convincere i miei compagni
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729946
    m_Localized: non capiscono il mio genio vai a convincerli
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729947
    m_Localized: che devo fare?
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729948
    m_Localized: accidenti a quel Leonardo
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729949
    m_Localized: mi ha rovinato tutto
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729950
    m_Localized: "ciao scusa cos'\xE8 successo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729951
    m_Localized: Leonardo mi ha appena distrutto la frutta che dovevo usare
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729952
    m_Localized: mi serviva come modello per la mia opera
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729953
    m_Localized: accidenti a quel Leonardo
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729954
    m_Localized: mi ha rovinato tutto
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729955
    m_Localized: "ciao scusa cos'\xE8 successo?"
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729956
    m_Localized: Leonardo mi ha appena distrutto la frutta che dovevo usare
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729957
    m_Localized: mi serviva come modello per la mia opera
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729958
    m_Localized: "ma lui \xE8 arrivato ha distrutto tutto e se l'\xE8 portata via"
    m_Metadata:
      m_Items: []
  - m_Id: 3088433307729959
    m_Localized: puoi trovarmi altri soggetti?
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924352
    m_Localized: no mi serve di colore bianco
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924353
    m_Localized: "perch\xE8 il bianco significa purezza"
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924354
    m_Localized: e la colomba raffigura Dio
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924355
    m_Localized: quando vedi un elemento in un opera di colore bianco
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924356
    m_Localized: molto spesso significa la purezza
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924357
    m_Localized: bravo adesso portamela qui
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924358
    m_Localized: risolvi i loro problemi dicendo che ti ho detto io come fare
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924359
    m_Localized: miao
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924360
    m_Localized: "perch\xE8 sto parlando con un gatto"
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924361
    m_Localized: miao
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924362
    m_Localized: che gatto particolare
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924363
    m_Localized: va bene
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924364
    m_Localized: no miao
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924365
    m_Localized: "trover\xF2 un altro modo"
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924366
    m_Localized: miao?
    m_Metadata:
      m_Items: []
  - m_Id: 3094019629924367
    m_Localized: che carino
    m_Metadata:
      m_Items: []
