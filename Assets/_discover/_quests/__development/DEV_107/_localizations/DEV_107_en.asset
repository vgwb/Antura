    m_Metadata:
      m_Items: []
  - m_Id: 5207665414877187
    m_Localized: dovrebbe esserci Leonardo Da Vinci da queste parti
    m_Metadata:
      m_Items: []
  - m_Id: 5207665414877188
    m_Localized: Ecco la carta che ti mancava
    m_Metadata:
      m_Items: []
  - m_Id: 5207665414877189
    m_Localized: Sono Verrocchio un artista
    m_Metadata:
      m_Items: []
  - m_Id: 5207665414877190
    m_Localized: "la mia bottega \xE8 la pi\xF9 importante di tutta Firenze"
    m_Metadata:
      m_Items: []
  - m_Id: 5207665414877191
    m_Localized: quando vedi un elemento in un opera di colore bianco
