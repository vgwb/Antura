      m_Items: []
  - m_Id: 5937822602641571
    m_Localized: accidenti a quel Leonardo
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641572
    m_Localized: "come far\xF2 adesso?!"
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641573
    m_Localized: "ciao scusa cos'\xE8 successo?"
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641574
    m_Localized: Leonardo mi ha rovinato i colori che dovevo usare
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641575
    m_Localized: mi puoi aiutare a ritrovarli?
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641576
    m_Localized: va bene
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641577
    m_Localized: dovrebbero esserci dei secchio di colore a giro per la bottega
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641578
    m_Localized: mi bastano quelli per ricreare i miei colori
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641579
    m_Localized: no miao
    m_Metadata:
      m_Items: []
  - m_Id: 5937822602641580
    m_Localized: va bene grazie comunque
