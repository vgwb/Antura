    m_Localized: raccogli la colomba bianca e portamela
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906569
    m_Localized: "ti aiuter\xF2 a cercare leonardo"
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906570
    m_Localized: grazie mille
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906571
    m_Localized: Leonardo si trova dentro la mia bottega
    m_Metadata:
      m_Items: []
  - m_Id: 4875263123906572
    m_Localized: "\xE8 quella qui dietro entra pure"
