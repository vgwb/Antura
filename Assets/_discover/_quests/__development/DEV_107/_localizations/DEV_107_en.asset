  m_TableData:
  - m_Id: 2586341007360
    m_Localized: Siamo a Firenze. Oggi.
    m_Metadata:
      m_Items: []
  - m_Id: 2586341007361
    m_Localized: hai completato la quest sugli artisti della bottega del Verrocchio.
    m_Metadata:
      m_Items: []
  - m_Id: 2586341007362
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 2586341007363
    m_Localized: Hallo
    m_Metadata:
      m_Items: []
  - m_Id: 2586341007364
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 2633806888677376
    m_Localized: Ciao siamo un gruppo di scienziati
    m_Metadata:
      m_Items: []
  - m_Id: 2633806930620416
    m_Localized: stiamo facendo degli esperimenti per viaggiare nel tempo
    m_Metadata:
      m_Items: []
  - m_Id: 2633806930620417
    m_Localized: vuoi aiutarci a sistemare le ultime modifiche?
    m_Metadata:
      m_Items: []
  - m_Id: 2633806930620418
    m_Localized: si che emozione
    m_Metadata:
      m_Items: []
  - m_Id: 2633886853083136
    m_Localized: aiuooooo
    m_Metadata:
      m_Items: []
  - m_Id: 2637686267555840
    m_Localized: no
    m_Metadata:
      m_Items: []
  - m_Id: 2637686338859008
    m_Localized: allora cercheremo qualcun' altro
    m_Metadata:
      m_Items: []
  - m_Id: 2637686338859009
    m_Localized: grazie per aver trovato Leonardo
    m_Metadata:
      m_Items: []
  - m_Id: 2637686338859010
    m_Localized: allora prendimi i colori
    m_Metadata:
      m_Items: []
  - m_Id: 2667906353704960
    m_Localized: ok
    m_Metadata:
      m_Items: []
  - m_Id: 2676352440446976
    m_Localized: no aspetta che stai facendo Antura?
    m_Metadata:
      m_Items: []
  - m_Id: 2677558181212160
    m_Localized: ti paice il rosso?
    m_Metadata:
      m_Items: []
  - m_Id: 2697156066652160
    m_Localized: allora aggiusta la data di dove andremo
    m_Metadata:
      m_Items: []
  - m_Id: 2697156133761024
    m_Localized: grazie adesso andiamo a vedere il Rinascimento
    m_Metadata:
      m_Items: []
  - m_Id: 2721255295922176
    m_Localized: Ecco la carta che ti mancava
