    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433670
    m_Localized: va bene grazie comunque
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433671
    m_Localized: grazie gattino adesso posso finalmente tornare a casa
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433672
    m_Localized: me le ha nascoste mentre stavo completando il mio quadro
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433673
    m_Localized: per la famosa Cappella Sistina
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433674
    m_Localized: in questo quadro commissionatomi da Papa Sisto IV
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433675
    m_Localized: dovevo rappresentare la sua importanza
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433676
    m_Localized: "cos\xEC ho fatto ges\xF9 che gli consegna le chiavi della chiesa"
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433677
    m_Localized: "il soggetto inginocchiato \xE8 San Pietro"
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433678
    m_Localized: ma vuole rappresentare Papa Sisto IV
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433679
    m_Localized: Leonardo mi ha detto di dirti che gli dispiace
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433680
    m_Localized: oh scuse accettate
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433681
    m_Localized: "solo la prossima volta me le nasconda in modo pi\xF9 visibile"
    m_Metadata:
      m_Items: []
  - m_Id: 5240226824433682
    m_Localized: grazie mille porta qui tutto quello che hai trovato
    m_Metadata:
      m_Items: []
