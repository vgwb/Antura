  m_TableData:
  - m_Id: 1204649189376
    m_Localized: Welcome to this quest
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383680
    m_Localized: The quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383681
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383682
    m_Localized: Mi potresti aiutare a trovare i miei progetti, sono 5 fogli dove
      sarano andati?
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383683
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 3402308406288384
    m_Localized: "carista: Ma che \xE8 succeso tutti i progetti dove sono ora come
      facio?"
    m_Metadata:
      m_Items: []
  - m_Id: 3402308515340288
    m_Localized: Mi potresti aiutare a trovare i miei progetti, sono 5 fogli dove
      sarano andati?
    m_Metadata:
      m_Items: []
  - m_Id: 3437940658741248
    m_Localized: 'carista: Ottimo grazie del aiuto. Ti va di aiutarmi per prendere
      gli ultimi oggeti per creare il mio carro che per colpa di quella libeciatta
      gli oggetti sono sparpagliati in giro'
    m_Metadata:
      m_Items: []
  - m_Id: 3455049228951552
