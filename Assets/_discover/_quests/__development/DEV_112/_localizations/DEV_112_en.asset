  m_TableData:
  - m_Id: 1204649189376
    m_Localized: Welcome to this quest
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383680
    m_Localized: The quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383681
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383682
    m_Localized: Mi potresti aiutare a trovare i miei progetti, sono 5 fogli dove
      sarano andati?
    m_Metadata:
      m_Items: []
  - m_Id: 1204653383683
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 3402308406288384
    m_Localized: "carista: Ma che \xE8 succeso tutti i progetti dove sono ora come
      facio?"
    m_Metadata:
      m_Items: []
  - m_Id: 3402308515340288
    m_Localized: Mi potresti aiutare a trovare i miei progetti, sono 5 fogli dove
      sarano andati?
    m_Metadata:
      m_Items: []
  - m_Id: 3437940658741248
    m_Localized: 'carista: Ottimo grazie del aiuto. Ti va di aiutarmi per prendere
      gli ultimi oggeti per creare il mio carro che per colpa di quella libeciatta
      gli oggetti sono sparpagliati in giro'
    m_Metadata:
      m_Items: []
  - m_Id: 3455049228951552
    m_Localized: "Ma che \xE8 succeso tutti i progetti dove sono ora come facio?"
    m_Metadata:
      m_Items: []
  - m_Id: 3455049283477504
    m_Localized: Ottimo grazie del aiuto.
    m_Metadata:
      m_Items: []
  - m_Id: 3455049283477505
    m_Localized: Ti va di aiutarmi per prendere gli ultimi oggeti per creare il mio
      carro
    m_Metadata:
      m_Items: []
  - m_Id: 3455049283477506
    m_Localized: che per colpa di quella libeciatta gli oggetti sono sparpagliati
      in giro
    m_Metadata:
      m_Items: []
  - m_Id: 3455049283477507
    m_Localized: Ottimo grazie del aiuto.
    m_Metadata:
      m_Items: []
  - m_Id: 3457563869388800
    m_Localized: Ottimo grazie del aiuto.
    m_Metadata:
      m_Items: []
  - m_Id: 3457563873583104
    m_Localized: Ti va di aiutarmi per prendere gli ultimi oggeti per creare il mio
      carro
    m_Metadata:
      m_Items: []
  - m_Id: 3457563873583105
    m_Localized: che per colpa di quella libeciatta gli oggetti sono sparpagliati
      in giro
    m_Metadata:
      m_Items: []
  - m_Id: 3460721807007744
    m_Localized: Ti va di aiutarmi per prendere gli ultimi oggeti per creare il mio
      carro
    m_Metadata:
      m_Items: []
  - m_Id: 3460721811202048
    m_Localized: che per colpa di quella libeciatta gli oggetti sono sparpagliati
      in giro
    m_Metadata:
      m_Items: []
  - m_Id: 4940886852575232
    m_Localized: Siamo a Viareggio!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518272
    m_Localized: "\xC8 il periodo del Carnevale!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518273
    m_Localized: Ciao! Sono un costruttore di carri.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518274
    m_Localized: Il vento ha fatto un disastro!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518275
    m_Localized: I miei disegni sono sparpagliati per la piazza.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518276
    m_Localized: Ho bisogno di tutti e cinque i fogli.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518277
    m_Localized: Puoi aiutarmi a raccoglierli?
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518278
    m_Localized: "S\xEC, li cerco subito!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518279
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518280
    m_Localized: Cerca ancora, mancano ancora dei fogli!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518281
    m_Localized: Grazie mille per i disegni!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518282
    m_Localized: "Ma c'\xE8 ancora un problema..."
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518283
    m_Localized: "Il mio carro non \xE8 ancora pronto."
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518284
    m_Localized: Il libeccio ha portato via i pezzi!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518285
    m_Localized: "Il libeccio \xE8 un vento forte del mare."
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518286
    m_Localized: Puoi raccogliere i pezzi del carro?
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518287
    m_Localized: "S\xEC, li cerco!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518288
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518289
    m_Localized: "Il carro \xE8 quasi pronto!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518290
    m_Localized: Manca solo l'ultimo pezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518291
    m_Localized: Un disegno del carista!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518292
    m_Localized: Un pezzo del carro di carnevale!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518293
    m_Localized: Ottimo! Hai trovato tutto!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518294
    m_Localized: Adesso dobbiamo assemblare il carro.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518295
    m_Localized: Sei pronto ad aiutarmi?
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518296
    m_Localized: "S\xEC, proviamo!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518297
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518298
    m_Localized: Quasi! Proviamo ancora una volta.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518299
    m_Localized: "Fantastico! Il carro \xE8 pronto!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518300
    m_Localized: I carri del Carnevale di Viareggio sono famosi.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518301
    m_Localized: Sono fatti di cartapesta.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518302
    m_Localized: Ora vai a vedere la sfilata!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518303
    m_Localized: Ciao! Sei qui per il Carnevale?
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518304
    m_Localized: Guarda che belle maschere!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518305
    m_Localized: Sai riconoscere le maschere tradizionali?
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518306
    m_Localized: Facciamo un gioco?
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518307
    m_Localized: "S\xEC, giochiamo!"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518308
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518309
    m_Localized: "Hai visto com'\xE8 bello il carro?"
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518310
    m_Localized: Quasi! Guarda bene le maschere.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518311
    m_Localized: Riproviamo!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518312
    m_Localized: Bravissimo! Conosci bene le maschere!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518313
    m_Localized: "Il Carnevale di Viareggio \xE8 famoso in tutto il mondo."
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518314
    m_Localized: Il Carnevale di Viareggio dura un mese!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518315
    m_Localized: I carri sono alti come un palazzo.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518316
    m_Localized: La cartapesta si fa con carta e colla.
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518317
    m_Localized: "Il libeccio \xE8 il vento del mare."
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518318
    m_Localized: Hai aiutato il carista e visto la sfilata!
    m_Metadata:
      m_Items: []
  - m_Id: 4940886894518319
    m_Localized: Disegna la tua maschera di carnevale!
    m_Metadata:
      m_Items: []
  - m_Id: 4948324083376128
    m_Localized: Hai trovato tutti i disegni!
    m_Metadata:
      m_Items: []
  - m_Id: 4948324129513472
    m_Localized: Torna dal carista.
    m_Metadata:
      m_Items: []
  - m_Id: 4948324129513473
    m_Localized: Hai trovato tutti i pezzi!
    m_Metadata:
      m_Items: []
  - m_Id: 4948324129513474
    m_Localized: Torna dal carista.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
