%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: DEV_103_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 997553e0f2e504a0fa2d1ead804be4e8, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 5808417923072
    m_Localized: Welcome to this quest
    m_Metadata:
      m_Items: []
  - m_Id: 5808417923073
    m_Localized: The quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 5808417923074
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 5808417923075
    m_Localized: Hallo
    m_Metadata:
      m_Items: []
  - m_Id: 5808417923076
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 2629285713956864
    m_Localized: Siamo a Firenze!
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482816
    m_Localized: Vuoi entrare nel Campanile di Giotto?
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482817
    m_Localized: "La porta \xE8 chiusa."
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482818
    m_Localized: "Il Campanile oggi \xE8 chiuso."
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482819
    m_Localized: Non ho la chiave per aprirlo.
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482820
    m_Localized: Sai dove posso trovarla?
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482821
    m_Localized: Sai chi la possiede?
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482822
    m_Localized: La chiave ce l'ha Giotto!
    m_Metadata:
      m_Items: []
  - m_Id: 2629285768482823
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 2633897959378944
    m_Localized: Buongiorno! Hai bisogno di qualcosa?
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099200
    m_Localized: Conosci Giotto?
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099201
    m_Localized: Chi era la persona passata prima?
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099202
    m_Localized: Certo che conosco Giotto!
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099203
    m_Localized: Era Giotto di Bondone!
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099204
    m_Localized: "\xC8 un pittore famosissimo."
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099205
    m_Localized: Le sue figure sembrano persone vere!
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099206
    m_Localized: Guarda qui, ho un suo quadro.
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099207
    m_Localized: "Ma \xE8 pieno di polvere..."
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099208
    m_Localized: "Accidenti! C'\xE8 ancora troppa polvere."
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099209
    m_Localized: Proviamo ancora!
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099210
    m_Localized: Ottimo lavoro! Il quadro si vede benissimo.
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099211
    m_Localized: Non so dove sia andato Giotto...
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099212
    m_Localized: Ha lasciato una scia di colore!
    m_Metadata:
      m_Items: []
  - m_Id: 2633898018099213
    m_Localized: Forse puoi seguirla.
    m_Metadata:
      m_Items: []
  - m_Id: 2643083749380096
    m_Localized: Puoi aiutarmi a pulirlo?
    m_Metadata:
      m_Items: []
  - m_Id: 2673574439440384
    m_Localized: Niente, grazie.
    m_Metadata:
      m_Items: []
  - m_Id: 2673574493966336
    m_Localized: Prego! A presto.
    m_Metadata:
      m_Items: []
  - m_Id: 3108411012960256
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3108411054903296
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3108411054903297
    m_Localized: Forse puoi seguirla.
    m_Metadata:
      m_Items: []
  - m_Id: 3119377058516992
    m_Localized: Ciao!
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265728
    m_Localized: Sto guardando questi due quadri.
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265729
    m_Localized: "Quello di destra ha qualcosa in pi\xF9..."
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265730
    m_Localized: "Non riesco a capire perch\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265731
    m_Localized: "Perch\xE9 ha usato colori pi\xF9 forti"
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265732
    m_Localized: "Perch\xE9 le persone sembrano pi\xF9 vere"
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265733
    m_Localized: Non lo so
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265734
    m_Localized: Forse quella persona sa dove trovarlo.
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265735
    m_Localized: Non penso sia quello il motivo.
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265736
    m_Localized: Vuoi provare ancora?
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265737
    m_Localized: Guarda bene i personaggi nei due quadri!
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265738
    m_Localized: "S\xEC! Hai ragione!"
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265739
    m_Localized: "Le persone sembrano pi\xF9 vere e realistiche."
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265740
    m_Localized: Mi aiuteresti a capirlo meglio?
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265741
    m_Localized: Alcuni collegamenti sono sbagliati.
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265742
    m_Localized: Riproviamo!
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265743
    m_Localized: Ora ho capito!
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265744
    m_Localized: "Giotto rendeva le persone molto pi\xF9 vere."
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265745
    m_Localized: "Hai visto dove \xE8 andato Giotto?"
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265746
    m_Localized: "S\xEC! Poco fa era laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3119377096265747
    m_Localized: Forse quella persona sa dove trovarlo.
    m_Metadata:
      m_Items: []
  - m_Id: 3771259757256704
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3771259761451008
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3771259761451009
    m_Localized: Forse puoi seguirla.
    m_Metadata:
      m_Items: []
  - m_Id: 3771259761451010
    m_Localized: Forse quella persona sa dove trovarlo.
    m_Metadata:
      m_Items: []
  - m_Id: 3781627057528832
    m_Localized: Accendo giotto
    m_Metadata:
      m_Items: []
  - m_Id: 3781627065917440
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3781627065917441
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3781627065917442
    m_Localized: Forse puoi seguirla.
    m_Metadata:
      m_Items: []
  - m_Id: 3781627065917443
    m_Localized: Forse quella persona sa dove trovarlo.
    m_Metadata:
      m_Items: []
  - m_Id: 3783646757511168
    m_Localized: Spengo giotto
    m_Metadata:
      m_Items: []
  - m_Id: 3783646761705472
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3783646761705473
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 3783646761705474
    m_Localized: Forse puoi seguirla.
    m_Metadata:
      m_Items: []
  - m_Id: 3783646761705475
    m_Localized: Forse quella persona sa dove trovarlo.
    m_Metadata:
      m_Items: []
  - m_Id: 3809427131879424
    m_Localized: Salve! Hai bisogno di qualcosa?
    m_Metadata:
      m_Items: []
  - m_Id: 3809427282874368
    m_Localized: Sto cercando Giotto, lo hai visto?
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068672
    m_Localized: Cosa stai facendo?
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068673
    m_Localized: Niente, grazie.
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068674
    m_Localized: Prego! A presto.
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068675
    m_Localized: "Se lo cerchi, sar\xE0 gi\xE0 tornato al campanile."
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068676
    m_Localized: Le mie lettere sono cadute per terra!
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068677
    m_Localized: "\xC8 una giornata proprio storta."
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068678
    m_Localized: "S\xEC, \xE8 venuto da me poco fa."
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068679
    m_Localized: Le mie lettere sono cadute per terra!
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068680
    m_Localized: "Non \xE8 che mi aiuteresti a cercarle?"
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068681
    m_Localized: Ne mancano ancora alcune!
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068682
    m_Localized: Riproviamo!
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068683
    m_Localized: Grazie mille!
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068684
    m_Localized: Stavo consegnando lettere proprio a Giotto.
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068685
    m_Localized: "\xC8 molto cercato da tutta Italia!"
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068686
    m_Localized: Il Papa in persona lo mise alla prova.
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068687
    m_Localized: "Voleva testare le sue capacit\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068688
    m_Localized: Sai cosa fece Giotto?
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068689
    m_Localized: "Disegn\xF2 un cerchio perfetto a mano libera!"
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068690
    m_Localized: "Senza righello n\xE9 compasso."
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068691
    m_Localized: "Prova anche tu... non \xE8 facile!"
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068692
    m_Localized: "Visto? Non era cos\xEC facile!"
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068693
    m_Localized: "Giotto ci riusc\xEC al primo colpo."
    m_Metadata:
      m_Items: []
  - m_Id: 3809427287068694
    m_Localized: Roba da non credere!
    m_Metadata:
      m_Items: []
  - m_Id: 3894017473269760
    m_Localized: "Sar\xE0 gi\xE0 tornato al suo campanile."
    m_Metadata:
      m_Items: []
  - m_Id: 3894017506824192
    m_Localized: "Se lo cerchi, sar\xE0 gi\xE0 tornato al campanile."
    m_Metadata:
      m_Items: []
  - m_Id: 4448913532538880
    m_Localized: "L'ho visto alla bancarella laggi\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 4448913578676224
    m_Localized: Forse puoi seguirla.
    m_Metadata:
      m_Items: []
  - m_Id: 4448913578676225
    m_Localized: Forse quella persona sa dove trovarlo.
    m_Metadata:
      m_Items: []
  - m_Id: 4448913578676226
    m_Localized: Una lettera del messaggero!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372461576192
    m_Localized: "S\xEC, ci provo!"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324928
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324929
    m_Localized: "S\xEC, proviamo!"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324930
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324931
    m_Localized: Posso aiutarti a raccoglierle?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324932
    m_Localized: Hai visto passare Giotto?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324933
    m_Localized: "S\xEC! \xC8 passato poco fa."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324934
    m_Localized: "Ho per\xF2 ancora questo problema..."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324935
    m_Localized: Potresti aiutarmi prima?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324936
    m_Localized: Grazie! Sono sparite qui intorno.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324937
    m_Localized: "Ho per\xF2 un problema..."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324938
    m_Localized: Ci provo!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324939
    m_Localized: Non ora.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324940
    m_Localized: Oh, sei tu!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324941
    m_Localized: La guardia mi ha detto che cercavi la chiave.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324942
    m_Localized: Non la do a chiunque, sai.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324943
    m_Localized: Prima voglio capire se meriti di salire.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324944
    m_Localized: "Ti far\xF2 due domande su di me."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324945
    m_Localized: Se rispondi bene... le chiavi sono tue!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324946
    m_Localized: Sono pronto!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324947
    m_Localized: Le chiavi le hai guadagnate. Buona salita!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324948
    m_Localized: Prima domanda!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324949
    m_Localized: Cosa rende i miei dipinti speciali?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324950
    m_Localized: "Le persone sembrano pi\xF9 vere"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324951
    m_Localized: "Usi colori pi\xF9 brillanti"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324952
    m_Localized: "I tuoi quadri sono pi\xF9 grandi"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324953
    m_Localized: Mmm... non direi!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324954
    m_Localized: Pensa ai due quadri che hai visto prima.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324955
    m_Localized: Cosa notavi nelle persone?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324956
    m_Localized: Esatto! Le mie figure hanno emozioni vere.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324957
    m_Localized: "\xC8 quello che ho sempre cercato di fare."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324958
    m_Localized: Bene, passiamo alla seconda domanda!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324959
    m_Localized: Seconda domanda!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324960
    m_Localized: Cosa feci quando il Papa mi mise alla prova?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324961
    m_Localized: Disegnasti un cerchio perfetto a mano libera
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324962
    m_Localized: Dipingesti un ritratto del Papa
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324963
    m_Localized: Costruisti un modello del campanile
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324964
    m_Localized: No no! Ricordi la prova che hai fatto tu?
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324965
    m_Localized: "Il messaggero te lo ha gi\xE0 raccontato!"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324966
    m_Localized: "Proprio cos\xEC! A mano libera, senza righello."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324967
    m_Localized: Il Papa rimase a bocca aperta!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324968
    m_Localized: Bene! Hai dimostrato di sapere chi sono.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324969
    m_Localized: Le chiavi le hai guadagnate!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324970
    m_Localized: Alla fine lo hai trovato!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324971
    m_Localized: Benvenuto nel Campanile di Giotto!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324972
    m_Localized: "Da quass\xF9 puoi vedere tutta Firenze."
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324973
    m_Localized: Proprio come la vedeva lui.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324974
    m_Localized: Era un grande pittore e anche un architetto.
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324975
    m_Localized: "Questo campanile \xE8 il suo capolavoro!"
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324976
    m_Localized: Hai scoperto Giotto e salito il suo campanile!
    m_Metadata:
      m_Items: []
  - m_Id: 4459372499324977
    m_Localized: Disegna il campanile di Giotto!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
