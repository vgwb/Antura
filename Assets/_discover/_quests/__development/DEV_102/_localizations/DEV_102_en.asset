  m_Name: DEV_102_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 5e8cceb3f51f044faa5d7f0bc3a59a77, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 160702642774016
    m_Localized: Benvenuti a Collodi
    m_Metadata:
      m_Items: []
  - m_Id: 160702642774017
    m_Localized: The quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 160702642774018
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 160702642774019
    m_Localized: "Pinocchio siamo spacciati Che cosa dirai alla maestra, se non puoi
      pi\xF9 studiare sui miei appunti?"
    m_Metadata:
      m_Items: []
  - m_Id: 160702642774020
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 2847730650882048
    m_Localized: "Grillo: Oh, cielo! E adesso come far\xF2? Quel terribile cagnaccio
      blu ha strappato le pagine del mio diario!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630784
    m_Localized: "Pinocchio siamo spacciati Che cosa dirai alla maestra, se non puoi
      pi\xF9 studiare sui miei appunti?"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630785
    m_Localized: "Pinocchio: Grillo, Grillo! Guarda un po\u2019: quel gatto laggi\xF9
      ha proprio l\u2019aria di poterci dare una mano!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630786
    m_Localized: "Grillo: Mmm\u2026 hai proprio ragione! Questo gattino sembra davvero
      sveglio. Allora, che ne dici? Ti andrebbe di darci una zampa?"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630787
    m_Localized: "Certo che vi aiuter\xF2"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630788
    m_Localized: Un'altra volta
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630789
    m_Localized: 'Grillo: Oh povero me..'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630790
    m_Localized: "Grillo: Grazie mille! L\u2019ultima volta che ho visto quel cane,
      si stava dirigendo verso il parco. Prova a cercare l\xEC dentro!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630791
    m_Localized: 'Lucignolo: Oh, sono davvero curiosissimo di scoprire chi sia la
      persona raffigurata!'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630792
    m_Localized: Potresti aiutarmi a capirlo?
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630793
    m_Localized: Va bene ti aiuto
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630794
    m_Localized: No grazie
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630795
    m_Localized: "Lucignolo: Oh s\xEC, grazie\u2026 questa pagina si \xE8 tutta sporcata
      e ora non riesco pi\xF9 a capire chi fosse la persona raffigurata."
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630796
    m_Localized: "E, siccome sono un povero asino, con gli zoccoli non riesco proprio
      a pulirla\u2026 ti prego, aiutami a scoprire chi \xE8!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630797
    m_Localized: "Lucignolo: Oh\u2026 capisco. Va bene, non importa\u2026 anche se
      la curiosit\xE0 \xE8 tanta, cercher\xF2 di farmela passare."
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630798
    m_Localized: Successo
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630799
    m_Localized: Fallimento
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630800
    m_Localized: "Lucignolo: Amico, credo di non aver ancora capito chi sia\u2026
      non \xE8 che vuoi riprovare?"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630801
    m_Localized: 'Lucignolo: Proviamo ancora!'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630802
    m_Localized: Successo
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630803
    m_Localized: Fallimento
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630804
    m_Localized: "Lucignolo: Ho capito di chi si tratta, \xE8 Carlo Collodi!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630805
    m_Localized: Hai visto un cane blu aggirarsi da queste parti?
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630806
    m_Localized: "Lucignolo: Uhm\u2026 fammi pensare\u2026 \xE8 andato di l\xE0.
      Per\xF2 fai attenzione: proprio in quella direzione c\u2019\xE8 il pescecane!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630807
    m_Localized: "Geppetto: Oh caro gattino, potresti aiutare questo povero vecchio
      a rimettere in ordine questa pagina strappata? Basta solo ricomporre i pezzi\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630808
    m_Localized: Va bene ti aiuto
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630809
    m_Localized: No grazie
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630810
    m_Localized: 'Geppetto: Oh ho grazie infinitamente'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630811
    m_Localized: "Geppetto: Oh fa niente, ci prover\xF2 io"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630812
    m_Localized: Successo
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630813
    m_Localized: Fallimento
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630814
    m_Localized: 'Geppetto: Oh no non ci siamo, i pezzi sono messi male'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630815
    m_Localized: 'Geppetto: Riproviamo!'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630816
    m_Localized: Successo
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630817
    m_Localized: Fallimento
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630818
    m_Localized: 'Geppetto: Ah che ricordi la Villa Garzoni!'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630819
    m_Localized: Hai visto un cane blu aggirarsi da queste parti?
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630820
    m_Localized: "Geppetto: Non sono sicuro fosse proprio un cane, ma una figura
      blu \xE8 scappata verso il labirinto\u2026 prova a cercare da quelle parti!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630821
    m_Localized: 'Fata: Buongiorno bel gattino, ti sei per caso perso?'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630822
    m_Localized: Sto cercando una pagina di un diario, l' hai vista?
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630823
    m_Localized: Credo di essermi perso
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630824
    m_Localized: si mi sono perso
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630825
    m_Localized: "Fata: Va bene, aspetta un attimo\u2026 con la mia magia ti riporter\xF2
      all\u2019ingresso del parco!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630826
    m_Localized: Va bene
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630827
    m_Localized: No grazie
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630828
    m_Localized: "Fata: Ecco cosa aveva quel cagnolino tra i denti\u2026 caro gattino!
      \xC8 scappato proprio dentro al labirinto!"
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630829
    m_Localized: 'Antura: Bau Bau'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630830
    m_Localized: Eccoti qui Antura, puoi darmi la pagina?
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630831
    m_Localized: 'Antura: Bau!'
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630832
    m_Localized: Successo
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630833
    m_Localized: Fallimento
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630834
    m_Localized: Grazie Antura!
    m_Metadata:
      m_Items: []
  - m_Id: 2847730688630835
    m_Localized: 'Antura: Bau!'
    m_Metadata:
      m_Items: []
  - m_Id: 2848712625528832
    m_Localized: "Oh, cielo! E adesso come far\xF2? Quel terribile cagnaccio blu
      ha strappato le pagine del mio diario!"
    m_Metadata:
