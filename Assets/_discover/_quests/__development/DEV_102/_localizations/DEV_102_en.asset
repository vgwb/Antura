  - m_Id: 10617646057562112
    m_Localized: Ultima domanda!
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562113
    m_Localized: "In quale altro famosissimo adattamento  \xE8 stata raccontata la
      storia di Pinocchio"
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562114
    m_Localized: Disney
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562115
    m_Localized: Dancey
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562116
    m_Localized: Donny
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562117
    m_Localized: Ricordi l'immagine che hai visto sulla pagina che aveva in bocca
      Antura?
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562118
    m_Localized: Esatto! Pinocchio della Disney!
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562119
    m_Localized: Nel 1940 Walt Disney decide di creare un film trattato sul romanzo
      di Carlo Collodi
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562120
    m_Localized: "Il Film di pinocchio \xE8 piaciuto cos\xEC tanto che a volte la
      versione Disney viene considerata l'originale"
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562121
    m_Localized: "Per\xF2 la vera storia di Pinocchio \xE8 quella scritta da Carlo
      Collodi!"
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562122
    m_Localized: "Bene! Credo che sia te che Pinocchio adesso conosciate molto di
      pi\xF9 Collodi, la storia di Pinocchio e il suo parco"
    m_Metadata:
      m_Items: []
  - m_Id: 10617646057562123
    m_Localized: "Non \xE8 vero Pinocchio?"
