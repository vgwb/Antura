      m_Items: []
  - m_Id: 5152397762015254
    m_Localized: Hai visto la statua?
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015255
    m_Localized: "\xC8 uno degli aretini pi\xF9 famosi della storia."
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015256
    m_Localized: Hai visto la statua?
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015257
    m_Localized: Hai trovato il Pentagramma!
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015258
    m_Localized: "\xC8 il foglio su cui si scrivono le note."
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015259
    m_Localized: Ha 5 righe e 4 spazi. Le note si posizionano su queste righe e spazi.
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015260
    m_Localized: "Ma \xE8 ancora vuoto... dobbiamo trovare le note!"
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015261
    m_Localized: 'title: anfiteatroromano'
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015262
    m_Localized: ---
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015263
    m_Localized: "Questo \xE8 l'Anfiteatro Romano di Arezzo, costruito tantissimo
      tempo fa."
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015264
    m_Localized: Qui i romani venivano a guardare recite e opere teatrali.
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015265
    m_Localized: Grazie mille ora possiamo tornare a cantare!
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015266
    m_Localized: Sta sotto il pentagramma, su una piccola linea tutta sua.
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015267
    m_Localized: "\xC8 la prima nota della scala."
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015268
    m_Localized: Sta sotto il pentagramma, su una piccola linea tutta sua.
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015269
    m_Localized: Chiave inglese
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015270
    m_Localized: Punto musicale
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015271
    m_Localized: Chiave inglese
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015272
    m_Localized: Punto musicale
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015273
    m_Localized: Prendi pure il foglio!
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015274
    m_Localized: Me lo ha spiegato proprio lui, Guido d'Arezzo!
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015275
    m_Localized: Prendi pure il foglio!
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015276
    m_Localized: hallo
    m_Metadata:
      m_Items: []
  - m_Id: 5152397762015277
    m_Localized: "Mmm, non \xE8 questa! Riprova."
    m_Metadata:
      m_Items: []
  - m_Id: 5158972241260544
    m_Localized: Hai trovato il Pentagramma!
    m_Metadata:
      m_Items: []
