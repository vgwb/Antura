  m_TableData:
  - m_Id: 169025920294912
    m_Localized: "Esplora e risolvi i problemi nella citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489216
    m_Localized: The quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489217
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489218
    m_Localized: Hallo
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489219
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 2812171349700608
    m_Localized: Benvenuto ad Arezzo!
    m_Metadata:
      m_Items: []
  - m_Id: 2812171404226560
    m_Localized: Antura ha combinato un disastro!
    m_Metadata:
      m_Items: []
  - m_Id: 2812171404226561
    m_Localized: Antura ha combinato un disastro!
    m_Metadata:
      m_Items: []
  - m_Id: 2812171404226562
    m_Localized: "Ha sparpagliato le pagine dello spartito del coro per tutta la
      citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811072
    m_Localized: "Benvenuto in citt\xE0!"
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811073
    m_Localized: Io sono Guido d'Arezzo, monaco e musicista.
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811074
    m_Localized: Tanto tempo fa ho inventato il modo di scrivere le note che usiamo
      ancora oggi per leggere la musica!
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811075
    m_Localized: "Ma oggi \xE8 un giorno molto triste..."
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811076
    m_Localized: Quel birbante di Antura ha sparpagliato le pagine del nostro spartito
      per tutta Arezzo!
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811077
    m_Localized: "Senza di loro, il coro della Cattedrale non pu\xF2 cantare."
    m_Metadata:
      m_Items: []
  - m_Id: 2815809031811078
    m_Localized: Mi accompagni a cercarle?
    m_Metadata:
      m_Items: []
  - m_Id: 2838793591238656
    m_Localized: Mi accompagni a cercarle?
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210176
    m_Localized: "S\xEC!"
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210177
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210178
    m_Localized: Grazie mille!
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210179
    m_Localized: "Sar\xF2 la tua guida in citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210180
    m_Localized: Ho segnato sulla mappa i posti in cui ho visto volare via le pagine.
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210181
    m_Localized: Andiamo!
    m_Metadata:
      m_Items: []
  - m_Id: 2838793612210182
    m_Localized: Ti prego, ho davvero bisogno di aiuto!
    m_Metadata:
      m_Items: []
  - m_Id: 2852691962802176
    m_Localized: Do you want to join my party?
    m_Metadata:
      m_Items: []
  - m_Id: 2852692000550912
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 2852692000550913
    m_Localized: Now i'm following you!
    m_Metadata:
      m_Items: []
  - m_Id: 2852692000550914
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 2852692000550915
    m_Localized: ok
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
