    m_Metadata:
      m_Items: []
  - m_Id: 5051701684854787
    m_Localized: Incontra Guido d'Arezzo!
    m_Metadata:
      m_Items: []
  - m_Id: 5051701684854788
    m_Localized: "Non c'\xE8 tempo da perdere."
    m_Metadata:
      m_Items: []
  - m_Id: 5051701684854789
    m_Localized: "Ti do il benvenuto in citt\xE0!"
    m_Metadata:
      m_Items: []
