  m_SharedData: {fileID: 11400000, guid: 970c03b31e53e4ed4af752f6da8250a6, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 169025920294912
    m_Localized: Welcome to this quest
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489216
    m_Localized: The quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489217
    m_Localized: Why don't you do this homework?
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489218
    m_Localized: Hallo
    m_Metadata:
      m_Items: []
  - m_Id: 169025924489219
    m_Localized: I'm a Living Letter tourist
    m_Metadata:
      m_Items: []
  - m_Id: 3289082517557248
    m_Localized: Eccoci ad Arezzo.
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528768
    m_Localized: Antura ha combinato un disastro!
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528769
    m_Localized: "Risolvi i problemi in citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528770
    m_Localized: "Aiuta Guido a ritrovarle tutte cos\xEC il coro potr\xE0 cantare
      di nuovo!"
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528771
    m_Localized: Io sono Guido d'Arezzo, monaco e musicista.
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528772
    m_Localized: Tanto tempo fa ho inventato il modo di scrivere le note che usiamo
      ancora oggi per leggere la musica!
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528773
    m_Localized: "Ma oggi \xE8 un giorno molto triste..."
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528774
    m_Localized: Quel birbante di Antura ha sparpagliato le pagine del nostro spartito
      per tutta Arezzo!
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528775
    m_Localized: "Senza di loro, il coro della Cattedrale non pu\xF2 cantare."
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528776
    m_Localized: "Senza di loro, il coro della Cattedrale non pu\xF2 cantare."
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528777
    m_Localized: "S\xEC!"
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528778
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528779
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528780
    m_Localized: "Sar\xF2 la tua guida in citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528781
    m_Localized: Ho segnato sulla mappa i posti in cui ho visto volare via le pagine.
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528782
    m_Localized: Andiamo!
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528783
    m_Localized: Andiamo!
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528784
    m_Localized: '>>'
    m_Metadata:
      m_Items: []
  - m_Id: 3289082538528785
    m_Localized: Ti prego, ho davvero bisogno di aiuto!
    m_Metadata:
      m_Items: []
  - m_Id: 3289797554114560
    m_Localized: Mi aiuti a cercarle?
    m_Metadata:
      m_Items: []
  - m_Id: 3295853944541184
    m_Localized: Ti prego, ho davvero bisogno di aiuto!
    m_Metadata:
      m_Items: []
  - m_Id: 3318953599864832
    m_Localized: Raccogli tutte le pagine.
    m_Metadata:
      m_Items: []
  - m_Id: 3959471807696896
    m_Localized: Il simbolo all'inizio del pentagramma si chiama...
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417152
    m_Localized: Chiave di Violino
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417153
    m_Localized: Chiave inglese
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417154
    m_Localized: Punto musicale
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417155
    m_Localized: "S\xEC! La Chiave di Violino, esatto!"
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417156
    m_Localized: Me lo ha spiegato proprio lui, Guido d'Arezzo!
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417157
    m_Localized: Prendi pure il foglio!
    m_Metadata:
      m_Items: []
  - m_Id: 3959471866417158
    m_Localized: "Mmm, non \xE8 questa! Riprova."
    m_Metadata:
      m_Items: []
  - m_Id: 4050095726694400
    m_Localized: hallo
    m_Metadata:
      m_Items: []
  - m_Id: 4050095764443136
    m_Localized: '>>'
    m_Metadata:
      m_Items: []
  - m_Id: 4050095764443137
    m_Localized: "Mmm, non \xE8 questa! Riprova."
