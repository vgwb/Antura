%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: "\xA1El Guardi\xE1n de las Llaves necesita las 10 Llaves Enanas!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "\xA1Int\xE9ntalo de nuevo m\xE1s tarde!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "\xA1Para desbloquear la jaula, resuelve este rompecabezas!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: A nuestro enano viajero le encanta visitar lugares nuevos.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: Esta es la catedral de Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: "Aqu\xED, en el antiguo ayuntamiento, se custodian las leyes de
      la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: "\xA1Esta fuente utiliza agua, luces de colores y m\xFAsica!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "\xA1Este enano necesita una \xFAltima llave para ser libre!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: Ellos leen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: Ellos leen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: Ellos rezan
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: Ellos rezan
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: Ellos juegan
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: Ellos juegan
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: "\xA1Tienen sombreritos y botas diminutas!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "\xA1Hay algo que hacer en el zool\xF3gico!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "Hay un problema en la ciudad... \xA1vamos a investigar!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "Hay una llave detr\xE1s de ese cartel de all\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "\xA1Aqu\xED hay una famosa escultura del artista Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "\xA1Hay m\xE1s de 800 enanos en la ciudad!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "\xA1El zool\xF3gico fue construido hace mucho tiempo, en 1865!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: "\xA1El Enano Escritor sigue encerrado!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: "El Enano Viajero est\xE1 en la plaza."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "El tranv\xEDa est\xE1 listo. Primero, dir\xEDgete a la catedral."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: "\xA1El panorama parece una imagen gigante a mi alrededor!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "El Origin Dwarf ya est\xE1 en el mercado."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: El antiguo ayuntamiento es un edificio antiguo e importante.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: "La fuente multimedia utiliza agua, luz y m\xFAsica."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: "\xA1La Fuente Multimedia necesita nuestra ayuda!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "\xA1El Guardi\xE1n de la Llave est\xE1 atrapado cerca del ascensor!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "Mu\xE9vete y salta sobre los estantes para alcanzarlo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "\xA1La llave est\xE1 cerca del rinc\xF3n de lectura!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: "La llave del ayuntamiento, que est\xE1 escondida, se encuentra
      detr\xE1s del letrero."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: "\xA1El agua de la fuente esconde una llave cerca del escenario!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: "\xA1El espect\xE1culo de la fuente parece un gran concierto!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: "\xA1La ronda final!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: "El ascensor ya est\xE1 abierto."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "El Concejal Enano est\xE1 cerca del Antiguo Ayuntamiento."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "\xA1La ciudad se ve preciosa desde aqu\xED arriba!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: "\xA1El cofre se abre!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "El cofre est\xE1 cerrado con llave."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: "\xA1La zona central est\xE1 terminada!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: "\xA1La zona del Sal\xF3n del Centenario est\xE1 terminada!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "La catedral se encuentra en una de las zonas m\xE1s antiguas de
      Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "El obispo enano est\xE1 encerrado cerca."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: "\xA1Gracias! \xA1Me salvaste!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: "H\xE1blame si necesitas ayuda."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: "Qu\xE9date aqu\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: "A veces me siento aqu\xED e imagino mis propias historias."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: "\xA1Algunos enanos de Breslavia tienen un aspecto gracioso, y otros,
      serio!"
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "La Sky Tower es uno de los edificios m\xE1s altos de Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: Sky Tower
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: Escuela
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: Salven al enano de la escuela.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: "\xA1Encuentra la m\xFAsica y salva al enano director de orquesta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: "\xA1Encuentra y salva al Arquitecto Enano!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: "La gente viene aqu\xED a rezar y a pensar en silencio."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Panorama Rac\u0142awicka es el \xFAltimo lugar aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "\xA1El Panorama Rac\u0142awicka es un cuadro enorme que rodea toda
      la habitaci\xF3n!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "\xA1Panorama Rac\u0142awicka es una pintura redonda gigante!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: "Ella gan\xF3 un gran premio por sus libros. \xA1El Premio Nobel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: "Ahora ya sabes c\xF3mo liberar a los dem\xE1s enanos."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: "Ahora se han transformado en veh\xEDculos m\xE1gicos llamados \"tranv\xEDas\"."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: Ahora ve y libera a mis 10 amigos enanos.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: "No. \xA1Int\xE9ntalo de nuevo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: "No, quiero quedarme aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "Mis amigos todav\xEDa necesitan ayuda en Centennial Hall y en el
      centro de la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: "\xA1Mi familia ha vivido aqu\xED durante much\xEDsimo tiempo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: "\xA1Mueve la planta para encontrarla!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: "\xBFQuiz\xE1s puedas leer un libro en la biblioteca?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "La plaza del mercado es uno de los lugares m\xE1s concurridos de
      Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: La Plaza del Mercado es un lugar muy animado y divertido.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: Mercado
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: Mucha gente visita Breslavia para buscar estatuas de enanos.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: "\xA1Mucha gente busca estatuas de enanos mientras pasea!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: "Mira en el zool\xF3gico, en el gran sal\xF3n y en la fuente."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: Recoge todos los colores que haya por el parque.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: Mira la estrella en el mapa.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "\xA1Observen la Plaza del Mercado, el Ayuntamiento y el Panorama
      Rac\u0142awicka!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: "Hace mucho tiempo, constru\xED t\xFAneles para enanos en la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: "Alguien cerca de aqu\xED lo tiene."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: "Es un espect\xE1culo \"multimedia\" porque utiliza muchas cosas
      diferentes."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: "\xA1Fue construida alrededor del a\xF1o 1300!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: "\xA1Te hace sentir como si estuvieras dentro del cuadro!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "\xA1Es uno de los edificios m\xE1s famosos de la ciudad!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "Est\xE1 cerrado con llave. \xA1Encuentra la llave dorada!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: Es una imagen que te envuelve por completo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: Tiene torres altas y ventanas preciosas.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: He estado dibujando un mapa de Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: Siempre estoy pensando en nuevos edificios para dibujar.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: "Te abrir\xE9 el ascensor."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: "Yo cuido de los animales. \xBFA ti tambi\xE9n te gustan los animales?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: "Alg\xFAn d\xEDa quiero viajar por todo el mundo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: "Me quedo aqu\xED para ayudar a la gente a encontrar la paz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: "\xA1Ya lo veo! \xA1Est\xE1 en la cima de la Iglica!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: Pinto la historia de Breslavia para que todos la vean.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: "\xA1Me encantan los tejados y los arcos altos!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "\xA1Me encanta contemplar esa escultura de Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: "\xA1Me encantan los colores brillantes y las im\xE1genes gigantes!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: "\xA1Me encanta tener un buen libro en mis manos!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: "\xA1Espero que te diviertas en el zool\xF3gico!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: "\xA1Te doy este boleto especial para viajar a todas partes!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: "\xA1Por fin puedo volver a vigilar todas las cerraduras!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: "Soy el Concejal Enano. \xA1Ayudo al Alcalde de la Ciudad!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "\xA1Soy uno de los enanos m\xE1s viejos de la ciudad! Aparec\xED
      por primera vez en 2005."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: "\xBFEn qu\xE9 puedo ayudar?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: "\xBFC\xF3mo puedo liberar al enano?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: "\xA1Hola! Soy profesora de la escuela Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: "\xA1Aqu\xED tienes tu llave!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: Ayuda al escritor enano.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: "\xA1Encuentra todos los colores!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: "\xA1Encuentra a todos los animales y libera al enano!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: "\xA1Por favor, encuentren todos los libros de enanos!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: "Pero se perdi\xF3 en un laberinto."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: Le encantan las historias, los libros y... las bibliotecas.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: "\xA1Pero ahora ha perdido todas las notas!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: Lo necesitamos para mejorar los edificios.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: Nuestro enano amante de los animales adora a todos los animales.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "\xA1Buen trabajo! Exploraste Breslavia y liberaste a todos los
      enanos."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: "Adi\xF3s"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "\xA1Desde lo alto se puede ver casi toda la ciudad!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: Liberen al Enano del Origen.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: Primero, ve a la Catedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: "Encuentra al Enano Pintor aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "Encuentra la llave. \xA1Luego abre la jaula!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "\xA1Encuentra la llave de la catedral y lib\xE9ralo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: "Aqu\xED vienen familias para ver animales de todo el mundo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Cada jaula est\xE1 cerrada con una llave de oro."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: Dibuja tu enano favorito de Breslavia y el lugar donde lo encontraste.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "\xBFQuieres subir a la azotea?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "\xBFQuieres responder algunas preguntas para completar esta misi\xF3n?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: "\xBFTocas alg\xFAn instrumento musical?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: "\xBFTe gusta ir a la escuela?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: "\xBFRevisaste el interior del Centennial Hall?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: "\xA1Correcto! Aqu\xED tienes tu llave."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: "\xA1Completa la tarea primero!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: "\xA1Ven aqu\xED por la noche a ver el espect\xE1culo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: "Vuelve cuando est\xE9s listo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: "\xA1Pero nuestro concejal enano ha perdido todos sus libros!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: El Centennial Hall es famoso por su gran techo redondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: "\xA1Socorro! \xA1Nuestro arquitecto enano ha desaparecido!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: El Centennial Hall tiene un enorme techo redondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: "Sal\xF3n del Centenario"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: Catedral
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "\xA1Antura corri\xF3 por todo Breslavia esta noche!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: "\xA1Antura est\xE1 en la cima de la Sky Tower!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: "\xA1Y esta ma\xF1ana, diez enanos fueron encerrados en jaulas!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "\xA1Y mira... Antura tambi\xE9n est\xE1 aqu\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: "\xA1Todos los enanos de la Torre del Cielo son gratis!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: Un escritor
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: "Un cient\xEDfico"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: "Un pol\xEDtico"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "Una plaza es un lugar amplio y abierto donde la gente se re\xFAne."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: "\xA1Nuestro enano pintor ha perdido todos sus colores!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: Hay una llave debajo de una maceta en el mercado.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: Una fuente
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: "\xA1La famosa escritora Olga Tokarczuk viv\xEDa cerca de aqu\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: Un enano
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: Una clave
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: "Primero desbloquea a los otros dos enanos aqu\xED, y luego regresa."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: "\xA1Encuentra y salva al Enano Viajero!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: "\xA1Subimos hasta la cima de la Sky Tower!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: "\xA1\xDAsalo para ver d\xF3nde est\xE1s y ad\xF3nde ir!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: "Utilice el tranv\xEDa para elegir su pr\xF3xima parada."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: Estamos en la parada de Bema, cerca de la catedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: "\xA1Estamos en la escuela primaria Leonardo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: "\xA1Bienvenidos a Centennial Hall!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: "\xA1Bienvenidos a Sky Tower! Es muy alta."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: "\xA1Bienvenidos a Breslavia!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: "\xBFQu\xE9 hace la gente en una catedral?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: "\xBFQu\xE9 hace la gente en una catedral?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "\xBFCu\xE1l es un s\xEDmbolo famoso de Breslavia?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: "\xBFAd\xF3nde quieres ir?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: "\xBFD\xF3nde est\xE1 el enano?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: "\xBFD\xF3nde est\xE1 la llave?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: "\xBFQui\xE9n es Olga Tokarczuk?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: "\xBFNos encontrar\xE1s a todos?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Breslavia es famosa por sus peque\xF1os enanos."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "\xA1El zool\xF3gico de Breslavia es el zool\xF3gico m\xE1s grande
      de Polonia!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: "S\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: "\xA1S\xED, as\xED es!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: "\xA1Ya puedes ir a la Sky Tower!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: "Puedes usar el tranv\xEDa si no quieres caminar."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: "Has completado esta misi\xF3n. \xBFTe ha gustado?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: "\xA1Lo encontraste! \xA1Ahora ve y desbloquea al enano!"
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767041
    m_Localized: "\xA1Los encontraste todos! Regresa para obtener una recompensa."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089992
    m_Localized: "\xBFD\xF3nde est\xE1 mi gato?"
    m_Metadata:
      m_Items: []
  - m_Id: 75056277766529024
    m_Localized: "\xA1Utiliza el mapa si no los encuentras todos!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284289
    m_Localized: "\xA1El ascensor no funciona!"
    m_Metadata:
      m_Items: []
  - m_Id: 75156437523750912
    m_Localized: Alguien lo vio subir al tejado.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284225
    m_Localized: Alguien lo vio subir al tejado.
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675521
    m_Localized: Rompecabezas
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284241
    m_Localized: Toca las notas en el orden correcto.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284250
    m_Localized: "\xA1Toca las notas para desbloquearme!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284236
    m_Localized: "Nuestro enano sol\xEDa dirigir el espect\xE1culo de la fuente."
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767042
    m_Localized: "\xA1Ahora puedes desbloquear al enano!"
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675520
    m_Localized: Memoria
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089991
    m_Localized: Quiero proteger a todos los animales.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089990
    m_Localized: "\xA1Me gusta el zool\xF3gico!"
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767040
    m_Localized: "\xA1Ve al enano que tiene la llave!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284280
    m_Localized: "\xA1Ve con el Maestro Enano!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284266
    m_Localized: "Coge la llave que est\xE1 encima de los libros."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284243
    m_Localized: "Encuentra todas las notas musicales por aqu\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089997
    m_Localized: "Encuentra todos los animales del zool\xF3gico."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284300
    m_Localized: "\xBFQuieres jugar un juego?"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089957
    m_Localized: Colecciona todos los libros.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089988
    m_Localized: "\xA1Pero huyeron cuando pas\xF3 un perro azul grande!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
