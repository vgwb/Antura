%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "Gira como un pincel, creando un \xFAltimo remolino alegre."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "El dise\xF1o de la fuente muestra una llave cerca del escenario."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: "\xBFQui\xE9n es Olga Tokarczuk?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: El Centennial Hall es conocido por su gran techo redondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "Has completado la misi\xF3n de los enanos de Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Nada
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "Una plaza es un lugar abierto donde la gente se re\xFAne."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: Dibuja tu enano favorito de Breslavia y el lugar donde lo encontraste.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "El tranv\xEDa est\xE1 listo. Primero, dir\xEDgete a la catedral."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "A las familias les gusta ver el espect\xE1culo de la fuente."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: Torre del cielo
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: "\xBFEn qu\xE9 puedo ayudar?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: "La gente viene aqu\xED a rezar."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "Una letra viviente se\xF1ala una llave junto a la puerta de la
      catedral."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: Es una imagen gigante que te rodea por completo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "La plaza del mercado es uno de los lugares m\xE1s concurridos de
      la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "El enano director de orquesta ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "La Sky Tower es f\xE1cilmente visible desde muchos puntos de la
      ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: A este enano le encantan los lugares concurridos y los caminos nuevos.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: "\xBFD\xF3nde est\xE1 la llave?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "El Enano del Origen ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "\xA1Ahora ve y desbloquea al enano!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: "Encuentra al Enano de la Escuela aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "Hay un problema en la ciudad... \xA1vamos a investigar!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: Encuentra la llave del Ayuntamiento.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: Responde a esta pregunta para abrir la jaula.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: Mira la estrella en el mapa.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "La llave est\xE1 cerca del ascensor."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: Ellos juegan
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "La ciudad se ve preciosa desde aqu\xED arriba."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "Utilice el tranv\xEDa para elegir su pr\xF3xima parada."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "La llave del ayuntamiento, que est\xE1 escondida, se encuentra
      detr\xE1s del letrero."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: Ellos rezan
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "Encuentra la llave. Luego copia el patr\xF3n de la fuente."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: Este es el Enano Pintor del centro de operaciones.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: Nuestra plaza del mercado es un lugar animado para pasear y encontrarse
      con amigos.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: Olga Tokarczuk es una escritora famosa.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: A este enano le encantan las patas, las alas y los bigotes.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "Ahora ya sabes c\xF3mo liberar a los enanos. \xA1Encuentra 10 ahora!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "\xBFC\xF3mo puedo liberar al enano?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "Los l\xEDderes de la ciudad trabajan y se re\xFAnen aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: Encuentra la llave escondida en el mercado.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: Ellos pescan
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "\xBFCu\xE1l es un s\xEDmbolo famoso de Breslavia?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: El mapa de Breslavia es tuyo ahora.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: El panorama parece una imagen que me rodea por completo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: Encuentra la llave. Luego abre la jaula.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: "\xBFD\xF3nde est\xE1 el enano?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: A este enano le encantan los planes, los papeles y las reuniones
      importantes.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: Estamos orgullosos del Centennial Hall y de su gran techo redondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Breslavia es famosa por sus peque\xF1os enanos."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: "Mira en el zool\xF3gico, en el vest\xEDbulo y en la fuente."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: Bienvenidos a Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "Se endereza el peque\xF1o sombrero como un alcalde muy ocupado."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: A este enano le encantan los colores, la pintura y los cuadros grandes.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "La Sky Tower es uno de los edificios m\xE1s altos de Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: Un panorama es una imagen gigante que te rodea por completo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "\xBFQuieres responder algunas preguntas?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: "La catedral es uno de los lugares m\xE1s famosos de Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: Encuentra la llave y luego une las piezas de la imagen para abrir
      la jaula.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "El obispo enano est\xE1 encerrado cerca."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "El zool\xF3gico de Breslavia es el zool\xF3gico m\xE1s grande de
      Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: Encuentra la llave de la plaza.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: "\xBFQu\xE9 hace la gente en una catedral?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: "La fuente multimedia utiliza agua, luz y m\xFAsica."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "El Enano Viajero ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: Agita su diminuta batuta y hace una reverencia ante la fuente.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: Tiene torres altas y ventanas luminosas.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: Algunos enanos de Breslavia tienen un aspecto gracioso, y otros,
      serio.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: Mueve sus botitas y hace una reverencia alegre.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "Primero ve a la Catedral. All\xED te ayudar\xE1n a leer el mapa."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: A este enano le encantan las historias, los libros y los lugares
      tranquilos.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "\xA1Bienvenidos a Breslavia!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Cada jaula est\xE1 sellada con una llave de oro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "El consejero enano ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "A este enano le encantan las formas, los edificios y los dise\xF1os
      ingeniosos."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: "\xA1Hola! Soy profesora de la escuela Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: Resuelve el rompecabezas del pasillo para encontrar la llave oculta.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: Un escritor
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: "\xA1Antura est\xE1 en la cima de la Sky Tower!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "Encuentra la llave del zool\xF3gico. Luego habla con el cuidador."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "El Concejal Enano est\xE1 cerca del Antiguo Ayuntamiento."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: Ellos rezan
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: Muchos habitantes de Breslavia conocen a su enano favorito.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: Mueve la planta para encontrarla.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "El enano pintor ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: Un piloto
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "Encuentra la clave del escritor. Luego, dir\xEDgete al lector."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "La llave est\xE1 debajo de un banco en la plaza."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: Una ballena
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: "Gira en un peque\xF1o c\xEDrculo como si estuviera lista para el
      pr\xF3ximo viaje."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: "Hay una llave detr\xE1s del cartel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: Liberen a mis 10 amigos enanos en Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: "Diez enanos est\xE1n encerrados en jaulas m\xE1gicas en Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: "Vuelve cuando est\xE9s listo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: Un enano
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: "El Enano Escritor ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: Corren coches
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: Subimos hasta la cima de la Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: "Abraza un peque\xF1o libro y te sonr\xEDe radiante."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: "\xA1Completa la tarea primero!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: "El Arquitecto Enano ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: El Centennial Hall es muy grande y tiene un famoso techo redondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: Un gato gigante
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: Un cohete
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Clink, clank, tintineo. Te abrir\xE9 el ascensor."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: "Encuentra al Enano Pintor aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: "F\xEDjese en la Plaza del Mercado, el Ayuntamiento y el Panorama
      Raclawika."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "\xA1Buen trabajo! Exploraste Breslavia y liberaste a todos los
      enanos."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: Golpea el aire con orgullo, como si estuviera dibujando un techo
      nuevo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: Escuela
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: Hay una llave debajo de una maceta en el mercado.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: Mucha gente visita Breslavia en busca de estatuas de enanos.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: "Esta fuente utiliza agua, luces y m\xFAsica."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: "\xDAsalo para ir al centro de la ciudad o al Centennial Hall."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: Estamos en la parada de Bema, cerca de la catedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: "La llave est\xE1 cerca del rinc\xF3n de lectura."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: "Bienvenidos al \xE1rea del Sal\xF3n del Centenario."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: Este es el antiguo ayuntamiento.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: "Correcto. Aqu\xED tienes la llave."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: Ellos leen
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: "Hace mucho tiempo, constru\xED t\xFAneles para enanos en la ciudad."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "El enano guardi\xE1n de las llaves ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: "\xBFQu\xE9 hace la gente en una catedral?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: "Los otros enanos te indican d\xF3nde mirar."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: "Encuentra la \xFAltima llave cerca del letrero del ascensor."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: Esta es la catedral de Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: Encuentra la llave de la catedral y libera al obispo enano.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "El enano amante de los animales ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: A este enano le encantan las salpicaduras, los brillos y las canciones.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: Tienen sombreros diminutos y botas diminutas.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: Piaba, olfatea y saluda con la mano, todo a la vez.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: Panorama Raclawika forma parte del centro comercial Center.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: Este es uno de los enanos de la Torre del Cielo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: "El obispo enano ya est\xE1 a salvo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: "Aqu\xED tienes tu llave."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: Todos los enanos de la Torre del Cielo son gratis.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: Otro enano se encuentra cerca del Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: "La zona del Sal\xF3n del Centenario ya est\xE1 terminada."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "La zona central est\xE1 terminada."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: "Ahora se han convertido en veh\xEDculos m\xE1gicos."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "El Concejal Enano est\xE1 cerca del Antiguo Ayuntamiento."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: "\xA1Gracias! \xA1Me salvaste!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: "El ascensor ya est\xE1 abierto."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: "La fuente es el \xFAltimo lugar aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: La imagen final muestra una llave debajo del marco.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "La jaula del guardi\xE1n de la llave est\xE1 cerca del ascensor."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "Est\xE1 cerrado con llave. \xA1Encuentra la llave dorada!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: "Panorama Raclawika es el \xFAltimo lugar aqu\xED."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: Para desbloquear la jaula, resuelve este rompecabezas.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: "Qu\xE9date aqu\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: "H\xE1blame si necesitas ayuda."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: Catedral
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: "Sal\xF3n del Centenario"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: Mercado
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: "El Enano Viajero est\xE1 en la plaza."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: "No. Int\xE9ntalo de nuevo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "\xA1Int\xE9ntalo de nuevo m\xE1s tarde!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: "\xBFAd\xF3nde quieres ir?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: "S\xED"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: "S\xED, as\xED es."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
