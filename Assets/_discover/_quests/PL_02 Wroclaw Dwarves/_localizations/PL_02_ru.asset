  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: "\u0425\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044E \u043A\u043B\u044E\u0447\u0435\u0439
      \u043D\u0443\u0436\u043D\u044B 10 \u0433\u043D\u043E\u043C\u044C\u0438\u0445
      \u043A\u043B\u044E\u0447\u0435\u0439!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "\u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435 \u043F\u043E\u0437\u0436\u0435!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "\u0427\u0442\u043E\u0431\u044B \u043E\u0442\u043A\u0440\u044B\u0442\u044C
      \u043A\u043B\u0435\u0442\u043A\u0443, \u0440\u0435\u0448\u0438\u0442\u0435
      \u044D\u0442\u0443 \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: "\u041D\u0430\u0448 \u043A\u0430\u0440\u043B\u0438\u043A-\u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A
      \u043E\u0431\u043E\u0436\u0430\u0435\u0442 \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C
      \u043D\u043E\u0432\u044B\u0435 \u043C\u0435\u0441\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "\u042D\u0442\u043E \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u043A\u0438\u0439
      \u0441\u043E\u0431\u043E\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: "\u0417\u0434\u0435\u0441\u044C, \u0432 \u0421\u0442\u0430\u0440\u043E\u0439
      \u0440\u0430\u0442\u0443\u0448\u0435, \u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F
      \u0437\u0430\u043A\u043E\u043D\u044B \u0433\u043E\u0440\u043E\u0434\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: "\u042D\u0442\u043E\u0442 \u0444\u043E\u043D\u0442\u0430\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0432\u043E\u0434\u0443, \u0440\u0430\u0437\u043D\u043E\u0446\u0432\u0435\u0442\u043D\u0443\u044E
      \u043F\u043E\u0434\u0441\u0432\u0435\u0442\u043A\u0443 \u0438 \u043C\u0443\u0437\u044B\u043A\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "\u042D\u0442\u043E\u043C\u0443 \u0433\u043D\u043E\u043C\u0443 \u043D\u0443\u0436\u0435\u043D
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u043A\u043B\u044E\u0447,
      \u0447\u0442\u043E\u0431\u044B \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: "\u041E\u043D\u0438 \u0447\u0438\u0442\u0430\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: "\u041E\u043D\u0438 \u0447\u0438\u0442\u0430\u043B\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: "\u041E\u043D\u0438 \u043C\u043E\u043B\u044F\u0442\u0441\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: "\u041E\u043D\u0438 \u043C\u043E\u043B\u044F\u0442\u0441\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: "\u041E\u043D\u0438 \u0438\u0433\u0440\u0430\u044E\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: "\u041E\u043D\u0438 \u0438\u0433\u0440\u0430\u044E\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: "\u0423 \u043D\u0438\u0445 \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u044B\u0435
      \u0448\u043B\u044F\u043F\u043A\u0438 \u0438 \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u044B\u0435
      \u0441\u0430\u043F\u043E\u0436\u043A\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "\u0412 \u0437\u043E\u043E\u043F\u0430\u0440\u043A\u0435 \u0432\u0441\u0435\u0433\u0434\u0430
      \u043D\u0430\u0439\u0434\u0435\u0442\u0441\u044F \u0447\u0435\u043C \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "\u0412 \u0433\u043E\u0440\u043E\u0434\u0435 \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u0430
      \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430... \u0434\u0430\u0432\u0430\u0439\u0442\u0435
      \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u043C\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "\u0417\u0430 \u0442\u043E\u0439 \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u043E\u0439
      \u043B\u0435\u0436\u0438\u0442 \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "\u0417\u0434\u0435\u0441\u044C \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
      \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0441\u043A\u0443\u043B\u044C\u043F\u0442\u0443\u0440\u0430
      \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430 \u0421\u0430\u043B\u044C\u0432\u0430\u0434\u043E\u0440\u0430
      \u0414\u0430\u043B\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "\u0412 \u0433\u043E\u0440\u043E\u0434\u0435 \u0431\u043E\u043B\u0435\u0435
      800 \u0433\u043D\u043E\u043C\u043E\u0432!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "\u0417\u043E\u043E\u043F\u0430\u0440\u043A \u0431\u044B\u043B \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D
      \u043E\u0447\u0435\u043D\u044C \u0434\u0430\u0432\u043D\u043E, \u0432 1865
      \u0433\u043E\u0434\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: "\xAB\u041F\u0438\u0441\u0430\u0442\u0435\u043B\u044C-\u043A\u0430\u0440\u043B\u0438\u043A\xBB
      \u043F\u043E-\u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443 \u0437\u0430\u043F\u0435\u0440\u0442!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: "\u0413\u043D\u043E\u043C-\u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A
      \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043D\u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "\u0422\u0440\u0430\u043C\u0432\u0430\u0439 \u0433\u043E\u0442\u043E\u0432.
      \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u0438\u0434\u0438\u0442\u0435 \u043A
      \u0441\u043E\u0431\u043E\u0440\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: "\u041F\u0430\u043D\u043E\u0440\u0430\u043C\u0430 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
      \u043A\u0430\u043A \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0430\u044F
      \u043A\u0430\u0440\u0442\u0438\u043D\u0430, \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0430\u044F
      \u043C\u0435\u043D\u044F \u0441\u043E \u0432\u0441\u0435\u0445 \u0441\u0442\u043E\u0440\u043E\u043D!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "\xAB\u0418\u0441\u0445\u043E\u0434\u043D\u044B\u0439 \u0433\u043D\u043E\u043C\xBB
      \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u043E\u0434\u0430\u0436\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "\u0421\u0442\u0430\u0440\u0430\u044F \u0440\u0430\u0442\u0443\u0448\u0430
      \u2014 \u044D\u0442\u043E \u0441\u0442\u0430\u0440\u0438\u043D\u043D\u043E\u0435
      \u0438 \u0432\u0430\u0436\u043D\u043E\u0435 \u0437\u0434\u0430\u043D\u0438\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: "\u041C\u0443\u043B\u044C\u0442\u0438\u043C\u0435\u0434\u0438\u0439\u043D\u044B\u0439
      \u0444\u043E\u043D\u0442\u0430\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
      \u0432\u043E\u0434\u0443, \u0441\u0432\u0435\u0442 \u0438 \u043C\u0443\u0437\u044B\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: "\u041C\u0443\u043B\u044C\u0442\u0438\u043C\u0435\u0434\u0438\u0439\u043D\u043E\u043C\u0443
      \u0444\u043E\u043D\u0442\u0430\u043D\u0443 \u043D\u0443\u0436\u043D\u0430 \u043D\u0430\u0448\u0430
      \u043F\u043E\u043C\u043E\u0449\u044C!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "\u0425\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C \u043A\u043B\u044E\u0447\u0435\u0439
      \u0437\u0430\u0441\u0442\u0440\u044F\u043B \u0432\u043E\u0437\u043B\u0435 \u043B\u0438\u0444\u0442\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "\u0427\u0442\u043E\u0431\u044B \u0434\u043E\u0441\u0442\u0430\u0442\u044C
      \u0435\u0433\u043E, \u043D\u0443\u0436\u043D\u043E \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
      \u0438 \u043F\u0435\u0440\u0435\u043F\u0440\u044B\u0433\u0438\u0432\u0430\u0442\u044C
      \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u043B\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "\u041A\u043B\u044E\u0447 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
      \u0440\u044F\u0434\u043E\u043C \u0441 \u0443\u0433\u043E\u043B\u043A\u043E\u043C
      \u0434\u043B\u044F \u0447\u0442\u0435\u043D\u0438\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: "\u041A\u043B\u044E\u0447 \u043E\u0442 \u0440\u0430\u0442\u0443\u0448\u0438
      \u0441\u043F\u0440\u044F\u0442\u0430\u043D \u0437\u0430 \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u043E\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: "\u0412 \u0432\u043E\u0434\u0435 \u0444\u043E\u043D\u0442\u0430\u043D\u0430,
      \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0435\u043A\u0443 \u043E\u0442 \u0441\u0446\u0435\u043D\u044B,
      \u0441\u043F\u0440\u044F\u0442\u0430\u043D \u043A\u043B\u044E\u0447!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: "\u0424\u043E\u043D\u0442\u0430\u043D\u043D\u043E\u0435 \u0448\u043E\u0443
      \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
      \u043A\u043E\u043D\u0446\u0435\u0440\u0442!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: "\u0424\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0439 \u0440\u0430\u0443\u043D\u0434!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: "\u041B\u0438\u0444\u0442 \u043E\u0442\u043A\u0440\u044B\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "\u0413\u043D\u043E\u043C-\u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A
      \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
      \u043E\u0442 \u0421\u0442\u0430\u0440\u043E\u0439 \u0440\u0430\u0442\u0443\u0448\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "\u041E\u0442\u0441\u044E\u0434\u0430 \u0433\u043E\u0440\u043E\u0434
      \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u0432\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u043D\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: "\u0421\u0443\u043D\u0434\u0443\u043A \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "\u0421\u0443\u043D\u0434\u0443\u043A \u0437\u0430\u043F\u0435\u0440\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: "\u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F
      \u0437\u043E\u043D\u0430 \u0433\u043E\u0442\u043E\u0432\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: "\u0421\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
      \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u0430 Centennial Hall \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "\u0421\u043E\u0431\u043E\u0440 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D
      \u0432 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u0441\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u0445
      \u0440\u0430\u0439\u043E\u043D\u043E\u0432 \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "\u0413\u043D\u043E\u043C-\u0435\u043F\u0438\u0441\u043A\u043E\u043F
      \u0437\u0430\u043F\u0435\u0440\u0442 \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0435\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E! \u0412\u044B \u043C\u0435\u043D\u044F
      \u0441\u043F\u0430\u0441\u043B\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: "\u041E\u0431\u0440\u0430\u0449\u0430\u0439\u0442\u0435\u0441\u044C
      \u043A\u043E \u043C\u043D\u0435, \u0435\u0441\u043B\u0438 \u0432\u0430\u043C
      \u043D\u0443\u0436\u043D\u0430 \u043F\u043E\u043C\u043E\u0449\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: "\u041E\u0441\u0442\u0430\u0432\u0430\u0439\u0442\u0435\u0441\u044C
