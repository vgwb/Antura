      \u043C\u0438\u0440\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "\u041A\u0430\u0436\u0434\u0430\u044F \u043A\u043B\u0435\u0442\u043A\u0430
      \u0437\u0430\u043F\u0438\u0440\u0430\u0435\u0442\u0441\u044F \u0437\u043E\u043B\u043E\u0442\u044B\u043C
      \u043A\u043B\u044E\u0447\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "\u041D\u0430\u0440\u0438\u0441\u0443\u0439\u0442\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
      \u043B\u044E\u0431\u0438\u043C\u043E\u0433\u043E \u0432\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u043A\u043E\u0433\u043E
      \u0433\u043D\u043E\u043C\u0430 \u0438 \u043C\u0435\u0441\u0442\u043E, \u0433\u0434\u0435
      \u0432\u044B \u0435\u0433\u043E \u043D\u0430\u0448\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "\u0425\u043E\u0442\u0438\u0442\u0435 \u043F\u043E\u0434\u043D\u044F\u0442\u044C\u0441\u044F
      \u043D\u0430 \u043A\u0440\u044B\u0448\u0443?"
    m_Metadata:
      m_Items: []
