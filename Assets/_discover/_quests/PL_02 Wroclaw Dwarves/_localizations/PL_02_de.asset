%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_de
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "Es wirbelt wie ein Pinsel und vollf\xFChrt einen letzten, fr\xF6hlichen
      Wirbel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "Das Font\xE4nenmuster zeigt einen Schl\xFCssel in der N\xE4he der
      B\xFChne."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: Wer ist Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "Die Centennial Hall ist f\xFCr ihr gro\xDFes rundes Dach bekannt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "Du hast die Quest \u201EDie Zwerge von Breslau\u201C abgeschlossen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Nichts
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: Ein Platz ist ein offener Ort, an dem sich Menschen treffen.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: Zeichne deinen Lieblingszwerg aus Breslau und den Ort, an dem du
      ihn gefunden hast.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "Die Stra\xDFenbahn ist bereit. Gehen Sie zuerst zur Kathedrale."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "Familien schauen sich gerne die Font\xE4nenshow an."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: Sky Tower
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: Wie kann ich helfen?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: Die Menschen kommen hierher, um zu beten.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "Ein lebendiger Buchstabe weist auf einen Schl\xFCssel neben der
      Kathedralent\xFCr."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: Es ist ein riesiges Bild, das dich umgibt.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: Der Marktplatz ist einer der belebtesten Orte der Stadt.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: Der Dirigentenzwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: Der Sky Tower ist von vielen Teilen der Stadt aus gut zu sehen.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: Dieser Zwerg liebt belebte Orte und neue Wege.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: "Wo ist der Schl\xFCssel?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: Der Ursprungszwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: Jetzt geh und schalte den Zwerg frei!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: Hier findet ihr den Schulzwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: Es gibt ein Problem in der Stadt... lasst es uns untersuchen!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "Finde den Rathausschl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "Beantworte diese Frage, um den K\xE4fig zu \xF6ffnen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: Schau dir den Stern auf der Karte an.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "Der Schl\xFCssel befindet sich in der N\xE4he des Aufzugs."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: Sie spielen
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "Von hier oben sieht die Stadt wundersch\xF6n aus."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "Nutzen Sie die Stra\xDFenbahn, um Ihre n\xE4chste Haltestelle auszuw\xE4hlen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "Der versteckte Rathausschl\xFCssel befindet sich hinter dem Schild."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: Sie beten
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "Finde den Schl\xFCssel. Dann kopiere das Font\xE4nenmuster."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: Dies ist der Malerzwerg aus dem Zentrum-Hub.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: Unser Marktplatz ist ein lebhafter Ort zum Spazierengehen und um
      Freunde zu treffen.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "Olga Tokarczuk ist eine ber\xFChmte Schriftstellerin."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: "Dieser Zwerg liebt Pfoten, Fl\xFCgel und Schnurrhaare."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: Jetzt wisst ihr, wie man Zwerge befreit. Findet jetzt 10!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: Wie kann ich den Zwerg befreien?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "Hier arbeiten und tagen die st\xE4dtischen F\xFChrungskr\xE4fte."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "Finde den verborgenen Schl\xFCssel auf dem Markt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: Sie fischen
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: Was ist ein bekanntes Symbol von Breslau?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "Die Karte von Breslau geh\xF6rt nun Ihnen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "Das Panorama um mich herum sieht aus wie ein Gem\xE4lde."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "Finde den Schl\xFCssel. Dann \xF6ffne den K\xE4fig."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: Wo ist der Zwerg?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "Dieser Zwerg liebt Pl\xE4ne, Papiere und wichtige Besprechungen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: "Wir sind stolz auf die Centennial Hall und ihr gro\xDFes rundes
      Dach."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Breslau ist ber\xFChmt f\xFCr seine kleinen Zwerge."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: Schau im Zoo, in der Halle und am Brunnen nach.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: Willkommen im Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "Es r\xFCckt seinen winzigen Hut zurecht wie ein sehr besch\xE4ftigter
      B\xFCrgermeister."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: "Dieser Zwerg liebt Farben, Malerei und gro\xDFe Bilder."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "Der Sky Tower ist eines der h\xF6chsten Geb\xE4ude in Breslau."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: Ein Panorama ist ein riesiges Bild, das Sie rundherum umgibt.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "M\xF6chten Sie einige Fragen beantworten?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: Der Dom ist einer der bekanntesten Orte in Breslau.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: "Finde den Schl\xFCssel und setze dann die Bildteile zusammen, um
      den K\xE4fig zu \xF6ffnen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "Der Bischofszwerg ist in der N\xE4he eingesperrt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "Der Zoo von Breslau ist der gr\xF6\xDFte Zoo Polens."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: "Finde den Schl\xFCssel zum Platz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: Was machen die Menschen in einer Kathedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: Der Multimedia-Brunnen nutzt Wasser, Licht und Musik.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: Der Reisende Zwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: Es schwingt seinen winzigen Taktstock und verbeugt sich vor dem
      Brunnen.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: "Es hat hohe T\xFCrme und helle Fenster."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: Manche Breslauer Zwerge sehen komisch aus, andere wiederum ernst.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: "Es wackelt mit seinen Stiefelchen und verbeugt sich fr\xF6hlich."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: Gehen Sie zuerst zur Kathedrale. Dort wird man Ihnen beim Lesen
      der Karte helfen.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: "Dieser Zwerg liebt Geschichten, B\xFCcher und ruhige Orte."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: Willkommen in Breslau!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Jeder K\xE4fig ist mit einem goldenen Schl\xFCssel versiegelt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: Der Ratszwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "Dieser Zwerg liebt Formen, Geb\xE4ude und clevere Konstruktionen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: Hallo! Ich bin Lehrerin an der Leonardo-Schule.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: "L\xF6se das Flurr\xE4tsel, um den versteckten Schl\xFCssel zu finden."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: Ein Schriftsteller
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: Antura befindet sich ganz oben im Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "Finde den Zooschl\xFCssel. Sprich dann mit dem Tierpfleger."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "Der Ratszwerg befindet sich in der N\xE4he des Alten Rathauses."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: Sie beten
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: Viele Menschen in Breslau kennen ihren Lieblingszwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: Verschiebe die Pflanze, um sie zu finden.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: Der Malerzwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: Ein Pilot
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "Finde den Schl\xFCssel zum Autor. Dann sprich mit dem Leser."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "Der Schl\xFCssel befindet sich unter einer Bank auf dem Platz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: Ein Wal
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: "Es dreht sich in einem kleinen Kreis, als w\xE4re es bereit f\xFCr
      die n\xE4chste Reise."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: "Hinter dem Schild befindet sich ein Schl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: Befreit alle 10 meiner Zwergenfreunde in Breslau.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: "Zehn Zwerge sind in Breslau in magischen K\xE4figen eingesperrt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: Komm wieder, wenn du bereit bist.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: Ein Zwerg
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: Der Schriftstellerzwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: Sie fahren Autorennen
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: Wir fahren hinauf zur Spitze des Sky Towers.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: Es umarmt ein winziges Buch und strahlt dich an.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: Erledige zuerst die Aufgabe!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: Der Architektenzwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: "Die Centennial Hall ist sehr gro\xDF und hat ein ber\xFChmtes rundes
      Dach."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: Eine riesige Katze
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: Eine Rakete
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Klirr, klirr, klingel. Ich werde Ihnen den Aufzug aufschlie\xDFen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: Hier findest du den Malerzwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: Schauen Sie sich den Marktplatz, das Rathaus und das Panorama Raclawicka
      an.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "Gro\xDFartige Leistung! Du hast Breslau erkundet und jeden Zwerg
      befreit."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: "Es klopft stolz in die Luft, als w\xFCrde es ein neues Dach zeichnen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: Schule
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: "Auf dem Markt liegt ein Schl\xFCssel unter einem Blumentopf."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: Viele Menschen besuchen Breslau, um nach Zwergenstatuen Ausschau
      zu halten.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: Dieser Brunnen nutzt Wasser, Licht und Musik.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: Nutzen Sie es, um ins Stadtzentrum oder zur Centennial Hall zu gelangen.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: "Wir befinden uns an der Haltestelle Bema, in der N\xE4he der Kathedrale."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: "Der Schl\xFCssel befindet sich in der N\xE4he der Leseecke."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: Willkommen im Bereich der Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: Das ist das Alte Rathaus.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: "Richtig. Hier ist Ihr Schl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: Sie lesen
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: Vor langer Zeit habe ich Zwergentunnel in der Stadt gebaut.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "Der Schl\xFCsselmeister-Zwerg ist nun in Sicherheit."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: Was machen die Menschen in einer Kathedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: Die anderen Zwerge zeigen dir, wo du suchen musst.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: "Den letzten Schl\xFCssel finden Sie in der N\xE4he des Aufzugsschildes."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: Dies ist der Dom von Breslau.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: "Finde den Kathedralenschl\xFCssel und befreie den Zwergbischof."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: Der tierliebe Zwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: Dieser Zwerg liebt Spritzer, Glitzer und Lieder.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: "Sie tragen winzige H\xFCte und winzige Stiefel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: "Es zwitschert, schn\xFCffelt und winkt gleichzeitig."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: Panorama Raclawicka ist Teil des Zentrums.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: Dies ist einer der Zwerge des Himmelsturms.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: Der Bischofszwerg ist nun in Sicherheit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: "Hier ist Ihr Schl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: Alle Zwerge im Himmelsturm sind frei.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: "Ein weiterer Zwerg befindet sich in der N\xE4he der Centennial
      Hall."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: Der Bereich der Centennial Hall ist fertiggestellt.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: Der Mittelbereich ist fertig.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: Nun haben sie sich in magische Fahrzeuge verwandelt.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "Der Ratszwerg befindet sich in der N\xE4he des Alten Rathauses."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: Danke! Du hast mich gerettet!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: Der Aufzug ist jetzt in Betrieb.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: Der Brunnen ist der letzte Ort hier.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: "Das fertige Bild zeigt einen Schl\xFCssel unter dem Rahmen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "Der Keymaster-K\xE4fig befindet sich in der N\xE4he des Aufzugs."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "Es ist verschlossen. Finde einen goldenen Schl\xFCssel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: NEIN
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: Panorama Raclawicka ist der letzte Ort hier.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: "Um den K\xE4fig zu \xF6ffnen, l\xF6se dieses R\xE4tsel."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: Bleiben Sie hier.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: Sprich mich an, wenn du Hilfe brauchst.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: Kathedrale
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: Centennial Hall
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: Markthalle
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: Der Reisende Zwerg befindet sich auf dem Platz.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: Nein. Versuchen Sie es erneut.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "Versuchen Sie es sp\xE4ter noch einmal!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: "Wohin m\xF6chtest du reisen?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: Ja
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: Ja, das stimmt.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
