%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_de
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: "Schalte den Schl\xFCsselmeister frei!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "Versuchen Sie es sp\xE4ter noch einmal!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "Um den K\xE4fig zu \xF6ffnen, musst du dieses R\xE4tsel l\xF6sen!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: Dieser Platz ist ein belebter Ort im Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: Dies ist der Dom von Breslau.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: Das ist das Alte Rathaus.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: Dieser Brunnen nutzt Wasser, bunte Lichter und Musik!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "Dieser Zwerg braucht noch einen letzten Schl\xFCssel, um frei zu
      sein!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: Sie lesen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: Sie lesen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: Sie beten
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: Sie beten
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: Sie spielen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: Sie spielen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: "Sie haben winzige H\xFCte und winzige Stiefel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: Im Zoo gibt es etwas zu unternehmen!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: Es gibt ein Problem in der Stadt... lasst es uns untersuchen!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "Hinter dem Schild dort dr\xFCben befindet sich ein Schl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "Hier befindet sich eine ber\xFChmte Skulptur eines K\xFCnstlers
      namens Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "Es gibt \xFCber 800 Zwerge in der Stadt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: Der Zoo wurde vor langer Zeit, im Jahr 1865, erbaut!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: Der Schriftstellerzwerg ist immer noch eingesperrt!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: Der Reisende Zwerg befindet sich auf dem Platz.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "Die Stra\xDFenbahn ist bereit. Gehen Sie zuerst zur Kathedrale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: Das Panorama sieht aus wie ein riesiges Bild, das mich umgibt!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "Der Origin Dwarf ist im Handel erh\xE4ltlich."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "Das Alte Rathaus ist ein sehr wichtiges altes Geb\xE4ude."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: Der Multimedia-Brunnen nutzt Wasser, Licht und Musik.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: Der Multimedia-Brunnen braucht unsere Hilfe!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "Der Schl\xFCsselmeister ist in der N\xE4he des Aufzugs gefangen!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "Der Schl\xFCssel befindet sich unter einer Bank auf dem Platz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "Der Schl\xFCssel befindet sich in der N\xE4he der Leseecke!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: "Der versteckte Rathausschl\xFCssel befindet sich hinter dem Schild."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: "Im Brunnenwasser ist ein Schl\xFCssel in der N\xE4he der B\xFChne
      versteckt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: "Die Font\xE4nenshow f\xFChlt sich an wie ein gro\xDFes Konzert!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: Die letzte Runde!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: Der Aufzug ist jetzt in Betrieb.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "Der Ratszwerg befindet sich in der N\xE4he des Alten Rathauses."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "Von hier oben sieht die Stadt wundersch\xF6n aus!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: "Die Truhe \xF6ffnet sich!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: Die Truhe ist verschlossen.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: Der Centerbereich ist fertig!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: Der Bereich der Centennial Hall ist fertig!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "Die Kathedrale befindet sich in einem der \xE4ltesten Teile von
      Breslau."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "Der Bischofszwerg ist in der N\xE4he eingesperrt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: Danke! Du hast mich gerettet!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: Sprich mich an, wenn du Hilfe brauchst.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: Bleiben Sie hier.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: Manchmal sitze ich hier und stelle mir meine eigenen Geschichten
      vor.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: Manche Zwerge aus Breslau sehen lustig aus, andere wiederum ernst!
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "Der Sky Tower ist eines der h\xF6chsten Geb\xE4ude in Breslau."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761834
    m_Localized: "Der Sky Tower ist eines der h\xF6chsten Geb\xE4ude in Breslau."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: Sky Tower
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: Schule
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: Rettet den Schulzwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: "Rettet den Dirigentenzwerg! (Er leitet die Font\xE4nenshow)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: "Rettet den Architektenzwerg! (Er entwirft Geb\xE4ude)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567418
    m_Localized: Die Menschen kommen hierher, um zu beten oder einfach nur in Stille
      zu sein.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: Die Menschen kommen hierher, um zu beten und in Ruhe nachzudenken.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Panorama Rac\u0142awicka ist der letzte Ort hier."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "Das Panorama Rac\u0142awicka ist ein riesiges Bild."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "Panorama Rac\u0142awicka ist ein riesiges, rundes Gem\xE4lde!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: "Olga Tokarczuk ist eine polnische Schriftstellerin, die f\xFCr
      ihre B\xFCcher einen bedeutenden Preis gewonnen hat!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: "Jetzt wisst ihr, wie ihr die anderen Zwerge befreien k\xF6nnt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: "Nun haben sie sich in magische Fahrzeuge namens \u201EStra\xDFenbahnen\u201C
      verwandelt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: Geh nun und befreie alle 10 meiner Zwergenfreunde.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: Nein. Versuchen Sie es erneut!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: "Nein, ich m\xF6chte hier bleiben."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: NEIN
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "Meine Freunde ben\xF6tigen weiterhin Hilfe in der Centennial Hall
      und im Stadtzentrum."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: Meine Familie lebt schon sehr, sehr lange hier!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: Verschiebe die Pflanze, um sie zu finden!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: Vielleicht findest du in der Bibliothek eine unterhaltsame Geschichte
      zum Lesen.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: Der Marktplatz ist einer der belebtesten Orte in Breslau.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: Der Marktplatz ist ein sehr belebter und unterhaltsamer Ort.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: Markthalle
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: Viele Menschen besuchen Breslau, um nach Zwergenstatuen zu suchen.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: Viele Menschen halten beim Spazierengehen Ausschau nach Zwergenstatuen!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: "Schau dir den Zoo, die gro\xDFe Halle und den Brunnen an."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: "Schau genau hin! Der Schl\xFCssel ist unter dem Bilderrahmen versteckt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: Schau dir den Stern auf der Karte an.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "Schauen Sie sich den Marktplatz, das Rathaus und das Panorama Rac\u0142awicka
      an!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: Vor langer Zeit habe ich Zwergentunnel in der Stadt gebaut.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: Es befindet sich neben dem Eingang der Kathedrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: Es handelt sich um eine "Multimedia"-Show, weil sie viele verschiedene
      Elemente verwendet.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: Es wurde um das Jahr 1300 erbaut!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: "Man hat das Gef\xFChl, mitten in der Geschichte zu sein!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "Es ist eines der ber\xFChmtesten Geb\xE4ude der Stadt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "Es ist verschlossen. Finde einen goldenen Schl\xFCssel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: Es ist ein Bild, das Sie von allen Seiten umgibt.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: "Es hat hohe T\xFCrme und wundersch\xF6ne Fenster."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: Ich habe eine Karte von Breslau gezeichnet.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: "Ich denke st\xE4ndig \xFCber neue Geb\xE4ude nach, die ich zeichnen
      kann."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: "Ich werde Ihnen den Aufzug aufschlie\xDFen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: Ich passe auf die Tiere auf. Liebst du Tiere auch?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: "Ich m\xF6chte eines Tages die ganze Welt bereisen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: Ich bleibe hier, um Menschen zu helfen, Frieden zu finden.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: "Ich sehe es! Der Schl\xFCssel hinter einem Baum."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "Ich male die Geschichte von Breslau f\xFCr alle sichtbar."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: "Ich liebe D\xE4cher und hohe B\xF6gen!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "Ich liebe es, mir diese Salvador-Dal\xED-Skulptur anzusehen!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: Ich liebe leuchtende Farben und riesige Bilder!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: "Ich liebe es, ein gutes Buch in den H\xE4nden zu halten!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: "Ich hoffe, du hast viel Spa\xDF im Zoo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: "Ich schenke dir dieses besondere Ticket, mit dem du \xFCberall
      hinreisen kannst!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: "Endlich kann ich wieder alle Schl\xF6sser bewachen!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: "Ich bin der Zwergenrat. Ich helfe dem B\xFCrgermeister!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "Ich bin einer der \xE4ltesten Zwerge der Stadt! Mein erster Auftritt
      war im Jahr 2005."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: Wie kann ich helfen?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: Wie kann ich den Zwerg befreien?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: Hallo! Ich bin Lehrerin an der Leonardo-Schule.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: "Hier ist Ihr Schl\xFCssel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: Hilf dem Schriftstellerzwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: Hilf dem Malerzwerg!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: Hilf dem tierlieben Zwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: Helft unserem Zwergenrat! (Er hilft bei der Stadtverwaltung).
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: Er liebt es, neue Orte zu besuchen.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: "Er liebt Geschichten, B\xFCcher und ruhige Ecken."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: Er liebt Musik und tanzendes Wasser!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: "Er zeichnet unheimlich gerne coole Formen und H\xE4user."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: Er liebt alle Tiere hier!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "Gro\xDFartige Leistung! Du hast Breslau erkundet und jeden Zwerg
      befreit."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: Auf Wiedersehen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "Von oben hat man fast einen Panoramablick \xFCber die ganze Stadt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: Befreit den Ursprungszwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: Besuchen Sie zuerst die Kathedrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: Hier findest du den Malerzwerg.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "Finde den Schl\xFCssel. Dann \xF6ffne den K\xE4fig!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "Finde den Kathedralenschl\xFCssel und befreie ihn!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: Familien kommen hierher, um Tiere aus aller Welt zu sehen.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Jeder K\xE4fig ist mit einem goldenen Schl\xFCssel verschlossen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: Zeichne deinen Lieblingszwerg aus Breslau und den Ort, an dem du
      ihn gefunden hast.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "M\xF6chtest du aufs Dach steigen?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "M\xF6chtest du einige Fragen beantworten, um diese Quest abzuschlie\xDFen?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: Spielen Sie ein Musikinstrument?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: Gehst du gern zur Schule?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: Hast du in der Centennial Hall nachgesehen?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: "Richtig! Hier ist Ihr Schl\xFCssel."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: Erledige zuerst die Aufgabe!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: Kommen Sie abends hierher, um die Show zu sehen!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: Komm wieder, wenn du bereit bist.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: "Hier arbeiten und tagen die st\xE4dtischen F\xFChrungskr\xE4fte."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: "Die Centennial Hall ist ber\xFChmt f\xFCr ihr gro\xDFes rundes
      Dach."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: "Die Centennial Hall ist ein riesiges, ber\xFChmtes Geb\xE4ude."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: Die Centennial Hall hat ein riesiges rundes Dach.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: Centennial Hall
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: Kathedrale
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "Antura war heute Abend \xFCberall in Breslau unterwegs!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: Antura befindet sich ganz oben im Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: "Und heute Morgen sind zehn Zwerge in K\xE4figen eingesperrt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "Und seht mal \u2013 Antura ist auch hier!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: Alle Zwerge des Himmelsturms sind frei!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: Ein Schriftsteller
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: Ein Wissenschaftler
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: Ein Politiker
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "Ein Platz ist ein gro\xDFer, offener Ort, an dem sich Menschen
      treffen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: Ein Panorama ist ein riesiges Bild, das den ganzen Raum einnimmt!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: "Auf dem Markt liegt ein Schl\xFCssel unter einem Blumentopf."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: Ein Brunnen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: "Eine ber\xFChmte Schriftstellerin namens Olga Tokarczuk lebte hier
      in der N\xE4he!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: Ein Zwerg
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: "\xDCber"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: "Schalte zuerst die anderen beiden Zwerge hier frei, dann komm zur\xFCck."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: Schalte den Reisenden Zwerg frei!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: Wir fahren hinauf zur Spitze des Sky Towers!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: Nutze es, um zu sehen, wo du bist und wohin du gehen musst!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: "Nutzen Sie die Stra\xDFenbahn, um Ihre n\xE4chste Haltestelle auszuw\xE4hlen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: "Wir befinden uns an der Haltestelle Bema, in der N\xE4he der Kathedrale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: Wir sind in der Leonardo-Grundschule!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: Willkommen in der Centennial Hall!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: Willkommen im Sky Tower! Er ist sehr hoch.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: Willkommen in Breslau!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: Was machen die Menschen in einer Kathedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: Was machen die Menschen in einer Kathedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: Was ist ein bekanntes Symbol von Breslau?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: "Wohin m\xF6chtest du reisen?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: Wo ist der Zwerg?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: "Wo ist der Schl\xFCssel?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: Wer ist Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: Werdet ihr uns alle finden?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Breslau ist ber\xFChmt f\xFCr seine kleinen Zwerge."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "Der Zoo von Breslau ist der gr\xF6\xDFte Zoo Polens!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: Ja
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: Ja, das stimmt!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: "Sie k\xF6nnen jetzt zum Sky Tower fahren!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: "Wer nicht laufen m\xF6chte, kann die Stra\xDFenbahn benutzen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: Du hast diese Quest abgeschlossen. Hat sie dir gefallen?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: Du hast es gefunden! Jetzt geh und schalte den Zwerg frei!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
