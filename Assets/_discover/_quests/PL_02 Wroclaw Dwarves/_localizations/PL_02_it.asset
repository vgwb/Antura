%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_it
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: it
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: Il Custode delle Chiavi ha bisogno delle 10 Chiavi dei Nani!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "Riprova pi\xF9 tardi!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: Per sbloccare la gabbia, risolvi questo enigma!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: Il nostro nano viaggiatore adora visitare posti nuovi.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "Questa \xE8 la cattedrale di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: "Qui, nel vecchio municipio, custodiamo le leggi della citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: Questa fontana utilizza acqua, luci colorate e musica!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: A questo nano manca solo un'ultima chiave per essere libero!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: Essi leggono
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: Essi leggono
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: Pregano
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: Pregano
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: Giocano
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: Giocano
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: Hanno cappellini e stivali minuscoli!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "Allo zoo c'\xE8 sempre qualcosa da fare!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "C'\xE8 un problema in citt\xE0... andiamo a scoprire di cosa si
      tratta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "Dietro quel cartello laggi\xF9 c'\xE8 una chiave."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "Qui si trova una famosa scultura dell'artista Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "In citt\xE0 ci sono pi\xF9 di 800 nani!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "Lo zoo \xE8 stato costruito molto tempo fa, nel 1865!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: "Il Nano Scrittore \xE8 ancora bloccato!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: Il nano viaggiatore si trova nella piazza.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "Il tram \xE8 pronto. Per prima cosa, andate alla Cattedrale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: Il panorama sembra un'immagine gigantesca che mi circonda!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "Il Nano Origine \xE8 disponibile al mercato."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "Il vecchio municipio \xE8 un edificio antico e importante."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: La fontana multimediale utilizza acqua, luce e musica.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: La Fontana Multimediale ha bisogno del nostro aiuto!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "Il Custode delle Chiavi \xE8 intrappolato vicino all'ascensore!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: Muoviti e salta sopra gli scaffali per prenderlo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "La chiave \xE8 vicino all'angolo lettura!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: La chiave nascosta del Municipio si trova dietro il cartello.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: Nell'acqua della fontana, vicino al palco, si nasconde una chiave!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: Lo spettacolo delle fontane sembra un grande concerto!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: Il round finale!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: "L'ascensore \xE8 ora aperto."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: Il consigliere nano si trova vicino al vecchio municipio.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "La citt\xE0 \xE8 bellissima vista da quass\xF9!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: Il forziere si apre!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "Lo scrigno \xE8 chiuso a chiave."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: "La zona centrale \xE8 completata!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: "L'area della Centennial Hall \xE8 completata!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "La cattedrale si trova in una delle zone pi\xF9 antiche di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "Il vescovo nano \xE8 rinchiuso qui vicino."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: Grazie! Mi hai salvato!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: Parlami se hai bisogno di aiuto.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: Resta qui
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: A volte mi siedo qui e immagino le mie storie.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: Alcuni nani di Breslavia hanno un aspetto buffo, altri invece sembrano
      seri!
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "Sky Tower \xE8 uno degli edifici pi\xF9 alti di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: Sky Tower
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: Scuola
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: Salvate il nano della scuola.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: Trova la musica e salva il nano direttore d'orchestra!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: Trova e salva il nano architetto!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: "Le persone vengono qui per pregare e riflettere in tranquillit\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Panorama Rac\u0142awicka \xE8 l'ultimo luogo di questa zona."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "Panorama Rac\u0142awicka \xE8 un'enorme immagine che avvolge l'intera
      stanza!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "Panorama Rac\u0142awicka \xE8 un dipinto gigante e rotondo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: 'Lei ha vinto un grande premio per i suoi libri: il Premio Nobel!'
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: Ora sapete come liberare gli altri nani.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: Ora si sono trasformati in veicoli magici chiamati "tram".
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: Ora vai e libera tutti e 10 i miei amici nani.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: No. Riprova!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: No, voglio restare qui
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: NO
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "I miei amici hanno ancora bisogno di aiuto al Centennial Hall e
      in centro citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: La mia famiglia vive qui da tantissimo tempo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: Sposta la pianta per trovarla!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: Magari potresti leggere un libro in biblioteca?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "Piazza del Mercato \xE8 uno dei luoghi pi\xF9 frequentati di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: "Piazza del Mercato \xE8 un luogo molto frequentato e divertente."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: Mercato coperto
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: Molte persone visitano Breslavia alla ricerca di statue di nani.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: Molte persone, mentre passeggiano, cercano statue di nani!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: Dai un'occhiata allo zoo, alla grande sala e alla fontana.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: Raccogli tutti i colori presenti nel parco.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: Osserva la stella sulla mappa.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "Ammirate Piazza del Mercato, il Municipio e il Panorama Rac\u0142awicka!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: "Molto tempo fa, ho costruito dei tunnel nanici in citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: Qualcuno qui vicino ce l'ha.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: "\xC8 uno spettacolo \"multimediale\" perch\xE9 utilizza molti elementi
      diversi."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: Fu costruito intorno all'anno 1300!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: Ti fa sentire come se fossi dentro il dipinto!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "\xC8 uno degli edifici pi\xF9 famosi della citt\xE0!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "\xC8 chiuso a chiave. Trova una chiave d'oro!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: "\xC8 un'immagine che ti circonda completamente."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: Ha alte torri e bellissime finestre.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: Ho disegnato una mappa di Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: Penso sempre a nuovi edifici da disegnare.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: "Ti aprir\xF2 l'ascensore."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: Mi prendo cura degli animali. Anche tu ami gli animali?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: Un giorno vorrei viaggiare in tutto il mondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: Rimango qui per aiutare le persone a trovare la pace.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: "Lo vedo! \xC8 in cima all'Iglica!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "Dipingo la storia di Breslavia affinch\xE9 tutti possano vederla."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: Adoro i tetti e gli archi alti!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "Adoro ammirare quella scultura di Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: Adoro i colori vivaci e le immagini giganti!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: Adoro avere un buon libro tra le mani!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: Spero che ti divertirai allo zoo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: Ti regalo questo biglietto speciale per viaggiare ovunque!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: Finalmente posso di nuovo sorvegliare tutte le serrature!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: "Io sono il Consigliere Nano. Aiuto il Sindaco della Citt\xE0!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "Sono uno dei nani pi\xF9 anziani della citt\xE0! Sono apparso per
      la prima volta nel 2005."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: Come posso essere d'aiuto?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: Come posso liberare il nano?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: Ciao! Sono un'insegnante della scuola Leonardo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: Ecco la tua chiave!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: Aiuta il nano scrittore.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: Trova tutti i colori!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: Trova tutti gli animali e libera il nano!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: Trovate tutti i libri sui nani!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: "Ma si \xE8 perso in un labirinto."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: Ama le storie, i libri e... le biblioteche.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: Ma ora ha perso tutti gli appunti!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: Abbiamo bisogno di lui per migliorare gli edifici
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: Il nostro nano amante degli animali adora tutti gli animali
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: Ottimo lavoro! Hai esplorato Breslavia e liberato tutti i nani.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: Arrivederci
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "Dall'alto si pu\xF2 vedere quasi tutta la citt\xE0!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: Liberate il Nano Originario.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: Per prima cosa, recatevi alla Cattedrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: Trova qui il nano pittore.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: Trova la chiave. Poi apri la gabbia!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: Trova la chiave della cattedrale e liberalo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: Le famiglie vengono qui per vedere animali provenienti da tutto
      il mondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Ogni gabbia \xE8 chiusa con una chiave d'oro."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: Disegna il tuo nano di Breslavia preferito e il luogo in cui l'hai
      trovato.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: Vuoi salire sul tetto?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: Vuoi rispondere ad alcune domande per completare questa missione?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: Suoni uno strumento musicale?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: Ti piace andare a scuola?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: Hai controllato all'interno della Centennial Hall?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: Esatto! Ecco la chiave.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: Completa prima il compito!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: Venite qui di notte per assistere allo spettacolo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: Torna quando sei pronto.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: Ma il nostro consigliere nano ha perso tutti i suoi libri!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: "La Centennial Hall \xE8 famosa per il suo grande tetto rotondo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: "Aiuto! Il nostro nano architetto \xE8 scomparso!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: La Centennial Hall ha un enorme tetto rotondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: Sala del Centenario
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: Cattedrale
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: Antura ha girato tutta Breslavia stasera!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: Antura si trova in cima alla Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: E stamattina, dieci nani sono stati rinchiusi in gabbie!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "E guarda... anche Antura \xE8 qui!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: Tutti i nani della Torre Celeste sono gratis!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: Uno scrittore
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: Uno scienziato
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: Un politico
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "Una piazza \xE8 un grande spazio aperto dove le persone si incontrano."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: Il nostro nano pittore ha perso tutti i suoi colori!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: Una chiave si trova sotto un vaso di fiori al mercato.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: Una fontana
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: La famosa scrittrice Olga Tokarczuk viveva qui vicino!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: Un nano
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: Una chiave
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: Sblocca prima gli altri due nani, poi torna qui.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: Trova e salva il nano viaggiatore!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: Saliamo in cima alla Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: Usalo per vedere dove ti trovi e dove devi andare!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: Utilizza il tram per scegliere la tua prossima fermata.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: Ci troviamo alla fermata Bema, vicino alla cattedrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: Ci troviamo alla scuola elementare Leonardo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: Benvenuti alla Centennial Hall!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: "Benvenuti alla Sky Tower! \xC8 altissima."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: Benvenuti a Breslavia!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: Cosa fanno le persone in una cattedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: Cosa fanno le persone in una cattedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "Qual \xE8 un famoso simbolo di Breslavia?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: Dove vuoi andare?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: "Dov'\xE8 il nano?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: "Dov'\xE8 la chiave?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: "Chi \xE8 Olga Tokarczuk?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: Riuscirai a trovarci tutti?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Breslavia \xE8 famosa per i suoi piccoli nani."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "Lo zoo di Breslavia \xE8 il pi\xF9 grande della Polonia!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: "S\xCC"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: "S\xEC, \xE8 proprio cos\xEC!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: Ora puoi andare alla Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: Se non vuoi camminare, puoi prendere il tram.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: "Hai completato questa missione. Ti \xE8 piaciuta?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: L'hai trovato! Ora vai e libera il nano!
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767041
    m_Localized: Li hai trovati tutti! Torna indietro per ricevere una ricompensa.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089992
    m_Localized: "Dov'\xE8 il mio gatto?"
    m_Metadata:
      m_Items: []
  - m_Id: 75056277766529024
    m_Localized: Se non li trovi tutti, usa la mappa!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284289
    m_Localized: L'ascensore non funziona!
    m_Metadata:
      m_Items: []
  - m_Id: 75156437523750912
    m_Localized: Qualcuno lo ha visto salire sul tetto
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284225
    m_Localized: Qualcuno lo ha visto salire sul tetto
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675521
    m_Localized: Puzzle
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284241
    m_Localized: Suona le note nell'ordine corretto.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284250
    m_Localized: Suona le note per sbloccarmi!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284236
    m_Localized: Il nostro nano era solito dirigere lo spettacolo delle fontane.
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767042
    m_Localized: Ora puoi sbloccare il nano!
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675520
    m_Localized: Memoria
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089991
    m_Localized: Voglio proteggere tutti gli animali
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089990
    m_Localized: Mi piace lo zoo!
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767040
    m_Localized: Vai dal nano con la chiave!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284280
    m_Localized: Vai dal Maestro dei Nani!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284266
    m_Localized: Prendi la chiave che si trova sopra i libri.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284243
    m_Localized: Trova tutte le note musicali qui intorno
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089997
    m_Localized: Trova tutti gli animali presenti nello zoo.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284300
    m_Localized: Vuoi fare una partita?
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089957
    m_Localized: Raccogli tutti i libri.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089988
    m_Localized: "Ma sono scappati via quando \xE8 passato un grosso cane blu!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
