%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_it
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: it
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: Gira come un pennello, compiendo un ultimo, felice vortice.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: Il disegno della fontana mostra una chiave vicino al palco.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: "Chi \xE8 Olga Tokarczuk?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "La Centennial Hall \xE8 nota per il suo grande tetto rotondo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: Hai completato la missione dei Nani di Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Niente
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "Una piazza \xE8 uno spazio aperto dove le persone si incontrano."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: Disegna il tuo nano di Breslavia preferito e il luogo in cui l'hai
      trovato.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "Il tram \xE8 pronto. Prima di tutto, andate alla Cattedrale."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: Alle famiglie piace assistere allo spettacolo delle fontane.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: Torre del Cielo
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: Come posso essere d'aiuto?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: La gente viene qui a pregare.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: Una lettera vivente indica una chiave accanto alla porta della cattedrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "\xC8 un'immagine gigantesca che ti circonda completamente."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "La piazza del mercato \xE8 uno dei luoghi pi\xF9 frequentati della
      citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "Il nano direttore d'orchestra ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "La Sky Tower \xE8 facilmente visibile da molte zone della citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: Questo nano adora i luoghi affollati e i percorsi nuovi.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: "Dov'\xE8 la chiave?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "Il Nano Originario ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: Ora vai e libera il nano!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: Trova qui il nano della scuola.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "C'\xE8 un problema in citt\xE0... andiamo a scoprire di cosa si
      tratta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: Trova la chiave del municipio.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: Rispondi a questa domanda per aprire la gabbia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: Osserva la stella sulla mappa.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: La chiave si trova vicino all'ascensore.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: Giocano
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "La citt\xE0 \xE8 bellissima vista da quass\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: Utilizza il tram per scegliere la tua prossima fermata.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: La chiave nascosta del Municipio si trova dietro il cartello.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: Pregano
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: Trova la legenda. Poi copia il disegno della fontana.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: "Questo \xE8 il nano pittore del centro nevralgico."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "La nostra piazza del mercato \xE8 un luogo vivace dove passeggiare
      e incontrare amici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "Olga Tokarczuk \xE8 una famosa scrittrice."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: Questo nano adora zampe, ali e baffi.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: Ora sai come liberare i nani. Trovane 10 subito!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: Come posso liberare il nano?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "I leader della citt\xE0 lavorano e si incontrano qui."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: Trova la chiave nascosta nel mercato.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: Pescare
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "Qual \xE8 un famoso simbolo di Breslavia?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "Ora la mappa di Breslavia \xE8 tua."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: Il panorama che mi circonda sembra un quadro.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: Trova la chiave. Poi apri la gabbia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: "Dov'\xE8 il nano?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: Questo nano adora i progetti, i documenti e le riunioni importanti.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: Siamo orgogliosi della Centennial Hall e del suo grande tetto rotondo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Breslavia \xE8 famosa per i suoi piccoli nani."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: Guardate nello zoo, nella sala e nella fontana.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: Benvenuti alla Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: Si raddrizza il cappellino minuscolo come un sindaco molto impegnato.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: Questo nano adora i colori, la pittura e le immagini grandi.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "La Sky Tower \xE8 uno degli edifici pi\xF9 alti di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: "Un panorama \xE8 un'immagine gigantesca che ti circonda completamente."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: Vuoi rispondere ad alcune domande?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: "La cattedrale \xE8 uno dei luoghi pi\xF9 famosi di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: Trova la chiave, poi abbina i pezzi dell'immagine per aprire la
      gabbia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "Il vescovo nano \xE8 rinchiuso qui vicino."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "Lo zoo di Breslavia \xE8 il pi\xF9 grande zoo della Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: Trova la chiave della piazza.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: Cosa fanno le persone in una cattedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: La fontana multimediale utilizza acqua, luce e musica.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "Il nano viaggiatore ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: Agita il suo minuscolo bastone e si inchina alla fontana.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: Ha alte torri e finestre luminose.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: Alcuni nani di Breslavia hanno un aspetto buffo, altri invece sembrano
      seri.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: Muove i suoi stivaletti e fa un inchino felice.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "Per prima cosa, recatevi alla Cattedrale. L\xEC vi aiuteranno a
      leggere la mappa."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: Questo nano adora le storie, i libri e i luoghi tranquilli.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: Benvenuti a Breslavia!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Ogni gabbia \xE8 sigillata con una chiave d'oro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "Il consigliere nano ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: Questo nano adora le forme, gli edifici e i progetti ingegnosi.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: Ciao! Sono un'insegnante della scuola Leonardo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: Risolvi l'enigma del corridoio per trovare la chiave nascosta.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: Uno scrittore
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: Antura si trova in cima alla Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: Trova la chiave dello zoo. Poi parla con il guardiano dello zoo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: Il consigliere nano si trova vicino al vecchio municipio.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: Pregano
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: A Breslavia, molti conoscono il loro nano preferito.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: Sposta la pianta per trovarla.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "Il nano pittore ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: Un pilota
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: Individua la chiave di lettura dell'autore. Poi parla con il lettore.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: La chiave si trova sotto una panchina nella piazza.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: Una balena
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: Gira su se stessa in un piccolo cerchio, come se fosse pronta per
      il prossimo viaggio.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: "Dietro il cartello c'\xE8 una chiave."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: Liberate tutti e 10 i miei amici nani di Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: Dieci nani sono rinchiusi in gabbie magiche a Breslavia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: Torna quando sei pronto.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: Un nano
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: "Il nano scrittore ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: Corrono con le auto
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: Saliamo fino in cima alla Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: Abbraccia un minuscolo libro e ti sorride raggiante.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: Completa prima il compito!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: "L'architetto nano ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: "La Centennial Hall \xE8 molto grande e ha il famoso tetto rotondo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: Un gatto gigante
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: Un razzo
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Clink, clang, tintinnio. Ti aprir\xF2 l'ascensore."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: Trova qui il nano pittore.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: Osservate Piazza del Mercato, il Municipio e il Panorama Raclawicka.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: Ottimo lavoro. Hai esplorato Breslavia e liberato tutti i nani.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: Si libra nell'aria con orgoglio, come se stesse disegnando un nuovo
      tetto.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: Scuola
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: Una chiave si trova sotto un vaso di fiori al mercato.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: Molte persone visitano Breslavia alla ricerca di statue di nani.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: Questa fontana utilizza acqua, luci e musica.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: "Usalo per raggiungere il centro citt\xE0 o la Centennial Hall."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: Ci troviamo alla fermata Bema, vicino alla cattedrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: La chiave si trova vicino all'angolo lettura.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: Benvenuti nell'area della Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: "Questo \xE8 il vecchio municipio."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: Corretto. Ecco la chiave.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: Essi leggono
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: "Molto tempo fa, ho costruito dei tunnel nanici in citt\xE0."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "Il nano custode delle chiavi ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: Cosa fanno le persone in una cattedrale?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: Gli altri nani ti mostrano dove guardare.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: Trova l'ultima chiave vicino al cartello dell'ascensore.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "Questa \xE8 la cattedrale di Breslavia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: Trova la chiave della cattedrale e libera il vescovo nano.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "Il nano amante degli animali ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: Questo nano adora gli schizzi, i brillantini e le canzoni.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: Hanno cappellini e stivali minuscoli.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: Cinguetta, annusa e saluta con la mano, tutto allo stesso tempo.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: Panorama Raclawicka fa parte del polo centrale.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: "Questo \xE8 uno dei nani della Torre Celeste."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: "Il vescovo nano ora \xE8 al sicuro."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: Ecco la tua chiave.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: Tutti i nani della Torre Celeste sono gratuiti.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: Un altro nano si trova vicino alla Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: "L'area della Centennial Hall \xE8 completata."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "La zona centrale \xE8 terminata."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: Ora si sono trasformati in veicoli magici.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: Il consigliere nano si trova vicino al vecchio municipio.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: Grazie! Mi hai salvato!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: "L'ascensore \xE8 ora aperto."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: "La fontana \xE8 l'ultimo posto rimasto qui."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: L'immagine finale mostra una chiave sotto la cornice.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: La gabbia del custode delle chiavi si trova vicino all'ascensore.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "\xC8 chiuso a chiave. Trova una chiave d'oro!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: NO
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: "Panorama Raclawicka \xE8 l'ultimo locale di questa zona."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: Per sbloccare la gabbia risolvi questo enigma
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: Resta qui
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: Parlami se hai bisogno di aiuto.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: Cattedrale
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: Sala del Centenario
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: Mercato coperto
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: Il nano viaggiatore si trova nella piazza.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: No. Riprova.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "Riprova pi\xF9 tardi!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: Dove vuoi andare?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: "S\xCC"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: "S\xEC, \xE8 corretto."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
