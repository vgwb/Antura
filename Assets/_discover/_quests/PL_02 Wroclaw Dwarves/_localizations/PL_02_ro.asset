%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_ro
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: ro
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "Se \xEEnv\xE2rte ca o pensul\u0103, f\u0103c\xE2nd un ultim v\xE2rtej
      fericit."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "Modelul f\xE2nt\xE2nii prezint\u0103 o cheie l\xE2ng\u0103 scen\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: Cine este Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "Sala Centennial este cunoscut\u0103 pentru acoperi\u0219ul s\u0103u
      rotund \u0219i mare."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "Ai terminat misiunea Piticii din Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Nimic
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "O pia\u021B\u0103 este un loc deschis unde se \xEEnt\xE2lnesc oamenii."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "Deseneaz\u0103 piticul t\u0103u preferat din Wroc\u0142aw \u0219i
      locul unde l-ai g\u0103sit."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "Tramvaiul este gata. Mai \xEEnt\xE2i merge\u021Bi la Catedral\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "Familiilor le place s\u0103 urm\u0103reasc\u0103 spectacolul cu
      f\xE2nt\xE2ni."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: "Panoram\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: Turnul Cerului
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: Cum pot ajuta?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: "Oamenii vin aici s\u0103 se roage."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "O liter\u0103 vie indic\u0103 o cheie de l\xE2ng\u0103 u\u0219a
      catedralei."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "Este o imagine gigantic\u0103 \xEEn jurul t\u0103u."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "Pia\u021Ba Central\u0103 este unul dintre cele mai aglomerate locuri
      din ora\u0219."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "Piticul Conductor este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "Turnul Sky este u\u0219or de v\u0103zut din multe p\u0103r\u021Bi
      ale ora\u0219ului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: "Acest pitic iube\u0219te locurile aglomerate \u0219i c\u0103r\u0103rile
      noi."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: Unde este cheia?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "Piticul Originii este acum \xEEn siguran\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "Acum du-te \u0219i deblocheaz\u0103 piticul!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: "G\u0103se\u0219te-l pe Piticul \u0218colii aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "Exist\u0103 o problem\u0103 \xEEn ora\u0219... hai s\u0103 explor\u0103m!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "G\u0103se\u0219te cheia Prim\u0103riei."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "R\u0103spunde\u021Bi la aceast\u0103 \xEEntrebare pentru a deschide
      cu\u0219ca."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: "Uit\u0103-te la steaua de pe hart\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "Cheia este l\xE2ng\u0103 lift."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: "Ei joac\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "Ora\u0219ul arat\u0103 frumos de aici de sus."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "Folose\u0219te tramvaiul pentru a-\u021Bi alege urm\u0103toarea
      sta\u021Bie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "Cheia ascuns\u0103 de la Prim\u0103rie este \xEEn spatele indicatorului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: "Ei se roag\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "G\u0103se\u0219te cheia. Apoi copiaz\u0103 modelul f\xE2nt\xE2nii."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: "Acesta este Pictorul Pictor din centrul ora\u0219ului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "Pia\u021Ba noastr\u0103 este un loc animat pentru a te plimba \u0219i
      a-\u021Bi \xEEnt\xE2lni prietenii."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "Olga Tokarczuk este o scriitoare celebr\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: "Acest pitic iube\u0219te labele, aripile \u0219i must\u0103\u021Bile."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "Acum \u0219tii cum s\u0103 eliberezi piticii. G\u0103se\u0219te
      10 acum!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "Cum pot s\u0103-l eliberez pe Pitic?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "Liderii ora\u0219ului lucreaz\u0103 \u0219i se \xEEnt\xE2lnesc
      aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "G\u0103se\u0219te cheia ascuns\u0103 \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: Ei pescuiesc
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "Care este un simbol faimos al ora\u0219ului Wroc\u0142aw?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "Harta ora\u0219ului Wroc\u0142aw este acum a ta."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "Panorama arat\u0103 ca o imagine \xEEn jurul meu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "G\u0103se\u0219te cheia. Apoi deschide cu\u0219ca."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: Unde este piticul?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "Acest pitic iube\u0219te planurile, h\xE2rtiile \u0219i \xEEnt\xE2lnirile
      importante."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: "Suntem m\xE2ndri de Centennial Hall \u0219i de acoperi\u0219ul
      s\u0103u rotund \u0219i mare."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Wroc\u0142aw este faimos pentru micu\u021Bii s\u0103i pitici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: "Uit\u0103-te la gr\u0103dina zoologic\u0103, la hol \u0219i la
      f\xE2nt\xE2n\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: "Bine a\u021Bi venit \xEEn Turnul Cerului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "\xCE\u0219i \xEEndreapt\u0103 p\u0103l\u0103ria mic\u0103 ca un
      primar foarte ocupat."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: "Acest pitic iube\u0219te culorile, vopseaua \u0219i imaginile mari."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "Turnul Sky este una dintre cele mai \xEEnalte cl\u0103diri din
      Wroclaw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: "O panoram\u0103 este o imagine gigantic\u0103 \xEEn jurul t\u0103u."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "Vrei s\u0103 r\u0103spunzi la ni\u0219te \xEEntreb\u0103ri?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: Catedrala este unul dintre cele mai faimoase locuri din Wroclaw.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: "G\u0103se\u0219te cheia, apoi potrive\u0219te piesele din imagine
      pentru a deschide cu\u0219ca."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "Piticul Episcop este \xEEncuiat \xEEn apropiere."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "Gr\u0103dina Zoologic\u0103 din Wroc\u0142aw este cea mai mare
      gr\u0103din\u0103 zoologic\u0103 din Polonia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: "G\u0103se\u0219te cheia pie\u021Bei."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: "Ce fac oamenii \xEEntr-o catedral\u0103?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: "F\xE2nt\xE2na multimedia folose\u0219te ap\u0103, lumin\u0103 \u0219i
      muzic\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "Piticul C\u0103l\u0103tor este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: "\xCE\u0219i flutur\u0103 bagheta mic\u0103 \u0219i se \xEEnclin\u0103
      \xEEn fa\u021Ba f\xE2nt\xE2nii."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: "Are turnuri \xEEnalte \u0219i ferestre luminoase."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: "Unii pitici din Wroclaw arat\u0103 amuzant, iar al\u021Bii par
      serio\u0219i."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: "\xCE\u0219i mi\u0219c\u0103 cizmele \u0219i face o plec\u0103ciune
      fericit\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "Mai \xEEnt\xE2i mergi la Catedral\u0103. Te vor ajuta s\u0103 cite\u0219ti
      harta."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: "Acest pitic iube\u0219te pove\u0219tile, c\u0103r\u021Bile \u0219i
      locurile lini\u0219tite."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "Bine a\u021Bi venit la Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Fiecare cu\u0219c\u0103 este sigilat\u0103 cu o cheie de aur."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "Piticul Consilier este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "Acest pitic iube\u0219te formele, cl\u0103dirile \u0219i designurile
      ingenioase."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: "Bun\u0103! Sunt profesor la \u0218coala Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: "Rezolv\u0103 puzzle-ul holului pentru a g\u0103si cheia ascuns\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: Un scriitor
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: "Antura este \xEEn v\xE2rful Sky Tower!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "G\u0103se\u0219te cheia de la gr\u0103dina zoologic\u0103. Apoi
      vorbe\u0219te cu \xEEngrijitorul gr\u0103dinii zoologice."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "Piticul Consilier este l\xE2ng\u0103 Prim\u0103ria Veche."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: "Ei se roag\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: "Mul\u021Bi oameni din Wroclaw \xEE\u0219i cunosc piticul preferat."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: "Mut\u0103 \u200B\u200Bplanta pentru a o g\u0103si."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "Piticul Pictor este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: Un pilot
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "G\u0103se\u0219te cheia scriitorului. Apoi vorbe\u0219te cu cititorul."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "Cheia este sub o banc\u0103 \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: "O balen\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: "Se \xEEnv\xE2rte \xEEntr-un mic cerc, ca \u0219i cum ar fi gata
      pentru urm\u0103toarea c\u0103l\u0103torie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: "Exist\u0103 o cheie \xEEn spatele semnului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: "Elibereaz\u0103-i pe to\u021Bi cei 10 prieteni pitici ai mei din
      Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: "Zece pitici sunt \xEEnchi\u0219i \xEEn cu\u0219ti magice \xEEn
      Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: "\xCEntoarce-te c\xE2nd e\u0219ti gata."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: Un pitic
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: "Piticul Scriitor este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: "Ei curseaz\u0103 ma\u0219ini"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: "Mergem \xEEn v\xE2rful Turnului Ceresc."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: "\xCEmbr\u0103\u021Bi\u0219eaz\u0103 o carte mic\u0103 \u0219i \xEE\u021Bi
      z\xE2mbe\u0219te larg."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: "Finaliza\u021Bi sarcina, mai \xEEnt\xE2i!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: "Piticul Arhitect este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: "Sala Centenar este foarte mare \u0219i are un acoperi\u0219 rotund
      faimos."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: "O pisic\u0103 uria\u0219\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: "O rachet\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Clic, clanc, clinchet. \xCE\u021Bi voi descuia liftul."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: "G\u0103se\u0219te-l pe Piticul Pictor aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: "Uita\u021Bi-v\u0103 la Pia\u021Ba Central\u0103, Prim\u0103ria
      \u0219i Panorama Raclawicka."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "Bravo. Ai explorat Wroc\u0142aw-ul \u0219i ai eliberat to\u021Bi
      piticii."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: "Bate cu m\xE2ndrie aerul ca \u0219i cum ar desena un acoperi\u0219
      nou."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: "\u015Ecoal\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: "O cheie se afl\u0103 sub un ghiveci de flori \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: "Mul\u021Bi oameni viziteaz\u0103 Wroclaw pentru a c\u0103uta statui
      de pitici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: "Aceast\u0103 f\xE2nt\xE2n\u0103 folose\u0219te ap\u0103, lumini
      \u0219i muzic\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: "Folose\u0219te-l pentru a merge la Centrul Ora\u0219ului sau la
      Sala Centennial."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: "Suntem la sta\u021Bia Bema, l\xE2ng\u0103 Catedral\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: "Cheia este l\xE2ng\u0103 col\u021Bul de citit."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: "Bine a\u021Bi venit \xEEn zona S\u0103lii Centenare."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: "Aceasta este Prim\u0103ria Veche."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: "Corect. Iat\u0103 cheia ta."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: Ei citesc
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: "Cu mult timp \xEEn urm\u0103, am construit Tuneluri pentru Pitici
      \xEEn ora\u0219."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "Piticul Maestru al Cheilor este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: "Ce fac oamenii \xEEntr-o catedral\u0103?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: "Ceilal\u021Bi pitici \xEE\u021Bi arat\u0103 unde s\u0103 cau\u021Bi."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: "G\u0103se\u0219te ultima cheie l\xE2ng\u0103 semnul liftului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "Aceasta este catedrala din Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: "G\u0103se\u0219te cheia catedralei \u0219i elibereaz\u0103-l pe
      Piticul Episcop."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "Piticul iubitor de animale este acum \xEEn siguran\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: "Acest pitic iube\u0219te stropii, sclipirile \u0219i c\xE2ntecele."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: "Au p\u0103l\u0103rii mici \u0219i cizme mici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: "Ciripe\u0219te, adulmec\u0103 \u0219i face cu m\xE2na toate deodat\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: "Panorama Raclawicka face parte din centrul ora\u0219ului."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: Acesta este unul dintre piticii din Turnul Cerului.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: "Piticul Episcop este \xEEn siguran\u021B\u0103 acum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: "Iat\u0103 cheia ta."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: "To\u021Bi piticii din Sky Tower sunt liberi."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: "Un alt pitic este l\xE2ng\u0103 Centennial Hall."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: "Zona S\u0103lii Centenare este gata."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "Zona central\u0103 este gata."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: "Acum s-au transformat \xEEn vehicule magice."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "Piticul Consilier este l\xE2ng\u0103 Prim\u0103ria Veche."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: "Mul\u021Bumesc! M-ai salvat!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: Liftul este deschis acum.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: "F\xE2nt\xE2na este ultimul loc aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: "Imaginea finalizat\u0103 prezint\u0103 o cheie sub ram\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "Cu\u0219ca Keymaster este l\xE2ng\u0103 lift."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "Este \xEEncuiat\u0103. G\u0103se\u0219te o cheie de aur!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: Nu
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: Panorama Raclawicka este ultimul loc de aici.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: "Pentru a debloca cu\u0219ca, rezolva\u021Bi acest puzzle"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: "R\u0103m\xE2i aici"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: "Vorbe\u0219te cu mine dac\u0103 ai nevoie de ajutor."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: "Catedral\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: "Sala Centenar\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: "Pia\u021Ba"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: "Piticul C\u0103l\u0103tor este \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: "Nu. \xCEncearc\u0103 din nou."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "\xCEncearc\u0103 din nou mai t\xE2rziu!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: "Unde vrei s\u0103 mergi?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: Da
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: "Da, a\u0219a este."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
