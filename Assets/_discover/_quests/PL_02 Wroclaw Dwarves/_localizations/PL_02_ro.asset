%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_ro
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: ro
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: "Deblocheaz\u0103 Maestrul Cheilor!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "\xCEncearc\u0103 din nou mai t\xE2rziu!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "Pentru a debloca cu\u0219ca, rezolv\u0103 acest puzzle!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: "Aceast\u0103 pia\u021B\u0103 este un loc aglomerat din Turnul Cerului."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "Aceasta este Catedrala din Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: "Aceasta este Prim\u0103ria Veche."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: "Aceast\u0103 f\xE2nt\xE2n\u0103 folose\u0219te ap\u0103, lumini
      colorate \u0219i muzic\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "Acest pitic mai are nevoie de o cheie ca s\u0103 fie liber!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: Ei citesc
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: Ei citesc
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: "Ei se roag\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: "Ei se roag\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: "Ei joac\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: "Ei joac\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: "Au p\u0103l\u0103rii minuscule \u0219i cizme minuscule!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "E ceva de f\u0103cut la Gr\u0103dina Zoologic\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "Exist\u0103 o problem\u0103 \xEEn ora\u0219... hai s\u0103 explor\u0103m!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "Exist\u0103 o cheie \xEEn spatele semnului \u0103la de acolo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "Exist\u0103 o sculptur\u0103 faimoas\u0103 aici, realizat\u0103
      de un artist pe nume Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "Sunt peste 800 de pitici \xEEn ora\u0219!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "Gr\u0103dina Zoologic\u0103 a fost construit\u0103 cu mult timp
      \xEEn urm\u0103, \xEEn 1865!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: "Piticul Scriitor e \xEEnc\u0103 blocat!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: "Piticul C\u0103l\u0103tor este \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "Tramvaiul este gata. Mai \xEEnt\xE2i, merge\u021Bi la Catedral\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: "Panorama arat\u0103 ca o imagine gigantic\u0103 \xEEn jurul meu!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "Piticul Originii este la pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "Prim\u0103ria Veche este o cl\u0103dire veche foarte important\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: "F\xE2nt\xE2na multimedia folose\u0219te ap\u0103, lumin\u0103 \u0219i
      muzic\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: "F\xE2nt\xE2na Multimedia are nevoie de ajutorul nostru!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "Maestrul Cheilor este prins l\xE2ng\u0103 lift!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "Cheia este sub o banc\u0103 \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "Cheia este l\xE2ng\u0103 col\u021Bul de lectur\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: "Cheia ascuns\u0103 de la Prim\u0103rie este \xEEn spatele indicatorului."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: "Apa f\xE2nt\xE2nii ascunde o cheie l\xE2ng\u0103 scen\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: "Spectacolul cu f\xE2nt\xE2na se simte ca un mare concert!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: "Runda final\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: Liftul este deschis acum.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "Piticul Consilier este l\xE2ng\u0103 Prim\u0103ria Veche."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "Ora\u0219ul arat\u0103 superb de aici de sus!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: "Cuf\u0103rul se deschide!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "Cuf\u0103rul este \xEEncuiat."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: "Zona central\u0103 e gata!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: "Zona S\u0103lii Centenare este gata!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "Catedrala se afl\u0103 \xEEntr-una dintre cele mai vechi zone ale
      ora\u0219ului Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "Piticul Episcop este \xEEncuiat \xEEn apropiere."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: "Mul\u021Bumesc! M-ai salvat!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: "Vorbe\u0219te cu mine dac\u0103 ai nevoie de ajutor."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: "R\u0103m\xE2i aici"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: "Uneori stau aici \u0219i \xEEmi imaginez propriile mele pove\u0219ti."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: "Unii pitici din Wroc\u0142aw arat\u0103 amuzant, iar al\u021Bii
      par serio\u0219i!"
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "Turnul Sky este una dintre cele mai \xEEnalte cl\u0103diri din
      Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761834
    m_Localized: "Turnul Sky este una dintre cele mai \xEEnalte cl\u0103diri din
      Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: Turnul Cerului
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: "\u015Ecoal\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: "Salva\u021Bi piticul \u0219colii."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: "Salva\u021Bi-l pe Piticul Dirijor! (El conduce spectacolul f\xE2nt\xE2nii
      arteziene)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: "Salva\u021Bi-l pe Piticul Arhitect! (El proiecteaz\u0103 cl\u0103diri)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567418
    m_Localized: "Oamenii vin aici s\u0103 se roage sau s\u0103 stea lini\u0219ti\u021Bi."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: "Oamenii vin aici s\u0103 se roage \u0219i s\u0103 g\xE2ndeasc\u0103
      \xEEn lini\u0219te."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Panorama Rac\u0142awicka este ultimul loc de aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "Panorama Rac\u0142awicka este o imagine imens\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "Panorama Rac\u0142awicka este o pictur\u0103 gigantic\u0103, rotund\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: "Panoram\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: "Olga Tokarczuk este o scriitoare polonez\u0103 care a c\xE2\u0219tigat
      un mare premiu pentru c\u0103r\u021Bile sale!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: "Acum \u0219tii cum s\u0103-i eliberezi pe ceilal\u021Bi pitici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: "Acum s-au transformat \xEEn vehicule magice numite \u201Etramvaie\u201D."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: "Acum du-te \u0219i elibereaz\u0103-i pe to\u021Bi cei 10 prieteni
      ai mei pitici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: "Nu. \xCEncearc\u0103 din nou!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: "Nu, vreau s\u0103 r\u0103m\xE2n aici"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: Nu
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "Prietenii mei au \xEEnc\u0103 nevoie de ajutor la Centennial Hall
      \u0219i \xEEn centrul ora\u0219ului."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: "Familia mea locuie\u0219te aici de mult, mult timp!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: "Mut\u0103 \u200B\u200Bplanta ca s\u0103 o g\u0103se\u0219ti!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: "Poate g\u0103se\u0219ti o poveste amuzant\u0103 de citit la bibliotec\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "Pia\u021Ba Central\u0103 este unul dintre cele mai aglomerate locuri
      din Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: "Pia\u021Ba Central\u0103 este un loc foarte aglomerat \u0219i distractiv."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: "Pia\u021Ba"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: "Mul\u021Bi oameni viziteaz\u0103 Wroc\u0142aw pentru a c\u0103uta
      statui de pitici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: "Mul\u021Bi oameni caut\u0103 statui de pitici \xEEn timp ce merg!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: "Uit\u0103-te la Gr\u0103dina Zoologic\u0103, la Sala Mare \u0219i
      la F\xE2nt\xE2n\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: "Uit\u0103-te cu aten\u021Bie! Cheia este ascuns\u0103 sub rama
      tabloului."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: "Uit\u0103-te la steaua de pe hart\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "Uita\u021Bi-v\u0103 la Pia\u021Ba Central\u0103, Prim\u0103ria
      \u0219i Panorama Rac\u0142awicka!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: "Cu mult timp \xEEn urm\u0103, am construit Tuneluri pentru Pitici
      \xEEn ora\u0219."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: "Este l\xE2ng\u0103 u\u0219a Catedralei."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: "Este un spectacol \u201Emultimedia\u201D deoarece folose\u0219te
      multe lucruri diferite."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: "A fost construit\u0103 \xEEn jurul anului 1300!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: "Te face s\u0103 sim\u021Bi c\u0103 e\u0219ti \xEEn mijlocul pove\u0219tii!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "Este una dintre cele mai faimoase cl\u0103diri din ora\u0219!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "Este \xEEncuiat\u0103. G\u0103se\u0219te o cheie de aur!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: "Este o imagine care te \xEEnconjoar\u0103 peste tot."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: "Are turnuri \xEEnalte \u0219i ferestre frumoase."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: "Am desenat o hart\u0103 a ora\u0219ului Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: "M\u0103 g\xE2ndesc mereu la cl\u0103diri noi de desenat."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: "\xCE\u021Bi voi descuia liftul."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: "Eu am grij\u0103 de animale. \u0218i tu iube\u0219ti animalele?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: "Vreau s\u0103 c\u0103l\u0103toresc \xEEn jurul lumii \xEEntr-o
      zi."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: "R\u0103m\xE2n aici ca s\u0103-i ajut pe oameni s\u0103 g\u0103seasc\u0103
      pacea."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: "O v\u0103d! Cheia din spatele unui copac."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "Pictez istoria ora\u0219ului Wroc\u0142aw pentru ca toat\u0103
      lumea s\u0103 o vad\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: "Ador acoperi\u0219urile \u0219i arcadele \xEEnalte!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "\xCEmi place la nebunie s\u0103 m\u0103 uit la sculptura aia de
      Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: "\xCEmi plac culorile vii \u0219i imaginile gigantice!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: "\xCEmi place o carte bun\u0103 \xEEn m\xE2ini!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: "Sper s\u0103 te distrezi la Gr\u0103dina Zoologic\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: "\xCE\u021Bi ofer acest bilet special ca s\u0103 c\u0103l\u0103tore\u0219ti
      peste tot!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: "\xCEn sf\xE2r\u0219it pot p\u0103zi din nou toate \xEEncuietorile!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: "Sunt Piticul Consilier. \xCEl ajut pe Primarul ora\u0219ului!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "Sunt unul dintre cei mai b\u0103tr\xE2ni pitici din ora\u0219!
      Am ap\u0103rut prima dat\u0103 \xEEn 2005."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: Cum pot ajuta?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: "Cum pot s\u0103-l eliberez pe Pitic?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: "Bun\u0103! Sunt profesor la \u0218coala Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: "Iat\u0103 cheia ta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: "Ajut\u0103-l pe Piticul Scriitor."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: "Ajuta\u021Bi-l pe Piticul Pictor!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: "Ajut\u0103 piticul iubitor de animale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: "Ajuta\u021Bi-l pe Piticul Consilier! (El ajut\u0103 la conducerea
      ora\u0219ului)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: "\xCEi place s\u0103 viziteze locuri noi."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: "Iube\u0219te pove\u0219tile, c\u0103r\u021Bile \u0219i col\u021Burile
      lini\u0219tite."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: "Iube\u0219te muzica \u0219i apa dansant\u0103!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: "\xCEi place s\u0103 deseneze forme \u0219i case interesante."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: "Iube\u0219te toate animalele de aici!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "Bravo! Ai explorat Wroc\u0142aw-ul \u0219i ai eliberat to\u021Bi
      piticii."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: La revedere
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "De sus, po\u021Bi vedea aproape tot ora\u0219ul!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: "Elibereaz\u0103 Piticul Originii."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: "Mai \xEEnt\xE2i, merge\u021Bi la Catedral\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: "G\u0103se\u0219te-l pe Piticul Pictor aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "G\u0103se\u0219te cheia. Apoi deschide cu\u0219ca!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "G\u0103se\u0219te cheia Catedralei \u0219i elibereaz\u0103-l!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: "Familiile vin aici s\u0103 vad\u0103 animale din \xEEntreaga lume."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Fiecare cu\u0219c\u0103 este \xEEncuiat\u0103 cu o cheie de aur."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "Deseneaz\u0103 piticul t\u0103u preferat din Wroc\u0142aw \u0219i
      locul unde l-ai g\u0103sit."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "Vrei s\u0103 urci pe acoperi\u0219?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "Vrei s\u0103 r\u0103spunzi la c\xE2teva \xEEntreb\u0103ri pentru
      a termina aceast\u0103 misiune?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: "C\xE2n\u021Bi la un instrument muzical?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: "\xCE\u021Bi place s\u0103 mergi la \u0219coal\u0103?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: "Ai verificat \xEEn interiorul S\u0103lii Centenare?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: "Corect! Iat\u0103 cheia ta."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: "Finaliza\u021Bi sarcina, mai \xEEnt\xE2i!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: "Vino aici seara s\u0103 vezi spectacolul!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: "\xCEntoarce-te c\xE2nd e\u0219ti gata."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: "Liderii ora\u0219ului lucreaz\u0103 \u0219i se \xEEnt\xE2lnesc
      aici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: "Centennial Hall este renumit\u0103 pentru acoperi\u0219ul s\u0103u
      rotund \u0219i mare."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: "Centennial Hall este o cl\u0103dire gigantic\u0103 \u0219i faimoas\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: "Sala Centennial are un acoperi\u0219 rotund gigantic."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: "Sala Centenar\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: "Catedral\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "Antura a alergat prin tot Wroc\u0142aw-ul \xEEn seara asta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: "Antura este \xEEn v\xE2rful Sky Tower!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: "\u0218i \xEEn diminea\u021Ba asta, zece pitici sunt \xEEnchi\u0219i
      \xEEn cu\u0219ti!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "\u0218i uite \u2014 e \u0219i Antura aici!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: "To\u021Bi piticii din Sky Tower sunt liberi!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: Un scriitor
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: "Un om de \u0219tiin\u021B\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: Un politician
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "O pia\u021B\u0103 este un loc mare \u0219i deschis unde se \xEEnt\xE2lnesc
      oamenii."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: "O panoram\u0103 este o imagine gigantic\u0103 care \xEEnconjoar\u0103
      camera!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: "O cheie se afl\u0103 sub un ghiveci de flori \xEEn pia\u021B\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: "O f\xE2nt\xE2n\u0103"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: "O scriitoare celebr\u0103 pe nume Olga Tokarczuk a locuit \xEEn
      apropiere!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: Un pitic
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: O cruce
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: "Deblocheaz\u0103-i mai \xEEnt\xE2i pe ceilal\u021Bi doi pitici
      de aici, apoi \xEEntoarce-te."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: "Deblocheaz\u0103 Piticul C\u0103l\u0103tor!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: "Mergem sus, \xEEn v\xE2rful Turnului Ceresc!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: "Folose\u0219te-l ca s\u0103 vezi unde te afli \u0219i unde s\u0103
      mergi!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: "Folose\u0219te tramvaiul pentru a-\u021Bi alege urm\u0103toarea
      sta\u021Bie."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: "Suntem la sta\u021Bia Bema, l\xE2ng\u0103 Catedral\u0103."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: "Suntem la \u0218coala Primar\u0103 Leonardo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: "Bine a\u021Bi venit la Sala Centenarului!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: "Bine a\u021Bi venit la Sky Tower! Este foarte \xEEnalt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: "Bine a\u021Bi venit la Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: "Ce fac oamenii \xEEntr-o catedral\u0103?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: "Ce fac oamenii \xEEntr-o catedral\u0103?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "Care este un simbol faimos al ora\u0219ului Wroc\u0142aw?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: "Unde vrei s\u0103 mergi?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: Unde este piticul?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: Unde este cheia?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: Cine este Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: "Ne vei g\u0103si pe to\u021Bi?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Wroc\u0142aw este faimos pentru micu\u021Bii s\u0103i pitici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "Gr\u0103dina Zoologic\u0103 din Wroc\u0142aw este cea mai mare
      gr\u0103din\u0103 zoologic\u0103 din Polonia!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: Da
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: "Da, a\u0219a este!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: "Acum po\u021Bi merge la Turnul Cerului!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: "Po\u021Bi folosi tramvaiul dac\u0103 nu vrei s\u0103 mergi pe jos."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: "Ai terminat aceast\u0103 misiune. \u021Ai-a pl\u0103cut?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: "Ai g\u0103sit-o! Acum du-te \u0219i deblocheaz\u0103 piticul!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
