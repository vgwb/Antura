      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: "\u041E\u0441\u044C \u0432\u0430\u0448 \u043A\u043B\u044E\u0447!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: "\u0414\u043E\u043F\u043E\u043C\u043E\u0436\u0456\u0442\u044C \u0433\u043D\u043E\u043C\u0443-\u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u0438\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0438 \u0432\u0441\u0456 \u043A\u043E\u043B\u044C\u043E\u0440\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u0443\u0441\u0456\u0445
      \u0442\u0432\u0430\u0440\u0438\u043D \u0456 \u0437\u0432\u0456\u043B\u044C\u043D\u0456\u0442\u044C
      \u0433\u043D\u043E\u043C\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: "\u0411\u0443\u0434\u044C \u043B\u0430\u0441\u043A\u0430, \u0437\u043D\u0430\u0439\u0434\u0456\u0442\u044C
      \u0443\u0441\u0456 \u043A\u043D\u0438\u0433\u0438 \u043F\u0440\u043E \u0433\u043D\u043E\u043C\u0456\u0432!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: "\u0410\u043B\u0435 \u0432\u0456\u043D \u0437\u0430\u0433\u0443\u0431\u0438\u0432\u0441\u044F
      \u0432 \u043B\u0430\u0431\u0456\u0440\u0438\u043D\u0442\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: "\u0412\u0456\u043D \u043B\u044E\u0431\u0438\u0442\u044C \u0456\u0441\u0442\u043E\u0440\u0456\u0457,
      \u043A\u043D\u0438\u0433\u0438 \u0442\u0430... \u0431\u0456\u0431\u043B\u0456\u043E\u0442\u0435\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: "\u0410\u043B\u0435 \u0442\u0435\u043F\u0435\u0440 \u0432\u0456\u043D
      \u0432\u0442\u0440\u0430\u0442\u0438\u0432 \u0443\u0441\u0456 \u043D\u043E\u0442\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: "\u041D\u0430\u043C \u043F\u043E\u0442\u0440\u0456\u0431\u0435\u043D
      \u0432\u0456\u043D, \u0449\u043E\u0431 \u043F\u043E\u043A\u0440\u0430\u0449\u0438\u0442\u0438
      \u0431\u0443\u0434\u0456\u0432\u043B\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: "\u041D\u0430\u0448 \u0433\u043D\u043E\u043C, \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C
      \u0442\u0432\u0430\u0440\u0438\u043D, \u043B\u044E\u0431\u0438\u0442\u044C
      \u0443\u0441\u0456\u0445 \u0442\u0432\u0430\u0440\u0438\u043D"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "\u0427\u0443\u0434\u043E\u0432\u0430 \u0440\u043E\u0431\u043E\u0442\u0430!
      \u0412\u0438 \u0434\u043E\u0441\u043B\u0456\u0434\u0438\u043B\u0438 \u0412\u0440\u043E\u0446\u043B\u0430\u0432
      \u0456 \u0437\u0432\u0456\u043B\u044C\u043D\u0438\u043B\u0438 \u0432\u0441\u0456\u0445
      \u0433\u043D\u043E\u043C\u0456\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: "\u041F\u0440\u043E\u0449\u0430\u0432\u0430\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "\u0417\u0433\u043E\u0440\u0438 \u0432\u0438\u0434\u043D\u043E \u043C\u0430\u0439\u0436\u0435
      \u0432\u0441\u0435 \u043C\u0456\u0441\u0442\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: "\u0417\u0432\u0456\u043B\u044C\u043D\u0456\u0442\u044C \u041F\u043E\u0445\u0456\u0434\u043D\u043E\u0433\u043E
      \u0413\u043D\u043E\u043C\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: "\u0421\u043F\u043E\u0447\u0430\u0442\u043A\u0443 \u0441\u0445\u043E\u0434\u0456\u0442\u044C
      \u0434\u043E \u0441\u043E\u0431\u043E\u0440\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u0433\u043D\u043E\u043C\u0430-\u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430
      \u0442\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0438 \u043A\u043B\u044E\u0447.
      \u041F\u043E\u0442\u0456\u043C \u0432\u0456\u0434\u0447\u0438\u043D\u0438 \u043A\u043B\u0456\u0442\u043A\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447
      \u0432\u0456\u0434 \u0441\u043E\u0431\u043E\u0440\u0443 \u0442\u0430 \u0437\u0432\u0456\u043B\u044C\u043D\u0456\u0442\u044C
      \u0439\u043E\u0433\u043E!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: "\u0421\u044E\u0434\u0438 \u043F\u0440\u0438\u0457\u0436\u0434\u0436\u0430\u044E\u0442\u044C
      \u0441\u0456\u043C'\u0457 \u0437 \u0443\u0441\u044C\u043E\u0433\u043E \u0441\u0432\u0456\u0442\u0443,
      \u0449\u043E\u0431 \u043F\u043E\u0431\u0430\u0447\u0438\u0442\u0438 \u0442\u0432\u0430\u0440\u0438\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "\u041A\u043E\u0436\u043D\u0430 \u043A\u043B\u0456\u0442\u043A\u0430
      \u0437\u0430\u043C\u043A\u043D\u0435\u043D\u0430 \u043D\u0430 \u0437\u043E\u043B\u043E\u0442\u0438\u0439
      \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "\u041D\u0430\u043C\u0430\u043B\u044E\u0439 \u0441\u0432\u043E\u0433\u043E
      \u0443\u043B\u044E\u0431\u043B\u0435\u043D\u043E\u0433\u043E \u0432\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u044C\u043A\u043E\u0433\u043E
      \u0433\u043D\u043E\u043C\u0430 \u0442\u0430 \u043C\u0456\u0441\u0446\u0435,
      \u0434\u0435 \u0442\u0438 \u0439\u043E\u0433\u043E \u0437\u043D\u0430\u0439\u0448\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "\u0425\u043E\u0447\u0435\u0448 \u043F\u0456\u0434\u043D\u044F\u0442\u0438\u0441\u044F
      \u043D\u0430 \u0434\u0430\u0445?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "\u0425\u043E\u0447\u0435\u0442\u0435 \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0441\u0442\u0438
      \u043D\u0430 \u043A\u0456\u043B\u044C\u043A\u0430 \u0437\u0430\u043F\u0438\u0442\u0430\u043D\u044C,
      \u0449\u043E\u0431 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u0438 \u0446\u0435\u0439
      \u043A\u0432\u0435\u0441\u0442?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: "\u0412\u0438 \u0433\u0440\u0430\u0454\u0442\u0435 \u043D\u0430
      \u043C\u0443\u0437\u0438\u0447\u043D\u043E\u043C\u0443 \u0456\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0456?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: "\u0422\u043E\u0431\u0456 \u043F\u043E\u0434\u043E\u0431\u0430\u0454\u0442\u044C\u0441\u044F
      \u0445\u043E\u0434\u0438\u0442\u0438 \u0434\u043E \u0448\u043A\u043E\u043B\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: "\u0412\u0438 \u043F\u0435\u0440\u0435\u0432\u0456\u0440\u044F\u043B\u0438
      \u0432\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0456 \u0417\u0430\u043B\u0438
      \u0421\u0442\u043E\u043B\u0456\u0442\u0442\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: "\u041F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E! \u041E\u0441\u044C
      \u0432\u0430\u0448 \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: "\u0412\u0438\u043A\u043E\u043D\u0430\u0439\u0442\u0435 \u0437\u0430\u0432\u0434\u0430\u043D\u043D\u044F,
      \u0441\u043F\u043E\u0447\u0430\u0442\u043A\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: "\u041F\u0440\u0438\u0445\u043E\u0434\u044C\u0442\u0435 \u0441\u044E\u0434\u0438
      \u0432\u0432\u0435\u0447\u0435\u0440\u0456, \u0449\u043E\u0431 \u043F\u043E\u0434\u0438\u0432\u0438\u0442\u0438\u0441\u044F
      \u043D\u0430 \u0432\u0438\u0441\u0442\u0430\u0432\u0443!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: "\u041F\u043E\u0432\u0435\u0440\u0442\u0430\u0439\u0441\u044F, \u043A\u043E\u043B\u0438
      \u0431\u0443\u0434\u0435\u0448 \u0433\u043E\u0442\u043E\u0432\u0438\u0439/\u0433\u043E\u0442\u043E\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: "\u0410\u043B\u0435 \u043D\u0430\u0448 \u0440\u0430\u0434\u043D\u0438\u043A-\u0433\u043D\u043E\u043C
