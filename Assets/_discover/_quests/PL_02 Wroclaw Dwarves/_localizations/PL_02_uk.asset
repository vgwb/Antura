      \u0421\u0442\u043E\u043B\u0456\u0442\u0442\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: "\u0426\u0435 \u0421\u0442\u0430\u0440\u0430 \u0440\u0430\u0442\u0443\u0448\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: "\u041F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E. \u041E\u0441\u044C
      \u0432\u0430\u0448 \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: "\u0412\u043E\u043D\u0438 \u0447\u0438\u0442\u0430\u044E\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: "\u0414\u0430\u0432\u043D\u0438\u043C-\u0434\u0430\u0432\u043D\u043E
      \u044F \u0437\u0440\u043E\u0431\u0438\u0432 \u0433\u043D\u043E\u043C\u044C\u0457
      \u0442\u0443\u043D\u0435\u043B\u0456 \u0432 \u043C\u0456\u0441\u0442\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "\u0413\u043D\u043E\u043C-\u041A\u043B\u044E\u0447\u0430\u0440 \u0442\u0435\u043F\u0435\u0440
      \u0443 \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: "\u0429\u043E \u043B\u044E\u0434\u0438 \u0440\u043E\u0431\u043B\u044F\u0442\u044C
      \u0443 \u0441\u043E\u0431\u043E\u0440\u0456?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: "\u0406\u043D\u0448\u0456 \u0433\u043D\u043E\u043C\u0438 \u043F\u043E\u043A\u0430\u0437\u0443\u044E\u0442\u044C
      \u0442\u043E\u0431\u0456, \u0434\u0435 \u0448\u0443\u043A\u0430\u0442\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043E\u0441\u0442\u0430\u043D\u043D\u0456\u0439
      \u043A\u043B\u044E\u0447 \u0431\u0456\u043B\u044F \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u0438
      \u0437 \u043B\u0456\u0444\u0442\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "\u0426\u0435 \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u044C\u043A\u0438\u0439
      \u043A\u0430\u0444\u0435\u0434\u0440\u0430\u043B\u044C\u043D\u0438\u0439 \u0441\u043E\u0431\u043E\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447
      \u0432\u0456\u0434 \u0441\u043E\u0431\u043E\u0440\u0443 \u0442\u0430 \u0437\u0432\u0456\u043B\u044C\u043D\u0456\u0442\u044C
      \u0433\u043D\u043E\u043C\u0430-\u0454\u043F\u0438\u0441\u043A\u043E\u043F\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "\u0413\u043D\u043E\u043C-\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C
      \u0442\u0432\u0430\u0440\u0438\u043D \u0442\u0435\u043F\u0435\u0440 \u0443
      \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: "\u0426\u0435\u0439 \u0433\u043D\u043E\u043C \u043B\u044E\u0431\u0438\u0442\u044C
      \u0431\u0440\u0438\u0437\u043A\u0438, \u0431\u043B\u0438\u0441\u043A\u0456\u0442\u043A\u0438
      \u0442\u0430 \u043F\u0456\u0441\u043D\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: "\u0423 \u043D\u0438\u0445 \u043A\u0440\u0438\u0445\u0456\u0442\u043D\u0456
      \u043A\u0430\u043F\u0435\u043B\u044E\u0448\u043A\u0438 \u0442\u0430 \u043A\u0440\u0438\u0445\u0456\u0442\u043D\u0456
      \u0447\u043E\u0431\u0456\u0442\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: "\u0412\u043E\u043D\u043E \u0446\u0432\u0456\u0440\u0456\u043D\u044C\u043A\u0430\u0454,
      \u043D\u044E\u0445\u0430\u0454 \u0442\u0430 \u043C\u0430\u0445\u0430\u0454
      \u0440\u0443\u043A\u043E\u044E \u043E\u0434\u043D\u043E\u0447\u0430\u0441\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: "\u041F\u0430\u043D\u043E\u0440\u0430\u043C\u0430 \u0420\u0430\u0446\u043B\u0430\u0432\u0438\u0446\u044C\u043A\u0430
