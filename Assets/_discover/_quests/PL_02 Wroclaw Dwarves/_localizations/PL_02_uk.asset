      \u043F\u0430\u043D\u043E\u0440\u0430\u043C\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "\u0427\u0443\u0434\u043E\u0432\u0430 \u0440\u043E\u0431\u043E\u0442\u0430.
      \u0412\u0438 \u0434\u043E\u0441\u043B\u0456\u0434\u0438\u043B\u0438 \u0412\u0440\u043E\u0446\u043B\u0430\u0432
      \u0456 \u0437\u0432\u0456\u043B\u044C\u043D\u0438\u043B\u0438 \u0432\u0441\u0456\u0445
      \u0433\u043D\u043E\u043C\u0456\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: "\u0412\u043E\u043D\u043E \u0433\u043E\u0440\u0434\u043E \u043F\u043E\u0441\u0442\u0443\u043A\u0443\u0454
      \u043F\u043E\u0432\u0456\u0442\u0440\u044F\u043C, \u043D\u0456\u0431\u0438
      \u043C\u0430\u043B\u044E\u0454 \u043D\u043E\u0432\u0438\u0439 \u0434\u0430\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: "\u0428\u043A\u043E\u043B\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: "\u041A\u043B\u044E\u0447 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u043F\u0456\u0434 \u043A\u0432\u0456\u0442\u043A\u043E\u0432\u0438\u043C \u0433\u043E\u0440\u0449\u0438\u043A\u043E\u043C
      \u043D\u0430 \u0440\u0438\u043D\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: "\u0411\u0430\u0433\u0430\u0442\u043E \u043B\u044E\u0434\u0435\u0439
      \u0432\u0456\u0434\u0432\u0456\u0434\u0443\u044E\u0442\u044C \u0412\u0440\u043E\u0446\u043B\u0430\u0432,
      \u0449\u043E\u0431 \u0437\u043D\u0430\u0439\u0442\u0438 \u0441\u0442\u0430\u0442\u0443\u0457
      \u043A\u0430\u0440\u043B\u0438\u043A\u0456\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: "\u0426\u0435\u0439 \u0444\u043E\u043D\u0442\u0430\u043D \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0454
      \u0432\u043E\u0434\u0443, \u0441\u0432\u0456\u0442\u043B\u043E \u0442\u0430
      \u043C\u0443\u0437\u0438\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: "\u0412\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0439\u0442\u0435
      \u0439\u043E\u0433\u043E, \u0449\u043E\u0431 \u0434\u0456\u0441\u0442\u0430\u0442\u0438\u0441\u044F
      \u0434\u043E \u0446\u0435\u043D\u0442\u0440\u0443 \u043C\u0456\u0441\u0442\u0430
      \u0430\u0431\u043E \u0417\u0430\u043B\u0438 \u0441\u0442\u043E\u0440\u0456\u0447\u0447\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: "\u041C\u0438 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u044F
