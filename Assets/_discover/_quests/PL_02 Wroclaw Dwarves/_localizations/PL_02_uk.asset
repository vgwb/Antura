MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_uk
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: uk
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "\u0412\u043E\u043D\u043E \u043A\u0440\u0443\u0442\u0438\u0442\u044C\u0441\u044F,
      \u044F\u043A \u043F\u0435\u043D\u0437\u0435\u043B\u044C, \u0440\u043E\u0431\u043B\u044F\u0447\u0438
      \u043E\u0441\u0442\u0430\u043D\u043D\u0456\u0439 \u0449\u0430\u0441\u043B\u0438\u0432\u0438\u0439
      \u0432\u0438\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "\u041D\u0430 \u0432\u0456\u0437\u0435\u0440\u0443\u043D\u043A\u0443
      \u0444\u043E\u043D\u0442\u0430\u043D\u0443 \u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u043E
      \u043A\u043B\u044E\u0447 \u0431\u0456\u043B\u044F \u0441\u0446\u0435\u043D\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: "\u0425\u0442\u043E \u0442\u0430\u043A\u0430 \u041E\u043B\u044C\u0433\u0430
      \u0422\u043E\u043A\u0430\u0440\u0447\u0443\u043A?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "\u0417\u0430\u043B \u0421\u0442\u043E\u043B\u0456\u0442\u0442\u044F
      \u0432\u0456\u0434\u043E\u043C\u0438\u0439 \u0441\u0432\u043E\u0457\u043C \u0432\u0435\u043B\u0438\u043A\u0438\u043C
      \u043A\u0440\u0443\u0433\u043B\u0438\u043C \u0434\u0430\u0445\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "\u0412\u0438 \u0432\u0438\u043A\u043E\u043D\u0430\u043B\u0438 \u0437\u0430\u0432\u0434\u0430\u043D\u043D\u044F
      \"\u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u044C\u043A\u0456 \u0433\u043D\u043E\u043C\u0438\"."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: "\u041D\u0456\u0447\u043E\u0433\u043E"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "\u041F\u043B\u043E\u0449\u0430 \u2014 \u0446\u0435 \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u0438\u0439
      \u043F\u0440\u043E\u0441\u0442\u0456\u0440, \u0434\u0435 \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0430\u044E\u0442\u044C\u0441\u044F
      \u043B\u044E\u0434\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "\u041D\u0430\u043C\u0430\u043B\u044E\u0439 \u0441\u0432\u043E\u0433\u043E
      \u0443\u043B\u044E\u0431\u043B\u0435\u043D\u043E\u0433\u043E \u0432\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u044C\u043A\u043E\u0433\u043E
      \u0433\u043D\u043E\u043C\u0430 \u0442\u0430 \u043C\u0456\u0441\u0446\u0435,
      \u0434\u0435 \u0442\u0438 \u0439\u043E\u0433\u043E \u0437\u043D\u0430\u0439\u0448\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "\u0422\u0440\u0430\u043C\u0432\u0430\u0439 \u0433\u043E\u0442\u043E\u0432\u0438\u0439.
      \u0421\u043F\u043E\u0447\u0430\u0442\u043A\u0443 \u0457\u0434\u044C\u0442\u0435
      \u0434\u043E \u0441\u043E\u0431\u043E\u0440\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "\u0421\u0456\u043C'\u0457 \u043B\u044E\u0431\u043B\u044F\u0442\u044C
      \u0434\u0438\u0432\u0438\u0442\u0438\u0441\u044F \u0448\u043E\u0443 \u0444\u043E\u043D\u0442\u0430\u043D\u0456\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: "\u041F\u0430\u043D\u043E\u0440\u0430\u043C\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: "\u0421\u043A\u0430\u0439 \u0422\u0430\u0443\u0435\u0440"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: "\u042F\u043A \u044F \u043C\u043E\u0436\u0443 \u0434\u043E\u043F\u043E\u043C\u043E\u0433\u0442\u0438?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: "\u041B\u044E\u0434\u0438 \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442\u044C
      \u0441\u044E\u0434\u0438 \u043C\u043E\u043B\u0438\u0442\u0438\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "\u0416\u0438\u0432\u0438\u0439 \u043B\u0438\u0441\u0442 \u0432\u043A\u0430\u0437\u0443\u0454
      \u043D\u0430 \u043A\u043B\u044E\u0447 \u0431\u0456\u043B\u044F \u0434\u0432\u0435\u0440\u0435\u0439
      \u0441\u043E\u0431\u043E\u0440\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "\u0426\u0435 \u0433\u0456\u0433\u0430\u043D\u0442\u0441\u044C\u043A\u0430
      \u043A\u0430\u0440\u0442\u0438\u043D\u0430 \u043D\u0430\u0432\u043A\u043E\u043B\u043E
      \u0442\u0435\u0431\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "\u0420\u0438\u043D\u043A\u043E\u0432\u0430 \u043F\u043B\u043E\u0449\u0430
      \u2013 \u043E\u0434\u043D\u0435 \u0437 \u043D\u0430\u0439\u0436\u0432\u0430\u0432\u0456\u0448\u0438\u0445
      \u043C\u0456\u0441\u0446\u044C \u0443 \u043C\u0456\u0441\u0442\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "\u0413\u043D\u043E\u043C-\u041F\u0440\u043E\u0432\u0456\u0434\u043D\u0438\u043A
      \u0442\u0435\u043F\u0435\u0440 \u0443 \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "\u0421\u043A\u0430\u0439-\u0442\u0430\u0443\u0435\u0440 \u043B\u0435\u0433\u043A\u043E
      \u043F\u043E\u0431\u0430\u0447\u0438\u0442\u0438 \u0437 \u0431\u0430\u0433\u0430\u0442\u044C\u043E\u0445
      \u0447\u0430\u0441\u0442\u0438\u043D \u043C\u0456\u0441\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: "\u0426\u0435\u0439 \u043A\u0430\u0440\u043B\u0438\u043A \u043B\u044E\u0431\u0438\u0442\u044C
      \u0436\u0432\u0430\u0432\u0456 \u043C\u0456\u0441\u0446\u044F \u0442\u0430
      \u043D\u043E\u0432\u0456 \u0441\u0442\u0435\u0436\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: "\u0414\u0435 \u043A\u043B\u044E\u0447?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "\u041F\u043E\u0447\u0430\u0442\u043A\u043E\u0432\u0438\u0439 \u0413\u043D\u043E\u043C
      \u0442\u0435\u043F\u0435\u0440 \u0443 \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "\u0410 \u0442\u0435\u043F\u0435\u0440 \u0456\u0434\u0438 \u0442\u0430
      \u0432\u0456\u0434\u043C\u0438\u043A\u0430\u0439 \u0433\u043D\u043E\u043C\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u0428\u043A\u0456\u043B\u044C\u043D\u043E\u0433\u043E
      \u0413\u043D\u043E\u043C\u0430 \u0442\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "\u0423 \u043C\u0456\u0441\u0442\u0456 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430...
      \u0434\u0430\u0432\u0430\u0439\u0442\u0435 \u0434\u043E\u0441\u043B\u0456\u0434\u0436\u0443\u0432\u0430\u0442\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447
      \u0432\u0456\u0434 \u0440\u0430\u0442\u0443\u0448\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "\u0414\u0430\u0439\u0442\u0435 \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0434\u044C
      \u043D\u0430 \u0446\u0435 \u0437\u0430\u043F\u0438\u0442\u0430\u043D\u043D\u044F,
      \u0449\u043E\u0431 \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u0438 \u043A\u043B\u0456\u0442\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: "\u041F\u043E\u0434\u0438\u0432\u0456\u0442\u044C\u0441\u044F \u043D\u0430
      \u0437\u0456\u0440\u043A\u0443 \u043D\u0430 \u043A\u0430\u0440\u0442\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "\u041A\u043B\u044E\u0447 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0431\u0456\u043B\u044F \u043B\u0456\u0444\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: "\u0412\u043E\u043D\u0438 \u0433\u0440\u0430\u044E\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "\u041C\u0456\u0441\u0442\u043E \u0437\u0432\u0456\u0434\u0441\u0438
      \u0432\u0438\u0433\u043B\u044F\u0434\u0430\u0454 \u0447\u0443\u0434\u043E\u0432\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "\u0421\u043A\u043E\u0440\u0438\u0441\u0442\u0430\u0439\u0442\u0435\u0441\u044F
      \u0442\u0440\u0430\u043C\u0432\u0430\u0454\u043C, \u0449\u043E\u0431 \u0432\u0438\u0431\u0440\u0430\u0442\u0438
      \u043D\u0430\u0441\u0442\u0443\u043F\u043D\u0443 \u0437\u0443\u043F\u0438\u043D\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "\u0417\u0430\u0445\u043E\u0432\u0430\u043D\u0438\u0439 \u043A\u043B\u044E\u0447
      \u0432\u0456\u0434 \u0440\u0430\u0442\u0443\u0448\u0456 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0437\u0430 \u0432\u0438\u0432\u0456\u0441\u043A\u043E\u044E."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: "\u0412\u043E\u043D\u0438 \u043C\u043E\u043B\u044F\u0442\u044C\u0441\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447.
      \u041F\u043E\u0442\u0456\u043C \u0441\u043A\u043E\u043F\u0456\u044E\u0439\u0442\u0435
      \u0432\u0456\u0437\u0435\u0440\u0443\u043D\u043E\u043A \u0444\u043E\u043D\u0442\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: "\u0426\u0435 \u0433\u043D\u043E\u043C-\u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0435\u0446\u044C
      \u0437 \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
      \u0445\u0430\u0431\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "\u041D\u0430\u0448\u0430 \u0420\u0438\u043D\u043A\u043E\u0432\u0430
      \u043F\u043B\u043E\u0449\u0430 \u2014 \u0446\u0435 \u0436\u0432\u0430\u0432\u0435
      \u043C\u0456\u0441\u0446\u0435 \u0434\u043B\u044F \u043F\u0440\u043E\u0433\u0443\u043B\u044F\u043D\u043E\u043A
      \u0442\u0430 \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0435\u0439 \u0437
      \u0434\u0440\u0443\u0437\u044F\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "\u041E\u043B\u044C\u0433\u0430 \u0422\u043E\u043A\u0430\u0440\u0447\u0443\u043A
      \u2013 \u0432\u0456\u0434\u043E\u043C\u0430 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u0438\u0446\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: "\u0426\u0435\u0439 \u043A\u0430\u0440\u043B\u0438\u043A \u043B\u044E\u0431\u0438\u0442\u044C
      \u043B\u0430\u043F\u0438, \u043A\u0440\u0438\u043B\u0430 \u0442\u0430 \u0432\u0443\u0441\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "\u0422\u0435\u043F\u0435\u0440 \u0432\u0438 \u0437\u043D\u0430\u0454\u0442\u0435,
      \u044F\u043A \u0437\u0432\u0456\u043B\u044C\u043D\u0438\u0442\u0438 \u0433\u043D\u043E\u043C\u0456\u0432.
      \u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C 10 \u0437\u0430\u0440\u0430\u0437!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "\u042F\u043A \u044F \u043C\u043E\u0436\u0443 \u0437\u0432\u0456\u043B\u044C\u043D\u0438\u0442\u0438
      \u0433\u043D\u043E\u043C\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "\u0422\u0443\u0442 \u043F\u0440\u0430\u0446\u044E\u044E\u0442\u044C
      \u0442\u0430 \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0430\u044E\u0442\u044C\u0441\u044F
      \u043A\u0435\u0440\u0456\u0432\u043D\u0438\u043A\u0438 \u043C\u0456\u0441\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u0437\u0430\u0445\u043E\u0432\u0430\u043D\u0438\u0439
      \u043A\u043B\u044E\u0447 \u043D\u0430 \u0440\u0438\u043D\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: "\u0412\u043E\u043D\u0438 \u043B\u043E\u0432\u043B\u044F\u0442\u044C
      \u0440\u0438\u0431\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "\u042F\u043A\u0438\u0439 \u0432\u0456\u0434\u043E\u043C\u0438\u0439
      \u0441\u0438\u043C\u0432\u043E\u043B \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0430?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "\u041C\u0430\u043F\u0430 \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0430
      \u0442\u0435\u043F\u0435\u0440 \u0432\u0430\u0448\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "\u041F\u0430\u043D\u043E\u0440\u0430\u043C\u0430 \u0432\u0438\u0433\u043B\u044F\u0434\u0430\u0454
      \u044F\u043A \u043A\u0430\u0440\u0442\u0438\u043D\u0430 \u043D\u0430\u0432\u043A\u043E\u043B\u043E
      \u043C\u0435\u043D\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447.
      \u041F\u043E\u0442\u0456\u043C \u0432\u0456\u0434\u043A\u0440\u0438\u0439\u0442\u0435
      \u043A\u043B\u0456\u0442\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: "\u0414\u0435 \u0436 \u0433\u043D\u043E\u043C?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "\u0426\u0435\u0439 \u0433\u043D\u043E\u043C \u043B\u044E\u0431\u0438\u0442\u044C
      \u043F\u043B\u0430\u043D\u0438, \u043F\u0430\u043F\u0435\u0440\u0438 \u0442\u0430
      \u0432\u0430\u0436\u043B\u0438\u0432\u0456 \u0437\u0443\u0441\u0442\u0440\u0456\u0447\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: "\u041C\u0438 \u043F\u0438\u0448\u0430\u0454\u043C\u043E\u0441\u044F
      \u0417\u0430\u043B\u043E\u043C \u0421\u0442\u043E\u043B\u0456\u0442\u0442\u044F
      \u0442\u0430 \u0439\u043E\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u043C
      \u043A\u0440\u0443\u0433\u043B\u0438\u043C \u0434\u0430\u0445\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "\u0412\u0440\u043E\u0446\u043B\u0430\u0432 \u0441\u043B\u0430\u0432\u0438\u0442\u044C\u0441\u044F
      \u0441\u0432\u043E\u0457\u043C\u0438 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u043C\u0438
      \u0433\u043D\u043E\u043C\u0438\u043A\u0430\u043C\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: "\u0417\u0430\u0433\u043B\u044F\u043D\u044C\u0442\u0435 \u0432 \u0437\u043E\u043E\u043F\u0430\u0440\u043A,
      \u0437\u0430\u043B\u0443 \u0442\u0430 \u0444\u043E\u043D\u0442\u0430\u043D."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: "\u041B\u0430\u0441\u043A\u0430\u0432\u043E \u043F\u0440\u043E\u0441\u0438\u043C\u043E
      \u0434\u043E \u0421\u043A\u0430\u0439 \u0422\u0430\u0443\u0435\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "\u0412\u043E\u043D\u043E \u043F\u043E\u043F\u0440\u0430\u0432\u043B\u044F\u0454
      \u0441\u0432\u0456\u0439 \u043A\u0440\u0438\u0445\u0456\u0442\u043D\u0438\u0439
      \u043A\u0430\u043F\u0435\u043B\u044E\u0448\u043E\u043A, \u043D\u0435\u043C\u043E\u0432
      \u0434\u0443\u0436\u0435 \u0437\u0430\u0439\u043D\u044F\u0442\u0438\u0439 \u043C\u0435\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: "\u0426\u0435\u0439 \u0433\u043D\u043E\u043C \u043B\u044E\u0431\u0438\u0442\u044C
      \u043A\u043E\u043B\u044C\u043E\u0440\u0438, \u0444\u0430\u0440\u0431\u0438
      \u0442\u0430 \u0432\u0435\u043B\u0438\u043A\u0456 \u043A\u0430\u0440\u0442\u0438\u043D\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "\u0421\u043A\u0430\u0439 \u0422\u0430\u0443\u0435\u0440 \u2014
      \u043E\u0434\u043D\u0430 \u0437 \u043D\u0430\u0439\u0432\u0438\u0449\u0438\u0445
      \u0431\u0443\u0434\u0456\u0432\u0435\u043B\u044C \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: "\u041F\u0430\u043D\u043E\u0440\u0430\u043C\u0430 \u2014 \u0446\u0435
      \u0433\u0456\u0433\u0430\u043D\u0442\u0441\u044C\u043A\u0430 \u043A\u0430\u0440\u0442\u0438\u043D\u0430
      \u043D\u0430\u0432\u043A\u043E\u043B\u043E \u0432\u0430\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "\u0412\u0438 \u0445\u043E\u0447\u0435\u0442\u0435 \u0432\u0456\u0434\u043F\u043E\u0432\u0456\u0441\u0442\u0438
      \u043D\u0430 \u0434\u0435\u044F\u043A\u0456 \u0437\u0430\u043F\u0438\u0442\u0430\u043D\u043D\u044F?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: "\u041A\u0430\u0444\u0435\u0434\u0440\u0430\u043B\u044C\u043D\u0438\u0439
      \u0441\u043E\u0431\u043E\u0440 \u0454 \u043E\u0434\u043D\u0438\u043C \u0437
      \u043D\u0430\u0439\u0432\u0456\u0434\u043E\u043C\u0456\u0448\u0438\u0445 \u043C\u0456\u0441\u0446\u044C
      \u0443 \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447,
      \u0430 \u043F\u043E\u0442\u0456\u043C \u0437'\u0454\u0434\u043D\u0430\u0439\u0442\u0435
      \u0447\u0430\u0441\u0442\u0438\u043D\u0438 \u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u043D\u044F,
      \u0449\u043E\u0431 \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u0438 \u043A\u043B\u0456\u0442\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "\u0413\u043D\u043E\u043C-\u0454\u043F\u0438\u0441\u043A\u043E\u043F
      \u0437\u0430\u043C\u043A\u043D\u0435\u043D\u0438\u0439 \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0456\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "\u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u044C\u043A\u0438\u0439
      \u0437\u043E\u043E\u043F\u0430\u0440\u043A \u2014 \u043D\u0430\u0439\u0431\u0456\u043B\u044C\u0448\u0438\u0439
      \u0437\u043E\u043E\u043F\u0430\u0440\u043A \u0443 \u041F\u043E\u043B\u044C\u0449\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447
      \u0432\u0456\u0434 \u043F\u043B\u043E\u0449\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: "\u0429\u043E \u043B\u044E\u0434\u0438 \u0440\u043E\u0431\u043B\u044F\u0442\u044C
      \u0443 \u0441\u043E\u0431\u043E\u0440\u0456?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: "\u041C\u0443\u043B\u044C\u0442\u0438\u043C\u0435\u0434\u0456\u0439\u043D\u0438\u0439
      \u0444\u043E\u043D\u0442\u0430\u043D \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0442\u043E\u0432\u0443\u0454
      \u0432\u043E\u0434\u0443, \u0441\u0432\u0456\u0442\u043B\u043E \u0442\u0430
      \u043C\u0443\u0437\u0438\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "\u0413\u043D\u043E\u043C-\u043C\u0430\u043D\u0434\u0440\u0456\u0432\u043D\u0438\u043A
      \u0442\u0435\u043F\u0435\u0440 \u0443 \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: "\u0412\u043E\u043D\u043E \u0440\u043E\u0437\u043C\u0430\u0445\u0443\u0454
      \u0441\u0432\u043E\u0454\u044E \u043A\u0440\u0438\u0445\u0456\u0442\u043D\u043E\u044E
      \u043F\u0430\u043B\u0438\u0446\u0435\u044E \u0442\u0430 \u043A\u043B\u0430\u043D\u044F\u0454\u0442\u044C\u0441\u044F
      \u0444\u043E\u043D\u0442\u0430\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: "\u0412\u0456\u043D \u043C\u0430\u0454 \u0432\u0438\u0441\u043E\u043A\u0456
      \u0432\u0435\u0436\u0456 \u0442\u0430 \u044F\u0441\u043A\u0440\u0430\u0432\u0456
      \u0432\u0456\u043A\u043D\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: "\u0414\u0435\u044F\u043A\u0456 \u0432\u0440\u043E\u0446\u043B\u0430\u0432\u0441\u044C\u043A\u0456
      \u0433\u043D\u043E\u043C\u0438 \u0432\u0438\u0433\u043B\u044F\u0434\u0430\u044E\u0442\u044C
      \u043A\u0443\u043C\u0435\u0434\u043D\u043E, \u0430 \u0434\u0435\u044F\u043A\u0456
      \u2014 \u0441\u0435\u0440\u0439\u043E\u0437\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: "\u0412\u043E\u043D\u043E \u043F\u043E\u0445\u0438\u0442\u0430\u0454
      \u0441\u0432\u043E\u0457\u043C\u0438 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u043C\u0438
      \u0447\u043E\u0431\u0456\u0442\u043A\u0430\u043C\u0438 \u0442\u0430 \u0449\u0430\u0441\u043B\u0438\u0432\u043E
      \u0432\u043A\u043B\u043E\u043D\u044F\u0454\u0442\u044C\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "\u0421\u043F\u043E\u0447\u0430\u0442\u043A\u0443 \u0441\u0445\u043E\u0434\u0456\u0442\u044C
      \u0434\u043E \u0441\u043E\u0431\u043E\u0440\u0443. \u0412\u0430\u043C \u0434\u043E\u043F\u043E\u043C\u043E\u0436\u0443\u0442\u044C
      \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u0438 \u043A\u0430\u0440\u0442\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: "\u0426\u0435\u0439 \u0433\u043D\u043E\u043C \u043B\u044E\u0431\u0438\u0442\u044C
      \u0456\u0441\u0442\u043E\u0440\u0456\u0457, \u043A\u043D\u0438\u0433\u0438
      \u0442\u0430 \u0442\u0438\u0445\u0456 \u043C\u0456\u0441\u0446\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "\u041B\u0430\u0441\u043A\u0430\u0432\u043E \u043F\u0440\u043E\u0441\u0438\u043C\u043E
      \u0434\u043E \u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0430!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "\u041A\u043E\u0436\u043D\u0430 \u043A\u043B\u0456\u0442\u043A\u0430
      \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u0430 \u0437\u043E\u043B\u043E\u0442\u0438\u043C
      \u043A\u043B\u044E\u0447\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "\u0420\u0430\u0434\u043D\u0438\u043A-\u0433\u043D\u043E\u043C \u0442\u0435\u043F\u0435\u0440
      \u0443 \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "\u0426\u0435\u0439 \u0433\u043D\u043E\u043C \u043B\u044E\u0431\u0438\u0442\u044C
      \u0444\u043E\u0440\u043C\u0438, \u0431\u0443\u0434\u0456\u0432\u043B\u0456
      \u0442\u0430 \u0432\u0438\u0448\u0443\u043A\u0430\u043D\u0456 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0456\u0457."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: "\u041F\u0440\u0438\u0432\u0456\u0442! \u042F \u0432\u0447\u0438\u0442\u0435\u043B\u044C
      \u0437\u0456 \u0448\u043A\u043E\u043B\u0438 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: "\u0420\u043E\u0437\u0433\u0430\u0434\u0430\u0439\u0442\u0435 \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0443
      \u0432 \u0437\u0430\u043B\u0456, \u0449\u043E\u0431 \u0437\u043D\u0430\u0439\u0442\u0438
      \u0437\u0430\u0445\u043E\u0432\u0430\u043D\u0438\u0439 \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: "\u041F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u0438\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: "\u0410\u043D\u0442\u0443\u0440\u0430 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u043D\u0430 \u0432\u0435\u0440\u0448\u0438\u043D\u0456 \u0421\u043A\u0430\u0439
      \u0422\u0430\u0443\u0435\u0440!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447
      \u0432\u0456\u0434 \u0437\u043E\u043E\u043F\u0430\u0440\u043A\u0443. \u041F\u043E\u0442\u0456\u043C
      \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0456\u0442\u044C \u0456\u0437 \u0434\u043E\u0433\u043B\u044F\u0434\u0430\u0447\u0435\u043C
      \u0437\u043E\u043E\u043F\u0430\u0440\u043A\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "\u0420\u0430\u0434\u043D\u0438\u043A-\u0433\u043D\u043E\u043C \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0431\u0456\u043B\u044F \u0421\u0442\u0430\u0440\u043E\u0457 \u0440\u0430\u0442\u0443\u0448\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: "\u0412\u043E\u043D\u0438 \u043C\u043E\u043B\u044F\u0442\u044C\u0441\u044F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: "\u0411\u0430\u0433\u0430\u0442\u043E \u043B\u044E\u0434\u0435\u0439
      \u0443 \u200B\u200B\u0412\u0440\u043E\u0446\u043B\u0430\u0432\u0456 \u0437\u043D\u0430\u044E\u0442\u044C
      \u0441\u0432\u043E\u0433\u043E \u0443\u043B\u044E\u0431\u043B\u0435\u043D\u043E\u0433\u043E
      \u0433\u043D\u043E\u043C\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: "\u041F\u0435\u0440\u0435\u043C\u0456\u0441\u0442\u0456\u0442\u044C
      \u0440\u043E\u0441\u043B\u0438\u043D\u0443, \u0449\u043E\u0431 \u0437\u043D\u0430\u0439\u0442\u0438
      \u0457\u0457."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "\u0413\u043D\u043E\u043C-\u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0435\u0446\u044C
      \u0442\u0435\u043F\u0435\u0440 \u0443 \u0431\u0435\u0437\u043F\u0435\u0446\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: "\u041F\u0456\u043B\u043E\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "\u0417\u043D\u0430\u0439\u0434\u0456\u0442\u044C \u043A\u043B\u044E\u0447
      \u0434\u043E \u0440\u043E\u0437\u0433\u0430\u0434\u043A\u0438 \u0434\u043B\u044F
      \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u0438\u043A\u0430. \u041F\u043E\u0442\u0456\u043C
      \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0456\u0442\u044C \u0437 \u0447\u0438\u0442\u0430\u0447\u0435\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "\u041A\u043B\u044E\u0447 \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u043F\u0456\u0434 \u043B\u0430\u0432\u043A\u043E\u044E \u043D\u0430 \u043F\u043B\u043E\u0449\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
