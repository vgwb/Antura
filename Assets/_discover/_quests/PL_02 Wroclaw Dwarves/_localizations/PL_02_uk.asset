  - m_Id: 73346184641503352
    m_Localized: "\u0429\u0435 \u043E\u0434\u0438\u043D \u0433\u043D\u043E\u043C
      \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F \u0431\u0456\u043B\u044F
      \u0417\u0430\u043B\u0438 \u0421\u0442\u043E\u043B\u0456\u0442\u0442\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: "\u0420\u0430\u0439\u043E\u043D \u0417\u0430\u043B\u0438 \u0421\u0442\u043E\u043B\u0456\u0442\u0442\u044F
      \u0433\u043E\u0442\u043E\u0432\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "\u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0430 \u0437\u043E\u043D\u0430
      \u0433\u043E\u0442\u043E\u0432\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: "\u0422\u0435\u043F\u0435\u0440 \u0432\u043E\u043D\u0438 \u043F\u0435\u0440\u0435\u0442\u0432\u043E\u0440\u0438\u043B\u0438\u0441\u044F
      \u043D\u0430 \u0447\u0430\u0440\u0456\u0432\u043D\u0456 \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u043D\u0456
      \u0437\u0430\u0441\u043E\u0431\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "\u0420\u0430\u0434\u043D\u0438\u043A-\u0433\u043D\u043E\u043C \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0431\u0456\u043B\u044F \u0421\u0442\u0430\u0440\u043E\u0457 \u0440\u0430\u0442\u0443\u0448\u0456."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: "\u0414\u044F\u043A\u0443\u044E! \u0412\u0438 \u043C\u0435\u043D\u0435
      \u0432\u0440\u044F\u0442\u0443\u0432\u0430\u043B\u0438!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: "\u041B\u0456\u0444\u0442 \u0437\u0430\u0440\u0430\u0437 \u0432\u0456\u0434\u043A\u0440\u0438\u0442\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: "\u0424\u043E\u043D\u0442\u0430\u043D \u2014 \u0446\u0435 \u043E\u0441\u0442\u0430\u043D\u043D\u0454
      \u043C\u0456\u0441\u0446\u0435 \u0442\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: "\u041D\u0430 \u0433\u043E\u0442\u043E\u0432\u043E\u043C\u0443 \u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u043D\u0456
      \u043F\u0456\u0434 \u0440\u0430\u043C\u043A\u043E\u044E \u0432\u0438\u0434\u043D\u043E
      \u043A\u043B\u044E\u0447."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "\u041A\u043B\u0456\u0442\u043A\u0430 \u041A\u043B\u044E\u0447\u043D\u0438\u043A\u0430
      \u0437\u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F \u0431\u0456\u043B\u044F
      \u043B\u0456\u0444\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "\u0412\u043E\u043D\u043E \u0437\u0430\u043C\u043A\u043D\u0435\u043D\u0435.
      \u0417\u043D\u0430\u0439\u0434\u0438 \u0437\u043E\u043B\u043E\u0442\u0438\u0439
      \u043A\u043B\u044E\u0447\u0438\u043A!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: "\u041D\u0456"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: "\u041F\u0430\u043D\u043E\u0440\u0430\u043C\u0430 \u0420\u0430\u0446\u043B\u0430\u0432\u0438\u0446\u044C\u043A\u0430
      \u2013 \u043E\u0441\u0442\u0430\u043D\u043D\u0454 \u043C\u0456\u0441\u0446\u0435
      \u0442\u0443\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: "\u0429\u043E\u0431 \u0440\u043E\u0437\u0431\u043B\u043E\u043A\u0443\u0432\u0430\u0442\u0438
      \u043A\u043B\u0456\u0442\u043A\u0443, \u0440\u043E\u0437\u0433\u0430\u0434\u0430\u0439\u0442\u0435
      \u0446\u044E \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0443"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: "\u0417\u0430\u043B\u0438\u0448\u0430\u0439\u0442\u0435\u0441\u044F
      \u0442\u0443\u0442"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: "\u0417\u0432\u0435\u0440\u0442\u0430\u0439\u0441\u044F \u0434\u043E
      \u043C\u0435\u043D\u0435, \u044F\u043A\u0449\u043E \u0442\u043E\u0431\u0456
