%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_hu
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: hu
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "\xDAgy p\xF6r\xF6g, mint egy ecset, ami egy utols\xF3 boldog \xF6rv\xE9nyt
      csap."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "A sz\xF6k\u0151k\xFAt mint\xE1zata egy kulcsot mutat a sz\xEDnpad
      k\xF6zel\xE9ben."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: Ki az az Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "A Centennial Hall nagy, kerek tetej\xE9r\u0151l ismert."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "Befejezted a Wroc\u0142awi t\xF6rp\xF6k k\xFCldet\xE9st."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Semmi
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "A pl\xE1za egy nyitott t\xE9r, ahol az emberek tal\xE1lkoznak."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "Rajzold le a kedvenc wroc\u0142awi t\xF6rp\xE9det \xE9s a helyet,
      ahol tal\xE1ltad."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "A villamos k\xE9szen \xE1ll. El\u0151sz\xF6r menj a katedr\xE1lishoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "A csal\xE1dok szeretnek sz\xF6k\u0151k\xFAt-show-t n\xE9zni."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: "Panor\xE1ma"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: "\xC9gi torony"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: "Hogyan seg\xEDthetek?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: "Az emberek im\xE1dkozni j\xF6nnek ide."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "Egy \xE9l\u0151 lev\xE9l a katedr\xE1lis ajtaja melletti kulcsra
      mutat."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "Egy hatalmas k\xE9p vesz k\xF6r\xFCl t\xE9ged."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "A Piact\xE9r a v\xE1ros egyik legforgalmasabb helye."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "A Karmester T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "A Sky Tower a v\xE1ros sz\xE1mos r\xE9sz\xE9r\u0151l k\xF6nnyen
      l\xE1that\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: "Ez a t\xF6rpe im\xE1dja a forgalmas helyeket \xE9s az \xFAj \xF6sv\xE9nyeket."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: Hol van a kulcs?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "Az Eredeti T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "Most menj \xE9s oldd fel a t\xF6rp\xE9t!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: "Az Iskolai T\xF6rp\xE9t itt tal\xE1lod."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "Van egy kis probl\xE9ma a v\xE1rosban... fedezz\xFCk fel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "Keresd meg a V\xE1rosh\xE1za kulcs\xE1t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "V\xE1laszolj erre a k\xE9rd\xE9sre a ketrec kinyit\xE1s\xE1hoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: "N\xE9zd meg a csillagot a t\xE9rk\xE9pen."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "A kulcs a lift k\xF6zel\xE9ben van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: "J\xE1tszanak"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "A v\xE1ros gy\xF6ny\xF6r\u0171nek t\u0171nik innen fentr\u0151l."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "Haszn\xE1ld a villamost a k\xF6vetkez\u0151 meg\xE1ll\xF3 kiv\xE1laszt\xE1s\xE1hoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "A rejtett V\xE1rosh\xE1za kulcs a t\xE1bla m\xF6g\xF6tt tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: "Im\xE1dkoznak"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "Keresd meg a kulcsot. Ezut\xE1n m\xE1sold le a sz\xF6k\u0151k\xFAt
      mint\xE1j\xE1t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: "Ez a Fest\u0151t\xF6rpe a Center hubb\xF3l."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "A Piacter\xFCnk egy \xE9l\xE9nk hely a s\xE9t\xE1l\xE1shoz \xE9s
      a bar\xE1tokkal val\xF3 tal\xE1lkoz\xE1shoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "Olga Tokarczuk h\xEDres \xEDr\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: "Ez a t\xF6rpe im\xE1dja a mancsokat, sz\xE1rnyakat \xE9s bajuszokat."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "Most m\xE1r tudod, hogyan szabad\xEDtsd ki a t\xF6rp\xE9ket. Tal\xE1lj
      10-et most!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "Hogyan szabad\xEDthatn\xE1m ki a t\xF6rp\xE9t?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "A v\xE1ros vezet\u0151i itt dolgoznak \xE9s itt tal\xE1lkoznak."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "Tal\xE1ld meg az elrejtett kulcsot a piacon."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: "Hal\xE1sznak"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "Mi Wroc\u0142aw h\xEDres jelk\xE9pe?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "Wroc\u0142aw t\xE9rk\xE9pe most m\xE1r a ti\xE9d."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "A panor\xE1ma \xFAgy n\xE9z ki, mint egy k\xE9p k\xF6r\xFCl\xF6ttem."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "Keresd meg a kulcsot. Azt\xE1n nyisd ki a ketrecet."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: "Hol van a t\xF6rpe?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "Ez a t\xF6rpe im\xE1dja a terveket, a pap\xEDrokat \xE9s a fontos
      megbesz\xE9l\xE9seket."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: "B\xFCszk\xE9k vagyunk a Centennial Hallra \xE9s annak nagy, kerek
      tetej\xE9re."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Wroc\u0142aw h\xEDres a kis t\xF6rp\xE9ir\u0151l."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: "N\xE9zz be az \xE1llatkertbe, a csarnokba \xE9s a sz\xF6k\u0151k\xFAtba."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk a Sky Towerben."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "\xDAgy igazgatja apr\xF3 kalapj\xE1t, mint egy nagyon elfoglalt
      polg\xE1rmester."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: "Ez a t\xF6rpe im\xE1dja a sz\xEDneket, a fest\xE9ket \xE9s a nagy
      k\xE9peket."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "A Sky Tower Wroc\u0142aw egyik legmagasabb \xE9p\xFClete."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: "A panor\xE1ma egy hatalmas k\xE9p, ami minden\xFCtt k\xF6r\xFClvesz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "Szeretne v\xE1laszolni n\xE9h\xE1ny k\xE9rd\xE9sre?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: "A katedr\xE1lis Wroc\u0142aw egyik legh\xEDresebb helye."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: "Keresd meg a kulcsot, majd p\xE1ros\xEDtsd a k\xE9pdarabokat a
      ketrec kinyit\xE1s\xE1hoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "A P\xFCsp\xF6k T\xF6rpe a k\xF6zelben van bez\xE1rva."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "A wroc\u0142awi \xE1llatkert Lengyelorsz\xE1g legnagyobb \xE1llatkertje."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: "Keresd meg a t\xE9r kulcs\xE1t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: "Mit csin\xE1lnak az emberek egy katedr\xE1lisban?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: "A multim\xE9di\xE1s sz\xF6k\u0151k\xFAt vizet, f\xE9nyt \xE9s zen\xE9t
      haszn\xE1l."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "Az Utaz\xF3 T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: "Meglend\xEDti apr\xF3 botj\xE1t, \xE9s meghajol a sz\xF6k\u0151k\xFAt
      el\u0151tt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: "Magas tornyai \xE9s vil\xE1gos ablakai vannak."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: "N\xE9h\xE1ny wroc\u0142awi t\xF6rpe viccesen n\xE9z ki, m\xE1sok
      pedig komolynak."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: "Megr\xE1zza a kis csizm\xE1it, \xE9s boldogan meghajol."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "El\u0151sz\xF6r menj a katedr\xE1lishoz. Seg\xEDtenek majd elolvasni
      a t\xE9rk\xE9pet."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: "Ez a t\xF6rpe im\xE1dja a t\xF6rt\xE9neteket, a k\xF6nyveket \xE9s
      a csendes helyeket."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk Wroc\u0142awban!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Minden ketrecet aranykulccsal z\xE1rnak le."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "A Tan\xE1csos T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "Ez a t\xF6rpe im\xE1dja a form\xE1kat, az \xE9p\xFCleteket \xE9s
      az \xF6tletes terveket."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: "Sziasztok! A Leonardo Iskola tan\xE1ra vagyok."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: "Oldd meg a csarnok rejtv\xE9ny\xE9t, hogy megtal\xE1ld a rejtett
      kulcsot."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: "Egy \xEDr\xF3"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: "Antura a Sky Tower tetej\xE9n van!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "Keresd meg az \xE1llatkert kulcs\xE1t. Ezut\xE1n besz\xE9lj az
      \xE1llatkert gondoz\xF3j\xE1val."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "A Tan\xE1csos T\xF6rpe a R\xE9gi V\xE1rosh\xE1za k\xF6zel\xE9ben
      van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: "Im\xE1dkoznak"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: "Sok wroc\u0142awi ember ismeri kedvenc t\xF6rp\xE9j\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: "Mozgasd a n\xF6v\xE9nyt, hogy megtal\xE1ld."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "A Fest\u0151t\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: "Egy pil\xF3ta"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "Keresd meg az \xEDr\xF3i kulcsot. Azt\xE1n besz\xE9lj az olvas\xF3val."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "A kulcs egy pad alatt van a t\xE9ren."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: "Egy b\xE1lna"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: "Egy kis k\xF6rben forog, mintha k\xE9szen \xE1llna a k\xF6vetkez\u0151
      \xFAtra."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: "A t\xE1bla m\xF6g\xF6tt egy kulcs tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: "Szabad\xEDtsd meg mind a 10 t\xF6rpe bar\xE1tomat Wroc\u0142awban."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: "T\xEDz t\xF6rpe van bez\xE1rva var\xE1zsketrecekbe Wroc\u0142awban."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: "Gyere vissza, amikor k\xE9szen \xE1llsz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: "Egy t\xF6rpe"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: "Az \xCDr\xF3 T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: "Aut\xF3kkal versenyeznek"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: "Felmegy\xFCnk a Sky Tower tetej\xE9re."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: "Egy apr\xF3 k\xF6nyvet \xF6lel mag\xE1hoz, \xE9s r\xE1d mosolyog."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: "El\u0151sz\xF6r is teljes\xEDtsd a feladatot!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: "Az \xC9p\xEDt\xE9sz T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: "A Centennial Hall nagyon nagy, \xE9s h\xEDres kerek tet\u0151vel
      rendelkezik."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: "Egy \xF3ri\xE1s macska"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: "Egy rak\xE9ta"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Cseng, cs\xF6r\xF6g, csilingel. Kinyitom neked a liftet."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: "Itt tal\xE1lod a Fest\u0151 T\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: "N\xE9zd meg a Piacteret, a V\xE1rosh\xE1z\xE1t \xE9s a Rac\u0142awicka
      panor\xE1m\xE1t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "Remek munka. Felfedezted Wroc\u0142awot \xE9s kiszabad\xEDtottad
      az \xF6sszes t\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: "B\xFCszk\xE9n kopogtatja a leveg\u0151t, mintha \xFAj tet\u0151t
      h\xFAzna."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: Iskola
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: "Egy kulcs van egy vir\xE1gcser\xE9p alatt a piacon."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: "Sokan l\xE1togatnak Wroc\u0142awba t\xF6rpeszobrok ut\xE1n kutatva."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: "Ez a sz\xF6k\u0151k\xFAt vizet, f\xE9nyeket \xE9s zen\xE9t haszn\xE1l."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: "Haszn\xE1ld, hogy eljuss a v\xE1rosk\xF6zpontba vagy a Centennial
      Hallba."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: "A Bema meg\xE1ll\xF3n\xE1l vagyunk, a katedr\xE1lis k\xF6zel\xE9ben."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: "A kulcs az olvas\xF3sarok k\xF6zel\xE9ben van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk a Centennial Hallban!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: "Ez a r\xE9gi v\xE1rosh\xE1za."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: Rendben. Itt a kulcsod.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: Olvasnak
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: "R\xE9ges-r\xE9gen T\xF6rpe Alagutakat \xE9p\xEDtettem a v\xE1rosban."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "A Kulcsmester T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: "Mit csin\xE1lnak az emberek egy katedr\xE1lisban?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: "A t\xF6bbi t\xF6rpe megmutatja, merre kell keresned."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: "Keresd meg az utols\xF3 kulcsot a lift t\xE1bl\xE1ja k\xF6zel\xE9ben."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "Ez a wroc\u0142awi sz\xE9kesegyh\xE1z."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: "Tal\xE1ld meg a katedr\xE1lis kulcs\xE1t \xE9s szabad\xEDtsd ki
      a p\xFCsp\xF6k t\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "Az \xC1llatbar\xE1t T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: "Ez a t\xF6rpe im\xE1dja a fr\xF6ccsen\xE9st, a csillog\xE1st \xE9s
      az dalokat."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: "Apr\xF3 kalapjaik \xE9s apr\xF3 csizm\xE1ik vannak."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: "Egyszerre csipog, szippant \xE9s integet."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: "A Panorama Raclawicka a k\xF6zpont r\xE9sze."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: "Ez az egyik \xC9gi Torony t\xF6rpe."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: "A P\xFCsp\xF6k T\xF6rpe most m\xE1r biztons\xE1gban van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: Itt a kulcsod.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: "Minden \xC9gi Torony t\xF6rpe szabad."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: "Egy m\xE1sik t\xF6rpe a Centennial Hall k\xF6zel\xE9ben van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: "A Centennial Hall ter\xFClete elk\xE9sz\xFClt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "A k\xF6zponti ter\xFClet elk\xE9sz\xFClt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: "Mostanra var\xE1zslatos j\xE1rm\u0171vekk\xE9 v\xE1ltoztak."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "A Tan\xE1csos T\xF6rpe a R\xE9gi V\xE1rosh\xE1za k\xF6zel\xE9ben
      van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: "K\xF6sz\xF6n\xF6m! Megmentett\xE9l!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: A lift most nyitva van.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: "A sz\xF6k\u0151k\xFAt az utols\xF3 hely itt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: "A k\xE9sz k\xE9pen egy kulcs l\xE1that\xF3 a keret alatt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "A Keymaster ketrece a lift k\xF6zel\xE9ben van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "Z\xE1rva van. Keress egy aranykulcsot!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: Nem
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: "A Panorama Raclawicka az utols\xF3 hely itt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: "A ketrec kinyit\xE1s\xE1hoz oldd meg ezt a rejtv\xE9nyt"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: Maradj itt
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: "Sz\xF3lj, ha seg\xEDts\xE9gre van sz\xFCks\xE9ged."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: "Sz\xE9kesegyh\xE1z"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: "Centen\xE1riumi Csarnok"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: Piaccsarnok
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: "Az Utaz\xF3 T\xF6rpe a t\xE9ren van."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: "Nem. Pr\xF3b\xE1ld \xFAjra."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "Pr\xF3b\xE1ld meg k\xE9s\u0151bb!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: "Hov\xE1 akarsz menni?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: Igen
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: "Igen, ez \xEDgy van."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
