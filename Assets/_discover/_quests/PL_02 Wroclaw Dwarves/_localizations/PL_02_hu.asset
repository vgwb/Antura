%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_hu
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: hu
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: Oldd fel a Kulcsmestert!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "Pr\xF3b\xE1ld meg k\xE9s\u0151bb!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "A ketrec kinyit\xE1s\xE1hoz oldd meg ezt a rejtv\xE9nyt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: "Ez a t\xE9r egy forgalmas hely a Sky Towerben."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "Ez a wroc\u0142awi sz\xE9kesegyh\xE1z."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: "Ez a r\xE9gi v\xE1rosh\xE1za."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: "Ez a sz\xF6k\u0151k\xFAt vizet, sz\xEDnes f\xE9nyeket \xE9s zen\xE9t
      haszn\xE1l!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "Ennek a t\xF6rp\xE9nek m\xE9g egy utols\xF3 kulcsra van sz\xFCks\xE9ge
      a szabadul\xE1shoz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: Olvasnak
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: Olvasnak
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: "Im\xE1dkoznak"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: "Im\xE1dkoznak"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: "J\xE1tszanak"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: "J\xE1tszanak"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: "Apr\xF3 kalapjaik \xE9s apr\xF3 csizm\xE1ik vannak!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "Van mit csin\xE1lni az \xE1llatkertben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "Van egy kis probl\xE9ma a v\xE1rosban... fedezz\xFCk fel!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "Van egy kulcs ott a t\xE1bla m\xF6g\xF6tt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "Van itt egy h\xEDres szobor, egy Salvador Dal\xED nev\u0171 m\u0171v\xE9szt\u0151l!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "T\xF6bb mint 800 t\xF6rpe \xE9l a v\xE1rosban!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "Az \xE1llatkertet r\xE9gen, 1865-ben \xE9p\xEDtett\xE9k!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: "Az \xCDr\xF3 T\xF6rpe m\xE9g mindig z\xE1rva van!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: "Az Utaz\xF3 T\xF6rpe a t\xE9ren van."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "A villamos k\xE9szen \xE1ll. El\u0151sz\xF6r is menj a katedr\xE1lishoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: "A panor\xE1ma egy \xF3ri\xE1si k\xE9pnek t\u0171nik k\xF6r\xFCl\xF6ttem!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "Az Eredeti T\xF6rpe a piacon van."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "A r\xE9gi v\xE1rosh\xE1za egy nagyon fontos r\xE9gi \xE9p\xFClet."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: "A multim\xE9di\xE1s sz\xF6k\u0151k\xFAt vizet, f\xE9nyt \xE9s zen\xE9t
      haszn\xE1l."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: "A Multim\xE9di\xE1s Sz\xF6k\u0151k\xFAtnak sz\xFCks\xE9ge van a
      seg\xEDts\xE9g\xFCnkre!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "A Kulcsmester csapd\xE1ba esett a lift k\xF6zel\xE9ben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "A kulcs egy pad alatt van a t\xE9ren."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "A kulcs az olvas\xF3sarok k\xF6zel\xE9ben van!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: "A rejtett V\xE1rosh\xE1za kulcs a t\xE1bla m\xF6g\xF6tt tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: "A sz\xF6k\u0151k\xFAt vize egy kulcsot rejt a sz\xEDnpad k\xF6zel\xE9ben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: "A sz\xF6k\u0151k\xFAt-show olyan, mint egy nagy koncert!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: "Az utols\xF3 fordul\xF3!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: A lift most nyitva van.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "A Tan\xE1csos T\xF6rpe a R\xE9gi V\xE1rosh\xE1za k\xF6zel\xE9ben
      van."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "Gy\xF6ny\xF6r\u0171en n\xE9z ki a v\xE1ros innen fentr\u0151l!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: "Ny\xEDlik a mellkas!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "A mellkas z\xE1rva van."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: "Elk\xE9sz\xFClt a k\xF6zponti r\xE9sz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: "A Centennial Hall k\xF6rny\xE9ke elk\xE9sz\xFClt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "A sz\xE9kesegyh\xE1z Wroc\u0142aw egyik legr\xE9gebbi r\xE9sz\xE9n
      tal\xE1lhat\xF3."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "A P\xFCsp\xF6k T\xF6rpe a k\xF6zelben van bez\xE1rva."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: "K\xF6sz\xF6n\xF6m! Megmentett\xE9l!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: "Sz\xF3lj, ha seg\xEDts\xE9gre van sz\xFCks\xE9ged."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: Maradj itt
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: "N\xE9ha itt \xFCl\xF6k \xE9s a saj\xE1t t\xF6rt\xE9neteimet k\xE9pzelem
      el."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: "N\xE9h\xE1ny wroc\u0142awi t\xF6rpe viccesen n\xE9z ki, m\xE1sok
      pedig komolynak!"
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "A Sky Tower Wroc\u0142aw egyik legmagasabb \xE9p\xFClete."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761834
    m_Localized: "A Sky Tower Wroc\u0142aw egyik legmagasabb \xE9p\xFClete."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: "\xC9gi torony"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: Iskola
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: "Mentsd meg az iskolai t\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: "Ments\xE9tek meg a Karmester T\xF6rp\xE9t! (\u0150 vezeti a sz\xF6k\u0151k\xFAt-show-t)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: "Mentsd meg az \xC9p\xEDt\xE9sz T\xF6rp\xE9t! (\xC9p\xFCleteket
      tervez)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567418
    m_Localized: "Az emberek az\xE9rt j\xF6nnek ide, hogy im\xE1dkozzanak, vagy hogy
      csendben maradjanak."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: "Az emberek az\xE9rt j\xF6nnek ide, hogy csendben im\xE1dkozzanak
      \xE9s gondolkodjanak."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "A Panorama Rac\u0142awicka az utols\xF3 hely itt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "A Rac\u0142awicka panor\xE1ma egy hatalmas k\xE9p."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "A Rac\u0142awicka panor\xE1ma egy \xF3ri\xE1si, kerek festm\xE9ny!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: "Panor\xE1ma"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: "Olga Tokarczuk lengyel \xEDr\xF3n\u0151, aki nagy d\xEDjat nyert
      k\xF6nyvei\xE9rt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: "Most m\xE1r tudod, hogyan szabad\xEDtsd ki a t\xF6bbi t\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: "Most var\xE1zslatos j\xE1rm\u0171vekk\xE9 v\xE1ltoztak, amelyeket
      \"villamosoknak\" neveznek."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: "Most menj, \xE9s szabad\xEDtsd ki mind a 10 t\xF6rpe bar\xE1tomat."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: "Nem. Pr\xF3b\xE1ld \xFAjra!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: Nem, itt akarok maradni
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: Nem
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "A bar\xE1taimnak m\xE9g mindig seg\xEDts\xE9gre van sz\xFCks\xE9g\xFCk
      a Centennial Hallban \xE9s a v\xE1rosk\xF6zpontban."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: "A csal\xE1dom m\xE1r r\xE9g\xF3ta itt \xE9l, nagyon r\xE9g\xF3ta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: "Mozgasd meg a n\xF6v\xE9nyt, hogy megtal\xE1ld!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: "Tal\xE1n tal\xE1lsz egy sz\xF3rakoztat\xF3 mes\xE9t a k\xF6nyvt\xE1rban."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "A Piact\xE9r Wroc\u0142aw egyik legforgalmasabb helye."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: "A Piact\xE9r egy nagyon forgalmas \xE9s sz\xF3rakoztat\xF3 hely."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: Piaccsarnok
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: "Sokan l\xE1togatnak Wroc\u0142awba t\xF6rpeszobrok ut\xE1n kutatva."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: "Sokan t\xF6rpeszobrokat keresnek s\xE9ta k\xF6zben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: "N\xE9zz be az \xC1llatkertbe, a nagyterembe \xE9s a sz\xF6k\u0151k\xFAthoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: "N\xE9zd meg j\xF3l! A kulcs a k\xE9pkeret alatt van elrejtve."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: "N\xE9zd meg a csillagot a t\xE9rk\xE9pen."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "N\xE9zd meg a Piacteret, a V\xE1rosh\xE1z\xE1t \xE9s a Rac\u0142awicka
      panor\xE1m\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: "R\xE9ges-r\xE9gen T\xF6rpe Alagutakat \xE9p\xEDtettem a v\xE1rosban."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: "A katedr\xE1lis kapuja mellett van."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: "Ez egy \u201Emultim\xE9di\xE1s\u201D m\u0171sor, mert sokf\xE9le
      dolgot haszn\xE1l."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: "1300 k\xF6r\xFCl \xE9p\xFClt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: "Olyan \xE9rz\xE9st kelt benned, mintha benne lenn\xE9l a t\xF6rt\xE9netben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "Ez a v\xE1ros egyik legh\xEDresebb \xE9p\xFClete!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "Z\xE1rva van. Keress egy aranykulcsot!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: "Ez egy k\xE9p, ami minden\xFCtt k\xF6r\xFClvesz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: "Magas tornyai \xE9s gy\xF6ny\xF6r\u0171 ablakai vannak."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: "Rajzoltam egy t\xE9rk\xE9pet Wroc\u0142awr\xF3l."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: "Mindig \xFAj \xE9p\xFCleteken gondolkodom, amiket lerajzolhatok."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: Kinyitom neked a liftet.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: "\xC9n vigy\xE1zok az \xE1llatokra. Te is szereted az \xE1llatokat?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: "Egy nap k\xF6rbe akarom utazni az eg\xE9sz vil\xE1got."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: "Az\xE9rt maradok itt, hogy seg\xEDtsek az embereknek b\xE9k\xE9re
      tal\xE1lni."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: "L\xE1tom! A kulcs egy fa m\xF6g\xF6tt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "Wroc\u0142aw t\xF6rt\xE9nelm\xE9t festem le, hogy mindenki l\xE1thassa."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: "Im\xE1dom a tet\u0151ket \xE9s a magas bolt\xEDveket!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "Im\xE1dom n\xE9zegetni Salvador Dal\xED szobr\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: "Im\xE1dom az \xE9l\xE9nk sz\xEDneket \xE9s az \xF3ri\xE1si k\xE9peket!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: "Im\xE1dom a j\xF3 k\xF6nyveket a kezemben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: "Rem\xE9lem, j\xF3l fogj\xE1tok magatokat \xE9rezni az \xC1llatkertben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: "Ezt a k\xFCl\xF6nleges jegyet adom neked, hogy b\xE1rhov\xE1 utazhass!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: "V\xE9gre \xFAjra \u0151rizhetem az \xF6sszes z\xE1rat!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: "\xC9n vagyok a Tan\xE1csos T\xF6rpe. Seg\xEDtek a V\xE1rospolg\xE1rmesternek!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "\xC9n vagyok az egyik legid\u0151sebb t\xF6rpe a v\xE1rosban! El\u0151sz\xF6r
      2005-ben jelentem meg."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: "Hogyan seg\xEDthetek?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: "Hogyan szabad\xEDthatn\xE1m ki a t\xF6rp\xE9t?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: "Sziasztok! A Leonardo Iskola tan\xE1ra vagyok."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: Itt a kulcsod!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: "Seg\xEDts az \xCDr\xF3 T\xF6rp\xE9nek."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: "Seg\xEDts a Fest\u0151 T\xF6rp\xE9nek!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: "Seg\xEDts az \xC1llatbar\xE1t T\xF6rp\xE9nek."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: "Seg\xEDts a Tan\xE1csos T\xF6rp\xFCnknek! (Seg\xEDt a v\xE1ros
      ir\xE1ny\xEDt\xE1s\xE1ban)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: "Szeret \xFAj helyeket megl\xE1togatni."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: "Szereti a mes\xE9ket, a k\xF6nyveket \xE9s a csendes sarkokat."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: "Im\xE1dja a zen\xE9t \xE9s a t\xE1ncol\xF3 vizet!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: "Im\xE1d klassz form\xE1kat \xE9s h\xE1zakat rajzolni."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: "Im\xE1dja az \xF6sszes \xE1llatot itt!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "Remek munka! Felfedezted Wroc\u0142awot \xE9s kiszabad\xEDtottad
      az \xF6sszes t\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: "B\xFAcs\xFA"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "A tetej\xE9r\u0151l szinte az eg\xE9sz v\xE1ros bel\xE1that\xF3!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: "Szabad\xEDtsd ki az Eredeti T\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: "El\u0151sz\xF6r is, menj a katedr\xE1lisba."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: "Itt tal\xE1lod a Fest\u0151 T\xF6rp\xE9t."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "Keresd meg a kulcsot. Azt\xE1n nyisd ki a ketrecet!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "Tal\xE1ld meg a katedr\xE1lis kulcs\xE1t \xE9s szabad\xEDtsd ki!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: "Csal\xE1dok j\xF6nnek ide, hogy \xE1llatokat l\xE1ssanak a vil\xE1g
      minden t\xE1j\xE1r\xF3l."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Minden ketrecet aranykulccsal z\xE1rnak."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "Rajzold le a kedvenc wroc\u0142awi t\xF6rp\xE9det \xE9s a helyet,
      ahol tal\xE1ltad."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "Fel akarsz menni a tet\u0151re?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "Szeretn\xE9l v\xE1laszolni n\xE9h\xE1ny k\xE9rd\xE9sre a k\xFCldet\xE9s
      befejez\xE9s\xE9hez?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: "J\xE1tszol valamilyen hangszeren?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: "Szeretsz iskol\xE1ba j\xE1rni?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: "Ben\xE9zt\xE9l a Centennial Hallba?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: Rendben! Itt a kulcsod.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: "El\u0151sz\xF6r is teljes\xEDtsd a feladatot!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: "Gyere ide este, hogy megn\xE9zd az el\u0151ad\xE1st!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: "Gyere vissza, amikor k\xE9szen \xE1llsz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: "A v\xE1ros vezet\u0151i itt dolgoznak \xE9s itt tal\xE1lkoznak."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: "A Centennial Hall h\xEDres nagy, kerek tetej\xE9r\u0151l."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: "A Centennial Hall egy hatalmas, h\xEDres \xE9p\xFClet."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: A Centennial Hallnak hatalmas kerek teteje van.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: "Centen\xE1riumi Csarnok"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: "Sz\xE9kesegyh\xE1z"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "Antura ma este k\xF6rbefutotta Wroc\u0142awot!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: "Antura a Sky Tower tetej\xE9n van!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: "\xC9s ma reggel t\xEDz t\xF6rpe van ketrecekbe z\xE1rva!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "\xC9s n\xE9zd \u2013 Antura is itt van!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: "Az \xF6sszes \xC9gi Torony t\xF6rpe szabad!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: "Egy \xEDr\xF3"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: "Egy tud\xF3s"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: Egy politikus
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "A k\xF6zt\xE9r egy nagy, nyitott t\xE9r, ahol az emberek tal\xE1lkoznak."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: "A panor\xE1ma egy \xF3ri\xE1si k\xE9p, ami bebor\xEDtja a szob\xE1t!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: "Egy kulcs van egy vir\xE1gcser\xE9p alatt a piacon."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: "Egy sz\xF6k\u0151k\xFAt"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: "Egy h\xEDres \xEDr\xF3n\u0151, Olga Tokarczuk lakott a k\xF6zelben!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: "Egy t\xF6rpe"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: Egy kereszt
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: "El\u0151sz\xF6r oldd fel a m\xE1sik k\xE9t t\xF6rp\xE9t, azt\xE1n
      gyere vissza."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: "Oldd fel az Utaz\xF3 T\xF6rp\xE9t!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: "Felmegy\xFCnk a Sky Tower tetej\xE9re!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: "Haszn\xE1ld, hogy l\xE1sd, hol vagy \xE9s merre kell menned!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: "Haszn\xE1ld a villamost a k\xF6vetkez\u0151 meg\xE1ll\xF3 kiv\xE1laszt\xE1s\xE1hoz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: "A Bema meg\xE1ll\xF3n\xE1l vagyunk, a katedr\xE1lis k\xF6zel\xE9ben."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: "A Leonardo \xC1ltal\xE1nos Iskol\xE1ban vagyunk!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk a Centennial Hallban!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: "\xDCdv\xF6zl\xFCnk a Sky Towerben! Nagyon magas."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: "\xDCdv\xF6z\xF6lj\xFCk Wroc\u0142awban!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: "Mit csin\xE1lnak az emberek egy katedr\xE1lisban?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: "Mit csin\xE1lnak az emberek egy katedr\xE1lisban?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "Mi Wroc\u0142aw h\xEDres jelk\xE9pe?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: "Hov\xE1 akarsz menni?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: "Hol van a t\xF6rpe?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: Hol van a kulcs?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: Ki az az Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: "Megtal\xE1lsz mindannyiunkat?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Wroc\u0142aw h\xEDres a kis t\xF6rp\xE9ir\u0151l."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "A wroc\u0142awi \xE1llatkert Lengyelorsz\xE1g legnagyobb \xE1llatkertje!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: Igen
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: "Igen, ez \xEDgy van!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: "Most m\xE1r mehetsz a Sky Towerbe!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: "Ha nem akarsz gyalog menni, haszn\xE1lhatsz villamost."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: "Befejezted ezt a k\xFCldet\xE9st. Tetszett?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: "Megtal\xE1ltad! Most menj \xE9s oldd fel a t\xF6rp\xE9t!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
