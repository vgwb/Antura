%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_pl
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: pl
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: "Klucznik potrzebuje 10 Kluczy Krasnolud\xF3w!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "Spr\xF3buj ponownie p\xF3\u017Aniej!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "Aby otworzy\u0107 klatk\u0119, rozwi\u0105\u017C t\u0119 zagadk\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: "Nasz Krasnolud Podr\xF3\u017Cnik uwielbia zwiedza\u0107 nowe miejsca."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "To jest Katedra Wroc\u0142awska."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: Tutaj, w Starym Ratuszu, przestrzegamy praw miasta.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: "Ta fontanna wykorzystuje wod\u0119, kolorowe \u015Bwiat\u0142a
      i muzyk\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "Ten krasnolud potrzebuje ostatniego klucza, aby by\u0107 wolnym!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: "Oni czytaj\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: "Oni czytaj\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: "Oni si\u0119 modl\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: "Oni si\u0119 modl\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: "Oni graj\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: "Oni graj\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: "Maj\u0105 malutkie kapelusze i malutkie buty!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "W Zoo jest co robi\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "W mie\u015Bcie pojawi\u0142 si\u0119 problem... zbadajmy go!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: Klucz jest za tamtym znakiem.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "Znajduje si\u0119 tutaj s\u0142ynna rze\u017Aba autorstwa artysty
      o imieniu Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: "W mie\u015Bcie jest ponad 800 krasnolud\xF3w!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "Ogr\xF3d zoologiczny zosta\u0142 zbudowany dawno temu, w 1865 roku!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: Pisarz Krasnolud jest nadal zablokowany!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: "Podr\xF3\u017Cuj\u0105cy Krasnolud jest na placu."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "Tramwaj jest gotowy. Najpierw jed\u017A do Katedry."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: "Panorama wok\xF3\u0142 mnie wygl\u0105da jak gigantyczny obraz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: Krasnolud Origin jest na targu.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "Stary Ratusz to stary i wa\u017Cny budynek."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: "Fontanna multimedialna wykorzystuje wod\u0119, \u015Bwiat\u0142o
      i muzyk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: Fontanna Multimedialna potrzebuje naszej pomocy!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "Klucznik jest uwi\u0119ziony w pobli\u017Cu windy!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "Aby go zdoby\u0107, przeskakuj przez p\xF3\u0142ki."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "Klucz znajduje si\u0119 w k\u0105ciku czytelniczym!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: Klucz do ratusza ukryty jest za znakiem.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: Woda z fontanny ukrywa klucz niedaleko sceny!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: Pokaz fontann przypomina wielki koncert!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: "Runda fina\u0142owa!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: "Winda jest ju\u017C otwarta."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "Krasnoludek Radny znajduje si\u0119 w pobli\u017Cu Starego Ratusza."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: "Miasto st\u0105d wygl\u0105da przepi\u0119knie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: "Skrzynia si\u0119 otwiera!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "Skrzynia jest zamkni\u0119ta."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: Strefa centralna gotowa!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: Teren Hali Stulecia jest gotowy!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "Katedra znajduje si\u0119 w jednej z najstarszych cz\u0119\u015Bci
      Wroc\u0142awia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "Biskup Krasnolud jest zamkni\u0119ty w pobli\u017Cu."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: "Dzi\u0119kuj\u0119! Uratowa\u0142e\u015B mnie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: "Skontaktuj si\u0119 ze mn\u0105, je\u015Bli potrzebujesz pomocy."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: "Zosta\u0144 tutaj"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: "Czasami siedz\u0119 tu i wyobra\u017Cam sobie swoje w\u0142asne
      historie."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: "Niekt\xF3re wroc\u0142awskie krasnale wygl\u0105daj\u0105 zabawnie,
      a niekt\xF3re powa\u017Cnie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "Sky Tower jest jednym z najwy\u017Cszych budynk\xF3w we Wroc\u0142awiu."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: "Wie\u017Ca Sky Tower"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: "Szko\u0142a"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: Ratuj szkolnego krasnoludka.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: "Znajd\u017A muzyk\u0119 i uratuj krasnoluda-dyrygenta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: "Znajd\u017A i uratuj Krasnoluda Architekta!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: "Ludzie przychodz\u0105 tutaj, \u017Ceby si\u0119 pomodli\u0107
      i w ciszy pomy\u015Ble\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Ostatnim miejscem tutaj jest Panorama Rac\u0142awicka."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "Panorama Rac\u0142awicka to ogromny obraz, kt\xF3ry wype\u0142nia
      ca\u0142e pomieszczenie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "Panorama Rac\u0142awicka to gigantyczny, okr\u0105g\u0142y obraz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: "Ona dosta\u0142a wielk\u0105 nagrod\u0119 za swoje ksi\u0105\u017Cki.
      Nagrod\u0119 Nobla!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: "Teraz wiesz, jak uwolni\u0107 pozosta\u0142e krasnoludy."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: "Teraz zamieni\u0142y si\u0119 w magiczne pojazdy zwane \u201Etramwajami\u201D."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: "A teraz id\u017A i uwolnij wszystkich moich 10 krasnoludzkich przyjaci\xF3\u0142."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: "Nie. Spr\xF3buj ponownie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: "Nie, chc\u0119 tu zosta\u0107"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: NIE
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "Moi przyjaciele nadal potrzebuj\u0105 pomocy w Centennial Hall
      i centrum miasta."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: Moja rodzina mieszka tu od bardzo, bardzo dawna!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: "Przesu\u0144 ro\u015Blin\u0119, aby j\u0105 znale\u017A\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: "Mo\u017Ce mo\u017Cesz poczyta\u0107 ksi\u0105\u017Ck\u0119 w bibliotece?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "Rynek G\u0142\xF3wny jest jednym z najbardziej ruchliwych miejsc
      we Wroc\u0142awiu."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: "Rynek G\u0142\xF3wny to bardzo ruchliwe i przyjemne miejsce."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: Hala targowa
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: "Wiele os\xF3b odwiedza Wroc\u0142aw w poszukiwaniu figur krasnali."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: "Podczas spacer\xF3w wiele os\xF3b rozgl\u0105da si\u0119 za figurkami
      krasnoludk\xF3w!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: Zajrzyj do Zoo, do Wielkiej Hali i Fontanny.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: Zbierz wszystkie kolory w parku.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: "Sp\xF3jrz na gwiazdk\u0119 na mapie."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "Sp\xF3jrz na Rynek G\u0142\xF3wny, Ratusz i Panoram\u0119 Rac\u0142awick\u0105!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: "Dawno temu zbudowa\u0142em w mie\u015Bcie Tunele Krasnolud\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: "Kto\u015B w pobli\u017Cu to ma."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: "Jest to program multimedialny, poniewa\u017C wykorzystuje wiele
      r\xF3\u017Cnych rzeczy."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: "Zbudowano go oko\u0142o 1300 roku!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: "Dzi\u0119ki temu poczujesz si\u0119, jakby\u015B by\u0142 wewn\u0105trz
      obrazu!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "To jeden z najs\u0142ynniejszych budynk\xF3w w mie\u015Bcie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "Jest zamkni\u0119te. Znajd\u017A z\u0142oty klucz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: "To obraz, kt\xF3ry Ci\u0119 otacza."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: "Ma wysokie wie\u017Ce i pi\u0119kne okna."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: "Rysowa\u0142em map\u0119 Wroc\u0142awia."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: "Zawsze my\u015Bl\u0119 o nowych budynkach do narysowania."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: "Odblokuj\u0119 ci wind\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: "Opiekuj\u0119 si\u0119 zwierz\u0119tami. Ty te\u017C kochasz zwierz\u0119ta?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: "Chcia\u0142bym kiedy\u015B podr\xF3\u017Cowa\u0107 dooko\u0142a
      \u015Bwiata."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: "Zostaj\u0119 tutaj, aby pom\xF3c ludziom odnale\u017A\u0107 spok\xF3j."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: "Widz\u0119! Na szczycie Iglicy!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "Maluj\u0119 histori\u0119 Wroc\u0142awia, aby ka\u017Cdy m\xF3g\u0142
      j\u0105 zobaczy\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: "Uwielbiam dachy i wysokie \u0142uki!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "Uwielbiam patrze\u0107 na t\u0119 rze\u017Ab\u0119 Salvadora Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: Uwielbiam jaskrawe kolory i wielkie obrazy!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: "Uwielbiam trzyma\u0107 w r\u0119kach dobr\u0105 ksi\u0105\u017Ck\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: "Mam nadziej\u0119, \u017Ce b\u0119dziesz si\u0119 dobrze bawi\u0107
      w zoo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: "Daj\u0119 Ci ten specjalny bilet, dzi\u0119ki kt\xF3remu b\u0119dziesz
      m\xF3g\u0142 podr\xF3\u017Cowa\u0107 wsz\u0119dzie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: "W ko\u0144cu zn\xF3w mog\u0119 pilnowa\u0107 wszystkich zamk\xF3w!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: Jestem Radnym Krasnoludem. Pomagam Burmistrzowi Miasta!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "Jestem jednym z najstarszych krasnolud\xF3w w mie\u015Bcie! Po
      raz pierwszy pojawi\u0142em si\u0119 w 2005 roku."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: "Jak mog\u0119 pom\xF3c?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: "Jak mog\u0119 uwolni\u0107 Krasnoluda?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: "Cze\u015B\u0107! Jestem nauczycielem ze szko\u0142y Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: "Oto Tw\xF3j klucz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: "Pom\xF3\u017C krasnoludowi pisarzowi."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: "Znajd\u017A wszystkie kolory!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: "Znajd\u017A wszystkie zwierz\u0119ta i uwolnij krasnoluda!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: "Znajd\u017A wszystkie ksi\u0105\u017Cki o krasnoludach!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: "Ale zgubi\u0142 si\u0119 w labiryncie."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: "Uwielbia opowie\u015Bci, ksi\u0105\u017Cki i... biblioteki."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: "Ale teraz zgubi\u0142 wszystkie notatki!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: "Potrzebujemy go do ulepszenia budynk\xF3w"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: "Nasz krasnoludek, mi\u0142o\u015Bnik zwierz\u0105t, kocha wszystkie
      zwierz\u0119ta"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "\u015Awietna robota! Zwiedzi\u0142e\u015B Wroc\u0142aw i uwolni\u0142e\u015B
      wszystkich krasnoludk\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: Do widzenia
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: "Ze szczytu mo\u017Cna zobaczy\u0107 niemal ca\u0142e miasto!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: "Uwolnij Krasnoluda Pocz\u0105tkowego."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: "Najpierw udaj si\u0119 do Katedry."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: "Znajd\u017A Krasnoluda Malarza tutaj."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "Znajd\u017A klucz. Potem otw\xF3rz klatk\u0119!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "Znajd\u017A klucz do katedry i uwolnij go!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: "Rodziny przyje\u017Cd\u017Caj\u0105 tutaj, aby zobaczy\u0107 zwierz\u0119ta
      z ca\u0142ego \u015Bwiata."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Ka\u017Cda klatka jest zamkni\u0119ta na z\u0142oty klucz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "Narysuj swojego ulubionego wroc\u0142awskiego krasnala i miejsce,
      w kt\xF3rym go znalaz\u0142e\u015B."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: "Chcesz wej\u015B\u0107 na dach?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "Czy chcesz odpowiedzie\u0107 na kilka pyta\u0144, aby uko\u0144czy\u0107
      to zadanie?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: "Czy grasz na jakim\u015B instrumencie muzycznym?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: "Czy lubisz chodzi\u0107 do szko\u0142y?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: "Czy sprawdza\u0142e\u015B w \u015Brodku Centennial Hall?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: "Dobrze! Oto Tw\xF3j klucz."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: Najpierw wykonaj zadanie!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: "Przyjd\u017Acie tu wieczorem i zobaczcie to widowisko!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: "Wr\xF3\u0107, kiedy b\u0119dziesz gotowy."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: "Ale nasz radny Krasnolud zgubi\u0142 wszystkie swoje ksi\u0105\u017Cki!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: "Hala Stulecia s\u0142ynie ze swojego du\u017Cego, okr\u0105g\u0142ego
      dachu."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: "Pomocy! Nasz Krasnolud Architekt znikn\u0105\u0142!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: "Hala Stulecia ma gigantyczny, okr\u0105g\u0142y dach."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: Hala Stulecia
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: Katedra
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "Antura obieg\u0142a dzi\u015B ca\u0142y Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: Antura na szczycie Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: "A dzi\u015B rano dziesi\u0119ciu krasnoludk\xF3w zosta\u0142o zamkni\u0119tych
      w klatkach!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "I sp\xF3jrz... Antura te\u017C tu jest!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: "Wszystkie krasnoludy ze Sky Tower s\u0105 wolne!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: Pisarz
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: Naukowiec
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: Polityk
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "Plac to du\u017Ce, otwarte miejsce, gdzie spotykaj\u0105 si\u0119
      ludzie."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: "Nasz krasnoludek malarz straci\u0142 wszystkie swoje kolory!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: "Klucz znajduje si\u0119 pod doniczk\u0105 na targu."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: Fontanna
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: "W pobli\u017Cu mieszka\u0142a s\u0142ynna pisarka Olga Tokarczuk!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: Krasnolud
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: Klucz
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: "Najpierw odblokuj pozosta\u0142ych dw\xF3ch krasnolud\xF3w, a potem
      wr\xF3\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: "Znajd\u017A i uratuj Krasnoludzkiego Podr\xF3\u017Cnika!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: Wchodzimy na szczyt Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: "U\u017Cyj go, aby zobaczy\u0107, gdzie jeste\u015B i dok\u0105d
      i\u015B\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: "Wybierz nast\u0119pny przystanek tramwajem."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: "Jeste\u015Bmy na przystanku Bema, niedaleko Katedry."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: "Jeste\u015Bmy w Szkole Podstawowej Leonardo!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: Witamy w Centennial Hall!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: Witamy w Sky Tower! Jest bardzo wysoki.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: "Witamy we Wroc\u0142awiu!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: "Co robi\u0105 ludzie w katedrze?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: "Co robi\u0105 ludzie w katedrze?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "Jaki jest s\u0142ynny symbol Wroc\u0142awia?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: "Dok\u0105d chcesz i\u015B\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: Gdzie jest krasnolud?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: Gdzie jest klucz?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: Kim jest Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: Czy znajdziesz nas wszystkich?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Wroc\u0142aw s\u0142ynie z ma\u0142ych krasnoludk\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "Wroc\u0142awskie Zoo jest najwi\u0119kszym ogrodem zoologicznym
      w Polsce!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: Tak
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: Tak, to prawda!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: "Nie mo\u017Cna jeszcze wej\u015B\u0107 do Sky Tower."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: "Je\u015Bli nie chcesz i\u015B\u0107 pieszo, mo\u017Cesz skorzysta\u0107
      z tramwaju."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: "Uko\u0144czy\u0142e\u015B to zadanie. Podoba\u0142o Ci si\u0119?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: "Znalaz\u0142e\u015B! Teraz id\u017A i odblokuj krasnoluda!"
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767041
    m_Localized: "Znalaz\u0142e\u015B je wszystkie! Wr\xF3\u0107 po nagrod\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089992
    m_Localized: "Gdzie jest m\xF3j kot?"
    m_Metadata:
      m_Items: []
  - m_Id: 75056277766529024
    m_Localized: "Je\u015Bli nie znajdziesz ich wszystkich, skorzystaj z mapy!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284289
    m_Localized: "Winda nie dzia\u0142a!"
    m_Metadata:
      m_Items: []
  - m_Id: 75156437523750912
    m_Localized: "Kto\u015B widzia\u0142, jak wchodzi\u0142 na dach"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284225
    m_Localized: "Kto\u015B widzia\u0142, jak wchodzi\u0142 na dach"
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675521
    m_Localized: Puzzle
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284241
    m_Localized: "Zagraj nuty we w\u0142a\u015Bciwej kolejno\u015Bci."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284250
    m_Localized: "Zagraj nuty, aby mnie odblokowa\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284236
    m_Localized: "Nasz Krasnal prowadzi\u0142 pokazy fontann."
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767042
    m_Localized: "Teraz mo\u017Cesz odblokowa\u0107 krasnoluda!"
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675520
    m_Localized: "Pami\u0119\u0107"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089991
    m_Localized: "Chc\u0119 chroni\u0107 wszystkie zwierz\u0119ta"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089990
    m_Localized: "Lubi\u0119 zoo!"
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767040
    m_Localized: "Id\u017A do Krasnoluda z kluczem!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284280
    m_Localized: "Id\u017A do Mistrza Krasnolud\xF3w!"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284266
    m_Localized: "Po\u0142\xF3\u017C klucz na ksi\u0105\u017Ckach."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284243
    m_Localized: "Znajd\u017A wszystkie nuty muzyczne w tym miejscu"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089997
    m_Localized: "Znajd\u017A wszystkie zwierz\u0119ta w zoo."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284300
    m_Localized: "Chcesz zagra\u0107 w gr\u0119?"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089957
    m_Localized: "Zbierz wszystkie ksi\u0105\u017Cki."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089988
    m_Localized: "Ale uciekli, gdy pojawi\u0142 si\u0119 wielki niebieski pies!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
