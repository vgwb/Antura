%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_pl
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: pl
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "Wiruje jak p\u0119dzel wykonuj\u0105cy ostatni, radosny zakr\u0119t."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "Wz\xF3r fontanny przedstawia klucz znajduj\u0105cy si\u0119 w pobli\u017Cu
      sceny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: Kim jest Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "Hala Stulecia znana jest ze swojego du\u017Cego, okr\u0105g\u0142ego
      dachu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "Uko\u0144czy\u0142e\u015B zadanie Krasnoludki z Wroc\u0142awia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Nic
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "Plac to otwarte miejsce, gdzie spotykaj\u0105 si\u0119 ludzie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "Narysuj swojego ulubionego wroc\u0142awskiego krasnala i miejsce,
      w kt\xF3rym go znalaz\u0142e\u015B."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "Tramwaj jest gotowy. Najpierw id\u017A do katedry."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "Rodziny lubi\u0105 ogl\u0105da\u0107 pokazy fontann."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: "Wie\u017Ca Sky Tower"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: "Jak mog\u0119 pom\xF3c?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: "Ludzie przychodz\u0105 tu, \u017Ceby si\u0119 modli\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "\u017Bywa litera wskazuje na klucz znajduj\u0105cy si\u0119 obok
      drzwi katedry."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "To gigantyczny obraz wok\xF3\u0142 ciebie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "Rynek jest jednym z najbardziej ruchliwych miejsc w mie\u015Bcie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "Dyrygent Krasnolud jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "Wie\u017C\u0119 Sky Tower mo\u017Cna \u0142atwo zobaczy\u0107 z
      wielu cz\u0119\u015Bci miasta."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: "Ten krasnolud uwielbia ruchliwe miejsca i nowe \u015Bcie\u017Cki."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: Gdzie jest klucz?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "Krasnolud Origin jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "A teraz id\u017A i odblokuj krasnoluda!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: Szkolnego Krasnala znajdziesz tutaj.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "W mie\u015Bcie pojawi\u0142 si\u0119 problem... zbadajmy go!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "Znajd\u017A klucz do ratusza."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "Odpowiedz na to pytanie, aby otworzy\u0107 klatk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: "Sp\xF3jrz na gwiazdk\u0119 na mapie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "Klucz znajduje si\u0119 przy windzie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: "Oni graj\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "Miasto wygl\u0105da st\u0105d pi\u0119knie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "Wybierz nast\u0119pny przystanek tramwajem."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: Klucz do ratusza ukryty jest za znakiem.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: "Oni si\u0119 modl\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "Znajd\u017A klucz. Nast\u0119pnie skopiuj wz\xF3r fontanny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: To jest krasnoludek malarz z centrum.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "Nasz Rynek to t\u0119tni\u0105ce \u017Cyciem miejsce, gdzie mo\u017Cna
      spacerowa\u0107 i spotyka\u0107 si\u0119 ze znajomymi."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "Olga Tokarczuk jest znan\u0105 pisark\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: "Ten krasnolud uwielbia \u0142apy, skrzyd\u0142a i w\u0105sy."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "Teraz wiesz, jak uwolni\u0107 krasnoludy. Znajd\u017A 10!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "Jak mog\u0119 uwolni\u0107 Krasnoluda?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "Przyw\xF3dcy miasta pracuj\u0105 i spotykaj\u0105 si\u0119 tutaj."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "Znajd\u017A ukryty klucz na rynku."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: "Oni \u0142owi\u0105 ryby"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "Jaki jest s\u0142ynny symbol Wroc\u0142awia?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "Mapa Wroc\u0142awia jest teraz Twoja."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "Panorama wok\xF3\u0142 mnie wygl\u0105da jak obraz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "Znajd\u017A klucz. Potem otw\xF3rz klatk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: Gdzie jest krasnolud?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "Ten krasnolud uwielbia plany, papiery i wa\u017Cne spotkania."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: "Jeste\u015Bmy dumni z Hali Stulecia i jej du\u017Cego, okr\u0105g\u0142ego
      dachu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Wroc\u0142aw s\u0142ynie z ma\u0142ych krasnoludk\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: Zajrzyj do zoo, na hol i do fontanny.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: Witamy w Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "Poprawia sw\xF3j malutki kapelusz niczym bardzo zaj\u0119ty burmistrz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: "Ten krasnoludek uwielbia kolory, farby i du\u017Ce obrazy."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "Sky Tower jest jednym z najwy\u017Cszych budynk\xF3w we Wroc\u0142awiu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: "Panorama to gigantyczny obraz, kt\xF3ry Ci\u0119 otacza."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "Chcesz odpowiedzie\u0107 na kilka pyta\u0144?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: "Katedra jest jednym z najs\u0142ynniejszych miejsc we Wroc\u0142awiu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: "Znajd\u017A klucz, a nast\u0119pnie dopasuj elementy obrazka, aby
      otworzy\u0107 klatk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "Biskup Krasnolud jest zamkni\u0119ty w pobli\u017Cu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "Ogr\xF3d zoologiczny we Wroc\u0142awiu jest najwi\u0119kszym ogrodem
      zoologicznym w Polsce."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: "Znajd\u017A klucz do placu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: "Co robi\u0105 ludzie w katedrze?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: "Fontanna multimedialna wykorzystuje wod\u0119, \u015Bwiat\u0142o
      i muzyk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "Podr\xF3\u017Cuj\u0105cy Krasnolud jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: "Macha malutk\u0105 pa\u0142eczk\u0105 i k\u0142ania si\u0119 fontannie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: "Ma wysokie wie\u017Ce i jasne okna."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: "Niekt\xF3re wroc\u0142awskie krasnale wygl\u0105daj\u0105 zabawnie,
      inne za\u015B powa\u017Cnie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: "Porusza ma\u0142ymi bucikami i k\u0142ania si\u0119 rado\u015Bnie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "Najpierw udaj si\u0119 do katedry. Tam pomog\u0105 ci odczyta\u0107
      map\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: "Ten krasnolud uwielbia opowie\u015Bci, ksi\u0105\u017Cki i ciche
      miejsca."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "Witamy we Wroc\u0142awiu!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Ka\u017Cda klatka jest zamkni\u0119ta na z\u0142oty klucz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "Radny Krasnolud jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "Ten krasnolud uwielbia kszta\u0142ty, budynki i pomys\u0142owe
      projekty."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: "Cze\u015B\u0107! Jestem nauczycielem ze szko\u0142y Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: "Rozwi\u0105\u017C zagadk\u0119, aby znale\u017A\u0107 ukryty klucz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: Pisarz
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: Antura na szczycie Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "Znajd\u017A klucz do zoo. Nast\u0119pnie porozmawiaj z opiekunem
      zoo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "Krasnoludek Radny znajduje si\u0119 w pobli\u017Cu Starego Ratusza."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: "Oni si\u0119 modl\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: "Wielu wroc\u0142awian zna swojego ulubionego krasnala."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: "Przesu\u0144 ro\u015Blin\u0119, aby j\u0105 znale\u017A\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "Krasnolud Malarz jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: Pilot
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "Znajd\u017A klucz autora. Potem porozmawiaj z czytelnikiem."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "Klucz znajduje si\u0119 pod \u0142awk\u0105 na placu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: Wieloryb
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: "Kr\u0119ci si\u0119 w k\xF3\u0142ko, jakby szykowa\u0142 si\u0119
      do nast\u0119pnej podr\xF3\u017Cy."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: Klucz jest ukryty za znakiem.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: "Uwolni\u0119 wszystkich 10 moich przyjaci\xF3\u0142 krasnali z
      Wroc\u0142awia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: "Dziesi\u0119ciu krasnoludk\xF3w zostaje zamkni\u0119tych w magicznych
      klatkach we Wroc\u0142awiu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: "Wr\xF3\u0107, kiedy b\u0119dziesz gotowy."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: Krasnolud
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: "Pisarz Krasnolud jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: "Oni \u015Bcigaj\u0105 si\u0119 samochodami"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: Wchodzimy na szczyt Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: "Przytula malutk\u0105 ksi\u0105\u017Ceczk\u0119 i u\u015Bmiecha
      si\u0119 do ciebie promiennie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: Najpierw wykonaj zadanie!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: "Krasnolud Architekt jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: "Hala Stulecia jest bardzo du\u017Ca i ma s\u0142ynny okr\u0105g\u0142y
      dach."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: Gigantyczny kot
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: Rakieta
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Brzd\u0119k, brz\u0119k, brz\u0119k. Otworz\u0119 ci wind\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: "Znajd\u017A Krasnoluda Malarza tutaj."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: "Sp\xF3jrz na Rynek G\u0142\xF3wny, Ratusz i Panoram\u0119 Rac\u0142awick\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "\u015Awietna robota. Zwiedzi\u0142e\u015B Wroc\u0142aw i uwolni\u0142e\u015B
      wszystkich krasnoludk\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: "Z dum\u0105 wci\u0105ga powietrze, jakby rysowa\u0142 nowy dach."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: "Szko\u0142a"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: "Klucz znajduje si\u0119 pod doniczk\u0105 na targu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: "Wiele os\xF3b odwiedza Wroc\u0142aw w poszukiwaniu figur krasnali."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: "Fontanna wykorzystuje wod\u0119, \u015Bwiat\u0142a i muzyk\u0119."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: "U\u017Cyj go, aby uda\u0107 si\u0119 do City Center lub Centennial
      Hall."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: "Jeste\u015Bmy na przystanku Bema, niedaleko Katedry."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: "Klucz znajduje si\u0119 w k\u0105ciku czytelniczym."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: Witamy na terenie Hali Stulecia.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: To jest Stary Ratusz.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: "Zgadza si\u0119. Oto tw\xF3j klucz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: "Oni czytaj\u0105"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: "Dawno temu zbudowa\u0142em w mie\u015Bcie Tunele Krasnolud\xF3w."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "Krasnoludzki Klucznik jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: "Co robi\u0105 ludzie w katedrze?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: "Pozosta\u0142e krasnoludy poka\u017C\u0105 ci, gdzie szuka\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: Ostatni klucz znajdziesz przy znaku windy.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "To jest katedra wroc\u0142awska."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: "Znajd\u017A klucz do katedry i uwolnij krasnoludzkiego biskupa."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "Krasnolud Mi\u0142o\u015Bnik Zwierz\u0105t jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: Ten krasnal uwielbia pluski, iskierki i piosenki.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: "Maj\u0105 malutkie kapelusze i malutkie buty."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: "\u0106wierka, w\u0119szy i macha jednocze\u015Bnie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: "Panorama Rac\u0142awicka jest cz\u0119\u015Bci\u0105 w\u0119z\u0142a
      Centrum."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: "To jeden z krasnolud\xF3w ze Sky Tower."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: "Biskup Krasnolud jest ju\u017C bezpieczny."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: "Oto Tw\xF3j klucz."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: "Wszystkie krasnoludy ze Sky Tower s\u0105 darmowe."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: "Inny krasnoludek znajduje si\u0119 w pobli\u017Cu Hali Stulecia."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: Teren Hali Stulecia jest gotowy.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "Strefa \u015Brodkowa jest gotowa."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: "Teraz sta\u0142y si\u0119 magicznymi pojazdami."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "Krasnoludek Radny znajduje si\u0119 w pobli\u017Cu Starego Ratusza."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: "Dzi\u0119kuj\u0119! Uratowa\u0142e\u015B mnie!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: "Winda jest ju\u017C otwarta."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: Fontanna jest ostatnim miejscem tutaj.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: "Na gotowym obrazie wida\u0107 klucz umieszczony pod ram\u0105."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "Klatka Keymastera znajduje si\u0119 w pobli\u017Cu windy."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "Jest zamkni\u0119te. Znajd\u017A z\u0142oty klucz!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: NIE
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: "Panorama Rac\u0142awicka jest ostatnim miejscem tutaj."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: "Aby odblokowa\u0107 klatk\u0119 rozwi\u0105\u017C t\u0119 zagadk\u0119"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: "Zosta\u0144 tutaj"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: "Skontaktuj si\u0119 ze mn\u0105, je\u015Bli potrzebujesz pomocy."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: Katedra
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: Hala Stulecia
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: Hala targowa
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: "Podr\xF3\u017Cuj\u0105cy Krasnolud jest na placu."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: "Nie. Spr\xF3buj ponownie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "Spr\xF3buj ponownie p\xF3\u017Aniej!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: "Dok\u0105d chcesz i\u015B\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: Tak
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: Tak, to prawda.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
