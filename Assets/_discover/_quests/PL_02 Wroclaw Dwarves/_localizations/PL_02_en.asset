  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 123277926400
    m_Localized: Oh no! Antura is stuck at the top of the Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926401
    m_Localized: The dwarves locked the elevator.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926402
    m_Localized: "Find 10 dwarves around Wroc\u0142aw. They will help us."
    m_Metadata:
      m_Items: []
  - m_Id: 123277926403
    m_Localized: Explore the city. Talk to each dwarf you find.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926404
    m_Localized: "Wroc\u0142aw is the city of dwarves."
    m_Metadata:
      m_Items: []
  - m_Id: 123277926405
    m_Localized: They are small and kind. They like to play tricks.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926406
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926407
    m_Localized: This is the Old Town Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926408
    m_Localized: Meetings happen inside. The clock is very old.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926409
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926410
    m_Localized: This is the cathedral.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926411
    m_Localized: It has tall towers and colorful stained-glass windows.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926412
    m_Localized: What do people do in a cathedral?
    m_Metadata:
      m_Items: []
  - m_Id: 123277926413
    m_Localized: They shop for food.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926414
    m_Localized: Not here. Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926415
    m_Localized: They pray.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926416
    m_Localized: Yes. You may collect the dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926417
    m_Localized: They fly planes.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926418
    m_Localized: No. Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926419
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926420
    m_Localized: "Visit the Wroc\u0142aw zoo."
    m_Metadata:
      m_Items: []
  - m_Id: 123277926421
    m_Localized: It has many animals from around the world.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926422
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926423
    m_Localized: The Centennial Hall is huge.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926424
    m_Localized: The roof looks like a giant dome.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926425
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926426
    m_Localized: Water dances here with music and lights.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926427
    m_Localized: The shows are beautiful on summer nights.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926428
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926429
    m_Localized: A giant painting goes all around you.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926430
    m_Localized: You stand inside the story.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926431
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926432
    m_Localized: "Olga Tokarczuk is a famous writer in Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 123277926433
    m_Localized: She won the Nobel Prize in Literature.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926434
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926435
    m_Localized: This is the modern plaza near the Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926436
    m_Localized: People meet here to talk and play.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926437
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926438
    m_Localized: The Sky Tower is very tall.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926439
    m_Localized: You can see very far from the top.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926440
    m_Localized: A dwarf joined us.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926441
    m_Localized: I guard the elevator.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926442
    m_Localized: You found {0} / {1} dwarves. Keep exploring.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926443
    m_Localized: Great! You found them all. I open the door with my key.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926444
    m_Localized: The elevator goes up. Ding!
    m_Metadata:
      m_Items: []
  - m_Id: 123277926445
    m_Localized: The view is beautiful.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926446
    m_Localized: I'm here! Thank you!
    m_Metadata:
      m_Items: []
  - m_Id: 123277926447
    m_Localized: Wink... POOF!
    m_Metadata:
      m_Items: []
  - m_Id: 123277926448
    m_Localized: Magic! Antura is playful.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926449
    m_Localized: Quick check.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926450
    m_Localized: Two short questions.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926451
    m_Localized: "What is the symbol of Wroc\u0142aw?"
    m_Metadata:
      m_Items: []
  - m_Id: 123277926452
    m_Localized: a dog
    m_Metadata:
      m_Items: []
  - m_Id: 123277926453
    m_Localized: Not this.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926454
    m_Localized: a monkey
    m_Metadata:
      m_Items: []
  - m_Id: 123277926455
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926456
    m_Localized: a dwarf
    m_Metadata:
      m_Items: []
  - m_Id: 123277926457
    m_Localized: Correct!
    m_Metadata:
      m_Items: []
  - m_Id: 123277926458
    m_Localized: "Wroc\u0142aw is the ... biggest city in Poland."
    m_Metadata:
      m_Items: []
  - m_Id: 123277926459
    m_Localized: first
    m_Metadata:
      m_Items: []
  - m_Id: 123277926460
    m_Localized: No.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926461
    m_Localized: second
    m_Metadata:
      m_Items: []
  - m_Id: 123277926462
    m_Localized: Not this.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926463
    m_Localized: third
    m_Metadata:
      m_Items: []
  - m_Id: 123277926464
    m_Localized: Correct! Well done.
    m_Metadata:
      m_Items: []
  - m_Id: 123277926465
    m_Localized: Great! You finished the quest!
    m_Metadata:
      m_Items: []
  - m_Id: 1737453466542080
    m_Localized: "Welcome to Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 1742333543440384
    m_Localized: Bravo! You solved the puzzle.
    m_Metadata:
      m_Items: []
  - m_Id: 1742333560217600
    m_Localized: Now i come with you
    m_Metadata:
      m_Items: []
  - m_Id: 1742861899915264
    m_Localized: Bravo! You solved the puzzle.
    m_Metadata:
      m_Items: []
  - m_Id: 1742861899915265
    m_Localized: Now i come with you
    m_Metadata:
      m_Items: []
  - m_Id: 1745392029917184
    m_Localized: You found all the dwarves!
    m_Metadata:
      m_Items: []
  - m_Id: 1745392042500096
    m_Localized: Now go up the elevator!
    m_Metadata:
      m_Items: []
  - m_Id: 1745392042500097
    m_Localized: Bravo! You solved the puzzle.
    m_Metadata:
      m_Items: []
  - m_Id: 1745392042500098
    m_Localized: Now i come with you
    m_Metadata:
      m_Items: []
  - m_Id: 1748533244846080
    m_Localized: Do you want to play with me?.
    m_Metadata:
      m_Items: []
  - m_Id: 1748533257428992
    m_Localized: yes
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102186
    m_Localized: The market square is busy and bright.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102185
    m_Localized: The big painting goes all around us.
    m_Metadata:
      m_Items: []
  - m_Id: 1748533257428995
    m_Localized: Bravo! You solved the puzzle.
    m_Metadata:
      m_Items: []
  - m_Id: 1748533257428996
    m_Localized: Now i come with you
    m_Metadata:
      m_Items: []
  - m_Id: 1766276534886400
    m_Localized: Well done!
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080704
    m_Localized: Do you know what is a CHURCH?
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080705
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102179
    m_Localized: I like counting dwarves with my friend.
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080707
    m_Localized: A church is a place where people pray.
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080708
    m_Localized: Let' play a game
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080709
    m_Localized: Great! He is a another Dwarf
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080710
    m_Localized: Let's play a game
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080711
    m_Localized: Great!
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080712
    m_Localized: Let's do something with it
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080713
    m_Localized: Great!
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080714
    m_Localized: Let's see how you play this
    m_Metadata:
      m_Items: []
  - m_Id: 1766276539080715
    m_Localized: Great!
    m_Metadata:
      m_Items: []
  - m_Id: 1945184437788672
    m_Localized: "Welcome to Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 2007350457131008
    m_Localized: AHhh Antura was here.
    m_Metadata:
      m_Items: []
  - m_Id: 2007350482296832
    m_Localized: But it just went away!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102168
    m_Localized: But it ran away.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102167
    m_Localized: Antura was here!
    m_Metadata:
      m_Items: []
  - m_Id: 2007350482296835
    m_Localized: Would you like to anwear two short questions??
    m_Metadata:
      m_Items: []
  - m_Id: 2007350482296836
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102164
    m_Localized: Great!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102163
    m_Localized: Let's play a game.
    m_Metadata:
      m_Items: []
  - m_Id: 2241597356892160
    m_Localized: This quest is complete.
    m_Metadata:
      m_Items: []
  - m_Id: 2241597356892161
    m_Localized: Why don't you draw your Dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102188
    m_Localized: The keymaster guards the elevator door.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102187
    m_Localized: The hall has a round high roof.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102184
    m_Localized: The cathedral towers look very tall.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102183
    m_Localized: I got a map to find more dwarves.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102182
    m_Localized: The zoo has animals from many lands.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102181
    m_Localized: The fountain show is bright at night.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102180
    m_Localized: We look up at the Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102178
    m_Localized: Good job!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102177
    m_Localized: Good job!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102176
    m_Localized: Good job!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102175
    m_Localized: Good job!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102174
    m_Localized: Ok. Come back to me to end the game
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102173
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102172
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102171
    m_Localized: Would you like to answer two short questions?
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102170
    m_Localized: The view is beautiful!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102169
    m_Localized: Maybe next time you'll make it!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102166
    m_Localized: Great!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102165
    m_Localized: Let's play a game.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102162
    m_Localized: Great!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102161
    m_Localized: Let's play a game.
    m_Metadata:
      m_Items: []
  - m_Id: 2277616789741568
    m_Localized: Why don't you draw your Dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102191
    m_Localized: I want to write stories one day.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102190
    m_Localized: Olga won a big prize.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102189
    m_Localized: I read a book by Olga.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102160
    m_Localized: Great! He is another dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102159
    m_Localized: Let's play a game.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102158
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102157
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102156
    m_Localized: Do you know what a church is?
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102155
    m_Localized: Well done!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102154
    m_Localized: Now I come with you.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102153
    m_Localized: Good job! You solved the puzzle.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102152
    m_Localized: Oh, okay. Maybe later.
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102151
    m_Localized: no
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102150
    m_Localized: yes
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102149
    m_Localized: Do you want to play with me?
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102148
    m_Localized: Now go up the elevator!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102147
    m_Localized: You found all the dwarves!
    m_Metadata:
      m_Items: []
  - m_Id: 2377122852102146
    m_Localized: Why don't you draw your Dwarf?
    m_Metadata:
      m_Items: []
