%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503256
    m_Localized: "Ten dwarves are locked in magic cages in Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: Hi! I am a teacher from Leonardo School.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503249
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: Find the School Dwarf here.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: Each cage is sealed with a gold key.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: The Tram is ready. First go to the Cathedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: Antura is at the top of Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: Now you know how to free dwarves. Find 10 now!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503251
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503250
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503248
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: Complete the task, first!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503246
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503245
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503244
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: Stay here
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: Sky Tower
    m_Metadata:
      m_Items: []
  - m_Id: 2277616789741568
    m_Localized: Why don't you draw your Dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: How can I free the Dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: How can I help?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: Talk to me if you need help.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: Find the key. Then open the cage.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: Where is the key?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: Move the plant to find it.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: Where is the dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: Look at the star on the map.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Nothing
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: Now go and unlock the dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: "Free all 10 of my dwarf friends in Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: First go to the Cathedral. They will help you read the map.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: Long ago, I made Dwarf Tunnels in the city.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: Now they have turned into magical vehicles.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: To unlock the cage solve this puzzle
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: It is locked. Find a gold key!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: Thank you! You saved me!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: Try again later!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: We are at Bema Stop, near the Cathedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: Use the tram to choose your next stop.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "This is the Wroc\u0142aw cathedral."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: It has tall towers and bright windows.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: People come here to pray.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: The Bishop Dwarf is locked nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: Find the cathedral key and free the Bishop Dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503284
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: A living letter points to a key beside the cathedral door.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: What do people do in a cathedral?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: They pray
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: Correct. Here is your key.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: They read
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: No. Try again.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: They play
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503292
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: The Bishop Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "The map of Wroc\u0142aw is yours now."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: Use it to go to the City Center or Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: Answer this question to open the cage.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503297
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503298
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503299
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: Look at Market Square, the Town Hall, and Panorama Raclawicka.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: The Councilor Dwarf is near the Old Town Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: Panorama Raclawicka is the last place here.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: The Center area is done.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Wroc\u0142aw is famous for its little dwarves."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: They have tiny hats and tiny boots.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: Find the hidden key in the market.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503307
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: A key is under a flowerpot in the market.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: Here is your key.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: The Origin Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: It wiggles its little boots and gives a happy bow.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: The Councilor Dwarf is near the Old Town Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503313
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503314
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503315
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503316
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503317
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503318
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: This is the Old Town Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: This dwarf loves plans, papers, and important meetings.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: City leaders work and meet here.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: Find the Town Hall key.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503323
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: The hidden Town Hall key is behind the sign.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503325
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: The Councilor Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: It straightens its tiny hat like a very busy mayor.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503328
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503329
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503330
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503331
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503332
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: Panorama Raclawicka is part of the Center hub.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: It is a giant picture all around you.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: Find the Painter Dwarf here.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503336
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: This is the Painter Dwarf from the Center hub.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: A panorama is a giant picture all around you.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: This dwarf loves colors, paint, and big pictures.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: Find the key, then match the picture pieces to open the cage.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: The finished picture shows a key under the frame.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503342
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: The Painter Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503344
    m_Localized: It twirls like a brush making one last happy swirl.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503345
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503346
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503347
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503348
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503349
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: Welcome to the Centennial Hall area.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: Look in the zoo, the hall, and the fountain.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: Another dwarf is near Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: The fountain is the last place here.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: The Centennial Hall area is done.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "Wroc\u0142aw Zoo is the biggest zoo in Poland."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: This dwarf loves paws, wings, and whiskers.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: Find the zoo key. Then talk to the zoo keeper.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: There is a key behind the sign.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503359
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: The Animal Lover Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: It chirps, sniffs, and waves all at once.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503362
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503363
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503364
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503365
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503366
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503367
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503368
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: Centennial Hall is very big and has a famous round roof.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: This dwarf loves shapes, buildings, and clever designs.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: Solve the hall puzzle to find the hidden key.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503372
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503373
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: The Architect Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: It proudly taps the air like it is drawing a new roof.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503376
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503377
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503378
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503379
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503380
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503381
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: This fountain uses water, lights, and music.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: This dwarf loves splashes, sparkles, and songs.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: Find the key. Then copy the fountain pattern.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: The fountain pattern shows a key near the stage.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503386
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: The Conductor Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: The elevator is open now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503449
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: Who is Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: What do people do in a cathedral?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: The key is under a bench in the plaza.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503417
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "Welcome to Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: There is a problem in town... let's explore!
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "You finished the Wroc\u0142aw Dwarves quest."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "Draw your favorite Wroc\u0142aw dwarf and the place where you found
      it."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: Where do you want to go?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: School
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: Cathedral
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: Market Hall
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: Centennial Hall
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503412
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: Come back when you are ready.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: This dwarf loves busy places and new paths.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: Find the plaza key.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: A plaza is an open place where people meet.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503403
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: The Writer Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: It hugs a tiny book and beams at you.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503407
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503408
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503409
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503406
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503410
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503411
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503429
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: The Keymaster Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503433
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: Up we go to the top of the Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: The Traveler Dwarf is safe now.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: It spins in a little circle like it is ready for the next trip.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503420
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503421
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503422
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503423
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503424
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: The other dwarves show you where to look.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: Find the last key near the elevator sign.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: The key is near the elevator.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: Clink, clank, jingle. I will unlock the elevator for you.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503432
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "Great job. You explored Wroc\u0142aw and freed every dwarf."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503434
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503435
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503436
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: The city looks beautiful from up here.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: Do you want to answer some questions?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "What is a famous symbol of Wroc\u0142aw?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: A dwarf
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: Yes, that is right.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: A whale
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503447
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: A rocket
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: They pray
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503452
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: They race cars
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503454
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: They fish
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503456
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: A writer
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697536
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: A pilot
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697538
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: A giant cat
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697540
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: The panorama looks like a picture all around me.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: Many people visit Wroclaw to look for dwarf statues.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: Centennial Hall is known for its big round roof.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: The Multimedia Fountain uses water, light, and music.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: Sky Tower is one of the tallest buildings in Wroclaw.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: The Market Square is one of the busiest places in the city.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: Some Wroclaw dwarves look funny, and some look serious.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: Many people in Wroclaw know their favorite dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: Our Market Square is a lively place to walk and meet friends.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: We are proud of Centennial Hall and its big round roof.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: The Cathedral is one of the most famous places in Wroclaw.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: Families like to watch the fountain show.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: Sky Tower is easy to see from many parts of the city.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: The key is near the reading corner.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: Find the writer's key. Then talk to the reader.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: This dwarf loves stories, books, and quiet places.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: Olga Tokarczuk is a famous writer.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: This is one of the Sky Tower dwarves.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: All Sky Tower dwarves are free.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: The Keymaster cage is near the elevator.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: The Traveler Dwarf is in the plaza.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: Welcome to Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503393
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503392
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503391
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503390
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503389
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: It swishes its tiny baton and bows to the fountain.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
