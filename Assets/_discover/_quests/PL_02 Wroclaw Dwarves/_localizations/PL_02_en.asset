    m_Metadata:
      m_Items: []
  - m_Id: 73167567718441016
    m_Localized: No. Watch the fountain clue again.
    m_Metadata:
      m_Items: []
  - m_Id: 73167567718441017
    m_Localized: Milk, bread, and cheese
    m_Metadata:
      m_Items: []
  - m_Id: 73167567718441018
    m_Localized: No. Watch the fountain clue again.
    m_Metadata:
      m_Items: []
  - m_Id: 73167567718441019
