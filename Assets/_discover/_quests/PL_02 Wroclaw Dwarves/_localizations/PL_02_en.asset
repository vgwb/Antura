  - m_Id: 71727562651328512
    m_Localized: Ahhh you found me! Bravo!
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328513
    m_Localized: Many years ago I created Dwarf Tunnels to travel around the city...
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328514
    m_Localized: Modern technology is really amazing!
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328515
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328516
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328517
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328518
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328519
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328520
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 71727562651328521
    m_Localized: You finished the Panorama Zone. The Sky Tower District is open now.
    m_Metadata:
      m_Items: []
