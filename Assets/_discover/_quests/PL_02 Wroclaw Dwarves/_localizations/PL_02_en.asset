%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653607567364
    m_Localized: You can't go to the Sky Tower yet.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: School
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: Where do you want to go?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: You finished this quest. Did you like it?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: There is a problem in town... let's explore!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Panorama Rac\u0142awicka is the last place here."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: The Center area is done!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: They have tiny hats and tiny boots!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: Many people look for dwarf statues while they walk!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: A key is under a flowerpot in the market.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: Here is your key!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: I am one of the oldest dwarves in town! I first appeared in 2005.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: There are over 800 dwarves in town!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: Will you find all of us?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: You can use a tram if you don't want to walk.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Wroc\u0142aw is famous for its little dwarves."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: Free the Origin Dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "Market Square is one of the busiest places in Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: The chest is locked.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: But our Councilor Dwarf has lost all his books!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: The Old Town Hall is an old and important building.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: The Councilor Dwarf is near the Old Town Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: Someone near here has it.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: What do people do in a Cathedral?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: They pray
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: Correct! Here is your key.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: No. Try again!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: "I've been drawing a map of Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: Use it to see where you are and where to go!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: The Origin Dwarf is at the market.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: Here in the Old Town Hall we keep the laws of the city.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: Please find all Dwarf books!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: It was built around the year 1300!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: First, go to the Cathedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: It is locked. Find a gold key!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: Try again later!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: Find the Cathedral key and free him!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "The Cathedral is in one of the oldest parts of Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: To unlock the cage, solve this puzzle!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: The Bishop Dwarf is locked nearby.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: Complete the task, first!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: The Tram is ready. First, go to the Cathedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "Antura ran all around Wroc\u0142aw tonight!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: Save the School Dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: Talk to me if you need help.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: Do you like to go to school?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: How can I help?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: Find the key. Then open the cage!
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "Sky Tower is one of the tallest buildings in Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: "Some Wroc\u0142aw dwarves look funny, and some look serious!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: Market Square is a very busy and fun place.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: The Multimedia Fountain uses water, light, and music.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: Centennial Hall is famous for its big round roof.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: "Many people visit Wroc\u0142aw to look for dwarf statues."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: The panorama looks like a giant picture all around me!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "Great job! You explored Wroc\u0142aw and freed every dwarf."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: A writer
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: A scientist
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: A politician
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: Who is Olga Tokarczuk?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: They play
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: They read
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: They pray
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: What do people do in a Cathedral?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: A key
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: Yes, that is right!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: A dwarf
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: Centennial Hall
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: A fountain
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "What is a famous symbol of Wroc\u0142aw?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: No, I want to stay here
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: Do you want to answer some questions to finish this quest?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: And look... Antura is here too!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: We are at the Leonardo Primary School!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: The city looks beautiful from up here!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: Come back when you are ready.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: Hi! I am a teacher from Leonardo School.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: And this morning, ten dwarves were locked in cages!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: Each cage is locked with a gold key.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: No
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: Up we go to the top of the Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: How can I free the Dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: Where is the key?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: Yes
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: Move the plant to find it!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: Do you want to go up to the roof?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: I will unlock the elevator for you.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: I can finally guard all the locks again!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: This Dwarf needs one last key to be free!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: From the top, you can see almost the whole city!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: Unlock the other two dwarves here first, then come back.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761783
    m_Localized: The Keymaster needs the 10 Dwarf Keys!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: The final round!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: I want to travel all around the world one day.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "I love looking at that Salvador Dal\xED sculpture!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: Move and jump over the shelves to get it.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "There is a famous sculpture here by an artist named Salvador Dal\xED!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: A plaza is a big open place where people meet.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: But he got lost in a labyrinth.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: Find and save the Traveler Dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: Our Traveler Dwarf loves visiting new places.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: Sometimes I sit here and imagine my own stories.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: I love a good book in my hands!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: The key is near the reading corner!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: Maybe you can read a book in the library?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: She who a big prize for her books. The Nobel Prize!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: He loves stories, books, and ... libraries.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: Help the Writer Dwarf.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: The famous writer named Olga Tokarczuk lived near here!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: "Welcome to Wroc\u0142aw!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "Draw your favorite Wroc\u0142aw dwarf and the place where you found
      it."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: Cathedral
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: Market Hall
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: Sky Tower
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: Stay here
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284300
    m_Localized: Do you want to play a game?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: Now you know how to free the other dwarves.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: Antura is at the top of Sky Tower!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: The elevator is open now.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: All the Sky Tower dwarves are free!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: The Keymaster is trapped near the elevator!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: The Traveler Dwarf is in the plaza.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: The Writer Dwarf is still locked!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: Welcome to Sky Tower! It's very tall.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: Goodbye
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: Long ago, I made Dwarf Tunnels in the city.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: I give you this special ticket to travel everywhere!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: Do you play a musical instrument?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: The fountain show feels like a big concert!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: Thank you! You saved me!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: We are at Bema Stop, near the Cathedral.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: People come here to pray and think quietly.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: Come here at night to see the show!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: It's a "multimedia" show because it uses many different things.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: This fountain uses water, colorful lights, and music!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: But now he has lost all the notes!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: Find the music and save the Conductor Dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: My friends still need help at Centennial Hall and the city center.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: I'm always thinking of new buildings to draw.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: I love roofs and tall arches!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: I see it! It's at the top of the Iglica!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: It is one of the most famous buildings in the city!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: Centennial Hall has a giant round roof.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: We need him to improve the buildings
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: Find and save the Architect Dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: Help! Our Architect Dwarf has disappeared!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: Use the tram to choose your next stop.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "This is the Wroc\u0142aw Cathedral."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: I hope you have fun at the Zoo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: I watch over the animals. Do you love animals too?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: Families come here to see animals from all over the world.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: The Zoo was built a long time ago, in 1865!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: Our Animal Lover Dwarf loves all the animals
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: Find all the animals and free the Dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: The chest opens!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "Wroc\u0142aw Zoo is the biggest zoo in Poland!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: The Centennial Hall area is done!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: The Multimedia Fountain needs our help!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: Did you check inside Centennial Hall?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: There is something to do at the Zoo!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: Look in the Zoo, the big Hall, and the Fountain.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: Welcome to Centennial Hall!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: Where is the dwarf?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: Look at the star on the map.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: You found it! Now go and unlock the dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: Now they have turned into magical vehicles called "trams."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: Now go and free all 10 of my dwarf friends.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: It has tall towers and beautiful windows.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: I love bright colors and giant pictures!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "I paint the history of Wroc\u0142aw for everyone to see."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284289
    m_Localized: The elevator doesn't work!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: Collect all the colors around the park.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: It makes you feel like you are inside the painting!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "Panorama Rac\u0142awicka is a huge picture that wraps around the
      room!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: They read
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: They play
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: I stay here to help people find peace.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: Find all the colors!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: Our Painter Dwarf has lost all his colors!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: Find the Painter Dwarf here.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "Look at Market Square, the Town Hall, and Panorama Rac\u0142awicka!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: It is a picture that goes all around you.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "Panorama Rac\u0142awicka is a giant, round painting!"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: My family has lived here for a long, long time!
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: I am the Councilor Dwarf. I help the City Mayor!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284280
    m_Localized: Go to the Dwarf Master!
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767040
    m_Localized: Go to the Dwarf with the key!
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767041
    m_Localized: You found them all! Go back for a reward
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767042
    m_Localized: Now you can unlock the dwarf!
    m_Metadata:
      m_Items: []
  - m_Id: 75056277766529024
    m_Localized: Use the map if you don't find them all!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284266
    m_Localized: Get the key on top of the books.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284250
    m_Localized: Play the notes in order to unlock me!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284225
    m_Localized: Someone saw him going up to the roof
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284236
    m_Localized: Our Dwarf used to conduct the fountain show.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089997
    m_Localized: Find all the animals around the Zoo.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089992
    m_Localized: Where is my cat?
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089990
    m_Localized: I like the Zoo!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089988
    m_Localized: But they ran away when a big blue dog came by!
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284243
    m_Localized: Find all the musical notes around here
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284241
    m_Localized: Play the notes in the right order.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089991
    m_Localized: I want to protect all animals
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089957
    m_Localized: Collect all the books.
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675520
    m_Localized: Memory
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675521
    m_Localized: Puzzle
    m_Metadata:
      m_Items: []
