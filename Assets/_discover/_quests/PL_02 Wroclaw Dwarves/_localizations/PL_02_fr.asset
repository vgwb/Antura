%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73950653611761783
    m_Localized: "Le Ma\xEEtre des Cl\xE9s a besoin des 10 Cl\xE9s Naines !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567411
    m_Localized: "R\xE9essayez plus tard !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567408
    m_Localized: "Pour d\xE9verrouiller la cage, r\xE9solvez cette \xE9nigme !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761767
    m_Localized: Notre nain voyageur adore visiter de nouveaux endroits.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567416
    m_Localized: "Voici la cath\xE9drale de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567472
    m_Localized: "Ici, dans l'ancien h\xF4tel de ville, nous conservons les lois
      de la ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761733
    m_Localized: "Cette fontaine utilise de l'eau, des lumi\xE8res color\xE9es et
      de la musique !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761787
    m_Localized: "Ce nain a besoin d'une derni\xE8re cl\xE9 pour \xEAtre libre !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567435
    m_Localized: Ils ont lu
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761818
    m_Localized: Ils ont lu
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567433
    m_Localized: Ils prient
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761816
    m_Localized: Ils prient
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761820
    m_Localized: Ils jouent
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567437
    m_Localized: Ils jouent
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567456
    m_Localized: Ils ont des tout petits chapeaux et des toutes petites bottes !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761697
    m_Localized: "Il y a toujours quelque chose \xE0 faire au zoo !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567361
    m_Localized: "Il y a un probl\xE8me en ville... allons explorer !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761706
    m_Localized: "Il y a une cl\xE9 derri\xE8re ce panneau l\xE0-bas."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761771
    m_Localized: "On peut y admirer une c\xE9l\xE8bre sculpture d'un artiste nomm\xE9
      Salvador Dal\xED !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567464
    m_Localized: Il y a plus de 800 nains en ville !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761704
    m_Localized: "Le zoo a \xE9t\xE9 construit il y a longtemps, en 1865 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761747
    m_Localized: "Le Nain \xC9crivain est toujours verrouill\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761748
    m_Localized: Le Nain Voyageur se trouve sur la place.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567384
    m_Localized: "Le tram est pr\xEAt. Rendez-vous d'abord \xE0 la cath\xE9drale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761830
    m_Localized: "Le panorama ressemble \xE0 un tableau g\xE9ant qui m'entoure !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567450
    m_Localized: "Le Nain Originel est au march\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761666
    m_Localized: "L'ancien h\xF4tel de ville est un b\xE2timent ancien et important."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761833
    m_Localized: "La fontaine multim\xE9dia utilise l'eau, la lumi\xE8re et la musique."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761699
    m_Localized: "La fontaine multim\xE9dia a besoin de notre aide !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761749
    m_Localized: "Le Ma\xEEtre des Cl\xE9s est pi\xE9g\xE9 pr\xE8s de l'ascenseur
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761772
    m_Localized: "D\xE9placez-vous et sautez par-dessus les \xE9tag\xE8res pour l'attraper."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761757
    m_Localized: "La cl\xE9 se trouve pr\xE8s du coin lecture !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761668
    m_Localized: "La cl\xE9 de la mairie est cach\xE9e derri\xE8re le panneau."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761736
    m_Localized: "L'eau de la fontaine cache une cl\xE9 pr\xE8s de la sc\xE8ne !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761738
    m_Localized: "Le spectacle des fontaines donne l'impression d'\xEAtre un grand
      concert !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761782
    m_Localized: Le dernier round !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761751
    m_Localized: L'ascenseur est maintenant ouvert.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567451
    m_Localized: "Le conseiller nain se trouve pr\xE8s de l'ancien h\xF4tel de ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761802
    m_Localized: La ville est magnifique vue d'ici !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567470
    m_Localized: Le coffre s'ouvre !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567471
    m_Localized: "Le coffre est verrouill\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567454
    m_Localized: "La zone centrale est termin\xE9e !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761700
    m_Localized: "Le secteur du Centennial Hall est termin\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567422
    m_Localized: "La cath\xE9drale se trouve dans l'un des quartiers les plus anciens
      de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567419
    m_Localized: "Le nain \xE9v\xEAque est enferm\xE9 \xE0 proximit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567410
    m_Localized: "Merci ! Vous m'avez sauv\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567390
    m_Localized: "N'h\xE9sitez pas \xE0 me contacter si vous avez besoin d'aide."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567372
    m_Localized: Restez ici
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761760
    m_Localized: Parfois, je m'assieds ici et j'imagine mes propres histoires.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761836
    m_Localized: "Certains nains de Wroc\u0142aw ont l'air dr\xF4les, et d'autres
      ont l'air s\xE9rieux !"
    m_Metadata:
      m_Items: []
  - m_Id: 73951417621012480
    m_Localized: "La Sky Tower est l'un des plus hauts b\xE2timents de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567371
    m_Localized: Tour Sky
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567366
    m_Localized: "\xC9cole"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567389
    m_Localized: "Sauvez le nain de l'\xE9cole."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761731
    m_Localized: Trouvez la musique et sauvez le Nain Chef d'orchestre !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761717
    m_Localized: Trouvez et sauvez le nain architecte !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567423
    m_Localized: "Les gens viennent ici pour prier et r\xE9fl\xE9chir en silence."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567452
    m_Localized: "Panorama Rac\u0142awicka est le dernier endroit ici."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761683
    m_Localized: "Panorama Rac\u0142awicka est une immense image qui fait le tour
      de la pi\xE8ce !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761678
    m_Localized: "Panorama Rac\u0142awicka est une peinture ronde g\xE9ante !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567369
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761755
    m_Localized: "Elle a re\xE7u un prix prestigieux pour ses livres : le prix Nobel
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567382
    m_Localized: "Vous savez maintenant comment lib\xE9rer les autres nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567404
    m_Localized: "Ils se sont d\xE9sormais transform\xE9s en v\xE9hicules magiques
      appel\xE9s \xAB tramways \xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567406
    m_Localized: "Maintenant, allez lib\xE9rer mes dix amis nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567436
    m_Localized: "Non. R\xE9essayez !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761806
    m_Localized: Non, je veux rester ici
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761800
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567440
    m_Localized: "Mes amis ont encore besoin d'aide \xE0 Centennial Hall et dans
      le centre-ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761671
    m_Localized: "Ma famille vit ici depuis tr\xE8s, tr\xE8s longtemps !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567398
    m_Localized: "D\xE9placez la plante pour la trouver !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761756
    m_Localized: "Peut-\xEAtre pourriez-vous lire un livre \xE0 la biblioth\xE8que
      ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567459
    m_Localized: "La place du march\xE9 est l'un des endroits les plus anim\xE9s
      de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761835
    m_Localized: "La place du march\xE9 est un endroit tr\xE8s anim\xE9 et amusant."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567368
    m_Localized: "Halle du march\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761831
    m_Localized: "De nombreuses personnes visitent Wroc\u0142aw pour admirer les
      statues de nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567460
    m_Localized: Beaucoup de gens cherchent des statues de nains en se promenant
      !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761696
    m_Localized: Visitez le zoo, le grand hall et la fontaine.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761685
    m_Localized: Ramassez toutes les couleurs dans le parc.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567400
    m_Localized: "Regardez l'\xE9toile sur la carte."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567449
    m_Localized: "Admirez la place du march\xE9, l'h\xF4tel de ville et le panorama
      de Rac\u0142awicka !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567403
    m_Localized: Il y a longtemps, j'ai construit des tunnels pour les nains dans
      la ville.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567428
    m_Localized: "Quelqu'un pr\xE8s d'ici l'a."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761734
    m_Localized: "C'est une \xE9mission \xAB multim\xE9dia \xBB car elle utilise
      de nombreux \xE9l\xE9ments diff\xE9rents."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761667
    m_Localized: "Il a \xE9t\xE9 construit aux alentours de l'an 1300 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761684
    m_Localized: "On a l'impression d'\xEAtre \xE0 l'int\xE9rieur du tableau !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761720
    m_Localized: "C'est l'un des b\xE2timents les plus c\xE9l\xE8bres de la ville
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567409
    m_Localized: "Elle est verrouill\xE9e. Trouvez une cl\xE9 en or !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761679
    m_Localized: C'est une image qui vous entoure de toutes parts.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567417
    m_Localized: "Il poss\xE8de de hautes tours et de magnifiques fen\xEAtres."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567444
    m_Localized: "J'ai dessin\xE9 une carte de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761724
    m_Localized: "Je pense toujours \xE0 de nouveaux b\xE2timents \xE0 dessiner."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761790
    m_Localized: "Je vais vous d\xE9verrouiller l'ascenseur."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761708
    m_Localized: Je veille sur les animaux. Vous aimez les animaux aussi ?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761775
    m_Localized: "Je veux voyager \xE0 travers le monde un jour."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567439
    m_Localized: "Je reste ici pour aider les gens \xE0 trouver la paix."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761721
    m_Localized: Je le vois ! Il est tout en haut de l'Iglica !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761687
    m_Localized: "Je peins l'histoire de Wroc\u0142aw pour que tout le monde puisse
      la voir."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761723
    m_Localized: J'adore les toits et les hautes arches !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761774
    m_Localized: "J'adore regarder cette sculpture de Salvador Dal\xED !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761688
    m_Localized: J'adore les couleurs vives et les grands tableaux !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761759
    m_Localized: J'adore avoir un bon livre entre les mains !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761709
    m_Localized: "J'esp\xE8re que vous passerez un bon moment au zoo !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567405
    m_Localized: "Je vous offre ce billet sp\xE9cial pour voyager partout !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761789
    m_Localized: "Je peux enfin surveiller toutes les serrures \xE0 nouveau !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761670
    m_Localized: Je suis le conseiller nain. J'assiste le maire de la ville !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567463
    m_Localized: "Je suis l'un des plus vieux nains de la ville ! Je suis apparu
      pour la premi\xE8re fois en 2005."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567394
    m_Localized: Comment puis-je vous aider ?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567395
    m_Localized: "Comment puis-je lib\xE9rer le Nain ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567385
    m_Localized: "Bonjour ! Je suis enseignante \xE0 l'\xE9cole Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567462
    m_Localized: "Voici votre cl\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761753
    m_Localized: "Aidez le nain \xE9crivain."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761682
    m_Localized: Trouvez toutes les couleurs !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761702
    m_Localized: "Trouvez tous les animaux et lib\xE9rez le nain !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761664
    m_Localized: Veuillez trouver tous les livres sur les nains !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761769
    m_Localized: Mais il s'est perdu dans un labyrinthe.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761754
    m_Localized: "Il adore les histoires, les livres et\u2026 les biblioth\xE8ques."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761732
    m_Localized: Mais maintenant, il a perdu toutes les notes !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761718
    m_Localized: "Nous avons besoin de lui pour am\xE9liorer les b\xE2timents"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761703
    m_Localized: Notre nain amoureux des animaux adore tous les animaux
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761829
    m_Localized: "Excellent travail ! Vous avez explor\xE9 Wroc\u0142aw et lib\xE9r\xE9
      tous les nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567401
    m_Localized: Au revoir
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761786
    m_Localized: Du sommet, on peut voir presque toute la ville !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567457
    m_Localized: "Lib\xE9rez le Nain Originel."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567407
    m_Localized: "Tout d'abord, rendez-vous \xE0 la cath\xE9drale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761680
    m_Localized: Trouvez le Nain Peintre ici.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567396
    m_Localized: "Trouvez la cl\xE9. Puis ouvrez la cage !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567420
    m_Localized: "Trouvez la cl\xE9 de la cath\xE9drale et lib\xE9rez-le !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761705
    m_Localized: Des familles viennent ici pour voir des animaux du monde entier.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567388
    m_Localized: "Chaque cage est verrouill\xE9e par une cl\xE9 en or."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567363
    m_Localized: "Dessine ton nain de Wroc\u0142aw pr\xE9f\xE9r\xE9 et l'endroit
      o\xF9 tu l'as trouv\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761797
    m_Localized: Veux-tu monter sur le toit ?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761804
    m_Localized: "Souhaitez-vous r\xE9pondre \xE0 quelques questions pour terminer
      cette qu\xEAte\_?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761739
    m_Localized: Jouez-vous d'un instrument de musique ?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567391
    m_Localized: "Aimes-tu aller \xE0 l'\xE9cole ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761698
    m_Localized: "Avez-vous v\xE9rifi\xE9 \xE0 l'int\xE9rieur du Centennial Hall
      ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567434
    m_Localized: "Exact ! Voici votre cl\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567376
    m_Localized: "Terminez d'abord la t\xE2che !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761735
    m_Localized: Venez ici le soir pour voir le spectacle !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761801
    m_Localized: "Revenez quand vous serez pr\xEAt(e)."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567473
    m_Localized: Mais notre conseiller nain a perdu tous ses livres !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761832
    m_Localized: "Le Centennial Hall est c\xE9l\xE8bre pour son grand toit rond."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761716
    m_Localized: Au secours ! Notre nain architecte a disparu !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761719
    m_Localized: "Centennial Hall poss\xE8de un immense toit rond."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567370
    m_Localized: Salle du Centenaire
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567367
    m_Localized: "Cath\xE9drale"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567386
    m_Localized: "Antura a couru partout \xE0 Wroc\u0142aw ce soir !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567383
    m_Localized: Antura se trouve au sommet de la Sky Tower !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567387
    m_Localized: "Et ce matin, dix nains \xE9taient enferm\xE9s dans des cages !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761803
    m_Localized: "Et regardez... Antura est l\xE0 aussi !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761750
    m_Localized: "Tous les nains de la Tour C\xE9leste sont libres !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761827
    m_Localized: "Un \xE9crivain"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761825
    m_Localized: Un scientifique
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761823
    m_Localized: Un homme politique
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761770
    m_Localized: "Une place est un grand espace ouvert o\xF9 les gens se rencontrent."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761681
    m_Localized: Notre nain peintre a perdu toutes ses couleurs !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567461
    m_Localized: "Une cl\xE9 se trouve sous un pot de fleurs sur le march\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761809
    m_Localized: Une fontaine
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761752
    m_Localized: "La c\xE9l\xE8bre \xE9crivaine Olga Tokarczuk a v\xE9cu pr\xE8s
      d'ici !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761811
    m_Localized: Un nain
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761813
    m_Localized: "Une cl\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761784
    m_Localized: "D\xE9bloquez d'abord les deux autres nains ici, puis revenez."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761768
    m_Localized: Trouvez et sauvez le Nain Voyageur !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761799
    m_Localized: En route pour le sommet de la Sky Tower !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567445
    m_Localized: "Utilisez-le pour voir o\xF9 vous \xEAtes et o\xF9 aller !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567415
    m_Localized: "Utilisez le tram pour choisir votre prochain arr\xEAt."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567414
    m_Localized: "Nous sommes \xE0 l'arr\xEAt Bema, pr\xE8s de la cath\xE9drale."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567381
    m_Localized: "Nous sommes \xE0 l'\xE9cole primaire Leonardo !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761695
    m_Localized: Bienvenue au Centennial Hall !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761746
    m_Localized: "Bienvenue \xE0 la Sky Tower ! Elle est tr\xE8s haute."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567360
    m_Localized: "Bienvenue \xE0 Wroc\u0142aw !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761815
    m_Localized: "Que font les gens dans une cath\xE9drale ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567432
    m_Localized: "Que font les gens dans une cath\xE9drale ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761808
    m_Localized: "Quel est le symbole c\xE9l\xE8bre de Wroc\u0142aw ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567365
    m_Localized: "O\xF9 veux-tu aller ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567399
    m_Localized: "O\xF9 est le nain ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567397
    m_Localized: "O\xF9 est la cl\xE9 ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761822
    m_Localized: Qui est Olga Tokarczuk ?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567465
    m_Localized: Nous retrouverez-vous tous ?
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567455
    m_Localized: "Wroc\u0142aw est c\xE9l\xE8bre pour ses petits nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761701
    m_Localized: "Le zoo de Wroc\u0142aw est le plus grand zoo de Pologne !"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761798
    m_Localized: Oui
    m_Metadata:
      m_Items: []
  - m_Id: 73950653611761812
    m_Localized: Oui, c'est exact !
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567364
    m_Localized: "Vous ne pouvez pas encore aller \xE0 la Sky Tower."
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567453
    m_Localized: Vous pouvez prendre le tram si vous ne voulez pas marcher.
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567362
    m_Localized: "Vous avez termin\xE9 cette qu\xEAte. Vous a-t-elle plu\_?"
    m_Metadata:
      m_Items: []
  - m_Id: 73950653607567402
    m_Localized: "Vous l'avez trouv\xE9 ! Maintenant, allez lib\xE9rer le nain !"
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767041
    m_Localized: "Vous les avez tous trouv\xE9s ! Retournez chercher votre r\xE9compense."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089992
    m_Localized: "O\xF9 est mon chat ?"
    m_Metadata:
      m_Items: []
  - m_Id: 75056277766529024
    m_Localized: Utilisez la carte si vous ne les trouvez pas tous !
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284289
    m_Localized: L'ascenseur ne fonctionne pas !
    m_Metadata:
      m_Items: []
  - m_Id: 75156437523750912
    m_Localized: Quelqu'un l'a vu monter sur le toit.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284225
    m_Localized: Quelqu'un l'a vu monter sur le toit.
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675521
    m_Localized: Puzzle
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284241
    m_Localized: Jouez les notes dans le bon ordre.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284250
    m_Localized: "Jouez les notes pour me d\xE9bloquer !"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284236
    m_Localized: Notre nain s'occupait du spectacle de la fontaine.
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767042
    m_Localized: "Vous pouvez maintenant d\xE9bloquer le nain !"
    m_Metadata:
      m_Items: []
  - m_Id: 76324969053675520
    m_Localized: "M\xE9moire"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089991
    m_Localized: "Je veux prot\xE9ger tous les animaux"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089990
    m_Localized: J'aime le zoo !
    m_Metadata:
      m_Items: []
  - m_Id: 75055334903767040
    m_Localized: "Allez voir le nain qui a la cl\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284280
    m_Localized: "Allez voir le Ma\xEEtre Nain !"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284266
    m_Localized: "Prenez la cl\xE9 qui se trouve au-dessus des livres."
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284243
    m_Localized: Trouvez toutes les notes de musique ici.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089997
    m_Localized: Trouvez tous les animaux du zoo.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298927284300
    m_Localized: "Tu veux jouer \xE0 un jeu ?"
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089957
    m_Localized: Rassemblez tous les livres.
    m_Metadata:
      m_Items: []
  - m_Id: 76344298923089988
    m_Localized: "Mais ils se sont enfuis lorsqu'un gros chien bleu est pass\xE9
      !"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
