%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: PL_02_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: 76ed99c41e9c145fe815aa8d21584d38, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "Elle tournoie comme un pinceau, tra\xE7ant un dernier tourbillon
      joyeux."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "Le motif de la fontaine repr\xE9sente une cl\xE9 pr\xE8s de la
      sc\xE8ne."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: Qui est Olga Tokarczuk ?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: Centennial Hall est connu pour son grand toit rond.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "Vous avez termin\xE9 la qu\xEAte des Nains de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: Rien
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "Une place est un lieu ouvert o\xF9 les gens se rencontrent."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "Dessine ton nain de Wroc\u0142aw pr\xE9f\xE9r\xE9 et l'endroit
      o\xF9 tu l'as trouv\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "Le tram est pr\xEAt. Rendez-vous d'abord \xE0 la cath\xE9drale."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: Les familles aiment assister au spectacle de la fontaine.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: Panorama
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: Tour Sky
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: Comment puis-je vous aider ?
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: Les gens viennent ici pour prier.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "Une lettre vivante d\xE9signe une cl\xE9 pr\xE8s de la porte de
      la cath\xE9drale."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "C'est une image g\xE9ante qui vous entoure."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "La place du march\xE9 est l'un des endroits les plus anim\xE9s
      de la ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "Le Nain Chef d'Orchestre est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: La Sky Tower est facilement visible depuis de nombreux endroits
      de la ville.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: "Ce nain adore les endroits anim\xE9s et les nouveaux chemins."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: "O\xF9 est la cl\xE9 ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "Le Nain Originel est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "Maintenant, allez d\xE9verrouiller le nain !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: "Trouvez le nain de l'\xE9cole ici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "Il y a un probl\xE8me en ville... allons explorer !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "Trouvez la cl\xE9 de la mairie."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "R\xE9pondez \xE0 cette question pour ouvrir la cage."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: "Regardez l'\xE9toile sur la carte."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "La cl\xE9 se trouve pr\xE8s de l'ascenseur."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: Ils jouent
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: La ville est magnifique vue d'ici.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "Utilisez le tram pour choisir votre prochain arr\xEAt."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "La cl\xE9 de la mairie est cach\xE9e derri\xE8re le panneau."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: Ils prient
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "Trouvez la l\xE9gende. Puis copiez le motif de la fontaine."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: Voici le Nain Peintre du hub central.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "Notre place du march\xE9 est un endroit anim\xE9 o\xF9 se promener
      et retrouver des amis."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "Olga Tokarczuk est une \xE9crivaine c\xE9l\xE8bre."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: Ce nain adore les pattes, les ailes et les moustaches.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "Vous savez maintenant comment lib\xE9rer les nains. Trouvez-en
      10 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "Comment puis-je lib\xE9rer le Nain ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "Les dirigeants de la ville travaillent et se r\xE9unissent ici."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "Trouvez la cl\xE9 cach\xE9e sur le march\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: "Ils p\xEAchent"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "Quel est le symbole c\xE9l\xE8bre de Wroc\u0142aw ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "La carte de Wroc\u0142aw est \xE0 vous maintenant."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "Le panorama qui m'entoure ressemble \xE0 un tableau."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "Trouvez la cl\xE9. Puis ouvrez la cage."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: "O\xF9 est le nain ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "Ce nain adore les plans, les documents et les r\xE9unions importantes."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: Nous sommes fiers du Centennial Hall et de son grand toit rond.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503304
    m_Localized: "Wroc\u0142aw est c\xE9l\xE8bre pour ses petits nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503351
    m_Localized: Regardez dans le zoo, le hall et la fontaine.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503394
    m_Localized: "Bienvenue \xE0 la Sky Tower."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503327
    m_Localized: "Elle redresse son petit chapeau comme un maire tr\xE8s occup\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503339
    m_Localized: Ce nain adore les couleurs, la peinture et les grands tableaux.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697546
    m_Localized: "La Sky Tower est l'un des plus hauts b\xE2timents de Wroclaw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503338
    m_Localized: "Un panorama est une image g\xE9ante qui vous entoure."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503439
    m_Localized: "Souhaitez-vous r\xE9pondre \xE0 quelques questions ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697552
    m_Localized: "La cath\xE9drale est l'un des lieux les plus c\xE9l\xE8bres de
      Wroclaw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503340
    m_Localized: "Trouvez la cl\xE9, puis assemblez les morceaux de l'image pour
      ouvrir la cage."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503282
    m_Localized: "Le nain \xE9v\xEAque est enferm\xE9 \xE0 proximit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503355
    m_Localized: "Le zoo de Wroc\u0142aw est le plus grand zoo de Pologne."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503415
    m_Localized: "Trouvez la cl\xE9 de la place."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503450
    m_Localized: "Que font les gens dans une cath\xE9drale ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697545
    m_Localized: "La fontaine multim\xE9dia utilise l'eau, la lumi\xE8re et la musique."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503418
    m_Localized: "Le Nain Voyageur est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503388
    m_Localized: "Elle agite son petit b\xE2ton et s'incline devant la fontaine."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503280
    m_Localized: "Il poss\xE8de de hautes tours et des fen\xEAtres lumineuses."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697548
    m_Localized: "Certains nains de Wroclaw ont l'air dr\xF4les, d'autres ont l'air
      s\xE9rieux."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503311
    m_Localized: "Elle remue ses petites bottes et fait une r\xE9v\xE9rence joyeuse."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503270
    m_Localized: "Commencez par vous rendre \xE0 la cath\xE9drale. On vous aidera
      \xE0 lire le plan."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503400
    m_Localized: Ce nain adore les histoires, les livres et les endroits calmes.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503232
    m_Localized: "Bienvenue \xE0 Wroc\u0142aw !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503257
    m_Localized: "Chaque cage est scell\xE9e par une cl\xE9 en or."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503326
    m_Localized: "Le conseiller nain est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503370
    m_Localized: "Ce nain adore les formes, les b\xE2timents et les conceptions ing\xE9nieuses."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503255
    m_Localized: "Bonjour ! Je suis enseignante \xE0 l'\xE9cole Leonardo."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503371
    m_Localized: "R\xE9solvez l'\xE9nigme du couloir pour trouver la cl\xE9 cach\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503458
    m_Localized: "Un \xE9crivain"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503253
    m_Localized: Antura se trouve au sommet de la Sky Tower !
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503357
    m_Localized: "Trouvez la cl\xE9 du zoo. Ensuite, parlez au gardien."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503312
    m_Localized: "Le conseiller nain se trouve pr\xE8s de l'ancien h\xF4tel de ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503287
    m_Localized: Ils prient
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697549
    m_Localized: "\xC0 Wroclaw, beaucoup de gens connaissent leur nain pr\xE9f\xE9r\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503264
    m_Localized: "D\xE9placez la plante pour la trouver."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503343
    m_Localized: "Le nain peintre est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697537
    m_Localized: Un pilote
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503401
    m_Localized: "Trouvez la cl\xE9 de l'auteur. Ensuite, parlez au lecteur."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503416
    m_Localized: "La cl\xE9 se trouve sous un banc sur la place."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503446
    m_Localized: Une baleine
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503419
    m_Localized: "Il tourne sur lui-m\xEAme comme s'il \xE9tait pr\xEAt pour le prochain
      voyage."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503358
    m_Localized: "Il y a une cl\xE9 derri\xE8re le panneau."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503269
    m_Localized: "Lib\xE9rez mes 10 amis nains de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503256
    m_Localized: "Dix nains sont enferm\xE9s dans des cages magiques \xE0 Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503442
    m_Localized: "Revenez quand vous serez pr\xEAt(e)."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503444
    m_Localized: Un nain
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503404
    m_Localized: "Le Nain \xC9crivain est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503453
    m_Localized: Ils font des courses de voitures
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503437
    m_Localized: Nous montons au sommet de la Sky Tower.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503405
    m_Localized: Elle enserre un minuscule livre et vous sourit.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503247
    m_Localized: "Terminez d'abord la t\xE2che !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503374
    m_Localized: "L'architecte nain est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503369
    m_Localized: "Le Centennial Hall est tr\xE8s grand et poss\xE8de un c\xE9l\xE8bre
      toit rond."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697539
    m_Localized: "Un chat g\xE9ant"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503448
    m_Localized: "Une fus\xE9e"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503431
    m_Localized: "Cling, clang, tintement. Je vais vous d\xE9verrouiller l'ascenseur."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503335
    m_Localized: Trouvez le Nain Peintre ici.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503300
    m_Localized: "Admirez la place du march\xE9, l'h\xF4tel de ville et le panorama
      de Raclawicka."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697541
    m_Localized: "Excellent travail ! Vous avez explor\xE9 Wroc\u0142aw et lib\xE9r\xE9
      tous les nains."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503375
    m_Localized: "Elle tapote fi\xE8rement l'air comme si elle dessinait un nouveau
      toit."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503237
    m_Localized: "\xC9cole"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503308
    m_Localized: "Une cl\xE9 se trouve sous un pot de fleurs sur le march\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697543
    m_Localized: De nombreuses personnes visitent Wroclaw pour admirer les statues
      de nains.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503382
    m_Localized: "Cette fontaine utilise de l'eau, des lumi\xE8res et de la musique."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503295
    m_Localized: Utilisez-le pour vous rendre au centre-ville ou au Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503277
    m_Localized: "Nous sommes \xE0 l'arr\xEAt Bema, pr\xE8s de la cath\xE9drale."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503402
    m_Localized: "La cl\xE9 se trouve pr\xE8s du coin lecture."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503350
    m_Localized: Bienvenue dans l'espace du Centennial Hall.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503319
    m_Localized: "Voici l'ancien h\xF4tel de ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503288
    m_Localized: "Exact. Voici votre cl\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503289
    m_Localized: Ils ont lu
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503271
    m_Localized: Il y a longtemps, j'ai construit des tunnels pour les nains dans
      la ville.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503430
    m_Localized: "Le nain ma\xEEtre des cl\xE9s est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503286
    m_Localized: "Que font les gens dans une cath\xE9drale ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503426
    m_Localized: "Les autres nains vous indiquent o\xF9 regarder."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503427
    m_Localized: "Trouvez la derni\xE8re cl\xE9 pr\xE8s du panneau de l'ascenseur."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503279
    m_Localized: "Voici la cath\xE9drale de Wroc\u0142aw."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503283
    m_Localized: "Trouvez la cl\xE9 de la cath\xE9drale et lib\xE9rez l'\xE9v\xEAque
      nain."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503360
    m_Localized: "Le nain amoureux des animaux est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503383
    m_Localized: "Ce nain adore les \xE9claboussures, les paillettes et les chansons."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503305
    m_Localized: Ils ont des chapeaux minuscules et des bottes minuscules.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503361
    m_Localized: "Il gazouille, renifle et agite la patte en m\xEAme temps."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503333
    m_Localized: "Panorama Raclawicka fait partie du p\xF4le Centre."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503398
    m_Localized: "Voici l'un des nains de la Tour C\xE9leste."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503293
    m_Localized: "L'\xE9v\xEAque nain est d\xE9sormais en s\xE9curit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503309
    m_Localized: "Voici votre cl\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503397
    m_Localized: "Tous les nains de la Tour C\xE9leste sont libres."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503352
    m_Localized: "Un autre nain se trouve pr\xE8s du Centennial Hall."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503354
    m_Localized: "Les travaux dans le hall du Centenaire sont termin\xE9s."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503303
    m_Localized: "La zone centrale est termin\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503272
    m_Localized: "Ils se sont d\xE9sormais transform\xE9s en v\xE9hicules magiques."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503301
    m_Localized: "Le conseiller nain se trouve pr\xE8s de l'ancien h\xF4tel de ville."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503275
    m_Localized: "Merci ! Vous m'avez sauv\xE9 !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503425
    m_Localized: L'ascenseur est maintenant ouvert.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503353
    m_Localized: La fontaine est le dernier endroit ici.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503341
    m_Localized: "L'image finale montre une cl\xE9 sous le cadre."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503396
    m_Localized: "La cage du Ma\xEEtre des Cl\xE9s se trouve pr\xE8s de l'ascenseur."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503274
    m_Localized: "Elle est verrouill\xE9e. Trouvez une cl\xE9 en or !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503441
    m_Localized: Non
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503302
    m_Localized: Panorama Raclawicka est le dernier endroit ici.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503273
    m_Localized: "Pour d\xE9verrouiller la cage, r\xE9solvez ce puzzle."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503243
    m_Localized: Restez ici
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503259
    m_Localized: "N'h\xE9sitez pas \xE0 me contacter si vous avez besoin d'aide."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503238
    m_Localized: "Cath\xE9drale"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503241
    m_Localized: Salle du Centenaire
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503240
    m_Localized: "Halle du march\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503395
    m_Localized: Le Nain Voyageur se trouve sur la place.
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503290
    m_Localized: "Non. R\xE9essayez."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503276
    m_Localized: "R\xE9essayez plus tard !"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503236
    m_Localized: "O\xF9 veux-tu aller ?"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503440
    m_Localized: Oui
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503445
    m_Localized: Oui, c'est exact.
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
