  m_TableData:
  - m_Id: 73346184641503344
    m_Localized: "\u062A\u062F\u0648\u0631 \u0643\u0641\u0631\u0634\u0627\u0629\u060C
      \u0641\u062A\u0635\u0646\u0639 \u062F\u0648\u0627\u0645\u0629 \u0623\u062E\u064A\u0631\u0629
      \u0633\u0639\u064A\u062F\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503385
    m_Localized: "\u064A\u064F\u0638\u0647\u0631 \u062A\u0635\u0645\u064A\u0645 \u0627\u0644\u0646\u0627\u0641\u0648\u0631\u0629
      \u0645\u0641\u062A\u0627\u062D\u064B\u0627 \u0628\u0627\u0644\u0642\u0631\u0628
      \u0645\u0646 \u0627\u0644\u0645\u0633\u0631\u062D."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503457
    m_Localized: "\u0645\u0646 \u0647\u064A \u0623\u0648\u0644\u063A\u0627 \u062A\u0648\u0643\u0627\u0631\u062A\u0634\u0648\u0643\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697544
    m_Localized: "\u062A\u0634\u062A\u0647\u0631 \u0642\u0627\u0639\u0629 \u0633\u064A\u0646\u062A\u064A\u0646\u064A\u0627\u0644
      \u0628\u0633\u0642\u0641\u0647\u0627 \u0627\u0644\u062F\u0627\u0626\u0631\u064A
      \u0627\u0644\u0643\u0628\u064A\u0631."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503234
    m_Localized: "\u0644\u0642\u062F \u0623\u0646\u0647\u064A\u062A \u0645\u0647\u0645\u0629
      \u0623\u0642\u0632\u0627\u0645 \u0641\u0631\u0648\u062A\u0633\u0648\u0627\u0641."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503267
    m_Localized: "\u0644\u0627 \u0634\u0626"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503413
    m_Localized: "\u0627\u0644\u0633\u0627\u062D\u0629 \u0647\u064A \u0645\u0643\u0627\u0646
      \u0645\u0641\u062A\u0648\u062D \u064A\u0644\u062A\u0642\u064A \u0641\u064A\u0647
      \u0627\u0644\u0646\u0627\u0633."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503235
    m_Localized: "\u0627\u0631\u0633\u0645 \u0642\u0632\u0645\u0643 \u0627\u0644\u0645\u0641\u0636\u0644
      \u0645\u0646 \u0641\u0631\u0648\u062A\u0633\u0648\u0627\u0641 \u0648\u0627\u0644\u0645\u0643\u0627\u0646
      \u0627\u0644\u0630\u064A \u0648\u062C\u062F\u062A\u0647 \u0641\u064A\u0647."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503254
    m_Localized: "\u0627\u0644\u062A\u0631\u0627\u0645 \u062C\u0627\u0647\u0632.
      \u062A\u0648\u062C\u0647 \u0623\u0648\u0644\u0627\u064B \u0625\u0644\u0649
      \u0627\u0644\u0643\u0627\u062A\u062F\u0631\u0627\u0626\u064A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697553
    m_Localized: "\u062A\u062D\u0628 \u0627\u0644\u0639\u0627\u0626\u0644\u0627\u062A
      \u0645\u0634\u0627\u0647\u062F\u0629 \u0639\u0631\u0636 \u0627\u0644\u0646\u0627\u0641\u0648\u0631\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503239
    m_Localized: "\u0628\u0627\u0646\u0648\u0631\u0627\u0645\u0627"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503242
    m_Localized: "\u0628\u0631\u062C \u0633\u0643\u0627\u064A"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503260
    m_Localized: "\u0643\u064A\u0641 \u064A\u0645\u0643\u0646\u0646\u064A \u0627\u0644\u0645\u0633\u0627\u0639\u062F\u0629\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503281
    m_Localized: "\u064A\u0623\u062A\u064A \u0627\u0644\u0646\u0627\u0633 \u0625\u0644\u0649
      \u0647\u0646\u0627 \u0644\u0644\u0635\u0644\u0627\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503285
    m_Localized: "\u062A\u0634\u064A\u0631 \u0631\u0633\u0627\u0644\u0629 \u062D\u064A\u0629
      \u0625\u0644\u0649 \u0645\u0641\u062A\u0627\u062D \u0628\u062C\u0627\u0646\u0628
      \u0628\u0627\u0628 \u0627\u0644\u0643\u0627\u062A\u062F\u0631\u0627\u0626\u064A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503334
    m_Localized: "\u0625\u0646\u0647\u0627 \u0635\u0648\u0631\u0629 \u0639\u0645\u0644\u0627\u0642\u0629
      \u062A\u062D\u064A\u0637 \u0628\u0643 \u0645\u0646 \u0643\u0644 \u062C\u0627\u0646\u0628."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697547
    m_Localized: "\u062A\u064F\u0639\u062F \u0633\u0627\u062D\u0629 \u0627\u0644\u0633\u0648\u0642
      \u0648\u0627\u062D\u062F\u0629 \u0645\u0646 \u0623\u0643\u062B\u0631 \u0627\u0644\u0623\u0645\u0627\u0643\u0646
      \u0627\u0632\u062F\u062D\u0627\u0645\u0627\u064B \u0641\u064A \u0627\u0644\u0645\u062F\u064A\u0646\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503387
    m_Localized: "\u0623\u0635\u0628\u062D \u0627\u0644\u0642\u0632\u0645 \u0627\u0644\u0645\u0648\u0635\u0644
      \u0622\u0645\u0646\u0627\u064B \u0627\u0644\u0622\u0646."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697554
    m_Localized: "\u064A\u0633\u0647\u0644 \u0631\u0624\u064A\u0629 \u0628\u0631\u062C
      \u0633\u0643\u0627\u064A \u0645\u0646 \u0623\u062C\u0632\u0627\u0621 \u0643\u062B\u064A\u0631\u0629
      \u0645\u0646 \u0627\u0644\u0645\u062F\u064A\u0646\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503414
    m_Localized: "\u0647\u0630\u0627 \u0627\u0644\u0642\u0632\u0645 \u064A\u0639\u0634\u0642
      \u0627\u0644\u0623\u0645\u0627\u0643\u0646 \u0627\u0644\u0645\u0632\u062F\u062D\u0645\u0629
      \u0648\u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062A \u0627\u0644\u062C\u062F\u064A\u062F\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503263
    m_Localized: "\u0623\u064A\u0646 \u0627\u0644\u0645\u0641\u062A\u0627\u062D\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503310
    m_Localized: "\u0623\u0635\u0628\u062D \u0642\u0632\u0645 \u0627\u0644\u0623\u0635\u0644
      \u0622\u0645\u0646\u0627\u064B \u0627\u0644\u0622\u0646."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503268
    m_Localized: "\u0648\u0627\u0644\u0622\u0646 \u0627\u0630\u0647\u0628 \u0648\u0627\u0641\u062A\u062D
      \u0642\u0641\u0644 \u0627\u0644\u0642\u0632\u0645!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503258
    m_Localized: "\u0627\u0639\u062B\u0631 \u0639\u0644\u0649 \u0642\u0632\u0645
      \u0627\u0644\u0645\u062F\u0631\u0633\u0629 \u0647\u0646\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503233
    m_Localized: "\u0647\u0646\u0627\u0643 \u0645\u0634\u0643\u0644\u0629 \u0641\u064A
      \u0627\u0644\u0645\u062F\u064A\u0646\u0629... \u0647\u064A\u0627 \u0628\u0646\u0627
      \u0646\u0633\u062A\u0643\u0634\u0641\u0647\u0627!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503322
    m_Localized: "\u0627\u0628\u062D\u062B \u0639\u0646 \u0645\u0641\u062A\u0627\u062D
      \u0645\u0628\u0646\u0649 \u0627\u0644\u0628\u0644\u062F\u064A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503296
    m_Localized: "\u0623\u062C\u0628 \u0639\u0646 \u0647\u0630\u0627 \u0627\u0644\u0633\u0624\u0627\u0644
      \u0644\u0641\u062A\u062D \u0627\u0644\u0642\u0641\u0635."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503266
    m_Localized: "\u0627\u0646\u0638\u0631 \u0625\u0644\u0649 \u0627\u0644\u0646\u062C\u0645\u0629
      \u0639\u0644\u0649 \u0627\u0644\u062E\u0631\u064A\u0637\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503428
    m_Localized: "\u0627\u0644\u0645\u0641\u062A\u0627\u062D \u0645\u0648\u062C\u0648\u062F
      \u0628\u0627\u0644\u0642\u0631\u0628 \u0645\u0646 \u0627\u0644\u0645\u0635\u0639\u062F."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503291
    m_Localized: "\u064A\u0644\u0639\u0628\u0648\u0646"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503438
    m_Localized: "\u062A\u0628\u062F\u0648 \u0627\u0644\u0645\u062F\u064A\u0646\u0629
      \u062C\u0645\u064A\u0644\u0629 \u0645\u0646 \u0647\u0646\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503278
    m_Localized: "\u0627\u0633\u062A\u062E\u062F\u0645 \u0627\u0644\u062A\u0631\u0627\u0645
      \u0644\u0627\u062E\u062A\u064A\u0627\u0631 \u0645\u062D\u0637\u062A\u0643 \u0627\u0644\u062A\u0627\u0644\u064A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503324
    m_Localized: "\u064A\u0648\u062C\u062F \u0645\u0641\u062A\u0627\u062D \u0642\u0627\u0639\u0629
      \u0627\u0644\u0645\u062F\u064A\u0646\u0629 \u0627\u0644\u0645\u062E\u0641\u064A
      \u062E\u0644\u0641 \u0627\u0644\u0644\u0627\u0641\u062A\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503451
    m_Localized: "\u064A\u0635\u0644\u0651\u0648\u0646"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503384
    m_Localized: "\u0627\u0639\u062B\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u0641\u062A\u0627\u062D.
      \u062B\u0645 \u0627\u0646\u0633\u062E \u0646\u0645\u0637 \u0627\u0644\u0646\u0627\u0641\u0648\u0631\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503337
    m_Localized: "\u0647\u0630\u0627 \u0647\u0648 \u0642\u0632\u0645 \u0627\u0644\u0631\u0633\u0627\u0645
      \u0645\u0646 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0631\u0626\u064A\u0633\u064A."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697550
    m_Localized: "\u062A\u064F\u0639\u062F \u0633\u0627\u062D\u0629 \u0627\u0644\u0633\u0648\u0642
      \u0644\u062F\u064A\u0646\u0627 \u0645\u0643\u0627\u0646\u0627\u064B \u0646\u0627\u0628\u0636\u0627\u064B
      \u0628\u0627\u0644\u062D\u064A\u0627\u0629 \u0644\u0644\u062A\u0646\u0632\u0647
      \u0648\u0627\u0644\u0627\u0644\u062A\u0642\u0627\u0621 \u0628\u0627\u0644\u0623\u0635\u062F\u0642\u0627\u0621."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503399
    m_Localized: "\u0623\u0648\u0644\u063A\u0627 \u062A\u0648\u0643\u0627\u0631\u062A\u0634\u0648\u0643
      \u0643\u0627\u062A\u0628\u0629 \u0645\u0634\u0647\u0648\u0631\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503356
    m_Localized: "\u0647\u0630\u0627 \u0627\u0644\u0642\u0632\u0645 \u064A\u0639\u0634\u0642
      \u0627\u0644\u0643\u0641\u0648\u0641 \u0648\u0627\u0644\u0623\u062C\u0646\u062D\u0629
      \u0648\u0627\u0644\u0634\u0648\u0627\u0631\u0628."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503252
    m_Localized: "\u0627\u0644\u0622\u0646 \u062A\u0639\u0631\u0641 \u0643\u064A\u0641
      \u062A\u062D\u0631\u0631 \u0627\u0644\u0623\u0642\u0632\u0627\u0645. \u0627\u0628\u062D\u062B
      \u0639\u0646 10 \u0645\u0646\u0647\u0645 \u0627\u0644\u0622\u0646!"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503261
    m_Localized: "\u0643\u064A\u0641 \u064A\u0645\u0643\u0646\u0646\u064A \u062A\u062D\u0631\u064A\u0631
      \u0627\u0644\u0642\u0632\u0645\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503321
    m_Localized: "\u064A\u0639\u0645\u0644 \u0642\u0627\u062F\u0629 \u0627\u0644\u0645\u062F\u064A\u0646\u0629
      \u0648\u064A\u062C\u062A\u0645\u0639\u0648\u0646 \u0647\u0646\u0627."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503306
    m_Localized: "\u0627\u0628\u062D\u062B \u0639\u0646 \u0627\u0644\u0645\u0641\u062A\u0627\u062D
      \u0627\u0644\u0645\u062E\u0641\u064A \u0641\u064A \u0627\u0644\u0633\u0648\u0642."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503455
    m_Localized: "\u0625\u0646\u0647\u0645 \u064A\u0635\u0637\u0627\u062F\u0648\u0646
      \u0627\u0644\u0633\u0645\u0643"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503443
    m_Localized: "\u0645\u0627 \u0647\u0648 \u0627\u0644\u0631\u0645\u0632 \u0627\u0644\u0634\u0647\u064A\u0631
      \u0644\u0645\u062F\u064A\u0646\u0629 \u0641\u0631\u0648\u062A\u0633\u0648\u0627\u0641\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503294
    m_Localized: "\u062E\u0631\u064A\u0637\u0629 \u0641\u0631\u0648\u062A\u0633\u0648\u0627\u0641
      \u0623\u0635\u0628\u062D\u062A \u0645\u0644\u0643\u0643 \u0627\u0644\u0622\u0646."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697542
    m_Localized: "\u062A\u0628\u062F\u0648 \u0627\u0644\u0645\u0646\u0627\u0638\u0631
      \u0627\u0644\u0628\u0627\u0646\u0648\u0631\u0627\u0645\u064A\u0629 \u0643\u0644\u0648\u062D\u0629
      \u0641\u0646\u064A\u0629 \u062A\u062D\u064A\u0637 \u0628\u064A \u0645\u0646
      \u0643\u0644 \u062C\u0627\u0646\u0628."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503262
    m_Localized: "\u0627\u0639\u062B\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u0641\u062A\u0627\u062D.
      \u062B\u0645 \u0627\u0641\u062A\u062D \u0627\u0644\u0642\u0641\u0635."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503265
    m_Localized: "\u0623\u064A\u0646 \u0627\u0644\u0642\u0632\u0645\u061F"
    m_Metadata:
      m_Items: []
  - m_Id: 73346184641503320
    m_Localized: "\u0647\u0630\u0627 \u0627\u0644\u0642\u0632\u0645 \u064A\u0639\u0634\u0642
      \u0627\u0644\u062E\u0637\u0637 \u0648\u0627\u0644\u0623\u0648\u0631\u0627\u0642
      \u0648\u0627\u0644\u0627\u062C\u062A\u0645\u0627\u0639\u0627\u062A \u0627\u0644\u0645\u0647\u0645\u0629."
    m_Metadata:
      m_Items: []
  - m_Id: 73346184645697551
    m_Localized: "\u0646\u062D\u0646 \u0641\u062E\u0648\u0631\u0648\u0646 \u0628\u0642\u0627\u0639\u0629
      \u0633\u064A\u0646\u062A\u064A\u0646\u064A\u0627\u0644 \u0648\u0633\u0642\u0641\u0647\u0627
      \u0627\u0644\u062F\u0627\u0626\u0631\u064A \u0627\u0644\u0643\u0628\u064A\u0631."
    m_Metadata:
      m_Items: []
