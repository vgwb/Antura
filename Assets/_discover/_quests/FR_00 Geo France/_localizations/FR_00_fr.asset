  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_00_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: 9481a1e17b8714c969d2c646ab788881, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 189866696704
    m_Localized: "Bravo ! Tu as r\xE9ussi !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696752
    m_Localized: Nous sommes un petit pays et parlons trois langues !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696753
    m_Localized: Trouve le drapeau du Luxembourg.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696754
    m_Localized: Il est rouge, blanc et bleu clair.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696755
    m_Localized: Le drapeau du Luxembourg.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696757
    m_Localized: La capitale de la Suisse est Berne !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696758
    m_Localized: "Merci d'avoir rapport\xE9 mon drapeau !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696759
    m_Localized: Notre drapeau est rouge avec une croix blanche.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696760
    m_Localized: Bonjour ! Je viens de Suisse !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696761
    m_Localized: Chez nous, il y a du fromage et des montagnes avec de la neige.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696762
    m_Localized: Trouve le drapeau suisse.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696763
    m_Localized: Il est rouge avec une grande croix blanche comme une trousse de
      secours.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696764
    m_Localized: Bonjour ! Je suis de Monaco !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696765
    m_Localized: "Nous sommes un petit pays. Nous avons des courses de voitures et
      un palais au bord de la mer\_!"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696766
    m_Localized: Mon drapeau est rouge et blanc.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696767
    m_Localized: "Bonjour ! Je viens d\u2019Andorre !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696768
    m_Localized: Mon drapeau est bleu, jaune et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696769
    m_Localized: Le drapeau de l'Espagne
    m_Metadata:
      m_Items: []
  - m_Id: 189866696770
    m_Localized: Le drapeau de l'Allemagne.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696771
    m_Localized: Le drapeau de l'Italie.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696772
    m_Localized: Le drapeau de la Suisse.
    m_Metadata:
      m_Items: []
  - m_Id: 74274437062656
    m_Localized: "Bienvenue \xE0 la qu\xEAte de g\xE9ographie !"
    m_Metadata:
      m_Items: []
  - m_Id: 470753152589824
    m_Localized: "Vous avez d\xE9couvert une partie de l'Europe de l'Ouest !"
    m_Metadata:
      m_Items: []
  - m_Id: 470753152589825
    m_Localized: Merci de m'aider !
    m_Metadata:
      m_Items: []
  - m_Id: 470753152589826
    m_Localized: Peux-tu aider mes autres amis ?
    m_Metadata:
      m_Items: []
  - m_Id: 470753156784128
    m_Localized: Pouvez-vous aider mon ami luxembourgeois ?
    m_Metadata:
      m_Items: []
  - m_Id: 470753156784129
    m_Localized: Peux-tu aider mon ami suisse ?
    m_Metadata:
      m_Items: []
  - m_Id: 470753156784130
    m_Localized: "Retournez au d\xE9part et remportez votre victoire !"
    m_Metadata:
      m_Items: []
  - m_Id: 1510057664569344
    m_Localized: Bienvenue en France !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696705
    m_Localized: Oui, c'est mon drapeau ! Merci !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696706
    m_Localized: Maintenant, peux-tu aider nos amis allemands  ?
    m_Metadata:
      m_Items: []
  - m_Id: 189866696707
    m_Localized: Ce n'est pas mon drapeau. Le mien est bleu, blanc et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696708
    m_Localized: Bonjour ! Je viens de France !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696709
    m_Localized: "Antura a m\xE9lang\xE9 tous les drapeaux !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696710
    m_Localized: Mon drapeau est bleu, blanc et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696711
    m_Localized: Peux-tu m'aider?
    m_Metadata:
      m_Items: []
  - m_Id: 189866696712
    m_Localized: "Trouve le drapeau fran\xE7ais."
    m_Metadata:
      m_Items: []
  - m_Id: 189866696713
    m_Localized: Le drapeau de la France.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696715
    m_Localized: Berlin est la capitale de l'Allemagne.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696716
    m_Localized: Merci ! C'est mon drapeau !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696717
    m_Localized: Peux-tu aider mon ami italien ?
    m_Metadata:
      m_Items: []
  - m_Id: 189866696718
    m_Localized: Notre drapeau a des rayures noires, rouges et jaunes.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696719
    m_Localized: "Bonjour ! Je viens d\u2019Allemagne !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696720
    m_Localized: "Chez nous il y a beaucoup de ch\xE2teaux, de for\xEAts et de trains
      !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696721
    m_Localized: Trouve le drapeau allemand et rapporte-le.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696722
    m_Localized: Il a des lignes noires, rouges et jaunes.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696724
    m_Localized: Madrid est la capitale de l'Espagne.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696725
    m_Localized: C'est mon drapeau !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696726
    m_Localized: "Merci.  Peux-tu donner son drapeau \xE0 mon ami du Luxembourg ?"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696727
    m_Localized: Ce n'est pas le mien ! Notre drapeau est rouge et jaune.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696728
    m_Localized: "Bonjour ! Je viens d\u2019Espagne !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696729
    m_Localized: "Nous avons une danse appel\xE9e le flamenco !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696730
    m_Localized: Trouve le drapeau espagnol.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696731
    m_Localized: Il est rouge et jaune comme le soleil.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696732
    m_Localized: Notre capitale est Rome !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696733
    m_Localized: Merci ! C'est mon drapeau !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696734
    m_Localized: "Aide nos amis Belges \xE0 trouver leur drapeau !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696735
    m_Localized: Mon drapeau est vert, blanc et rouge.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696736
    m_Localized: Salut ! Je viens d'Italie !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696737
    m_Localized: Trouve le drapeau italien.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696738
    m_Localized: Il est vert, blanc et rouge, comme une pizza !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696740
    m_Localized: Bruxelles est la capitale de la Belgique.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696741
    m_Localized: Ah, C'est mon drapeau ! Merci !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696742
    m_Localized: 'N''oublie pas : mon drapeau a des lignes noires, jaunes et rouges.'
    m_Metadata:
      m_Items: []
  - m_Id: 189866696743
    m_Localized: Bonjour ! Je viens de Belgique !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696744
    m_Localized: "Nous parlons aussi fran\xE7ais !"
    m_Metadata:
      m_Items: []
  - m_Id: 189866696745
    m_Localized: Trouve le drapeau belge.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696746
    m_Localized: Il est noir, jaune et rouge avec des lignes verticales.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696747
    m_Localized: Le drapeau de la Belgique.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696748
    m_Localized: La capitale du Luxembourg est... Luxembourg !
    m_Metadata:
      m_Items: []
  - m_Id: 189866696749
    m_Localized: Merci ! C'est mon drapeau.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696750
    m_Localized: Non ! Notre drapeau est rouge, blanc et bleu clair.
    m_Metadata:
      m_Items: []
  - m_Id: 189866696751
    m_Localized: Bonjour, je suis du Luxembourg !
    m_Metadata:
      m_Items: []
  - m_Id: 1510057681346560
    m_Localized: "Tu as trouv\xE9 une partie de l'Europe !"
    m_Metadata:
      m_Items: []
  - m_Id: 1510057685540864
    m_Localized: Peux-tu aider mon ami espagnol ?
    m_Metadata:
      m_Items: []
  - m_Id: 1510057685540865
    m_Localized: Peux-tu aider mon ami suisse ?
    m_Metadata:
      m_Items: []
  - m_Id: 1510057685540866
    m_Localized: "Retourne au d\xE9but pour aller chercher ton cadeau !"
    m_Metadata:
      m_Items: []
  - m_Id: 2256027570397184
    m_Localized: Nous sommes en Europe.
    m_Metadata:
      m_Items: []
  - m_Id: 2256027570397185
    m_Localized: Faisons la connaissance des pays voisins.
    m_Metadata:
      m_Items: []
  - m_Id: 2256027570397186
    m_Localized: "La qu\xEAte est termin\xE9e."
    m_Metadata:
      m_Items: []
  - m_Id: 2256027570397187
    m_Localized: Maintenant, peux-tu dessiner ton drapeau ?
    m_Metadata:
      m_Items: []
  - m_Id: 2256027570397188
    m_Localized: En Europe, on parle plus de 100 langues !
    m_Metadata:
      m_Items: []
  - m_Id: 2256027570397190
    m_Localized: "La France est le deuxi\xE8me plus grand pays d'Europe apr\xE8s
      l'Ukraine."
    m_Metadata:
      m_Items: []
  - m_Id: 23225648972554240
    m_Localized: Paris est la capitale de la France.
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577664
    m_Localized: "Tu as trouv\xE9 le drapeau fran\xE7ais, retourne voir le monsieur
      fran\xE7ais."
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577665
    m_Localized: "Tu as trouv\xE9 le drapeau allemand, retourne en Allemagne."
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577666
    m_Localized: "Tu as trouv\xE9 le drapeau espagnol, retourne en Espagne."
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577667
    m_Localized: "Tu as trouv\xE9 le drapeau italien, retourne en Italie."
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577668
    m_Localized: "Tu as trouv\xE9 le drapeau belge, retourne en Belgique."
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577669
    m_Localized: "Tu as trouv\xE9 le drapeau du Luxembourg, retourne au Luxembourg."
    m_Metadata:
      m_Items: []
  - m_Id: 23225649102577670
    m_Localized: "Tu as trouv\xE9 le drapeau suisse, retourne en Suisse."
    m_Metadata:
      m_Items: []
  - m_Id: 23301984575545350
    m_Localized: "L'Europe compe environ 45 pays, tous \xE0 c\xF4t\xE9 les uns des
      autres, comme des voisins! "
    m_Metadata:
      m_Items: []
  - m_Id: 23301984575545351
    m_Localized: En France il y a la tour Eiffel, une tour en fer qui brille la nuit.
    m_Metadata:
      m_Items: []
  - m_Id: 23301984575545352
    m_Localized: "En Allemagne, il y a de la bi\xE8re et des saucisses."
    m_Metadata:
      m_Items: []
  - m_Id: 23301984575545353
    m_Localized: La capitale de l'Allemagne est Berlin.
    m_Metadata:
      m_Items: []
  - m_Id: 23301984575545354
    m_Localized: "L'Italie ressemble \xE0 une botte sur la carte !"
    m_Metadata:
      m_Items: []
  - m_Id: 23301984575545355
    m_Localized: "En Italie, il ya des pizzas et des p\xE2tes"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
