%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: FR_10_fr
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: fr
  m_SharedData: {fileID: 11400000, guid: b90ebc042e6dd4584b2dc55809f17693, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 58867199224307712
    m_Localized: "Bienvenue \xE0 Paris ! Paris est la capitale de la France. A Paris,
      il y a un fleuve tr\xE8s connu. Ce fleuve s'appelle la Seine. "
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307713
    m_Localized: "Aujourd'hui, tu vas d\xE9couvrir la Seine et ses nombreux ponts.
      Sur la Seine, il y a toutes sortes de bateaux."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307714
    m_Localized: "Super, tu as termin\xE9 cette qu\xEAte!"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307715
    m_Localized: "Tu as d\xE9couvert les ponts et les bateaux de la Seine. Les ponts
      permettent de franchir le fleuve qui passe \xE0 Paris: La Seine. "
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307716
    m_Localized: "Il y a des bateaux pour les touristes. Ils ont de grandes fen\xEAtres
      pour voir les monuments de Paris depuis la Seine."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307717
    m_Localized: "Il y a des bateaux- maison. Des personnes habitent sur ces bateaux.
      On les appelle des bateaux p\xE9niches.."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307718
    m_Localized: "Des monuments importants de Paris ont \xE9t\xE9 construits autour
      de la Seine ."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307719
    m_Localized: Dessine un pont dans ton cahier !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307720
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307721
    m_Localized: Merci!
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307722
    m_Localized: "Tu as trouv\xE9 toutes les photos de mon guide !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199224307723
    m_Localized: "Je peux enfin rentrer chez moi ! J'ai une derni\xE8re question\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502017
    m_Localized: Mais il me manque 7 photos de ponts et de bateaux sur la Seine !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502018
    m_Localized: "Prom\xE8ne toi au bord de la Seine et trouve les photos !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502019
    m_Localized: Si tu ne les trouves pas, tu peux utiliser la carte de Paris pour
      te situer!
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502020
    m_Localized: "Tu te d\xE9brouilles bien !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502021
    m_Localized: Au secours ! Aide-moi !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502022
    m_Localized: "Je visite Paris. Je suis un touriste. Le chien Antura a emport\xE9
      mon livre sur Paris !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502023
    m_Localized: "Les pages de mon livre et les photos sont tomb\xE9es pr\xE8s de
      la Seine !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502024
    m_Localized: "Marche pr\xE8s du fleuve et tu trouveras les photos !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502025
    m_Localized: "Tu as trouv\xE9 toutes les photos !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502026
    m_Localized: Retourne voir le touriste.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502029
    m_Localized: La fleuve qui traverse Paris s'appelle....
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502030
    m_Localized: La Loire....
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502031
    m_Localized: "Ce n'est pas la bonne r\xE9ponse. La Loire passe \xE0 Nantes, pr\xE8s
      du mus\xE9e Jules Verne."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502032
    m_Localized: La Seine.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502033
    m_Localized: Oui, c'est la Seine. Le fleuve qui traverse Paris s'appelle La Seine.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502034
    m_Localized: 
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502037
    m_Localized: Ce bateau transporte des marchandises.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502038
    m_Localized: Que transporte un bateau de marchandises ?
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502039
    m_Localized: 'Le bateau de marchandises s''appelle un cargo. Le cargo peut transporter
      des marchandises: du bois, du sable mais aussi des objets: des voitures, des
      meubles...'
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502040
    m_Localized: oui, tu peux ouvrir le coffre.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502041
    m_Localized: Des touristes avec des appareils photo
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502042
    m_Localized: "Tu n'as pas r\xE9ussi. Essaie encore."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502043
    m_Localized: '? '
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502045
    m_Localized: Je ne sais pas
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502046
    m_Localized: Reviens plus tard.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502047
    m_Localized: "Joue \xE0 un mini-jeu pour ouvrir le coffre !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502048
    m_Localized: "Le coffre s'ouvre. Tu as trouv\xE9 une photo !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502049
    m_Localized: Le coffre est vide.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502050
    m_Localized: "Le coffre est ferm\xE9 \xE0 cl\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502051
    m_Localized: "Ce bateau est une maison. Il y a des personnes qui habitent sur
      ce bateau. Ce bateau s'appelle une p\xE9niche. "
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502052
    m_Localized: Pourquoi ce bateau s'appelle bateau-maison ?
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502053
    m_Localized: On peut y vivre.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502055
    m_Localized: C'est un pont pour les trains.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502057
    m_Localized: Ce bateau transporte des marchandises
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502064
    m_Localized: "Ce bateau poss\xE8de de grandes fen\xEAtres. Les touristes peuvent
      admirer la ville. C'est un \xAB bateau-mouche \xBB."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502065
    m_Localized: "Pourquoi un bateau touristique a-t-il de grandes fen\xEAtres ?"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502066
    m_Localized: "Pour voir la ville et les lieux c\xE9l\xE8bres"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502068
    m_Localized: Pour transporter des voitures
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502070
    m_Localized: Pour aller sous l'eau
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502077
    m_Localized: "Voici le pont Alexandre III. C'est un pont tr\xE8s c\xE9l\xE8bre."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502078
    m_Localized: "Pourquoi ce pont est c\xE9l\xE8bre ?"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502079
    m_Localized: Il y a des statues en or.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502081
    m_Localized: C'est un pont pour les trains.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502083
    m_Localized: C'est un pont pour les voitures.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502090
    m_Localized: C'est un pont pour les voitures !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502091
    m_Localized: "Les voitures roulent vite. Comment traverser en toute s\xE9curit\xE9
      ?"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502092
    m_Localized: "Tu dois marcher sur le trottoir et traverser au passage pi\xE9ton."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502094
    m_Localized: "Tu peux transverser la route n'importe o\xF9."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502096
    m_Localized: Tu dois marcher sur la route
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502103
    m_Localized: C'est un pont pour les trains !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502104
    m_Localized: "Un pont ferrovi\xE8re est un pont ..."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502105
    m_Localized: "pour les pi\xE9tons"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502107
    m_Localized: pour les voitures
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502109
    m_Localized: pour les trains
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502116
    m_Localized: J'adorerais faire un tour en train !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502117
    m_Localized: J'adore les trains !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502118
    m_Localized: "C'est un pont pour les pi\xE9tons !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502119
    m_Localized: Un petit pont s'appelle ...
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502120
    m_Localized: une passerelle
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502122
    m_Localized: un pont ferroviaire
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502124
    m_Localized: un pont pour voitures
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502131
    m_Localized: Regarde cette carte de la Seine.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502132
    m_Localized: La Seine se jette dans la Manche (une mer) en direction du nord.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502133
    m_Localized: Non, je n'ai pas vu votre chien.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502134
    m_Localized: Un chien ? Il y a beaucoup de chiens ici...
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502135
    m_Localized: Oui, j'ai vu un chien se promener.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502136
    m_Localized: Regarde comme c'est joli !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502137
    m_Localized: "Il y a une \xEEle appel\xE9e \xCEle de la Cit\xE9."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502138
    m_Localized: Elle se situe dans le vieux centre de Paris.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502139
    m_Localized: La Seine se jette dans la Manche.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502140
    m_Localized: Bonjour !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502141
    m_Localized: La Seine est magnifique !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502142
    m_Localized: "Il y a beaucoup de ponts \xE0 Paris !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502143
    m_Localized: Salut !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502144
    m_Localized: "J'aime bien faire du v\xE9lo le long de la Seine !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502145
    m_Localized: Paris est la plus belle ville du monde !
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502146
    m_Localized: "La Seine est tr\xE8s longue !"
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502147
    m_Localized: "Un pont ferroviaire doit \xEAtre solide."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502148
    m_Localized: "Certains ponts sont uniquement destin\xE9s aux pi\xE9tons."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502149
    m_Localized: "Des voitures traversent la rivi\xE8re tous les jours."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502150
    m_Localized: La Seine permet aux bateaux de circuler dans Paris.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502151
    m_Localized: "Les cartes montrent les m\xE9andres du fleuve."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502152
    m_Localized: Le fleuve jette dans la mer.
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502153
    m_Localized: "Les bateaux touristiques ont de grandes fen\xEAtres."
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502154
    m_Localized: Les bateaux cargos transportent de nombreuses marchandises .
    m_Metadata:
      m_Items: []
  - m_Id: 58867199228502155
    m_Localized: "Une bateau-p\xE9niche peut \xEAtre une maison."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
